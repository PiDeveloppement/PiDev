<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.PieChart?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.sponsor.SponsorAdminController"
            prefHeight="900" prefWidth="1200"
            style="-fx-background-color: #f1f5f9;"
            stylesheets="@../../css/design-system.css">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

            <VBox spacing="0">

                <HBox alignment="CENTER_LEFT" spacing="20"
                      style="-fx-background-color: white; -fx-padding: 28 40; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 2 0;">

                    <VBox spacing="4">
                        <Label text="💼 Gestion des Sponsors" styleClass="label-title"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label text="Administration complète des sponsors et leurs contributions"
                               styleClass="label-description" style="-fx-text-fill: #64748b;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="2" alignment="CENTER_RIGHT">
                        <Label text="📊 Résumé" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                        <Label text="EventFlow Admin" style="-fx-text-fill: #1e293b; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <HBox spacing="20" style="-fx-padding: 24 40;">

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="💼" style="-fx-font-size: 28px;"/>
                            <VBox spacing="3">
                                <Label text="Sponsors Total" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                                <Label fx:id="totalSponsorsLabel" text="0"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="💎" style="-fx-font-size: 28px;"/>
                            <VBox spacing="3">
                                <Label text="Contribution Totale" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                                <Label fx:id="totalContributionLabel" text="0,00 DT"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #15803d;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="📊" style="-fx-font-size: 28px;"/>
                            <VBox spacing="3">
                                <Label text="Moyenne/Sponsor" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                                <Label fx:id="avgContributionLabel" text="0,00 DT"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox alignment="CENTER" style="-fx-padding: 0 40 20 40;">
                    <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                        <PieChart fx:id="contributionsChart" prefHeight="400"
                                  title="Répartition des contributions"
                                  style="-fx-font-size: 14px;"/>
                    </VBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-padding: 20 40; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">

                    <TextField fx:id="searchField" promptText="🔍 Rechercher sponsor..."
                               prefWidth="280" style="-fx-background-radius: 8; -fx-padding: 10;"/>

                    <ComboBox fx:id="companyFilter" promptText="🏢 Entreprise"
                              prefWidth="200" style="-fx-background-radius: 8;"/>

                    <ComboBox fx:id="eventFilter" promptText="📅 Événement"
                              prefWidth="200" style="-fx-background-radius: 8;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="addSponsorBtn" text="➕ Nouveau Sponsor"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <VBox spacing="20" style="-fx-padding: 30 40;">
                    <Label text="📋 Liste des Partenaires"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                    <TilePane fx:id="cardsPane"
                              prefColumns="3"
                              hgap="25"
                              vgap="25"
                              prefTileWidth="340"
                              alignment="TOP_LEFT"
                              style="-fx-background-color: transparent;">
                    </TilePane>

                    <Label fx:id="statusLabel" text="0 sponsor(s) trouvé(s)"
                           style="-fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
                </VBox>

                <Region prefHeight="50"/>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>