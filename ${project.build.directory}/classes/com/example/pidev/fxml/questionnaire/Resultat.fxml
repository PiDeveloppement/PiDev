<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="550.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.questionnaire.ResultatController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 24; -fx-text-fill: #2c3e50;" text="VOS RÉSULTATS" />
                <Separator />

                <ScrollPane fitToWidth="true" prefHeight="221.0" prefWidth="510.0" style="-fx-background-color: transparent; -fx-background: white; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="vboxCorrection" spacing="12.0" style="-fx-padding: 15; -fx-background-color: white;" />
                    </content>
                </ScrollPane>

                <HBox alignment="CENTER">
                    <children>
                        <Button fx:id="btnCertificat" managed="false" onAction="#onDownloadCertificat" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" text="🎓 TÉLÉCHARGER MON CERTIFICAT" visible="false" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 10;">
                    <children>
                        <Label fx:id="lblScore" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Score: 0 / 0" />
                        <Label fx:id="lblStatus" style="-fx-font-size: 18; -fx-font-weight: bold;" text="STATUS" />
                    </children>
                </HBox>

                <VBox prefHeight="153.0" prefWidth="510.0" spacing="12.0" style="-fx-background-color: #f9f9f9; -fx-padding: 20; -fx-border-color: #ecf0f1; -fx-border-radius: 12; -fx-border-width: 1.5;">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 14;" text="Modifier votre avis :" />

                        <HBox fx:id="editStarContainer" alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Button style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-padding: 0;" text="★" />
                                <Button style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-padding: 0;" text="★" />
                                <Button style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-padding: 0;" text="★" />
                                <Button style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-padding: 0;" text="★" />
                                <Button style="-fx-background-color: transparent; -fx-font-size: 25; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-padding: 0;" text="★" />
                            </children>
                        </HBox>

                        <TextArea fx:id="txtAreaComment" prefHeight="70.0" promptText="Laissez un commentaire..." style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-focus-color: #3b82f6;" wrapText="true" />

                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <children>
                                <Button onAction="#onModifier" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="METTRE À JOUR" />
                                <Button onAction="#onSupprimer" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="EFFACER MON AVIS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button maxWidth="Infinity" onAction="#retourAccueil" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;" text="RETOUR À L'ACCUEIL" />
            </children>
        </VBox>
    </children>
</AnchorPane>
