<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="900" prefWidth="1200"
            style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.depense.DepenseListController">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

            <VBox spacing="0">

                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 20 30;
                             -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

                    <VBox spacing="5" minWidth="250">
                        <Label text="Dépenses"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label text="Suivi financier"
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER" spacing="8">
                        <VBox alignment="CENTER" spacing="1"
                              style="-fx-padding: 10 15; -fx-background-color: #f0fdf4; -fx-background-radius: 8; -fx-border-color: #bbf7d0;">
                            <Label fx:id="depensesCountLabel" text="0"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                            <Label text="Nombre" style="-fx-text-fill: #22c55e; -fx-font-size: 10px;"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="1"
                              style="-fx-padding: 10 15; -fx-background-color: #eff6ff; -fx-background-radius: 8; -fx-border-color: #bfdbfe;">
                            <Label fx:id="totalDepensesLabel" text="0,00 DT"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                            <Label text="Total" style="-fx-text-fill: #3b82f6; -fx-font-size: 10px;"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="1"
                              style="-fx-padding: 10 15; -fx-background-color: #fef3c7; -fx-background-radius: 8; -fx-border-color: #fcd34d;">
                            <Label fx:id="monthDepensesLabel" text="0,00 DT"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
                            <Label text="Mois" style="-fx-text-fill: #f59e0b; -fx-font-size: 10px;"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="1"
                              style="-fx-padding: 10 15; -fx-background-color: #fee2e2; -fx-background-radius: 8; -fx-border-color: #fecaca;">
                            <Label fx:id="topCategoryLabel" text="—"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
                            <Label text="Top Cat." style="-fx-text-fill: #ef4444; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #f1f5f9; -fx-padding: 15 30;
                             -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

                    <TextField fx:id="searchField"
                               promptText="🔍 Rechercher..."
                               style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 8;
                                      -fx-pref-width: 250; -fx-border-color: #cbd5e1;"/>

                    <ComboBox fx:id="budgetFilter" promptText="💼 Budget" prefWidth="150"
                              style="-fx-background-color: white; -fx-background-radius: 8;"/>

                    <ComboBox fx:id="categoryFilter" promptText="🏷 Catégorie" prefWidth="150"
                              style="-fx-background-color: white; -fx-background-radius: 8;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="addDepenseBtn"
                            text="➕ Nouvelle"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                </HBox>

                <VBox spacing="20" style="-fx-padding: 25 30;" VBox.vgrow="ALWAYS">
                    <Label text="🧾 Liste des Dépenses"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                    <TilePane fx:id="cardsPane"
                              prefColumns="3"
                              hgap="15" vgap="15"
                              prefTileWidth="320"
                              alignment="TOP_LEFT"
                              style="-fx-background-color: transparent;">
                    </TilePane>

                    <Label fx:id="statusLabel"
                           text="0 résultat(s) trouvé(s)"
                           style="-fx-text-fill: #64748b; -fx-font-style: italic;"/>
                </VBox>

                <Region prefHeight="30"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>