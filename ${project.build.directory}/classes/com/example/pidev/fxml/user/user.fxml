<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.user.UserController"
      style="-fx-background-color: #f8fafc;"
      prefWidth="1200" prefHeight="800">

    <!-- Barre de recherche et filtres (sans le KPI) -->
    <HBox style="-fx-background-color: #f1f5f9; -fx-padding: 15 30; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;"
          spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un utilisateur..."
                   style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10 15; -fx-pref-width: 300;"/>
        <ComboBox fx:id="faculteFilterCombo" onAction="#filterByFaculte" promptText="📂 Faculté" prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
        <ComboBox fx:id="roleFilterCombo" onAction="#filterByRole" promptText="📊 Rôle" prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
        <Button text="🔄" onAction="#resetFilters" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;"/>

        <!-- Label stats caché mais conservé pour les informations (optionnel) -->
        <Label fx:id="statsLabel" text="0 utilisateurs"
               style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 0 0 0 20;"/>
    </HBox>

    <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 20 30;">

            <TableView fx:id="userTable"
                       style="-fx-background-color: white; -fx-border-radius: 12; -fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="firstname_column" text="Prénom" prefWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="lastname_column" text="Nom" prefWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="email_column" text="Email" prefWidth="200" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="faculte_column" text="Faculté" prefWidth="150" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="password_column" text="Mot de passe" prefWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="role_column" text="Rôle" prefWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="actions_column" text="Actions" prefWidth="120" style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="prevPageBtn" text="«"
                        style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <HBox spacing="5">
                    <Button fx:id="page1Btn" text="1"
                            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="page2Btn" text="2"
                            style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #e2e8f0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="page3Btn" text="3"
                            style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #e2e8f0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="lastPageBtn" text="Dernière"
                            style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                <Button fx:id="nextPageBtn" text="»"
                        style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="paginationLabel" text="Page 1 sur 1"
                       style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>