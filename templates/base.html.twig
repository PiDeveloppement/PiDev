<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventFlow{% endblock %}</title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="{{ asset('css/atlantafx-custom.css') }}">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }
        
        .app-container {
            display: flex;
            min-height: 100vh;
        }
        
        .public-container {
            width: 100%;
            min-height: 100vh;
        }

        /* Public pages: shared connected-user chip (blue frame) */
        .public-account-menu {
            position: relative;
        }

        .public-account-menu summary {
            list-style: none;
            cursor: pointer;
        }

        .public-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .public-account-chip {
            background: linear-gradient(135deg, #2f7dd7, #1e5fba);
            color: #fff;
            border-radius: 18px;
            padding: 4px 10px 4px 6px;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 6px 14px rgba(30, 95, 186, 0.32);
            border: 1px solid rgba(255, 255, 255, 0.28);
        }

        .public-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: rgba(10, 34, 71, 0.45);
            border: 2px solid rgba(255, 255, 255, 0.42);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
        }

        .public-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .public-account-name {
            font-size: 13px;
            font-weight: 700;
            max-width: 130px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .public-account-role {
            font-size: 11px;
            color: #d9ecff;
            margin-top: 2px;
        }

        .public-account-dropdown {
            position: absolute;
            right: 0;
            top: calc(100% + 6px);
            width: 210px;
            background: #fff;
            border: 1px solid #dbe4f2;
            border-radius: 10px;
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.18);
            overflow: hidden;
            z-index: 1200;
        }

        .public-account-action {
            display: block;
            width: 100%;
            text-align: left;
            text-decoration: none;
            border: 0;
            background: #fff;
            color: #0f172a;
            font-size: 13px;
            padding: 10px 12px;
            cursor: pointer;
        }

        .public-account-action:hover {
            background: #f1f5f9;
        }

        /* Keep profile dropdown above page actions */
        .profile-menu {
            z-index: 3200;
        }

        .profile-menu .profile-dropdown {
            z-index: 3300 !important;
        }

        /* Shared header slot for page actions (budget/depense) */
        #translationHeaderSlot {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        /* Google Translate banner can push body down; keep layout fixed */
        .goog-te-banner-frame,
        .goog-te-banner-frame.skiptranslate,
        iframe.skiptranslate {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            max-height: 0 !important;
        }

        body,
        body.translated-ltr,
        body.translated-rtl,
        html {
            top: 0 !important;
            margin-top: 0 !important;
        }

        /* Premium chatbot redesign */
        .chat-premium-panel {
            position: fixed;
            top: 0;
            right: 0;
            width: 560px;
            max-width: 96vw;
            height: 100vh;
            display: none;
            flex-direction: column;
            z-index: 5600;
            border-left: 1px solid rgba(148, 163, 184, 0.28);
            background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
            box-shadow: -20px 0 45px rgba(2, 6, 23, 0.22);
            backdrop-filter: blur(8px);
        }

        .chat-premium-header {
            padding: 14px 14px 12px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.22);
            background:
                radial-gradient(circle at 85% 10%, rgba(20, 184, 166, 0.24), transparent 42%),
                linear-gradient(135deg, #0f172a 0%, #1f2937 40%, #0f766e 100%);
        }

        .chat-premium-avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.22);
            border: 1px solid rgba(255, 255, 255, 0.35);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 21px;
            flex-shrink: 0;
        }

        .chat-premium-title {
            margin: 0;
            color: #fff;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: 0.1px;
            line-height: 1.2;
        }

        .chat-premium-subtitle {
            margin: 2px 0 0 0;
            color: #dbeafe;
            font-size: 11px;
            font-weight: 600;
        }

        .chat-premium-close {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.28);
            background: rgba(255, 255, 255, 0.16);
            color: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            flex-shrink: 0;
        }

        .chat-premium-layout {
            flex: 1;
            min-height: 0;
            display: flex;
        }

        .chat-premium-side {
            width: 172px;
            border-right: 1px solid rgba(148, 163, 184, 0.22);
            background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .chat-premium-side-top,
        .chat-premium-side-bottom {
            padding: 10px;
        }

        .chat-premium-side-top {
            border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        }

        .chat-premium-side-bottom {
            border-top: 1px solid rgba(148, 163, 184, 0.2);
        }

        .chat-premium-side-list {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            padding: 9px;
        }

        .chat-premium-btn {
            width: 100%;
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 9px 10px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            line-height: 1;
        }

        .chat-premium-btn-new {
            background: linear-gradient(135deg, #0f766e, #0ea5a8);
            color: #fff;
            box-shadow: 0 8px 18px rgba(15, 118, 110, 0.24);
        }

        .chat-premium-btn-delete {
            background: linear-gradient(135deg, #fff4f4, #ffecec);
            color: #b91c1c;
            border-color: rgba(239, 68, 68, 0.3);
        }

        .chat-premium-main {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .chat-premium-messages {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            padding: 14px 12px;
            background:
                radial-gradient(circle at 88% 3%, rgba(125, 211, 252, 0.28), transparent 30%),
                radial-gradient(circle at 8% 90%, rgba(147, 197, 253, 0.2), transparent 34%),
                linear-gradient(180deg, #f8fbff 0%, #f1f6ff 100%);
        }

        .chat-premium-suggestions {
            padding: 8px 10px 6px 10px;
            border-top: 1px solid rgba(148, 163, 184, 0.2);
            background: rgba(255, 255, 255, 0.72);
        }

        .chat-premium-form {
            padding: 10px;
            border-top: 1px solid rgba(148, 163, 184, 0.22);
            background: rgba(255, 255, 255, 0.88);
            display: flex;
            gap: 8px;
        }

        .chat-premium-input {
            flex: 1;
            min-width: 0;
            border: 1px solid #bfdbfe;
            background: #ffffff;
            color: #0f172a;
            border-radius: 12px;
            padding: 10px 12px;
            font-size: 13px;
            outline: none;
        }

        .chat-premium-send {
            border: 0;
            border-radius: 12px;
            padding: 0 15px;
            background: linear-gradient(135deg, #0f172a, #0f766e);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 16px rgba(15, 23, 42, 0.22);
        }

        .chat-thread-item {
            width: 100%;
            text-align: left;
            border: 1px solid #dbe7fb;
            background: rgba(255, 255, 255, 0.85);
            border-radius: 12px;
            padding: 9px;
            margin-bottom: 8px;
            cursor: pointer;
        }

        .chat-thread-item.is-active {
            border-color: #0f766e;
            background: linear-gradient(135deg, #effdf8, #ecfeff);
            box-shadow: 0 8px 16px rgba(15, 118, 110, 0.14);
        }

        .chat-thread-title {
            display: block;
            color: #0f172a;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .chat-thread-preview {
            display: block;
            color: #334155;
            font-size: 11px;
            line-height: 1.3;
        }

        .chat-msg-row {
            display: flex;
            margin-bottom: 11px;
        }

        .chat-msg-row.is-user {
            justify-content: flex-end;
        }

        .chat-msg-row.is-ai {
            justify-content: flex-start;
        }

        .chat-msg-bubble {
            max-width: 86%;
            white-space: pre-wrap;
            font-size: 13px;
            line-height: 1.48;
            padding: 11px 12px;
            border-radius: 14px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
        }

        .chat-msg-bubble.is-user {
            border-radius: 14px 5px 14px 14px;
            background: linear-gradient(135deg, #0f766e, #0ea5a8);
            color: #fff;
        }

        .chat-msg-bubble.is-ai {
            border-radius: 14px 14px 14px 5px;
            border: 1px solid #dbe7fb;
            background: #ffffff;
            color: #0f172a;
        }

        .chat-quick-btn {
            border: 1px solid #a7f3d0;
            background: #ecfdf5;
            color: #065f46;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 11px;
            font-weight: 700;
            margin-right: 6px;
            margin-bottom: 6px;
            cursor: pointer;
        }

        .chat-premium-fab {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 62px;
            height: 62px;
            border: 0;
            border-radius: 18px;
            color: #fff;
            font-size: 26px;
            cursor: pointer;
            z-index: 99;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                radial-gradient(circle at 22% 20%, rgba(94, 234, 212, 0.5), transparent 42%),
                linear-gradient(145deg, #0f172a 0%, #1f2937 56%, #0f766e 100%);
            box-shadow: 0 14px 30px rgba(2, 6, 23, 0.3);
        }

        .chat-premium-fab-dot {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: 2px solid #fff;
            background: #22c55e;
        }

        /* Hide account menu while chat is open */
        .chat-open .profile-menu {
            opacity: 0;
            pointer-events: none;
        }

        .chat-open .profile-dropdown {
            display: none !important;
        }

        @media (max-width: 760px) {
            .chat-premium-panel {
                width: 100vw;
                max-width: 100vw;
            }

            .chat-premium-side {
                width: 148px;
            }
        }
    </style>
    
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# ? Liste des routes publiques (sans sidebar) #}
    {% set current_route = app.request.get('_route') %}
    {% set public_routes = [
        'app_landing',
        'app_public_events',
        'app_public_event_show',
        'app_my_tickets',
        'app_login', 
        'app_register', 
        'app_forgot_password', 
        'app_reset_password', 
        'app_feedback_view',
        'app_demo_video',
        'app_quiz_start',
        'app_quiz_results',
        'app_quiz_final_results'
    ] %}
    
    {# Debug - ├Ć SUPPRIMER APR├łS R├ēSOLUTION #}
  {#  <div style="position: fixed; top: 0; left: 0; background: yellow; padding: 10px; z-index: 9999; font-size: 12px; border: 2px solid red;">
        <strong>DEBUG:</strong><br>
        Route: <strong>{{ app.request.get('_route') }}</strong><br>
        Publique: <strong>{{ app.request.get('_route') in public_routes ? 'OUI' : 'NON' }}</strong><br>
        User: <strong>{{ app.user ? app.user.email : 'NON' }}</strong>
    </div>
    #}
    {% set is_public = current_route in public_routes %}
    {% set show_translation_widget =
        current_route starts with 'app_sponsor_portal' or
        current_route starts with 'app_sponsors_' or
        current_route starts with 'app_depenses_' or
        current_route starts with 'app_budget_'
    %}
    
    {% if is_public %}
        {# ==================== PAGES PUBLIQUES (sans sidebar) ==================== #}
        <div class="public-container">
            {% block public_content %}{% endblock %}
        </div>
    {% else %}
        {# ==================== PAGES D'ADMINISTRATION (avec sidebar) ==================== #}
        <div class="app-container" id="app">
       <!-- Sidebar -->
<aside class="sidebar" style="width: 220px; display: flex; flex-direction: column;">
    <div class="sidebar-logo" style="background-color: #0D47A1; padding: 20px 15px; display: flex; flex-direction: column; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.1);">
        <img src="{{ asset('images/logo.png') }}" alt="EventFlow" style="width: 120px; height: auto; object-fit: contain;">
   
        <p style="color: rgba(255,255,255,0.7); font-size: 12px; margin: 0;">Gestion ├ēv├®nements</p>
    </div>
    <!-- Reste du code sidebar... -->
                
                <nav style="flex: 1; padding: 25px 15px; overflow-y: auto;">
                    <!-- Menu dashboard -->
                    <div style="margin-bottom: 4px;">
                        <a href="{{ path('app_dashboard') }}" class="menu-button {{ app.request.get('_route') == 'app_dashboard' ? 'active' : '' }}">
                            <i class="fas fa-chart-pie" style="width: 20px;"></i>
                            Dashboard
                        </a>
                    </div>

                    
                    <!-- Menu ├®v├®nements -->
                    <div style="margin-bottom: 4px;">
                        <button class="menu-button" onclick="toggleSubmenu('events-submenu', this)">
                            <i class="fas fa-calendar-alt" style="width: 20px;"></i>
                            <span style="flex: 1; text-align: left;">├ēv├®nements</span>
                            <i class="fas fa-chevron-right submenu-arrow" style="font-size: 12px; transition: transform 0.3s;"></i>
                        </button>
                        <div id="events-submenu" class="submenu" style="display: none; margin-left: 20px; margin-top: 2px;">
                            <a href="{{ path('app_event_index') }}" class="submenu-button">
                                <i class="fas fa-list" style="width: 18px;"></i>
                                Liste ├®v├®nements
                            </a>
                            <a href="{{ path('app_category_index') }}" class="submenu-button">
                                <i class="fas fa-tags" style="width: 18px;"></i>
                                Cat├®gories
                            </a>
                            <a href="{{ path('app_ticket_index') }}" class="submenu-button">
                                <i class="fas fa-ticket-alt" style="width: 18px;"></i>
                                Billets
                            </a>

                            <a href="{{ path('app_event_dashboard') }}"  class="submenu-button">
                                <i class="fas fa-chart-bar"  style="width: 18px;"></i>
                                Statistiques
                            </a>
                        </div>
                    </div>
                    
                    <!-- Menu participants (uniquement pour admin) -->
                    {% set is_admin = app.user and (app.user.role and app.user.role.roleName == 'Admin') or (app.user and app.user.roleId == 2) %}
                    {% if is_admin %}
                    <div style="margin-bottom: 4px;">
                        <button class="menu-button" onclick="toggleSubmenu('users-submenu', this)">
                            <i class="fas fa-users" style="width: 20px;"></i>
                            <span style="flex: 1; text-align: left;">Participants</span>
                            <i class="fas fa-chevron-right submenu-arrow" style="font-size: 12px;"></i>
                        </button>
                        <div id="users-submenu" class="submenu" style="display: none; margin-left: 20px; margin-top: 2px;">
                            <a href="{{ path('app_user_index') }}" class="submenu-button">
                                <i class="fas fa-user-plus" style="width: 18px;"></i>
                                Inscriptions
                            </a>
                            <a href="{{ path('app_role_index') }}" class="submenu-button">
                                <i class="fas fa-user-tag" style="width: 18px;"></i>
                                R├┤les
                            </a>
                        </div>
                    </div>
                    {% endif %}
                    
                    <!-- Menu sponsors -->
                    <div style="margin-bottom: 4px;">
                        <button class="menu-button" onclick="toggleSubmenu('sponsors-submenu', this)">
                            <i class="fas fa-handshake" style="width: 20px;"></i>
                            <span style="flex: 1; text-align: left;">Sponsors</span>
                            <i class="fas fa-chevron-right submenu-arrow" style="font-size: 12px;"></i>
                        </button>
                        <div id="sponsors-submenu" class="submenu" style="display: none; margin-left: 20px; margin-top: 2px;">
                            <a href="{{ path('app_sponsors_index') }}" class="submenu-button">
                                <i class="fas fa-list" style="width: 18px;"></i>
                                Sponsors
                            </a>
                            <a href="{{ path('app_budget_index') }}" class="submenu-button">
                                <i class="fas fa-coins" style="width: 18px;"></i>
                                Budget
                            </a>
                            <a href="{{ path('app_depenses_index') }}" class="submenu-button">
                                <i class="fas fa-file-invoice" style="width: 18px;"></i>
                                D├®penses
                            </a>
                        </div>
                    </div>
                    
                    <!-- Menu ressources -->
                    <div style="margin-bottom: 4px;">
                        {% set isResourceRoute = app.request.get('_route') in ['app_reservation_resource_index', 'app_reservation_resource_new', 'app_reservation_resource_edit', 'app_resource_equipement_index', 'app_resource_equipement_new', 'app_resource_equipement_edit', 'app_resource_salle_index', 'app_resource_salle_new', 'app_resource_salle_edit'] %}
                        <button class="menu-button" onclick="toggleSubmenu('ressources-submenu', this)">
                            <i class="fas fa-boxes" style="width: 20px;"></i>
                            <span style="flex: 1; text-align: left;">Ressources</span>
                            <i class="fas fa-chevron-right submenu-arrow" style="font-size: 12px;"></i>
                        </button>
                        <div id="ressources-submenu" class="submenu" style="display: {{ isResourceRoute ? 'block' : 'none' }}; margin-left: 20px; margin-top: 2px;">
                            <a href="{{ path('app_reservation_resource_index') }}" class="submenu-button {{ (app.request.get('_route') == 'app_reservation_resource_index' or app.request.get('_route') == 'app_reservation_resource_new' or app.request.get('_route') == 'app_reservation_resource_edit') ? 'active' : '' }}">
                                <i class="fas fa-calendar-check" style="width: 18px;"></i>
                                R├®servations
                            </a>
                            <a href="{{ path('app_resource_equipement_index') }}" class="submenu-button {{ (app.request.get('_route') == 'app_resource_equipement_index' or app.request.get('_route') == 'app_resource_equipement_new' or app.request.get('_route') == 'app_resource_equipement_edit') ? 'active' : '' }}">
                                <i class="fas fa-laptop" style="width: 18px;"></i>
                                ├ēquipements
                            </a>
                            <a href="{{ path('app_resource_salle_index') }}" class="submenu-button {{ (app.request.get('_route') == 'app_resource_salle_index' or app.request.get('_route') == 'app_resource_salle_new' or app.request.get('_route') == 'app_resource_salle_edit') ? 'active' : '' }}">
                                <i class="fas fa-door-open" style="width: 18px;"></i>
                                Salles
                            </a>
                        </div>
                    </div>
                    
                    <!-- Menu questionnaires -->
                    <div style="margin-bottom: 4px;">
                        <button class="menu-button" onclick="toggleSubmenu('questionnaires-submenu', this)">
                            <i class="fas fa-question-circle" style="width: 20px;"></i>
                            <span style="flex: 1; text-align: left;">Questionnaires</span>
                            <i class="fas fa-chevron-right submenu-arrow" style="font-size: 12px;"></i>
                        </button>
                        <div id="questionnaires-submenu" class="submenu" style="display: none; margin-left: 20px; margin-top: 2px;">
                            <a href="{{ path('app_questionnaire_feedback_index') }}" class="submenu-button {{ app.request.get('_route') == 'app_questionnaire_feedback_index' ? 'active' : '' }}">
                                <i class="fas fa-comments" style="width: 18px;"></i>
                                Avis
                            </a>
                            <a href="{{ path('app_question_index') }}" class="submenu-button {{ app.request.get('_route') == 'app_question_index' ? 'active' : '' }}">
                                <i class="fas fa-question" style="width: 18px;"></i>
                                Questions
                            </a>
                        </div>
                    </div>
                </nav>
                
                <div style="padding: 0 15px 25px 15px;">
                    <a href="{{ path('app_logout') }}" class="logout-button">
                        <i class="fas fa-sign-out-alt" style="width: 20px;"></i>
                        D&eacute;connexion
                    </a>
                </div>
            </aside>
            
            <!-- Main Content -->
            <main style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
                <!-- Top Bar avec recherche ├Ā gauche, date et profil ├Ā l'extr├®mit├® droite -->
                <div style="background: #1565C0; padding: 8px 20px; display: flex; align-items: center; height: 60px;">
                    <!-- Recherche ├Ā gauche -->
                    <div style="max-width: 400px; display: flex; align-items: center;">
                        <input type="text" id="globalSearch" placeholder="Recherche globale..."
