    <script>
        // Gestion des sous-menus
        function toggleSubmenu(id, button) {
            const submenu = document.getElementById(id);
            const arrow = button.querySelector('.submenu-arrow');
            
            if (!submenu || !arrow) return;
            
            if (submenu.style.display === 'none' || submenu.style.display === '') {
                submenu.style.display = 'block';
                arrow.style.transform = 'rotate(90deg)';
            } else {
                submenu.style.display = 'none';
                arrow.style.transform = 'rotate(0deg)';
            }
        }
        
        // Auto-open questionnaire submenu if on questionnaire page
        document.addEventListener('DOMContentLoaded', function() {
            const currentRoute = '{{ app.request.get('_route') }}';
            const questionnaireSubmenu = document.getElementById('questionnaires-submenu');
            const questionnaireButton = questionnaireSubmenu ? questionnaireSubmenu.previousElementSibling : null;
            
            // Open questionnaire submenu if we're on a questionnaire-related page
            if (currentRoute === 'app_questionnaire_feedback_index' || 
                currentRoute === 'app_question_index' ||
                currentRoute === 'app_question_new' ||
                currentRoute === 'app_question_edit' ||
                currentRoute === 'app_question_stats') {
                
                if (questionnaireSubmenu && questionnaireButton) {
                    questionnaireSubmenu.style.display = 'block';
                    const arrow = questionnaireButton.querySelector('.submenu-arrow');
                    if (arrow) {
                        arrow.style.transform = 'rotate(90deg)';
                    }
                }
            }
        });
        
        // Gestion du chatbot flottant (persistant)
        (function () {
            const panel = document.getElementById('chatPanel');
            const floatingButton = document.getElementById('chatFloatingButton');
            const floatingButtonCustom = document.getElementById('chatFloatingButtonCustom');
            const closeButton = document.getElementById('chatCloseButton');
            const messagesContainer = document.getElementById('chatMessages');
            const input = document.getElementById('chatInput');
            const form = document.getElementById('chatForm');
            const sendButton = document.getElementById('chatSendButton');
            const listContainer = document.getElementById('chatConversationList');
            const newButton = document.getElementById('chatNewConversationBtn');
            const deleteButton = document.getElementById('chatDeleteConversationBtn');
            const quickPrompts = document.querySelectorAll('.chatQuickPrompt');

            if (!panel || !floatingButton || !closeButton || !messagesContainer || !input || !form || !sendButton || !listContainer || !newButton || !deleteButton) {
                return;
            }

            const STORAGE_KEY = 'ef_ai_chat_threads_v1';
            let threads = [];
            let activeId = null;

            function nowIso() {
                return new Date().toISOString();
            }

            function safeText(value) {
                return String(value || '').replace(/[&<>"']/g, function (char) {
                    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char] || char;
                });
            }

            function normalizeStoredText(value) {
                let text = String(value || '');
                if (text === '') {
                    return '';
                }

                return text
                    .replace(/­¤öŹ/g, '??')
                    .replace(/­¤ōŖ/g, '??')
                    .replace(/Ō£ģ/g, '?')
                    .replace(/ŌĆ”/g, '...')
                    .replace(/D├®connexion/g, 'Deconnexion')
                    .replace(/Param├©tres/g, 'Parametres')
                    .replace(/Invit├®/g, 'Invite')
                    .replace(/connect├®/g, 'connecte');
            }

            function buildDefaultBotMessage() {
                return {
                    role: 'assistant',
                    content: '?? Constat:\nJe suis pret a t aider sur Sponsor, Budget et Depense.\n\n?? Chiffres exacts:\nJe reponds a partir des donnees reelles disponibles.\n\n? Actions recommandees:\nPose une question claire (ex: budgets critiques, top depenses, sponsors).',
                    createdAt: nowIso(),
                };
            }

            function createThread(title) {
                const id = 'conv_' + Date.now() + '_' + Math.floor(Math.random() * 10000);
                return {
                    id: id,
                    title: title || 'Nouvelle conversation',
                    updatedAt: nowIso(),
                    messages: [buildDefaultBotMessage()],
                };
            }

            function saveState() {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({ threads: threads, activeId: activeId }));
            }

            function loadState() {
                try {
                    const raw = localStorage.getItem(STORAGE_KEY);
                    if (!raw) {
                        throw new Error('empty');
                    }
                    const parsed = JSON.parse(raw);
                    threads = Array.isArray(parsed.threads) ? parsed.threads : [];
                    activeId = typeof parsed.activeId === 'string' ? parsed.activeId : null;
                } catch (e) {
                    threads = [];
                    activeId = null;
                }

                threads = threads.map(function (thread) {
                    const normalizedMessages = Array.isArray(thread.messages)
                        ? thread.messages.map(function (message) {
                            return {
                                role: message.role === 'user' ? 'user' : 'assistant',
                                content: normalizeStoredText(message.content),
                                createdAt: message.createdAt || nowIso(),
                            };
                        })
                        : [buildDefaultBotMessage()];

                    return {
                        id: String(thread.id || ('conv_' + Date.now() + '_' + Math.floor(Math.random() * 10000))),
                        title: normalizeStoredText(thread.title || 'Nouvelle conversation'),
                        updatedAt: thread.updatedAt || nowIso(),
                        messages: normalizedMessages.length > 0 ? normalizedMessages : [buildDefaultBotMessage()],
                    };
                });

                if (threads.length === 0) {
                    const thread = createThread('Conversation 1');
                    threads = [thread];
                    activeId = thread.id;
                    saveState();
                }

                if (!threads.some(function (thread) { return thread.id === activeId; })) {
                    activeId = threads[0].id;
                }
            }

            function getActiveThread() {
                return threads.find(function (thread) { return thread.id === activeId; }) || null;
            }

            function summarizeTitle(thread) {
                const firstUser = (thread.messages || []).find(function (message) { return message.role === 'user' && message.content; });
                if (!firstUser) {
                    return thread.title || 'Nouvelle conversation';
                }
                const title = String(firstUser.content).trim();
                return title.length > 22 ? title.slice(0, 22) + '...' : title;
            }

            function renderConversationList() {
                listContainer.innerHTML = '';
                threads
                    .slice()
                    .sort(function (a, b) { return new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime(); })
                    .forEach(function (thread, index) {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'chat-thread-item' + (thread.id === activeId ? ' is-active' : '');
                        button.innerHTML = '<strong class="chat-thread-title">' + safeText('Conv ' + (index + 1)) + '</strong>'
                            + '<span class="chat-thread-preview">' + safeText(summarizeTitle(thread)) + '</span>';
                        button.addEventListener('click', function () {
                            activeId = thread.id;
                            saveState();
                            renderConversationList();
                            renderMessages();
                        });
                        listContainer.appendChild(button);
                    });
            }

            function renderMessages() {
                const thread = getActiveThread();
                if (!thread) {
                    messagesContainer.innerHTML = '';
                    return;
                }

                messagesContainer.innerHTML = '';
                (thread.messages || []).forEach(function (message) {
                    const wrapper = document.createElement('div');
                    const isUser = message.role === 'user';
                    wrapper.className = 'chat-msg-row ' + (isUser ? 'is-user' : 'is-ai');

                    const bubble = document.createElement('div');
                    bubble.className = 'chat-msg-bubble ' + (isUser ? 'is-user' : 'is-ai');

                    bubble.textContent = String(message.content || '');
                    wrapper.appendChild(bubble);
                    messagesContainer.appendChild(wrapper);
                });

                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }

            function openPanel() {
                panel.style.display = 'flex';
                document.body.classList.add('chat-open');
                input.focus();
            }

            function closePanel() {
                panel.style.display = 'none';
                document.body.classList.remove('chat-open');
            }

            function setLoading(loading) {
                sendButton.disabled = loading;
                input.disabled = loading;
                sendButton.textContent = loading ? '...' : 'Envoyer';
            }

            async function askAssistant(question) {
                const thread = getActiveThread();
                if (!thread) {
                    return;
                }

                const cleanQuestion = String(question || '').trim();
                if (!cleanQuestion) {
                    return;
                }

                thread.messages.push({ role: 'user', content: cleanQuestion, createdAt: nowIso() });
                thread.updatedAt = nowIso();
                saveState();
                renderConversationList();
                renderMessages();
                setLoading(true);

                try {
                    const response = await fetch('{{ path('app_ai_chat_send') }}', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            message: cleanQuestion,
                            question: cleanQuestion,
                            history: thread.messages.map(function (message) {
                                return { role: message.role, content: message.content };
                            }),
                        }),
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        throw new Error(payload.error || 'Erreur serveur IA');
                    }

                    const answer = String(payload.response || payload.answer || '').trim() || 'Aucune reponse retournee.';
                    thread.messages.push({ role: 'assistant', content: answer, createdAt: nowIso() });
                    thread.updatedAt = nowIso();
                    thread.title = summarizeTitle(thread);
                    saveState();
                    renderConversationList();
                    renderMessages();
                } catch (error) {
                    thread.messages.push({ role: 'assistant', content: 'Erreur: ' + (error.message || 'Impossible de contacter le service IA.'), createdAt: nowIso() });
                    thread.updatedAt = nowIso();
                    saveState();
                    renderMessages();
                } finally {
                    setLoading(false);
                    input.focus();
                }
            }

            window.toggleChat = function () {
                if (panel.style.display === 'none' || panel.style.display === '') {
                    openPanel();
                } else {
                    closePanel();
                }
            };

            floatingButton.addEventListener('click', window.toggleChat);
            if (floatingButtonCustom) { floatingButtonCustom.addEventListener('click', openPanel); }
            closeButton.addEventListener('click', closePanel);

            form.addEventListener('submit', function (event) {
                event.preventDefault();
                const question = input.value.trim();
                if (!question) {
                    return;
                }
                input.value = '';
                askAssistant(question);
            });

            quickPrompts.forEach(function (button) {
                button.addEventListener('click', function () {
                    const prompt = button.getAttribute('data-prompt') || '';
                    if (!prompt) {
                        return;
                    }
                    askAssistant(prompt);
                });
            });

            newButton.addEventListener('click', function () {
                const thread = createThread('Nouvelle conversation');
                threads.push(thread);
                activeId = thread.id;
                saveState();
                renderConversationList();
                renderMessages();
                input.focus();
            });

            deleteButton.addEventListener('click', function () {
                if (!activeId) {
                    return;
                }

                if (!window.confirm('Supprimer cette conversation ?')) {
                    return;
                }

                threads = threads.filter(function (thread) { return thread.id !== activeId; });
                if (threads.length === 0) {
                    const thread = createThread('Conversation 1');
                    threads = [thread];
                    activeId = thread.id;
                } else {
                    activeId = threads[0].id;
                }

                saveState();
                renderConversationList();
                renderMessages();
            });

            loadState();
            renderConversationList();
            renderMessages();
        })();
        function updateDateTime() {
            const now = new Date();
            const options = { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            };
            const dateElement = document.getElementById('currentDate');
            const timeElement = document.getElementById('currentTime');
            
            if (dateElement) {
                dateElement.textContent = now.toLocaleDateString('fr-FR', options).replace(/^\w/, c => c.toUpperCase());
            }
            if (timeElement) {
                timeElement.textContent = now.toLocaleTimeString('fr-FR', { hour12: false });
            }
        }
        
        if (document.getElementById('currentDate')) {
            updateDateTime();
            setInterval(updateDateTime, 1000);
        }
        
        // Recherche globale
        function performSearch() {
            const query = document.getElementById('globalSearch').value.trim();
            if (query) {
                window.location.href = "{{ path('app_search') }}?q=" + encodeURIComponent(query);
            }
        }
        
        const searchInput = document.getElementById('globalSearch');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    performSearch();
                }
            });
        }
        
        // Gestion du dropdown profil
        const profileMenu = document.querySelector('.profile-menu');
        if (profileMenu) {
            profileMenu.addEventListener('mouseenter', function() {
                const dropdown = this.querySelector('.profile-dropdown');
                if (dropdown) dropdown.style.display = 'block';
            });
            
            profileMenu.addEventListener('mouseleave', function() {
                const dropdown = this.querySelector('.profile-dropdown');
                if (dropdown) dropdown.style.display = 'none';
            });
        }
        

        // Flash messages: show briefly then fade out.
        document.querySelectorAll('.auto-dismiss-flash').forEach(function(flash, index) {
            setTimeout(function() {
                flash.style.transition = 'opacity 0.35s ease, transform 0.35s ease, max-height 0.35s ease, margin 0.35s ease, padding 0.35s ease';
                flash.style.opacity = '0';
                flash.style.transform = 'translateY(-6px)';
                flash.style.maxHeight = '0';
                flash.style.marginBottom = '0';
                flash.style.paddingTop = '0';
                flash.style.paddingBottom = '0';

                setTimeout(function() {
                    flash.remove();
                }, 380);
            }, 4500 + (index * 120));
        });

        // Translation widget (Google Translate in-page mode)
        const currentRoute = '{{ current_route }}';
        const translationWidget = document.getElementById('translationWidget');
        const translationToggle = document.getElementById('translationToggle');
        const translationMenu = document.getElementById('translationMenu');
        const translationButtons = document.querySelectorAll('.translation-lang-btn');

        const setTranslateCookie = function (value) {
            const host = window.location.hostname;
            document.cookie = 'googtrans=' + value + ';path=/';

            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=' + value + ';path=/;domain=.' + host;
            }
        };

        const clearTranslateCookie = function () {
            const host = window.location.hostname;
            document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';

            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + host;
            }
        };

        const fixGoogleTranslateLayoutShift = function () {
            if (document.body) {
                document.body.style.top = '0px';
                document.body.style.marginTop = '0px';
            }
            if (document.documentElement) {
                document.documentElement.style.top = '0px';
                document.documentElement.style.marginTop = '0px';
            }
        };

        fixGoogleTranslateLayoutShift();
        setTimeout(fixGoogleTranslateLayoutShift, 50);
        setTimeout(fixGoogleTranslateLayoutShift, 200);
        setTimeout(fixGoogleTranslateLayoutShift, 800);

        if (translationToggle && translationMenu) {
            const placeTranslationMenuOverlay = function () {
                if (!translationWidget || !translationMenu || !translationToggle) {
                    return;
                }

                const widgetPosition = window.getComputedStyle(translationWidget).position;
                if (widgetPosition === 'static') {
                    translationWidget.style.position = 'relative';
                }

                translationMenu.style.position = 'absolute';
                translationMenu.style.left = '0';
                translationMenu.style.right = 'auto';
                translationMenu.style.marginTop = '0';
                translationMenu.style.zIndex = '4200';

                const toggleRect = translationToggle.getBoundingClientRect();
                const estimatedMenuHeight = Math.min(360, Math.max(260, translationMenu.scrollHeight || 0));
                const spaceBelow = window.innerHeight - toggleRect.bottom;

                if (spaceBelow < estimatedMenuHeight + 16) {
                    translationMenu.style.top = 'auto';
                    translationMenu.style.bottom = 'calc(100% + 8px)';
                } else {
                    translationMenu.style.top = 'calc(100% + 8px)';
                    translationMenu.style.bottom = 'auto';
                }
            };

            placeTranslationMenuOverlay();

            translationToggle.addEventListener('click', function () {
                placeTranslationMenuOverlay();
                translationMenu.style.display = translationMenu.style.display === 'none' || translationMenu.style.display === ''
                    ? 'block'
                    : 'none';
            });

            window.addEventListener('resize', function () {
                if (translationMenu.style.display === 'block') {
                    placeTranslationMenuOverlay();
                }
            });

            document.addEventListener('click', function (event) {
                const widget = document.getElementById('translationWidget');
                if (!widget || widget.contains(event.target)) {
                    return;
                }

                translationMenu.style.display = 'none';
            });
        }

        // Route-specific placement for translation button.
        const translationHeaderSlot = document.getElementById('translationHeaderSlot');
        const styleTranslationAsPill = function () {
            translationWidget.style.position = 'relative';
            translationWidget.style.inset = 'auto';
            translationWidget.style.margin = '0';
            translationWidget.style.zIndex = '10';

            translationToggle.style.width = 'auto';
            translationToggle.style.height = 'auto';
            translationToggle.style.borderRadius = '40px';
            translationToggle.style.padding = '9px 14px';
            translationToggle.style.fontSize = '14px';
            translationToggle.style.background = 'linear-gradient(135deg, #16a34a, #22c55e)';
            translationToggle.style.boxShadow = '0 8px 20px rgba(22, 163, 74, 0.35)';
            translationToggle.innerHTML = '<i class="fas fa-language"></i> Traduire';
        };

        const mountPageActionsInHeader = function (actionsId) {
            if (!translationHeaderSlot) {
                return false;
            }

            const actionsContainer = document.getElementById(actionsId);
            if (!actionsContainer) {
                return false;
            }

            styleTranslationAsPill();

            if (!actionsContainer.contains(translationWidget)) {
                actionsContainer.insertBefore(translationWidget, actionsContainer.firstChild);
            }

            if (actionsContainer.parentElement !== translationHeaderSlot) {
                translationHeaderSlot.appendChild(actionsContainer);
            }

            actionsContainer.style.position = 'static';
            actionsContainer.style.inset = 'auto';
            actionsContainer.style.display = 'flex';
            actionsContainer.style.alignItems = 'center';
            actionsContainer.style.gap = '10px';

            return true;
        };

        if (translationWidget && translationToggle) {
            if (currentRoute === 'app_budget_index') {
                if (!mountPageActionsInHeader('budgetTopActions')) {
                    styleTranslationAsPill();
                }
            } else if (currentRoute === 'app_depenses_index') {
                if (!mountPageActionsInHeader('depenseTopActions')) {
                    styleTranslationAsPill();
                }
            } else if (translationHeaderSlot &&
                (currentRoute.indexOf('app_depenses_') === 0 || currentRoute.indexOf('app_budget_') === 0)) {
                // Fallback for other budget/depense pages.
                styleTranslationAsPill();
                translationHeaderSlot.appendChild(translationWidget);
            }
        }

        translationButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                const targetLanguage = button.getAttribute('data-lang') || 'en';

                if (targetLanguage === 'original') {
                    clearTranslateCookie();
                } else if (targetLanguage === 'fr') {
                    setTranslateCookie('/fr/fr');
                } else {
                    setTranslateCookie('/fr/' + targetLanguage);
                }

                window.location.reload();
            });
        });

        // Keep guarding against late DOM injection from Google Translate.
        const translateShiftObserver = new MutationObserver(function () {
            fixGoogleTranslateLayoutShift();
        });
        translateShiftObserver.observe(document.documentElement, { attributes: true, childList: true, subtree: true });
        setTimeout(function () { translateShiftObserver.disconnect(); }, 6000);
    </script>

    {% if show_translation_widget %}
    <script>
        function googleTranslateElementInit() {
            if (!window.google || !window.google.translate || !window.google.translate.TranslateElement) {
                return;
            }

            new window.google.translate.TranslateElement({
                pageLanguage: 'fr',
                includedLanguages: 'fr,en,ar,es,de,it',
                autoDisplay: false,
                multilanguagePage: true
            }, 'google_translate_element');
        }
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    {% endif %}
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    {% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
</body>

</html>



