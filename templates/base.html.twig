                <button type="button" class="translation-lang-btn" data-lang="es" style="border: 1px solid #e2e8f0; background: #f8fafc; color: #0f172a; border-radius: 10px; padding: 8px 10px; text-align: left; font-size: 12px; font-weight: 600; cursor: pointer;">Espanol</button>
                <button type="button" class="translation-lang-btn" data-lang="de" style="border: 1px solid #e2e8f0; background: #f8fafc; color: #0f172a; border-radius: 10px; padding: 8px 10px; text-align: left; font-size: 12px; font-weight: 600; cursor: pointer;">Deutsch</button>
                <button type="button" class="translation-lang-btn" data-lang="it" style="border: 1px solid #e2e8f0; background: #f8fafc; color: #0f172a; border-radius: 10px; padding: 8px 10px; text-align: left; font-size: 12px; font-weight: 600; cursor: pointer;">Italiano</button>
            </div>
