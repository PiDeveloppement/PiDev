{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'add' ? 'Nouveau rôle' : 'Modifier le rôle' }} - EventFlow{% endblock %}

{% block admin_content %}
<div class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="bg-white rounded-2xl shadow-lg p-8">
        <!-- En-tête -->
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-700">{{ mode == 'add' ? '➕ Nouveau rôle' : '✏️ Modification du rôle' }}</h1>
            <span class="text-sm text-gray-500">{{ mode == 'add' ? 'Ajoutez un nouveau rôle' : 'Modifiez les informations du rôle' }}</span>
        </div>

        <!-- Formulaire -->
        <form method="post" action="{{ mode == 'add' ? path('app_role_new') : path('app_role_edit', {'id': role.id}) }}" class="space-y-6">
            <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-600">
                    Nom du rôle <span class="text-red-500">*</span>
                </label>
                <input type="text" 
                       name="role_name" 
                       value="{{ mode == 'edit' ? role.roleName : '' }}"
                       placeholder="Entrez le nom du rôle"
                       required
                       class="w-full px-5 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm">
            </div>

            <!-- Boutons d'action -->
            <div class="flex justify-center space-x-4 pt-4">
                <button type="submit" 
                        class="px-8 py-3 text-white font-bold rounded-lg shadow-lg transition-all hover:-translate-y-0.5"
                        style="background: linear-gradient(to right, {{ mode == 'add' ? '#10b981, #059669' : '#3b82f6, #1d4ed8' }});">
                    {{ mode == 'add' ? '➕ Ajouter' : '💾 Enregistrer' }}
                </button>
                <a href="{{ path('app_role_index') }}" 
                   class="px-8 py-3 bg-white text-gray-600 font-bold rounded-lg border border-gray-300 hover:bg-gray-50 transition-all">
                    🔄 Annuler
                </a>
            </div>

            <!-- Indication champ obligatoire -->
            <div class="text-center text-sm text-gray-500">
                ℹ️ Les champs marqués d'un * sont obligatoires
            </div>
        </form>
    </div>

    <!-- Informations additionnelles -->
    <div class="flex justify-center space-x-6 mt-6 text-sm">
        <span class="text-red-500 font-bold">⚡ Action non réversible</span>
        <span class="text-gray-300">•</span>
        <span class="text-gray-500">🔄 Retour à la liste après validation</span>
    </div>
</div>
{% endblock %}