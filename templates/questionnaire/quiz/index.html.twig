{% block javascripts %}
<!-- Popup reCAPTCHA -->
<div class="recaptcha-overlay" id="recaptchaOverlay">
    <div class="recaptcha-modal">
        <h3>🔒 Vérification de sécurité</h3>
        <p>Pour continuer, veuillez confirmer que vous n'êtes pas un robot en écrivant le texte ci-dessous.</p>
        
        <div style="margin: 20px 0;">
            <label style="display: block; margin-bottom: 10px; font-weight: bold; color: #2c3e50;">
                Veuillez écrire exactement : <span style="color: #e74c3c; font-family: monospace; font-size: 16px;">JE NE SUIS PAS UN ROBOT</span>
            </label>
            <input 
                type="text" 
                id="humanConfirmText" 
                placeholder="Écrivez JE NE SUIS PAS UN ROBOT ici..."
                style="
                    width: 100%;
                    padding: 12px;
                    border: 2px solid #ddd;
                    border-radius: 8px;
                    font-size: 16px;
                    text-align: center;
                    font-family: monospace;
                    text-transform: uppercase;
                "
                onkeyup="checkHumanText()"
            >
            <div id="textValidationMessage" style="margin-top: 10px; font-size: 14px; color: #e74c3c; display: none;">
                ❌ Texte incorrect. Veuillez écrire exactement : JE NE SUIS PAS UN ROBOT
            </div>
        </div>
        
        <div class="recaptcha-loading" id="recaptchaLoading">
            <div class="recaptcha-spinner"></div>
            <p>Vérification en cours...</p>
        </div>
        
        <button class="recaptcha-btn" id="recaptchaBtn" onclick="verifyRecaptcha()" disabled>
            ✅ Confirmer
        </button>
        <button class="recaptcha-btn" style="background: #e74c3c; margin-left: 10px;" onclick="cancelRecaptcha()">
            ❌ Annuler
        </button>
    </div>
</div>

<!-- Conteneur de notifications -->
<div class="notification-container" id="notificationContainer"></div>

<!-- reCAPTCHA v3 -->
<script src="https://www.google.com/recaptcha/api.js?render={{ recaptcha_site_key }}"></script>

<script>
let recaptchaToken = null;
let quizSubmitted = false;

// Afficher la popup reCAPTCHA au chargement de la page
document.addEventListener('DOMContentLoaded', function() {
    // Afficher la popup après 2 secondes
    setTimeout(function() {
        showRecaptchaPopup();
    }, 2000);
});

// Afficher la popup reCAPTCHA
function showRecaptchaPopup() {
    document.getElementById('recaptchaOverlay').style.display = 'flex';
    executeRecaptcha();
}

// Fermer la popup
function closeRecaptcha() {
    document.getElementById('recaptchaOverlay').style.display = 'none';
    // Réinitialiser le champ texte
    document.getElementById('humanConfirmText').value = '';
    document.getElementById('textValidationMessage').style.display = 'none';
    document.getElementById('recaptchaBtn').disabled = true;
}

// Annuler et revenir à la page précédente
function cancelRecaptcha() {
    showNotification('info', 'Annulation', 'Vous allez être redirigé vers la page précédente.');
    setTimeout(function() {
        window.history.back();
    }, 1500);
}

// Système de notifications
function showNotification(type, title, message, duration = 4000) {
    const container = document.getElementById('notificationContainer');
    
    const notification = document.createElement('div');
    notification.className = `notification ${type}`;
    
    let icon = '';
    switch(type) {
        case 'success':
            icon = '✅';
            break;
        case 'error':
            icon = '❌';
            break;
        case 'info':
            icon = 'ℹ️';
            break;
        default:
            icon = '📢';
    }
    
    notification.innerHTML = `
        <div class="notification-icon">${icon}</div>
        <div class="notification-content">
            <div class="notification-title">${title}</div>
            <div class="notification-message">${message}</div>
        </div>
        <button class="notification-close" onclick="closeNotification(this)">×</button>
    `;
    
    container.appendChild(notification);
    
    // Auto-suppression après la durée spécifiée
    if (duration > 0) {
        setTimeout(function() {
            closeNotification(notification.querySelector('.notification-close'));
        }, duration);
    }
}

function closeNotification(button) {
    const notification = button.closest('.notification');
    notification.classList.add('hiding');
    
    setTimeout(function() {
        if (notification.parentNode) {
            notification.parentNode.removeChild(notification);
        }
    }, 300);
}

// Vérifier le texte saisi par l'utilisateur
function checkHumanText() {
    const input = document.getElementById('humanConfirmText');
    const validationMessage = document.getElementById('textValidationMessage');
    const btn = document.getElementById('recaptchaBtn');
    const expectedText = 'JE NE SUIS PAS UN ROBOT';
    
    if (input.value.trim().toUpperCase() === expectedText) {
        validationMessage.style.display = 'none';
        input.style.borderColor = '#27ae60';
        btn.disabled = false;
        btn.style.background = 'linear-gradient(45deg, #27ae60, #229954)';
    } else {
        if (input.value.trim().length > 0) {
            validationMessage.style.display = 'block';
        } else {
            validationMessage.style.display = 'none';
        }
        input.style.borderColor = '#e74c3c';
        btn.disabled = true;
        btn.style.background = 'linear-gradient(45deg, #3498db, #2980b9)';
    }
}

// Exécuter reCAPTCHA
function executeRecaptcha() {
    const loading = document.getElementById('recaptchaLoading');
    
    loading.style.display = 'block';
    
    grecaptcha.ready(function() {
        grecaptcha.execute('{{ recaptcha_site_key }}', {action: 'quiz_start'}).then(function(token) {
            recaptchaToken = token;
            loading.style.display = 'none';
        }).catch(function(error) {
            console.error('reCAPTCHA error:', error);
            loading.style.display = 'none';
            showNotification('error', 'Erreur reCAPTCHA', 'La vérification reCAPTCHA a échoué. Veuillez réessayer.');
        });
    });
}

// Vérifier le reCAPTCHA
async function verifyRecaptcha() {
    const input = document.getElementById('humanConfirmText');
    const expectedText = 'JE NE SUIS PAS UN ROBOT';
    
    // Vérifier d'abord que le texte est correct
    if (input.value.trim().toUpperCase() !== expectedText) {
        showNotification('error', 'Texte incorrect', 'Veuillez d\'abord écrire correctement : JE NE SUIS PAS UN ROBOT');
        input.focus();
        return;
    }
    
    const btn = document.getElementById('recaptchaBtn');
    const loading = document.getElementById('recaptchaLoading');
    
    btn.disabled = true;
    btn.textContent = '⏳ Vérification...';
    
    try {
        const response = await fetch('/api/quiz/init', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                event_id: {{ eventId|default('null') }}
            })
        });

        const data = await response.json();

        if (data.success) {
            // Vérifier le reCAPTCHA avec l'API
            const verifyResponse = await fetch('/api/quiz/verify-recaptcha', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    session_token: data.session_token,
                    recaptcha_token: recaptchaToken
                })
            });

            const verifyData = await verifyResponse.json();

            if (verifyData.success) {
                // Succès - fermer la popup
                closeRecaptcha();
                showNotification('success', 'Vérification réussie !', 'Vous pouvez maintenant passer le quiz.');
                quizSubmitted = true;
            } else {
                btn.disabled = false;
                btn.textContent = '✅ Confirmer';
                showNotification('error', 'Échec de vérification', verifyData.message || 'La vérification a échoué');
            }
        } else {
            btn.disabled = false;
            btn.textContent = '✅ Confirmer';
            console.error('API Error:', data);
            showNotification('error', 'Erreur d\'initialisation', data.error || data.message || 'Erreur lors de l\'initialisation');
        }
    } catch (error) {
        console.error('Erreur:', error);
        btn.disabled = false;
        btn.textContent = '✅ Confirmer';
        showNotification('error', 'Erreur technique', 'Une erreur technique est survenue. Veuillez réessayer.');
    }
}
</script>
{% endblock %}