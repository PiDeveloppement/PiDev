{% extends 'base.html.twig' %}

{% block title %}Gestion des Feedbacks - EventFlow{% endblock %}

{# Utilisation du bloc admin_content défini dans ton base.html.twig #}
{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 text-gray-800">Liste des Feedbacks</h1>
            <p class="text-muted small">Visualisez et gérez les retours de vos participants.</p>
        </div>
        <a href="{{ path('app_questionnaire_feedback_new') }}" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Ajouter un Feedback
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover border-0" id="dataTable" width="100%" cellspacing="0">
                    <thead class="bg-light">
                        <tr>
                            <th>ID</th>
                            <th>Participant</th>
                            <th>Événement</th>
                            <th>Réponse</th>
                            <th>Note</th>
                            <th>Commentaire</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for feedback in feedbacks %}
                        <tr class="align-middle">
                            <td><span class="badge bg-secondary">#{{ feedback.id }}</span></td>
                            <td>
                                <div class="fw-bold">{{ feedback.userName }}</div>
                                <small class="text-muted">ID: {{ feedback.userId }}</small>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    {{ feedback.eventName }}
                                </span>
                            </td>
                            <td>
                                <code class="text-primary">{{ feedback.reponseDonnee }}</code>
                            </td>
                            <td class="text-warning fs-5" title="{{ feedback.etoiles }}/5">
                                {# Affiche le rendu des étoiles (méthode de ton entité) #}
                                {{ feedback.starsDisplay }}
                            </td>
                            <td>
                                <span class="text-muted" data-bs-toggle="tooltip" title="{{ feedback.comments }}">
                                    {{ feedback.comments|length > 30 ? feedback.comments|slice(0, 30) ~ '...' : feedback.comments }}
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a href="{{ path('app_questionnaire_feedback_show', {'id': feedback.id}) }}" class="btn btn-outline-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_questionnaire_feedback_edit', {'id': feedback.id}) }}" class="btn btn-outline-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    {# Inclusion du formulaire de suppression sécurisé #}
                                    {{ include('questionnaire/feedback/_delete_form.html.twig') }}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4">Aucun feedback trouvé pour le moment.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <p class="text-muted small">Total : <strong>{{ feedbacks|length }}</strong> feedbacks enregistrés.</p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Initialisation des tooltips Bootstrap pour les commentaires longs
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
{% endblock %}