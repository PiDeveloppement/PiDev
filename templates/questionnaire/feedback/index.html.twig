{% extends 'base.html.twig' %}

{% block admin_content %}
<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-comments text-primary me-2"></i>Tous les avis clients</h2>
    
    <div class="card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Date</th>
                    <th>ID User</th>
                    <th>Note</th>
                    <th>Commentaire</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for feedback in feedbacks %}
                <tr>
                    <td>{{ feedback.createdAt|date('d/m/Y') }}</td>
                    <td><span class="badge bg-secondary">User #{{ feedback.userId }}</span></td>
                    <td class="text-warning">{{ feedback.etoiles }} <i class="fas fa-star"></i></td>
                    <td>{{ feedback.comments }}</td>
                    <td>
                        <form method="post" action="{{ path('app_questionnaire_feedback_delete', {'id': feedback.id}) }}" onsubmit="return confirm('Supprimer cet avis ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ feedback.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}