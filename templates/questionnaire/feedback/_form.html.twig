{{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
    <div class="row g-4">
        {# Participant (Anciennement User) #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.user, 'Participant', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                <div class="input-group">
                    <span class="input-group-text bg-light text-primary"><i class="fas fa-user"></i></span>
                    {{ form_widget(form.user) }}
                </div>
                {{ form_errors(form.user) }}
            </div>
        </div>

        {# Question concernée #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.question, 'Question concernée', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                <div class="input-group">
                    <span class="input-group-text bg-light text-info"><i class="fas fa-question-circle"></i></span>
                    {{ form_widget(form.question) }}
                </div>
                {{ form_errors(form.question) }}
            </div>
        </div>

        {# Réponse donnée #}
        <div class="col-md-8">
            <div class="form-group">
                {{ form_label(form.reponseDonnee, 'Réponse du participant', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                <div class="input-group">
                    <span class="input-group-text bg-light text-success"><i class="fas fa-comment-dots"></i></span>
                    {{ form_widget(form.reponseDonnee) }}
                </div>
                {{ form_errors(form.reponseDonnee) }}
            </div>
        </div>

        {# Note en étoiles #}
        <div class="col-md-4">
            <div class="form-group">
                {{ form_label(form.etoiles, 'Note (0 à 5)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                <div class="input-group">
                    <span class="input-group-text bg-light text-warning"><i class="fas fa-star"></i></span>
                    {{ form_widget(form.etoiles) }}
                </div>
                {{ form_errors(form.etoiles) }}
            </div>
        </div>

        {# Commentaire / Avis #}
        <div class="col-12">
            <div class="form-group">
                {{ form_label(form.comments, 'Commentaire / Avis détaillé', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.comments) }}
                {{ form_errors(form.comments) }}
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
        <a href="{{ path('app_questionnaire_feedback_index') }}" class="btn btn-outline-secondary px-4 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
        <button type="submit" class="btn btn-primary px-5 shadow">
            <i class="fas fa-check-circle me-2"></i>{{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}