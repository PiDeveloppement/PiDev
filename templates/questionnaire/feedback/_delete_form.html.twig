<form method="post" action="{{ path('app_questionnaire_feedback_delete', {'id': feedback.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce feedback ?');" style="display:inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ feedback.id) }}">
    <button class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
</form>