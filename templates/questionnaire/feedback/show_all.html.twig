{% extends 'base.html.twig' %}

{% block title %}Avis des Utilisateurs - EventFlow{% endblock %}

{% block admin_content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            {# En-tête #}
            <div class="text-center mb-5">
                <h2 class="fw-bold">
                    <i class="fas fa-star text-warning me-2"></i>
                    Avis des Utilisateurs
                </h2>
                <p class="text-muted">Découvrez les derniers commentaires et évaluations</p>
            </div>

            {# Liste des feedbacks - un par utilisateur #}
            {% if userFeedbacks|length > 0 %}
                <div class="row">
                    {% for feedback in userFeedbacks %}
                        <div class="col-lg-6 col-xl-4 mb-4">
                            <div class="feedback-card h-100">
                                <div class="feedback-header">
                                    <div class="user-info">
                                        <i class="fas fa-user-circle"></i>
                                        <span>Utilisateur {{ feedback.getUserId() }}</span>
                                    </div>
                                    <div class="feedback-date">
                                        <small>{{ feedback.getCreatedAt() ? feedback.getCreatedAt()|date('d/m/Y') : '' }}</small>
                                    </div>
                                </div>
                                
                                <div class="feedback-rating">
                                    <div class="stars">
                                        {% for i in 1..5 %}
                                            {% if i <= feedback.getEtoiles() %}
                                                <i class="fas fa-star"></i>
                                            {% else %}
                                                <i class="far fa-star"></i>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                    <span class="rating-text">{{ feedback.getEtoiles() }}/5</span>
                                </div>
                                
                                <div class="feedback-comment">
                                    <p>{{ feedback.getComments() }}</p>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                {# Message si aucun avis #}
                <div class="text-center py-5">
                    <i class="fas fa-comment-slash fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Aucun avis trouvé</h4>
                    <p class="text-muted">
                        Aucun utilisateur n'a encore laissé d'avis.
                    </p>
                </div>
            {% endif %}

            {# Boutons de navigation #}
            <div class="text-center mt-5">
                <a href="{{ path('app_dashboard') }}" class="btn btn-outline-primary me-2">
                    <i class="fas fa-arrow-left me-2"></i>Retour au tableau
                </a>
                <a href="{{ path('app_questionnaire_feedback_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-list me-2"></i>Tous les feedbacks
                </a>
            </div>
        </div>
    </div>
</div>

<style>
.feedback-card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 3px 15px rgba(0,0,0,0.1);
    border: 1px solid #e9ecef;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
}

.feedback-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    border-color: #ffc107;
}

.feedback-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f8f9fa;
}

.user-info {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    color: #333;
}

.user-info i {
    font-size: 24px;
    color: #6c757d;
}

.feedback-date {
    font-size: 12px;
    color: #6c757d;
}

.feedback-rating {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
}

.stars {
    display: flex;
    gap: 3px;
}

.stars i {
    font-size: 18px;
    color: #ffc107;
}

.stars .far.fa-star {
    color: #dee2e6;
}

.rating-text {
    font-weight: 600;
    color: #6c757d;
    font-size: 14px;
}

.feedback-comment {
    flex-grow: 1;
}

.feedback-comment p {
    margin: 0;
    line-height: 1.6;
    color: #495057;
    font-size: 15px;
}

/* Responsive */
@media (max-width: 768px) {
    .feedback-card {
        padding: 20px;
    }
    
    .feedback-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
    
    .feedback-date {
        align-self: flex-end;
    }
}

/* Animation */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.feedback-card {
    animation: fadeInUp 0.6s ease-out;
}

.feedback-card:nth-child(1) { animation-delay: 0.1s; }
.feedback-card:nth-child(2) { animation-delay: 0.2s; }
.feedback-card:nth-child(3) { animation-delay: 0.3s; }
.feedback-card:nth-child(4) { animation-delay: 0.4s; }
.feedback-card:nth-child(5) { animation-delay: 0.5s; }
.feedback-card:nth-child(6) { animation-delay: 0.6s; }
</style>
{% endblock %}
