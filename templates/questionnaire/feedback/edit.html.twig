{% extends 'base.html.twig' %}

{% block title %}Modifier Feedback - EventFlow{% endblock %}

{# Utilisation du bloc spécifique à ton interface admin #}
{% block admin_content %} 
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h2 class="h5 mb-0"><i class="fas fa-edit me-2"></i>Modifier le Feedback</h2>
                </div>
                <div class="card-body p-4">
                    {# Inclusion du formulaire que tu as déjà créé #}
                    {{ include('questionnaire/feedback/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                </div>
            </div>
            
            <div class="mt-3 text-center">
                {{ include('questionnaire/feedback/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}