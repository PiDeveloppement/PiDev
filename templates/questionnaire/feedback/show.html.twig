{% extends 'base.html.twig' %}

{% block title %}Feedback{% endblock %}

{% block body %}
    <h1>Feedback</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ feedback.id }}</td>
            </tr>
            <tr>
                <th>UserId</th>
                <td>{{ feedback.userId }}</td>
            </tr>
            <tr>
                <th>QuestionId</th>
                <td>{{ feedback.questionId }}</td>
            </tr>
            <tr>
                <th>ReponseDonnee</th>
                <td>{{ feedback.reponseDonnee }}</td>
            </tr>
            <tr>
                <th>Comments</th>
                <td>{{ feedback.comments }}</td>
            </tr>
            <tr>
                <th>Etoiles</th>
                <td>{{ feedback.etoiles }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_questionnaire_feedback_index') }}">back to list</a>

    <a href="{{ path('app_questionnaire_feedback_edit', {'id': feedback.id}) }}">edit</a>

    {{ include('questionnaire/feedback/_delete_form.html.twig') }}
{% endblock %}
