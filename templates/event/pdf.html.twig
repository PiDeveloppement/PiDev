<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des événements</title>
    <style>
        @page {
            margin: 18mm 12mm 14mm 12mm;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: "Segoe UI", Arial, sans-serif;
            font-size: 12px;
            color: #1f2937;
            margin: 0;
            padding: 0;
            background: #ffffff;
        }

        .top-band {
            height: 6px;
            background: linear-gradient(90deg, #0f4c81 0%, #1d7bbf 55%, #38bdf8 100%);
            border-radius: 4px;
            margin-bottom: 14px;
        }

        .header {
            border: 1px solid #dbe7f3;
            border-radius: 10px;
            padding: 16px 18px;
            background: #f8fbff;
            margin-bottom: 14px;
        }

        .header table {
            width: 100%;
            border-collapse: collapse;
        }

        .brand {
            font-size: 11px;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            color: #0f4c81;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            color: #0f172a;
            font-weight: 800;
        }

        .header p {
            margin: 6px 0 0;
            font-size: 12px;
            color: #475569;
        }

        .meta {
            text-align: right;
            font-size: 11px;
            color: #64748b;
            line-height: 1.5;
            white-space: nowrap;
        }

        .stats {
            width: 100%;
            border-collapse: collapse;
            margin: 0 0 14px;
            table-layout: fixed;
        }

        .stats td {
            width: 33.33%;
            padding: 0 8px 0 0;
            vertical-align: top;
        }

        .stats td:last-child {
            padding-right: 0;
        }

        .stat-box {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 14px;
            background: #ffffff;
            min-height: 82px;
        }

        .stat-label {
            font-size: 10px;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .6px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 26px;
            line-height: 1;
            font-weight: 800;
            color: #0f4c81;
        }

        .stat-note {
            margin-top: 6px;
            font-size: 11px;
            color: #475569;
        }

        .table-wrap {
            border: 1px solid #dbe5ef;
            border-radius: 10px;
            overflow: hidden;
        }

        table.data-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .data-table thead th {
            background: #0f4c81;
            color: #ffffff;
            padding: 10px 10px;
            text-align: left;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
        }

        .data-table tbody tr:nth-child(odd) {
            background: #ffffff;
        }

        .data-table tbody tr:nth-child(even) {
            background: #f8fbff;
        }

        .data-table tbody td {
            padding: 9px 10px;
            border-bottom: 1px solid #e2e8f0;
            font-size: 11px;
            color: #1f2937;
            vertical-align: top;
            word-wrap: break-word;
        }

        .col-id { width: 6%; }
        .col-title { width: 24%; }
        .col-category { width: 15%; }
        .col-dates { width: 24%; }
        .col-location { width: 18%; }
        .col-price { width: 13%; }

        .event-title {
            font-weight: 700;
            color: #0f172a;
        }

        .small {
            color: #64748b;
            font-size: 10px;
        }

        .price-free {
            color: #166534;
            font-weight: 700;
        }

        .price-paid {
            color: #b45309;
            font-weight: 700;
        }

        .empty {
            text-align: center;
            padding: 20px;
            color: #64748b;
            font-size: 12px;
            font-style: italic;
        }

        .footer {
            margin-top: 12px;
            border-top: 1px solid #dbe5ef;
            padding-top: 8px;
            color: #64748b;
            font-size: 10px;
            text-align: right;
        }
    </style>
</head>
<body>
    <div class="top-band"></div>

    <div class="header">
        <table>
            <tr>
                <td>
                    <div class="brand">EventFlow</div>
                    <h1>Rapport des événements</h1>
                    <p>Vue globale des événements, catégories, dates et tarification.</p>
                </td>
                <td class="meta">
                    Généré le {{ "now"|date("d/m/Y") }}<br>
                    Heure {{ "now"|date("H:i") }}<br>
                    Document interne
                </td>
            </tr>
        </table>
    </div>

    <table class="stats">
        <tr>
            <td>
                <div class="stat-box">
                    <div class="stat-label">Total événements</div>
                    <div class="stat-value">{{ events|length }}</div>
                    <div class="stat-note">Tous statuts confondus</div>
                </div>
            </td>
            <td>
                <div class="stat-box">
                    <div class="stat-label">Événements gratuits</div>
                    <div class="stat-value">{{ events|filter(e => e.isFree)|length }}</div>
                    <div class="stat-note">Accès sans ticket payant</div>
                </div>
            </td>
            <td>
                <div class="stat-box">
                    <div class="stat-label">Événements payants</div>
                    <div class="stat-value">{{ events|filter(e => not e.isFree)|length }}</div>
                    <div class="stat-note">Avec ticket</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="col-id">#</th>
                    <th class="col-title">Événement</th>
                    <th class="col-category">Catégorie</th>
                    <th class="col-dates">Dates</th>
                    <th class="col-location">Lieu</th>
                    <th class="col-price">Tarif</th>
                </tr>
            </thead>
            <tbody>
            {% for event in events %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>
                        <div class="event-title">{{ event.title }}</div>
                        <div class="small">Capacité: {{ event.capacity ?? 0 }} places</div>
                    </td>
                    <td>{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : '-' }}</td>
                    <td>
                        Début: {{ event.startDate ? event.startDate|date('d/m/Y H:i') : '-' }}<br>
                        Fin: {{ event.endDate ? event.endDate|date('d/m/Y H:i') : '-' }}
                    </td>
                    <td>{{ event.location ?: '-' }}</td>
                    <td>
                        {% if event.isFree %}
                            <span class="price-free">Gratuit</span>
                        {% else %}
                            <span class="price-paid">{{ event.ticketPrice ?? 0 }} TND</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="empty">Aucun événement disponible.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="footer">
        EventFlow | Rapport événements | © {{ "now"|date("Y") }}
    </div>
</body>
</html>
