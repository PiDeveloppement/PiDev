{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - Événement{% endblock %}

{% block admin_content %}
{% set now = "now"|date('U') %}
{% set start = event.startDate ? event.startDate|date('U') : 0 %}
{% set end = event.endDate ? event.endDate|date('U') : 0 %}

{% if end < now %}
    {% set temporalStatus = 'termine' %}
    {% set statusLabel = 'Terminé' %}
{% elseif start > now %}
    {% set temporalStatus = 'avenir' %}
    {% set statusLabel = 'À venir' %}
{% else %}
    {% set temporalStatus = 'encours' %}
    {% set statusLabel = 'En cours' %}
{% endif %}

<style>
    .event-show-topbar {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .event-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 12px 18px;
        text-decoration: none;
        color: #48627d;
        font-size: 14px;
        font-weight: 600;
        background: #f8fbff;
    }

    .event-back-link:hover {
        background: #eef6ff;
        color: #27496d;
    }

    .event-show-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 16px;
    }

    .event-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .event-main-head {
        padding: 20px;
        border-bottom: 1px solid #e2e8f0;
        background: linear-gradient(140deg, #f4f9ff 0%, #ffffff 62%);
    }

    .event-main-title {
        margin: 0;
        color: #0f172a;
        font-size: 1.6rem;
        font-weight: 800;
    }

    .event-main-meta {
        margin-top: 12px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .event-meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border-radius: 999px;
        border: 1px solid #dbeafe;
        background: #f8fbff;
        color: #37506b;
        font-size: 12px;
        font-weight: 600;
        padding: 5px 12px;
        max-width: 100%;
    }

    .event-meta-icon {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #dbeafe;
        color: #1d4ed8;
        font-size: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .event-status-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .event-status-pill.avenir { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }
    .event-status-pill.encours { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    .event-status-pill.termine { background: #e2e8f0; color: #334155; border-color: #cbd5e1; }

    .event-main-body {
        padding: 20px;
    }

    .event-block-title {
        margin: 0 0 10px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .35px;
        color: #64748b;
        text-transform: uppercase;
    }

    .event-description {
        margin: 0;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        line-height: 1.65;
        color: #334155;
        white-space: pre-line;
    }

    .event-poster-wrap {
        margin-bottom: 16px;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        background: #f8fafc;
        min-height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .event-poster-wrap img {
        display: block;
        width: 100%;
        max-height: 520px;
        object-fit: contain;
    }

    .event-poster-empty {
        color: #64748b;
        font-size: 13px;
        text-align: center;
        padding: 16px;
    }

    .event-data-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .event-data-item {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: #ffffff;
        padding: 11px 12px;
    }

    .event-data-label {
        display: block;
        color: #94a3b8;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .event-data-value {
        margin-top: 5px;
        color: #0f172a;
        font-size: 14px;
        font-weight: 700;
    }

    .event-side {
        padding: 16px;
    }

    .event-side-item {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 10px;
        background: #ffffff;
    }

    .event-side-label {
        color: #94a3b8;
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 700;
    }

    .event-side-value {
        margin-top: 5px;
        color: #0f172a;
        font-size: 14px;
        font-weight: 700;
    }

    .event-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .event-btn {
        border: none;
        border-radius: 10px;
        padding: 9px 13px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
    }

    .event-btn.edit {
        background: linear-gradient(180deg, #1d7bbf 0%, #1565c0 100%);
        color: #ffffff;
    }

    .event-btn.delete {
        background: linear-gradient(180deg, #ef4444 0%, #dc2626 100%);
        color: #ffffff;
    }

    @media (max-width: 960px) {
        .event-show-topbar {
            flex-direction: column;
            align-items: flex-start;
        }

        .event-show-layout {
            grid-template-columns: 1fr;
        }

        .event-data-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="event-show-topbar">
    <a class="event-back-link" href="{{ path('app_event_index') }}">
        <span aria-hidden="true">←</span>
        <span>Retour à la liste</span>
    </a>
</div>

<div class="event-show-layout">
    <section class="event-card">
        <div class="event-main-head">
            <h3 class="event-main-title">{{ event.title }}</h3>
            <div class="event-main-meta">
                <span class="event-status-pill {{ temporalStatus }}">{{ statusLabel }}</span>
                <span class="event-meta-chip">
                    <span class="event-meta-icon">🏷️</span>
                    <span>{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : 'Sans catégorie' }}</span>
                </span>
                <span class="event-meta-chip">
                    <span class="event-meta-icon">📍</span>
                    <span>{{ event.location ?: 'Lieu non renseigné' }}</span>
                </span>
            </div>
        </div>

        <div class="event-main-body">
            <h4 class="event-block-title">Affiche de l'événement</h4>
            <div class="event-poster-wrap">
                {% if event.imageUrl %}
                    <img src="{{ asset(event.imageUrl) }}" alt="Affiche de {{ event.title }}">
                {% else %}
                    <div class="event-poster-empty">Aucune affiche n'a ete generee pour cet evenement.</div>
                {% endif %}
            </div>

            <h4 class="event-block-title">Description</h4>
            <p class="event-description">{{ event.description ?: 'Aucune description fournie.' }}</p>

            <div class="event-data-grid">
                <div class="event-data-item">
                    <span class="event-data-label">Début</span>
                    <div class="event-data-value">{{ event.startDate ? event.startDate|date('d/m/Y H:i') : '-' }}</div>
                </div>
                <div class="event-data-item">
                    <span class="event-data-label">Fin</span>
                    <div class="event-data-value">{{ event.endDate ? event.endDate|date('d/m/Y H:i') : '-' }}</div>
                </div>
                <div class="event-data-item">
                    <span class="event-data-label">Capacité</span>
                    <div class="event-data-value">{{ event.capacity ?? 0 }} personnes</div>
                </div>
                <div class="event-data-item">
                    <span class="event-data-label">Prix du ticket</span>
                    <div class="event-data-value">
                        {% if event.isFree %}
                            Gratuit
                        {% else %}
                            {{ event.ticketPrice ?? 0 }} TND
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <aside class="event-card event-side">
        <div class="event-side-item">
            <div class="event-side-label">Créé par</div>
            <div class="event-side-value">{{ event.creator ? (event.creator.firstName ~ ' ' ~ event.creator.lastName) : 'Non défini' }}</div>
        </div>

        <div class="event-side-item">
            <div class="event-side-label">Date de création</div>
            <div class="event-side-value">{{ event.createdAt ? event.createdAt|date('d/m/Y H:i') : '-' }}</div>
        </div>

        <div class="event-side-item">
            <div class="event-side-label">Dernière mise à jour</div>
            <div class="event-side-value">{{ event.updatedAt ? event.updatedAt|date('d/m/Y H:i') : 'Aucune' }}</div>
        </div>

        <div class="event-actions">
            <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="event-btn edit">
                <i class="fas fa-pen"></i>
                Modifier
            </a>
            <form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" style="margin:0;" onsubmit="return confirm('Supprimer cet événement ?');">
                <button type="submit" class="event-btn delete">
                    <i class="fas fa-trash"></i>
                    Supprimer
                </button>
            </form>
        </div>
    </aside>
</div>
{% endblock %}
