{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {# FIX TURBO: force full reload sur cette page #}
    <meta name="turbo-visit-control" content="reload">
{% endblock %}

{% block title %}Gestion des billets{% endblock %}

{% block kpi %}
<div style="background:#dcfce7; border-radius:12px; padding:12px 20px; text-align:center; min-width:130px;">
    <i class="fas fa-ticket-alt" style="color:#16a34a; font-size:20px;"></i>
    <div style="font-size:1.8rem; font-weight:700; color:#16a34a;">{{ totalTickets }}</div>
    <div style="color:#64748b; font-size:12px;">Billets</div>
</div>
<div style="background:#e3f2fd; border-radius:12px; padding:12px 20px; text-align:center; min-width:130px;">
    <i class="fas fa-calendar-alt" style="color:#1565c0; font-size:20px;"></i>
    <div style="font-size:1.8rem; font-weight:700; color:#1565c0;">{{ totalEvents }}</div>
    <div style="color:#64748b; font-size:12px;">Événements</div>
</div>
{% endblock %}

{% block admin_content %}
<style>
    .ticket-toolbar {
        display:flex; align-items:center; gap:10px; flex-wrap:wrap;
        background:#fff; border:1px solid #e2e8f0; border-radius:14px;
        padding:12px 16px; margin-bottom:16px;
    }
    .ticket-input, .ticket-select {
        border:1px solid #cbd5e1; border-radius:8px;
        padding:8px 12px; font-size:13px; color:#0f172a; outline:none;
    }
    .ticket-input { width:280px; }
    .ticket-select { width:170px; }
    .ticket-spacer { flex:1; }

    .ticket-table-wrap {
        background:#fff; border:1px solid #e2e8f0; border-radius:16px;
        overflow:hidden; box-shadow:0 2px 10px rgba(2,6,23,.04);
    }
    .ticket-table { width:100%; border-collapse:collapse; font-size:13px; }
    .ticket-table thead th {
        background:#f8fafc; color:#334155; border-bottom:1px solid #e2e8f0;
        padding:12px 14px; text-align:left; font-weight:700;
    }
    .ticket-table tbody td {
        border-bottom:1px solid #f1f5f9; padding:11px 14px;
        color:#334155; vertical-align:middle;
    }
    .ticket-table tbody tr:hover { background:#f8fbff; }

    .badge-used { background:#fee2e2; color:#991b1b; border-radius:999px; padding:4px 12px; font-size:11px; font-weight:700; }
    .badge-unused { background:#dcfce7; color:#166534; border-radius:999px; padding:4px 12px; font-size:11px; font-weight:700; }

    .btn-action {
        border:none; border-radius:8px; color:#fff;
        width:32px; height:32px; cursor:pointer;
        display:inline-flex; align-items:center; justify-content:center;
        text-decoration:none; font-size:13px;
    }
    .btn-view { background:#0891b2; }
    .btn-delete { background:#dc2626; }
    .btn-view:hover { background:#0e7490; }
    .btn-delete:hover { background:#b91c1c; }

    .result-pill {
        color:#64748b; font-size:13px; background:#fff;
        border:1px solid #e2e8f0; border-radius:20px; padding:5px 14px;
    }

    .pagination-shell {
        margin-top:16px;
        display:flex;
        align-items:center;
        justify-content:center;
        flex-direction:column;
        gap:10px;
        flex-wrap:wrap;
    }
    .pagination-info {
        color:#64748b;
        font-size:13px;
        font-weight:500;
        text-align:center;
        width:100%;
    }
    .pagination-nav {
        display:flex;
        align-items:center;
        gap:6px;
        flex-wrap:wrap;
    }
    .page-btn {
        min-width:52px;
        height:46px;
        border-radius:10px;
        border:1px solid #e5e7eb;
        background:#fff;
        color:#6b7280;
        font-size:13px;
        font-weight:500;
        text-decoration:none;
        display:inline-flex;
        align-items:center;
        justify-content:center;
        padding:0 14px;
    }
    .page-btn.current {
        background:#2196f3;
        color:#fff;
        border-color:#2196f3;
        font-weight:700;
    }
    .page-btn.disabled {
        color:#9ca3af;
        background:#f9fafb;
        border-color:#e5e7eb;
        pointer-events:none;
    }
    .page-btn.arrow {
        min-width:132px;
    }
</style>

<div class="ticket-toolbar">
    <form method="get" action="{{ path('app_ticket_index') }}" style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; width:100%;">
        <input class="ticket-input" type="text" name="search" value="{{ search }}" placeholder="🔍 Rechercher par code ticket...">

        <select class="ticket-select" name="event">
            <option value="">📅 Tous les événements</option>
            {% for event in events %}
                <option value="{{ event.id }}" {% if eventFilter is not null and eventFilter != '' and eventFilter == event.id %}selected{% endif %}>{{ event.title }}</option>
            {% endfor %}
        </select>

        <select class="ticket-select" name="status">
            <option value="">📊 Tous les statuts</option>
            <option value="unused" {% if statusFilter == 'unused' %}selected{% endif %}>Non utilisé</option>
            <option value="used" {% if statusFilter == 'used' %}selected{% endif %}>Utilisé</option>
        </select>

        <div class="ticket-spacer"></div>

        <button type="submit" style="background:#1565c0; color:#fff; border:none; border-radius:8px; padding:8px 16px; font-size:13px; font-weight:600; cursor:pointer;">Filtrer</button>
        <a href="{{ path('app_ticket_index') }}" style="background:#f1f5f9; color:#334155; border:1px solid #e2e8f0; border-radius:8px; padding:8px 16px; font-size:13px; font-weight:600; text-decoration:none;">Réinitialiser</a>
    </form>
    <span class="result-pill">{{ tickets.getTotalItemCount }} résultat(s)</span>
</div>

<div class="ticket-table-wrap">
    <table class="ticket-table">
        <thead>
            <tr>
                <th>Code Ticket</th>
                <th>Événement</th>
                <th>Participant</th>
                <th>Statut</th>
                <th>Date création</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for ticket in tickets %}
                <tr>
                    <td><strong>{{ ticket.ticketCode }}</strong></td>
                    <td>{{ ticket.event ? ticket.event.title : '-' }}</td>
                    <td>
                        {% if ticket.user %}
                            {{ ticket.user.firstName }} {{ ticket.user.lastName }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if ticket.isUsed %}
                            <span class="badge-used">Utilisé</span>
                        {% else %}
                            <span class="badge-unused">Non utilisé</span>
                        {% endif %}
                    </td>
                    <td>{{ ticket.createdAt ? ticket.createdAt|date('d/m/Y H:i') : '-' }}</td>
                    <td style="display:flex; gap:6px;">
                        <a href="{{ path('app_ticket_show', {'id': ticket.id}) }}" class="btn-action btn-view" title="Voir">
                            <i class="fas fa-eye"></i>
                        </a>
                        <form method="post" action="{{ path('app_ticket_delete', {'id': ticket.id}) }}" onsubmit="return confirm('Supprimer ce billet ?')" style="margin:0;">
                            <button type="submit" class="btn-action btn-delete" title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="text-align:center; color:#64748b; padding:28px;">Aucun billet trouvé</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% set p = tickets.paginationData %}
{% set startItem = tickets.getTotalItemCount > 0 ? ((p.current - 1) * tickets.getItemNumberPerPage + 1) : 0 %}
{% set endItem = tickets.getTotalItemCount > 0 ? (startItem + tickets|length - 1) : 0 %}

<div class="pagination-shell">
    <div class="pagination-info">
        Affichage {{ startItem }}-{{ endItem }} sur {{ tickets.getTotalItemCount }}
    </div>

    <div class="pagination-nav" aria-label="Pagination billets">
        {% if p.previous is defined %}
            <a class="page-btn arrow" href="{{ path('app_ticket_index', app.request.query.all|merge({'page': p.previous})) }}">&laquo; Précédent</a>
        {% else %}
            <span class="page-btn arrow disabled">&laquo; Précédent</span>
        {% endif %}

        {% if tickets.pageCount > 1 %}
            {% for page in p.pagesInRange %}
                {% if page == p.current %}
                    <span class="page-btn current">{{ page }}</span>
                {% else %}
                    <a class="page-btn" href="{{ path('app_ticket_index', app.request.query.all|merge({'page': page})) }}">{{ page }}</a>
                {% endif %}
            {% endfor %}
        {% else %}
            <span class="page-btn current">1</span>
        {% endif %}

        {% if p.next is defined %}
            <a class="page-btn arrow" href="{{ path('app_ticket_index', app.request.query.all|merge({'page': p.next})) }}">Suivant &raquo;</a>
        {% else %}
            <span class="page-btn arrow disabled">Suivant &raquo;</span>
        {% endif %}
    </div>
</div>
{% endblock %}
