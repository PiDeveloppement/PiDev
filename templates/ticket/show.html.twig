{% extends 'base.html.twig' %}
{% block title %}Détail billet{% endblock %}

{% block admin_content %}
<style>
    .ticket-show-wrap {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 2px 10px rgba(2, 6, 23, .04);
    }

    .ticket-show-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 0 16px;
        border-bottom: 1px solid #eef2f7;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .ticket-head-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-soft {
        background: #f1f5f9;
        color: #334155;
        border: 1px solid #dbe3ee;
        border-radius: 8px;
        padding: 9px 14px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
    }

    .ticket-title {
        font-size: 38px;
        font-weight: 800;
        color: #1f2937;
        line-height: 1;
        margin: 0;
    }

    .ticket-subtitle {
        margin: 3px 0 0;
        color: #94a3b8;
        font-size: 13px;
    }

    .ticket-status {
        border-radius: 999px;
        padding: 9px 18px;
        font-weight: 700;
        font-size: 18px;
        white-space: nowrap;
    }

    .ticket-status.valid {
        background: #d1fae5;
        color: #047857;
    }

    .ticket-status.used {
        background: #fee2e2;
        color: #b91c1c;
    }

    .ticket-main-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 18px;
    }

    .verify-label {
        font-size: 28px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 12px;
    }

    .verify-placeholder {
        width: 100%;
        height: 320px;
        background: #fbfdff;
        border: 2px dashed #d7dfeb;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 14px;
        text-align: center;
        padding: 16px;
    }

    .qr-preview {
        width: 100%;
        min-height: 320px;
        background: #ffffff;
        border: 2px solid #dbe3ee;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .65);
        margin-bottom: 12px;
    }

    .qr-preview img {
        width: 100%;
        max-width: 280px;
        height: auto;
        display: block;
    }

    .ticket-code-box {
        margin-top: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 14px;
    }

    .ticket-code-label {
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .ticket-code-value {
        color: #2563eb;
        font-size: 30px;
        font-weight: 800;
        letter-spacing: .5px;
    }

    .ticket-info-list {
        display: grid;
        gap: 12px;
    }

    .info-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
    }

    .info-title {
        color: #64748b;
        font-size: 18px;
        font-weight: 700;
        margin: 0 0 10px;
    }

    .info-main {
        font-size: 30px;
        font-weight: 800;
        color: #1f2937;
        margin: 0;
        line-height: 1.1;
    }

    .info-sub {
        margin-top: 6px;
        color: #64748b;
        font-size: 16px;
    }

    .dates-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(180px, 1fr));
        gap: 12px;
    }

    .date-item-label {
        color: #94a3b8;
        font-size: 12px;
        margin-bottom: 4px;
    }

    .date-item-value {
        color: #1f2937;
        font-size: 18px;
        font-weight: 700;
    }

    .ticket-actions {
        margin-top: 14px;
        display: flex;
        gap: 8px;
    }

    .btn-danger {
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 14px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
    }

    @media (max-width: 1080px) {
        .ticket-title { font-size: 30px; }
        .ticket-main-grid { grid-template-columns: 1fr; }
        .ticket-code-value { font-size: 24px; }
        .info-main { font-size: 24px; }
    }
</style>

<div class="ticket-show-wrap">
    <div class="ticket-show-head">
        <div class="ticket-head-left">
            <a href="{{ path('app_ticket_index') }}" class="btn-soft">&larr; Retour aux billets</a>
            <div>
                <h2 class="ticket-title">Détails du Billet</h2>
                <p class="ticket-subtitle">Consultation et gestion du billet d'événement</p>
            </div>
        </div>

        <span class="ticket-status {{ ticket.isUsed ? 'used' : 'valid' }}">
            {{ ticket.isUsed ? 'Billet Utilisé' : 'Ticket Valide' }}
        </span>
    </div>

    <div class="ticket-main-grid">
        <div>
            <h3 class="verify-label">Code de Vérification</h3>
            {% if ticket.qrCode %}
                <div class="qr-preview">
                    {% set scanUrl = url('app_ticket_scan_auto', { token: ticket.qrCode }) %}
                    <img src="{{ qr_code_data_uri(scanUrl, 'pdf') }}" alt="QR code du billet">
                </div>
            {% else %}
                <div class="verify-placeholder">
                    QR Code indisponible pour ce billet.
                </div>
            {% endif %}

            <div class="ticket-code-box">
                <div class="ticket-code-label">Numéro du Billet</div>
                <div class="ticket-code-value">{{ ticket.ticketCode }}</div>
            </div>
        </div>

        <div class="ticket-info-list">
            <div class="info-card">
                <h4 class="info-title">Événement</h4>
                <p class="info-main">{{ ticket.event ? ticket.event.title : '-' }}</p>
                <div class="info-sub">
                    {{ ticket.event and ticket.event.startDate ? ticket.event.startDate|date('d/m/Y') : '-' }}
                    {% if ticket.event and ticket.event.location %}
                        <br>{{ ticket.event.location }}
                    {% endif %}
                </div>
            </div>

            <div class="info-card">
                <h4 class="info-title">Participant</h4>
                <p class="info-main">
                    {% if ticket.user %}
                        {{ ticket.user.firstName }} {{ ticket.user.lastName }}
                    {% else %}
                        -
                    {% endif %}
                </p>
                <div class="info-sub">{{ ticket.user ? ticket.user.email : '-' }}</div>
            </div>

            <div class="info-card">
                <h4 class="info-title">Dates</h4>
                <div class="dates-grid">
                    <div>
                        <div class="date-item-label">Créé le</div>
                        <div class="date-item-value">{{ ticket.createdAt ? ticket.createdAt|date('d/m/Y H:i') : '-' }}</div>
                    </div>
                    <div>
                        <div class="date-item-label">Utilisé le</div>
                        <div class="date-item-value">{{ ticket.usedAt ? ticket.usedAt|date('d/m/Y H:i') : 'Non utilisé' }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="ticket-actions">
        <form method="post" action="{{ path('app_ticket_delete', {'id': ticket.id}) }}" onsubmit="return confirm('Supprimer ce billet ?')" style="margin:0;">
            <button type="submit" class="btn-danger">Supprimer</button>
        </form>
    </div>
</div>
{% endblock %}
