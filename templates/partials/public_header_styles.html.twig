.navbar {
    background: #ffffff;
    padding: 0 60px;
    border-bottom: 1px solid #e2e8f0;
    height: 80px;
    display: flex;
    align-items: center;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    font-family: 'Inter', sans-serif;
}

.nav-container {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
}

.logo-container {
    display: inline-flex;
    align-items: center;
}

.logo-container img {
    width: auto;
    height: 56px;
    max-width: 180px;
    object-fit: contain;
    display: block;
}

.nav-links {
    display: flex;
    gap: 40px;
    position: relative;
    top: -4px;
    align-items: center;
    flex-wrap: wrap;
}

.nav-link {
    background: transparent;
    color: #1e293b;
    font-size: 16px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
}

.nav-link:hover {
    color: #0D47A1;
}

.nav-link.is-active {
    color: #0D47A1;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid #2563eb;
    padding-bottom: 2px;
}

.nav-buttons {
    display: flex;
    gap: 15px;
    align-items: center;
    position: relative;
    top: -4px;
    min-height: 42px;
}

.btn-login {
    background: transparent;
    color: #0D47A1;
    font-weight: bold;
    border: 1.5px solid #0D47A1;
    border-radius: 8px;
    padding: 8px 24px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s ease;
}

.btn-login:hover {
    background: rgba(13, 71, 161, 0.05);
}

.btn-signup {
    background: #0D47A1;
    color: white;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 8px 24px;
    cursor: pointer;
    font-size: 14px;
    box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
    transition: all 0.2s ease;
}

.btn-signup:hover {
    background: #0A3A80;
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
}

.participant-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #7fb2ea;
    background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
    border-radius: 20px;
    padding: 4px 10px 4px 6px;
    color: #ffffff;
    box-sizing: border-box;
    min-height: 42px;
    width: 184px;
    min-width: 184px;
    max-width: 184px;
    cursor: pointer;
}

.participant-chip-menu {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin: 0;
}

.participant-chip-menu summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
}

.participant-chip-menu summary::-webkit-details-marker {
    display: none;
}

.participant-chip-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 170px;
    background: #ffffff;
    border: 1px solid #d9e2ef;
    border-radius: 12px;
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
    padding: 8px;
    z-index: 1200;
}

.participant-chip-action {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    text-decoration: none;
    padding: 10px 12px;
    border-radius: 8px;
    color: #1e293b;
    font-weight: 600;
    font-size: 14px;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
}

.participant-chip-action:hover {
    background: #f3f7fd;
}

.participant-chip-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #0f4d90;
    border: 2px solid rgba(255,255,255,0.75);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    color: #ffffff;
}

.participant-chip-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
}

.participant-chip-name {
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.participant-chip-role {
    font-size: 11px;
    color: rgba(255,255,255,0.84);
}

.public-header-offset {
    margin-top: 80px;
}
