    <script>
        // Fonction pour scroller vers une section
        function scrollToSection(sectionId) {
            const section = document.getElementById(sectionId);
            if (section) {
                const navbarHeight = 80;
                const elementPosition = section.getBoundingClientRect().top + window.pageYOffset;
                window.scrollTo({
                    top: elementPosition - navbarHeight,
                    behavior: 'smooth'
                });
            }
        }

        // Animation des cartes au survol
        document.querySelectorAll('.feature-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.boxShadow = '0 10px 25px rgba(0, 0, 0, 0.1)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
                this.style.boxShadow = 'none';
            });
        });
    </script>

    <script>
        // Theme toggle for front office
        function toggleTheme() {
            const body = document.body;
            const themeIconLanding = document.getElementById('themeIconLanding');
            const themeTextLanding = document.getElementById('themeTextLanding');
            
            if (body.classList.contains('dark-mode')) {
                body.classList.remove('dark-mode');
                localStorage.setItem('theme', 'light');
                if (themeIconLanding) {
                    themeIconLanding.classList.remove('fa-sun');
                    themeIconLanding.classList.add('fa-moon');
                }
                if (themeTextLanding) {
                    themeTextLanding.textContent = 'Mode Sombre';
                }
            } else {
                body.classList.add('dark-mode');
                localStorage.setItem('theme', 'dark');
                if (themeIconLanding) {
                    themeIconLanding.classList.remove('fa-moon');
                    themeIconLanding.classList.add('fa-sun');
                }
                if (themeTextLanding) {
                    themeTextLanding.textContent = 'Mode Clair';
                }
            }
        }

        // Load saved theme on page load for front office
        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('theme');
            const themeIconLanding = document.getElementById('themeIconLanding');
            const themeTextLanding = document.getElementById('themeTextLanding');
            
            if (savedTheme === 'dark') {
                document.body.classList.add('dark-mode');
                if (themeIconLanding) {
                    themeIconLanding.classList.remove('fa-moon');
                    themeIconLanding.classList.add('fa-sun');
                }
                if (themeTextLanding) {
                    themeTextLanding.textContent = 'Mode Clair';
                }
            }
        });

        (function () {
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function renderNotifications(listNode, notifications) {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    listNode.innerHTML = '<div class="notif-empty">Aucune notification.</div>';
                    return;
                }

                listNode.innerHTML = notifications.map(function (item) {
                    var icon = item.icon ? escapeHtml(item.icon) : '🔔';
                    var type = item.type ? escapeHtml(item.type) : 'INFO';
                    var createdAt = item.createdAt ? escapeHtml(item.createdAt) : '-';
                    var title = item.title ? escapeHtml(item.title) : 'Notification';
                    var message = item.message ? escapeHtml(item.message) : '';
                    var readClass = item.isRead ? 'read' : 'unread';
                    var notificationId = Number(item.id || 0);

                    return '' +
                        '<article class="notif-item ' + readClass + '">' +
                            '<div class="notif-item-head">' +
                                '<span class="notif-item-meta">' +
                                    '<span>' + icon + ' ' + type + '</span>' +
                                    '<span>•</span>' +
                                    '<span>' + createdAt + '</span>' +
                                '</span>' +
                                '<button type="button" class="notif-delete-btn" title="Supprimer" aria-label="Supprimer notification" data-notif-delete-id="' + notificationId + '"><i class="fas fa-trash-alt" aria-hidden="true"></i></button>' +
                            '</div>' +
                            '<p class="notif-item-title">' + title + '</p>' +
                            '<p class="notif-item-message">' + message + '</p>' +
                        '</article>';
                }).join('');
            }

            function updateBadge(badgeNode, unreadCount) {
                if (!badgeNode) {
                    return;
                }

                if (unreadCount > 0) {
                    badgeNode.hidden = false;
                    badgeNode.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
                } else {
                    badgeNode.hidden = true;
                    badgeNode.textContent = '0';
                }
            }

            async function fetchLatest(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifUrl, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        const bodyText = await response.text();
                        throw new Error('HTTP ' + response.status + ' ' + bodyText.slice(0, 120));
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    renderNotifications(listNode, payload.notifications || []);
                } catch (error) {
                    const message = error && error.message ? error.message : 'Impossible de charger les notifications.';
                    listNode.innerHTML = '<div class="notif-empty">' + escapeHtml(message) + '</div>';
                }
            }

            async function markAllAsRead(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifMarkReadUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('mark all failed');
                    }

                    updateBadge(badgeNode, 0);
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep silent to avoid intrusive UI in header.
                }
            }

            async function deleteNotification(root, notificationId, badgeNode, listNode) {
                const urlTemplate = root.dataset.notifDeleteUrlTemplate || '';
                if (!urlTemplate || !notificationId) {
                    return;
                }

                const deleteUrl = urlTemplate.replace('__id__', String(notificationId));

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifDeleteCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('delete failed');
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep quiet in header UI.
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                const roots = document.querySelectorAll('[data-notif-root]');

                roots.forEach(function (root) {
                    const toggle = root.querySelector('[data-notif-toggle]');
                    const dropdown = root.querySelector('[data-notif-dropdown]');
                    const badge = root.querySelector('[data-notif-badge]');
                    const list = root.querySelector('[data-notif-list]');
                    const markAll = root.querySelector('[data-notif-mark-all]');

                    if (!toggle || !dropdown || !list) {
                        return;
                    }

                    fetchLatest(root, badge, list);

                    toggle.addEventListener('click', function (event) {
                        event.preventDefault();
                        const isOpen = !dropdown.hidden;

                        document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                            node.hidden = true;
                        });

                        dropdown.hidden = isOpen;
                        if (!isOpen) {
                            fetchLatest(root, badge, list);
                        }
                    });

                    if (markAll) {
                        markAll.addEventListener('click', function (event) {
                            event.preventDefault();
                            markAllAsRead(root, badge, list);
                        });
                    }

                    list.addEventListener('click', function (event) {
                        const deleteBtn = event.target.closest('[data-notif-delete-id]');
                        if (!deleteBtn) {
                            return;
                        }

                        event.preventDefault();
                        const notificationId = Number(deleteBtn.getAttribute('data-notif-delete-id'));
                        if (!notificationId) {
                            return;
                        }

                        deleteNotification(root, notificationId, badge, list);
                    });

                    root.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            dropdown.hidden = true;
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    const inside = event.target.closest('[data-notif-root]');
                    if (inside) {
                        return;
                    }

                    document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                        node.hidden = true;
                    });
                });
            });
        })();
    </script>
{% endblock %}