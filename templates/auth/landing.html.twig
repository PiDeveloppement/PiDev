{# templates/auth/landing.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}EventFlow - Accueil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            overflow-x: hidden;
            background-color: #f8fafc;
        }
        
        /* ==================== NAVBAR ==================== */
        .navbar {
            background: white;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            height: 80px;
            display: flex;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }
        
        .nav-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .logo-container img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }
        
        .nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }
        
        .nav-link {
            background: transparent;
            color: #1e293b;
            font-size: 16px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            padding: 0;
        }
        
        .nav-link:hover {
            color: #0D47A1;
        }
        
        .nav-buttons {
            display: flex;
            gap: 15px;
            align-items: center;
            position: relative;
            top: -4px;
        }

        .participant-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
            cursor: pointer;
        }

        .participant-chip-menu {
            position: relative;
            display: inline-flex;
            align-items: center;
            margin: 0;
        }

        .participant-chip-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
        }

        .participant-chip-menu summary::-webkit-details-marker {
            display: none;
        }

        .participant-chip-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 170px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .participant-chip-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
        }

        .participant-chip-action:hover {
            background: #f3f7fd;
        }

        .participant-chip-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255,255,255,0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .participant-chip-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .participant-chip-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .participant-chip-role {
            font-size: 11px;
            color: rgba(255,255,255,0.84);
        }

        .notif-bell-btn {
            position: relative;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid #c7d7ec;
            background: #ffffff;
            color: #163f76;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 20px;
            line-height: 1;
        }

        .notif-bell-btn:hover {
            background: #f2f7ff;
        }

        .notif-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            background: #dc2626;
            color: #ffffff;
            border: 2px solid #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 800;
            padding: 0 5px;
        }

        .notif-bell-wrap {
            position: relative;
            display: inline-flex;
            align-items: center;
        }

        .notif-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: min(360px, 92vw);
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 14px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 10px;
            z-index: 1300;
        }

        .notif-dropdown[hidden] {
            display: none;
        }

        .notif-dropdown-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            padding: 4px 4px 10px;
            border-bottom: 1px solid #e5edf8;
        }

        .notif-dropdown-title {
            font-size: 15px;
            font-weight: 800;
            color: #133b70;
        }

        .notif-mark-read-btn {
            border: 1px solid #c7d7ec;
            background: #f2f7ff;
            color: #174a92;
            border-radius: 8px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .notif-list {
            display: grid;
            gap: 8px;
            margin-top: 10px;
            max-height: 320px;
            overflow-y: auto;
        }

        .notif-item {
            border-radius: 10px;
            border: 1px solid #dce8f6;
            padding: 10px;
            background: #ffffff;
        }

        .notif-item.unread {
            background: #eaf3ff;
            border-color: #c9defa;
        }

        .notif-item-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
            color: #5f7288;
            font-size: 12px;
        }

        .notif-item-meta {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            min-width: 0;
        }

        .notif-delete-btn {
            border: 1px solid #f0c9c9;
            background: #ffffff;
            color: #c22b23;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 12px;
            line-height: 1;
            transition: all 0.18s ease;
        }

        .notif-delete-btn:hover {
            background: #fff1f1;
            border-color: #e8aaaa;
            transform: translateY(-1px);
        }

        .notif-item-title {
            margin: 0 0 4px;
            color: #0f233b;
            font-size: 14px;
            font-weight: 800;
        }

        .notif-item-message {
            margin: 0;
            color: #516277;
            font-size: 13px;
            line-height: 1.4;
        }

        .notif-empty {
            color: #60758e;
            font-size: 13px;
            text-align: center;
            padding: 12px;
        }
        
        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: bold;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        
        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }
        
        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
        }
        
        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }
        
        /* ==================== MAIN CONTENT ==================== */
        .main-content {
            margin-top: 80px;
        }
        
        /* ==================== HERO SECTION ==================== */
        .hero-section {
            padding: 80px 100px;
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        }
        
        .hero-container {
            display: flex;
            gap: 60px;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .hero-left {
            flex: 1;
            max-width: 600px;
        }
        
        .hero-title {
            font-size: 48px;
            font-weight: bold;
            color: #0A1929;
            line-height: 1.2;
            margin-bottom: 20px;
        }
        
        .hero-subtitle {
            font-size: 18px;
            color: #546e7a;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .hero-buttons {
            display: flex;
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .btn-primary {
            background: #0D47A1;
            color: white;
            font-weight: bold;
            font-size: 16px;
            border: none;
            border-radius: 10px;
            padding: 15px 35px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(13, 71, 161, 0.4);
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(13, 71, 161, 0.5);
        }
        
        .btn-secondary {
            background: white;
            color: #1e293b;
            font-weight: 500;
            font-size: 16px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 15px 35px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-secondary:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }
        
        .hero-stats {
            display: flex;
            gap: 50px;
        }
        
        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .stat-number {
            font-size: 32px;
            font-weight: bold;
            color: #0D47A1;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 15px;
        }
        
        .hero-right {
            width: 450px;
            height: 400px;
            background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .hero-emoji {
            font-size: 140px;
        }
        
        /* ==================== FEATURES SECTION ==================== */
        .features-section {
            padding: 100px;
            background: white;
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }
        
        .section-tag {
            font-size: 14px;
            font-weight: bold;
            color: #0D47A1;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .section-title {
            font-size: 36px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 15px;
        }
        
        .section-subtitle {
            font-size: 18px;
            color: #546e7a;
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .feature-card {
            background: #f8fafc;
            border-radius: 20px;
            padding: 30px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        
        .feature-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }
        
        .feature-title {
            font-size: 22px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 10px;
        }
        
        .feature-description {
            color: #546e7a;
            font-size: 15px;
            line-height: 1.6;
        }
        
        /* ==================== FEEDBACK SECTION ==================== */
        .feedback-section {
            padding: 80px 100px;
            background: #f8fafc;
        }
        
        .feedback-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .feedback-tag {
            font-size: 14px;
            font-weight: bold;
            color: #0D47A1;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .feedback-title {
            font-size: 36px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 20px;
        }
        
        .rating-container {
            display: flex;
            gap: 20px;
            align-items: center;
            justify-content: center;
        }
        
        .rating-number {
            font-size: 52px;
            font-weight: bold;
            color: #0D47A1;
        }
        
        .rating-details {
            text-align: left;
        }
        
        .stars-container {
            display: flex;
            gap: 4px;
            margin-bottom: 6px;
        }
        
        .star-filled {
            color: #FFB400;
            font-size: 20px;
        }
        
        .star-empty {
            color: #cbd5e1;
            font-size: 20px;
        }
        
        .rating-count {
            color: #64748b;
            font-size: 15px;
        }
        
        .feedback-list {
            max-width: 800px;
            margin: 40px auto 0;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .feedback-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .feedback-header-card {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        
        .feedback-user {
            font-weight: bold;
            color: #0A1929;
        }
        
        .feedback-stars {
            display: flex;
            gap: 2px;
        }
        
        .feedback-comment {
            color: #546e7a;
            font-size: 14px;
            line-height: 1.6;
        }
        
        /* ==================== CONTACT SECTION ==================== */
        .contact-section {
            padding: 100px;
            background: linear-gradient(to right, #0D47A1, #1976D2);
        }
        
        .contact-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .contact-tag {
            font-size: 14px;
            font-weight: bold;
            color: rgba(255, 255, 255, 0.8);
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .contact-title {
            font-size: 36px;
            font-weight: bold;
            color: white;
            margin-bottom: 15px;
        }
        
        .contact-subtitle {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.8);
        }
        
        .contact-grid {
            display: flex;
            gap: 30px;
            justify-content: center;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .contact-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            width: 250px;
            text-align: center;
        }
        
        .contact-icon {
            font-size: 32px;
            margin-bottom: 15px;
        }
        
        .contact-card-title {
            font-size: 18px;
            font-weight: bold;
            color: white;
            margin-bottom: 10px;
        }
        
        .contact-card-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
        }
        
        /* ==================== FOOTER ==================== */
        .footer {
            padding: 50px 100px 30px;
            background: #0A1929;
        }
        
        .footer-container {
            display: flex;
            gap: 100px;
            margin-bottom: 40px;
        }
        
        .footer-brand {
            flex: 1;
        }
        
        .footer-brand-title {
            font-size: 20px;
            font-weight: bold;
            color: white;
            margin-bottom: 15px;
        }
        
        .footer-brand-text {
            color: #94a3b8;
            font-size: 13px;
            line-height: 1.6;
        }
        
        .footer-links {
            display: flex;
            gap: 50px;
        }
        
        .footer-column {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .footer-column-title {
            font-weight: bold;
            color: white;
            margin-bottom: 5px;
        }
        
        .footer-link {
            background: transparent;
            color: #94a3b8;
            border: none;
            cursor: pointer;
            text-align: left;
            padding: 0;
            font-size: 14px;
        }
        
        .footer-link:hover {
            color: white;
        }
        
        .footer-copyright {
            color: #64748b;
            font-size: 12px;
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #1e293b;
        }
        
        /* ==================== ANIMATIONS ==================== */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-fade-in {
            animation: fadeIn 0.8s ease forwards;
        }

        /* ==================== DARK MODE ==================== */
        body.dark-mode {
            background-color: #0f172a;
        }

        body.dark-mode .navbar {
            background: rgba(15, 23, 42, 0.95);
            border-bottom: 1px solid #1e293b;
        }

        body.dark-mode .nav-link {
            color: #e2e8f0;
        }

        body.dark-mode .nav-link:hover {
            color: #60a5fa;
        }

        body.dark-mode .hero-section {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }

        body.dark-mode .hero-title {
            color: #f1f5f9;
        }

        body.dark-mode .hero-subtitle {
            color: #cbd5e1;
        }

        body.dark-mode .stat-number {
            color: #60a5fa;
        }

        body.dark-mode .stat-label {
            color: #94a3b8;
        }

        body.dark-mode .features-section {
            background: #0f172a;
        }

        body.dark-mode .section-title {
            color: #f1f5f9;
        }

        body.dark-mode .section-subtitle {
            color: #94a3b8;
        }

        body.dark-mode .feature-card {
            background: #1e293b;
            border: 1px solid #334155;
        }

        body.dark-mode .feature-card:hover {
            background: #334155;
            border-color: #475569;
        }

        body.dark-mode .feature-title {
            color: #f1f5f9;
        }

        body.dark-mode .feature-description {
            color: #94a3b8;
        }

        body.dark-mode .feedback-section {
            background: #0f172a;
        }

        body.dark-mode .feedback-title {
            color: #f1f5f9;
        }

        body.dark-mode .feedback-card {
            background: #1e293b;
            border-color: #334155;
        }

        body.dark-mode .feedback-user {
            color: #f1f5f9;
        }

        body.dark-mode .feedback-comment {
            color: #94a3b8;
        }

        body.dark-mode .contact-section {
            background: linear-gradient(to right, #1e3a5f, #2563eb);
        }

        body.dark-mode .footer {
            background: #0f172a;
        }

        body.dark-mode .footer-brand-title {
            color: #f1f5f9;
        }

        body.dark-mode .footer-column-title {
            color: #f1f5f9;
        }

        body.dark-mode .footer-link {
            color: #94a3b8;
        }

        body.dark-mode .footer-link:hover {
            color: #60a5fa;
        }

        body.dark-mode .footer-copyright {
            color: #64748b;
        }

        body.dark-mode .btn-primary {
            background: #3b82f6;
            border-color: #3b82f6;
        }

        body.dark-mode .btn-primary:hover {
            background: #2563eb;
            border-color: #2563eb;
        }

        body.dark-mode .btn-secondary {
            background: #334155;
            color: #f1f5f9;
            border-color: #475569;
        }

        body.dark-mode .btn-secondary:hover {
            background: #475569;
        }

        body.dark-mode .btn-login {
            color: #60a5fa;
            border-color: #60a5fa;
        }

        body.dark-mode .btn-login:hover {
            background: rgba(96, 165, 250, 0.1);
        }

        body.dark-mode .btn-signup {
            background: #3b82f6;
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set isParticipantUser = app.user and ('ROLE_ADMIN' not in app.user.roles) and ('ROLE_ORGANISATEUR' not in app.user.roles) and ('ROLE_SPONSOR' not in app.user.roles) %}
    <!-- ==================== NAVBAR ==================== -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="scrollToSection('home')">Accueil</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>

                <button class="nav-link" onclick="window.location.href='{{ path('app_sponsor_portal') }}'">Recommandations sponsor</button>

                <button class="nav-link" onclick="scrollToSection('features')">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="scrollToSection('contact')">Contact</button>
            </div>

            <div class="nav-buttons">
                <button onclick="toggleTheme()" style="background: rgba(33, 150, 243, 0.1); color: #2196F3; border: 1px solid #2196F3; border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold; margin-right: 10px;">
                    <i class="fas fa-moon" id="themeIconLanding"></i>
                    <span id="themeTextLanding">Mode Sombre</span>
                </button>
                {% if isParticipantUser %}
                    {% set frontUnreadCount = unreadNotificationCount|default(notificationUnreadCount|default(0)) %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <details class="participant-chip-menu">
                        <summary class="participant-chip">
                            <span class="participant-chip-avatar">{{ app.user.initials }}</span>
                            <span class="participant-chip-meta">
