{# templates/auth/landing.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}EventFlow - Accueil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            overflow-x: hidden;
            background-color: #f8fafc;
        }
        
        /* ==================== NAVBAR ==================== */
        .navbar {
            background: white;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            height: 80px;
            display: flex;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }
        
        .nav-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .logo-container img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }
        
        .nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }
        
        .nav-link {
            background: transparent;
            color: #1e293b;
            font-size: 16px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            padding: 0;
        }
        
        .nav-link:hover {
            color: #0D47A1;
        }
        
        .nav-buttons {
            display: flex;
            gap: 15px;
            align-items: center;
            position: relative;
            top: -4px;
        }

        .participant-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            box-sizing: border-box;
            min-height: 42px;
            width: 184px;
            min-width: 184px;
            max-width: 184px;
            cursor: pointer;
        }

        .participant-chip-menu {
            position: relative;
            display: inline-flex;
            align-items: center;
            margin: 0;
        }

        .participant-chip-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
        }

        .participant-chip-menu summary::-webkit-details-marker {
            display: none;
        }

        .participant-chip-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 170px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .participant-chip-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
        }

        .participant-chip-action:hover {
            background: #f3f7fd;
        }

        .participant-chip-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255,255,255,0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .participant-chip-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
            min-width: 0;
        }

        .participant-chip-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .participant-chip-role {
            font-size: 11px;
            color: rgba(255,255,255,0.84);
        }
        
        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: bold;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        
        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }
        
        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
        }
        
        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }
        
        /* ==================== MAIN CONTENT ==================== */
        .main-content {
            margin-top: 80px;
        }
        
        /* ==================== HERO SECTION ==================== */
        .hero-section {
            padding: 80px 100px;
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        }
        
        .hero-container {
            display: flex;
            gap: 60px;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .hero-left {
            flex: 1;
            max-width: 600px;
        }
        
        .hero-title {
            font-size: 48px;
            font-weight: bold;
            color: #0A1929;
            line-height: 1.2;
            margin-bottom: 20px;
        }
        
        .hero-subtitle {
            font-size: 18px;
            color: #546e7a;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .hero-buttons {
            display: flex;
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .btn-primary {
            background: #0D47A1;
            color: white;
            font-weight: bold;
            font-size: 16px;
            border: none;
            border-radius: 10px;
            padding: 15px 35px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(13, 71, 161, 0.4);
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(13, 71, 161, 0.5);
        }
        
        .btn-secondary {
            background: white;
            color: #1e293b;
            font-weight: 500;
            font-size: 16px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 15px 35px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-secondary:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }
        
        .hero-stats {
            display: flex;
            gap: 50px;
        }
        
        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .stat-number {
            font-size: 32px;
            font-weight: bold;
            color: #0D47A1;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 15px;
        }
        
        .hero-right {
            width: 450px;
            height: 400px;
            background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .hero-emoji {
            font-size: 140px;
        }
        
        /* ==================== FEATURES SECTION ==================== */
        .features-section {
            padding: 100px;
            background: white;
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }
        
        .section-tag {
            font-size: 14px;
            font-weight: bold;
            color: #0D47A1;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .section-title {
            font-size: 36px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 15px;
        }
        
        .section-subtitle {
            font-size: 18px;
            color: #546e7a;
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .feature-card {
            background: #f8fafc;
            border-radius: 20px;
            padding: 30px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        
        .feature-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }
        
        .feature-title {
            font-size: 22px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 10px;
        }
        
        .feature-description {
            color: #546e7a;
            font-size: 15px;
            line-height: 1.6;
        }
        
        /* ==================== FEEDBACK SECTION ==================== */
        .feedback-section {
            padding: 80px 100px;
            background: #f8fafc;
        }
        
        .feedback-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .feedback-tag {
            font-size: 14px;
            font-weight: bold;
            color: #0D47A1;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .feedback-title {
            font-size: 36px;
            font-weight: bold;
            color: #0A1929;
            margin-bottom: 20px;
        }
        
        .rating-container {
            display: flex;
            gap: 20px;
            align-items: center;
            justify-content: center;
        }
        
        .rating-number {
            font-size: 52px;
            font-weight: bold;
            color: #0D47A1;
        }
        
        .rating-details {
            text-align: left;
        }
        
        .stars-container {
            display: flex;
            gap: 4px;
            margin-bottom: 6px;
        }
        
        .star-filled {
            color: #FFB400;
            font-size: 20px;
        }
        
        .star-empty {
            color: #cbd5e1;
            font-size: 20px;
        }
        
        .rating-count {
            color: #64748b;
            font-size: 15px;
        }
        
        .feedback-list {
            max-width: 800px;
            margin: 40px auto 0;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .feedback-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .feedback-header-card {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        
        .feedback-user {
            font-weight: bold;
            color: #0A1929;
        }
        
        .feedback-stars {
            display: flex;
            gap: 2px;
        }
        
        .feedback-comment {
            color: #546e7a;
            font-size: 14px;
            line-height: 1.6;
        }
        
        /* ==================== CONTACT SECTION ==================== */
        .contact-section {
            padding: 100px;
            background: linear-gradient(to right, #0D47A1, #1976D2);
        }
        
        .contact-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .contact-tag {
            font-size: 14px;
            font-weight: bold;
            color: rgba(255, 255, 255, 0.8);
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .contact-title {
            font-size: 36px;
            font-weight: bold;
            color: white;
            margin-bottom: 15px;
        }
        
        .contact-subtitle {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.8);
        }
        
        .contact-grid {
            display: flex;
            gap: 30px;
            justify-content: center;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .contact-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            width: 250px;
            text-align: center;
        }
        
        .contact-icon {
            font-size: 32px;
            margin-bottom: 15px;
        }
        
        .contact-card-title {
            font-size: 18px;
            font-weight: bold;
            color: white;
            margin-bottom: 10px;
        }
        
        .contact-card-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
        }
        
        /* ==================== FOOTER ==================== */
        .footer {
            padding: 50px 100px 30px;
            background: #0A1929;
        }
        
        .footer-container {
            display: flex;
            gap: 100px;
            margin-bottom: 40px;
        }
        
        .footer-brand {
            flex: 1;
        }
        
        .footer-brand-title {
            font-size: 20px;
            font-weight: bold;
            color: white;
            margin-bottom: 15px;
        }
        
        .footer-brand-text {
            color: #94a3b8;
            font-size: 13px;
            line-height: 1.6;
        }
        
        .footer-links {
            display: flex;
            gap: 50px;
        }
        
        .footer-column {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .footer-column-title {
            font-weight: bold;
            color: white;
            margin-bottom: 5px;
        }
        
        .footer-link {
            background: transparent;
            color: #94a3b8;
            border: none;
            cursor: pointer;
            text-align: left;
            padding: 0;
            font-size: 14px;
        }
        
        .footer-link:hover {
            color: white;
        }
        
        .footer-copyright {
            color: #64748b;
            font-size: 12px;
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #1e293b;
        }
        
        /* ==================== ANIMATIONS ==================== */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-fade-in {
            animation: fadeIn 0.8s ease forwards;
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set isParticipantUser = app.user and ('ROLE_ADMIN' not in app.user.roles) and ('ROLE_ORGANISATEUR' not in app.user.roles) and ('ROLE_SPONSOR' not in app.user.roles) %}
    <!-- ==================== NAVBAR ==================== -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="scrollToSection('home')">Accueil</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>

                <button class="nav-link" onclick="window.location.href='{{ path('app_sponsor_portal') }}'">Recommandations sponsor</button>

                <button class="nav-link" onclick="scrollToSection('features')">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="scrollToSection('contact')">Contact</button>
            </div>

            <div class="nav-buttons">
                {% include 'partials/public_auth_buttons.html.twig' %}
                <div style="display:none;">
                {% if isParticipantUser %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <details class="participant-chip-menu">
                        <summary class="participant-chip">
                            <span class="participant-chip-avatar">{{ app.user.initials }}</span>
                            <span class="participant-chip-meta">
                                <span class="participant-chip-name">{{ app.user.fullName }}</span>
                                <span class="participant-chip-role">Participant</span>
                            </span>
                        </summary>
                        <div class="participant-chip-dropdown">
                            <a class="participant-chip-action" href="{{ path('app_logout') }}">Déconnexion</a>
                        </div>
                    </details>
                {% elseif app.user %}
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_logout') }}'">Déconnexion</button>
                {% else %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_login') }}'">Connexion</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_register') }}'">Inscription</button>
                {% endif %}
                </div>
            </div>
        </div>
    </nav>

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="main-content">

        <!-- SECTION HERO -->
        <section id="home" class="hero-section">
            <div class="hero-container">
                <div class="hero-left animate-fade-in">
                    <h1 class="hero-title">Organisez vos événements comme jamais auparavant</h1>
                    <p class="hero-subtitle">EventFlow est la plateforme tout-en-un qui simplifie la gestion de vos événements, participants, sponsors et ressources. Rejoignez des milliers d'organisateurs satisfaits.</p>
                    
                    <div class="hero-buttons">
                        <button class="btn-primary" onclick="window.location.href='{{ path('app_login') }}'">Commencer maintenant</button>
                        <button class="btn-secondary" onclick="window.location.href='{{ path('app_demo_video') }}'">Voir la démo</button>
                    </div>

                    <div class="hero-stats">
                        <div class="stat-item">
                            <span class="stat-number">500+</span>
                            <span class="stat-label">Événements</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">10k+</span>
                            <span class="stat-label">Participants</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">200+</span>
                            <span class="stat-label">Sponsors</span>
                        </div>
                    </div>
                </div>

                <div class="hero-right">
                    <span class="hero-emoji">🚀</span>
                </div>
            </div>
        </section>

        <!-- SECTION FONCTIONNALITÉS -->
        <section id="features" class="features-section">
            <div class="section-header">
                <div class="section-tag">FONCTIONNALITÉS</div>
                <h2 class="section-title">Tout ce dont vous avez besoin</h2>
                <p class="section-subtitle">Une plateforme intuitive et puissante pour tous vos événements</p>
            </div>

            <div class="features-grid">
                <div class="feature-card" onclick="window.location.href='{{ path('app_public_events') }}'">
                    <div class="feature-icon">📅</div>
                    <h3 class="feature-title">Gestion d'événements</h3>
                    <p class="feature-description">Créez, modifiez et suivez vos événements en temps réel.</p>
                </div>

                <div class="feature-card" onclick="window.location.href='{{ path('app_public_events') }}'">
                    <div class="feature-icon">👥</div>
                    <h3 class="feature-title">Participants</h3>
                    <p class="feature-description">Gérez les inscriptions, les présences et l'historique.</p>
                </div>

                <div class="feature-card" onclick="window.location.href='{{ path('app_public_events') }}'">
                    <div class="feature-icon">💼</div>
                    <h3 class="feature-title">Sponsors</h3>
                    <p class="feature-description">Trouvez et gérez vos partenaires et leurs contrats.</p>
                </div>

                <div class="feature-card" onclick="window.location.href='{{ path('app_public_events') }}'">
                    <div class="feature-icon">📦</div>
                    <h3 class="feature-title">Ressources</h3>
                    <p class="feature-description">Gérez salles, équipements et réservations.</p>
                </div>
            </div>
        </section>

        <!-- SECTION FEEDBACK (version statique pour le moment) -->
        <section id="feedback" class="feedback-section">
            <div class="feedback-header">
                <div class="feedback-tag">FEEDBACKS</div>
                <h2 class="feedback-title">Ce que disent nos utilisateurs</h2>
                
                <div class="rating-container">
                    <span class="rating-number">4.8</span>
                    <div class="rating-details">
                        <div class="stars-container">
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                        </div>
                        <div class="rating-count">128 avis</div>
                    </div>
                </div>
            </div>

            <div class="feedback-list">
                <div class="feedback-card">
                    <div class="feedback-header-card">
                        <span class="feedback-user">Marie L.</span>
                        <div class="feedback-stars">
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                        </div>
                    </div>
                    <p class="feedback-comment">"Plateforme incroyable ! J'ai organisé mon premier événement de 200 personnes sans aucun stress."</p>
                </div>

                <div class="feedback-card">
                    <div class="feedback-header-card">
                        <span class="feedback-user">Ahmed K.</span>
                        <div class="feedback-stars">
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                        </div>
                    </div>
                    <p class="feedback-comment">"La gestion des participants est tellement simple. Je recommande vivement !"</p>
                </div>

                <div class="feedback-card">
                    <div class="feedback-header-card">
                        <span class="feedback-user">Sophie M.</span>
                        <div class="feedback-stars">
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-filled">★</span>
                            <span class="star-empty">☆</span>
                        </div>
                    </div>
                    <p class="feedback-comment">"Très bonne expérience, interface intuitive et support réactif."</p>
                </div>
            </div>
        </section>

        <!-- SECTION CONTACT -->
        <section id="contact" class="contact-section">
            <div class="contact-header">
                <div class="contact-tag">CONTACT</div>
                <h2 class="contact-title">Restons en contact</h2>
                <p class="contact-subtitle">Une question ? Notre équipe est là pour vous répondre</p>
            </div>

            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-icon">📧</div>
                    <h3 class="contact-card-title">Email</h3>
                    <p class="contact-card-text">contact@eventflow.com</p>
                </div>

                <div class="contact-card">
                    <div class="contact-icon">📞</div>
                    <h3 class="contact-card-title">Téléphone</h3>
                    <p class="contact-card-text">+216 92 500 441</p>
                </div>

                <div class="contact-card">
                    <div class="contact-icon">📍</div>
                    <h3 class="contact-card-title">Adresse</h3>
                    <p class="contact-card-text">Tunis, Ariana Soghra/Al ghazala</p>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="footer">
            <div class="footer-container">
                <div class="footer-brand">
                    <h4 class="footer-brand-title">EventFlow</h4>
                    <p class="footer-brand-text">La solution complète pour la gestion d'événements</p>
                </div>

                <div class="footer-links">
                    <div class="footer-column">
                        <h5 class="footer-column-title">Produit</h5>
                        <button class="footer-link" onclick="scrollToSection('features')">Fonctionnalités</button>
                        <span class="footer-link">Tarifs</span>
                    </div>

                    <div class="footer-column">
                        <h5 class="footer-column-title">Support</h5>
                        <button class="footer-link" onclick="scrollToSection('contact')">Contact</button>
                        <span class="footer-link">FAQ</span>
                    </div>
                </div>
            </div>

            <div class="footer-copyright">
                © 2026 EventFlow. Tous droits réservés.
            </div>
        </footer>
    </main>

    <script>
        // Fonction pour scroller vers une section
        function scrollToSection(sectionId) {
            const section = document.getElementById(sectionId);
            if (section) {
                const navbarHeight = 80;
                const elementPosition = section.getBoundingClientRect().top + window.pageYOffset;
                window.scrollTo({
                    top: elementPosition - navbarHeight,
                    behavior: 'smooth'
                });
            }
        }

        // Animation des cartes au survol
        document.querySelectorAll('.feature-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.boxShadow = '0 10px 25px rgba(0, 0, 0, 0.1)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
                this.style.boxShadow = 'none';
            });
        });
    </script>

{% endblock %}
