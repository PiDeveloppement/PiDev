<!-- Modal Face ID -->
{% if setup_face == 1 and user_email is defined %}
<div id="faceModal" class="face-modal">
    <div class="face-modal-content">
        <div class="face-modal-header">
            <h3>🔐 Configuration Face ID</h3>
            <p>Veuillez positionner votre visage devant la caméra</p>
        </div>
        <div class="face-modal-body">
            <div class="video-container">
                <video id="video" autoplay playsinline class="face-video" style="display: none;"></video>
                <div id="videoPlaceholder" class="video-placeholder">
                    <div>📷</div>
                    <p>Demande d'accès à la caméra...</p>
                </div>
                <div class="face-overlay" style="display: none;" id="faceOverlay">
                    <div class="face-frame"></div>
                </div>
            </div>
            <canvas id="canvas" style="display: none;"></canvas>
            <div id="faceStatus" class="face-status warning">
                ⚠️ Initialisation de la caméra...
            </div>
        </div>
        <div class="face-modal-footer">
            <button id="captureBtn" class="btn-capture" disabled>
                📸 Capturer mon visage
            </button>
            <button id="skipFaceBtn" class="btn-skip">
                ⏭ Ignorer pour l'instant
            </button>
        </div>
    </div>
</div>
<script>
// VERSION AVEC face-api.js - Vraie reconnaissance faciale
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM chargé, initialisation Face ID avec face-api.js...');
    setTimeout(initializeFaceRecognitionSimple, 500);
});

let mediaStream = null;
let isCapturing = false;

async function initializeFaceRecognitionSimple() {
    const video = document.getElementById('video');
    const videoPlaceholder = document.getElementById('videoPlaceholder');
    const faceOverlay = document.getElementById('faceOverlay');
    const canvas = document.getElementById('canvas');
    const captureBtn = document.getElementById('captureBtn');
    const faceStatus = document.getElementById('faceStatus');
    const userEmail = '{{ user_email }}';

    try {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            throw new Error('Votre navigateur ne supporte pas l\'accès à la caméra');
        }

        if (typeof faceapi === 'undefined') {
            throw new Error('La bibliothèque face-api.js n\'est pas chargée. Veuillez actualiser la page.');
        }

        faceStatus.innerHTML = ' Chargement des modèles de reconnaissance faciale...';
        faceStatus.className = 'face-status info';

        const MODEL_URL = '/models';
        await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
        await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
        await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);

        faceStatus.innerHTML = ' Demande d\'accès à la caméra...';

        const stream = await navigator.mediaDevices.getUserMedia({
            video: {
                width: { ideal: 640 },
                height: { ideal: 480 },
                facingMode: 'user'
            }
        });

        console.log(' Caméra accessible');
        mediaStream = stream;

        videoPlaceholder.style.display = 'none';
        video.style.display = 'block';
        faceOverlay.style.display = 'flex';

        video.srcObject = stream;

        await new Promise((resolve) => {
            video.onloadedmetadata = () => {
                video.play();
                console.log(' Vidéo en cours de lecture');
                resolve();
            };
        });

        faceStatus.innerHTML = ' Caméra prête ! Cliquez sur "Capturer mon visage"';
        faceStatus.className = 'face-status success';
        captureBtn.disabled = false;
        captureBtn.innerHTML = ' Capturer mon visage';

  async function captureFaceSimple() {
    if (isCapturing) return;
    isCapturing = true;

    try {
        captureBtn.disabled = true;
        captureBtn.innerHTML = '<span class="loading-spinner"></span> Traitement...';

        faceStatus.innerHTML = ' Détection du visage en cours...';
        faceStatus.className = 'face-status info';

        const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions())
            .withFaceLandmarks()
            .withFaceDescriptors();

        if (detections.length === 0) {
            faceStatus.innerHTML = '❌ Aucun visage détecté. Veuillez réessayer.';
            faceStatus.className = 'face-status error';
            captureBtn.disabled = false;
            captureBtn.innerHTML = '📸 Réessayer';
            isCapturing = false;
            return;
        }

        const descriptor = Array.from(detections[0].descriptor);

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        const context = canvas.getContext('2d');
        context.save();
        context.scale(-1, 1);
        context.drawImage(video, -canvas.width, 0, canvas.width, canvas.height);
        context.restore();

        const imageData = canvas.toDataURL('image/jpeg', 0.8);

        faceStatus.innerHTML = '🔍 Vérification et enregistrement...';

        // ✅ ÉTAPE 1 — appel fetch
        const response = await fetch('{{ path('app_save_face_descriptor') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                email: userEmail,
                descriptor: descriptor,
                image: imageData
            })
        });

        // ✅ ÉTAPE 2 — parse JSON
        const result = await response.json();

        // ✅ ÉTAPE 3 — visage déjà enregistré sur un autre compte → supprimer le compte et rediriger
        if (response.status === 409) {
            faceStatus.innerHTML = '❌ ' + result.message;
            faceStatus.className = 'face-status error';

            captureBtn.disabled = true;
            captureBtn.innerHTML = '❌ Inscription annulée';

            const skipBtn = document.getElementById('skipFaceBtn');
            if (skipBtn) {
                skipBtn.disabled = true;
                skipBtn.style.opacity = '0.5';
                skipBtn.style.cursor = 'not-allowed';
            }

            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }

            setTimeout(() => {
                window.location.href = result.redirect || '{{ path('app_login') }}';
            }, 3000);
            return;
        }

        // ✅ ÉTAPE 4 — succès
        if (result.status === 'success') {
            faceStatus.innerHTML = '✅ Configuration enregistrée ! Redirection...';
            faceStatus.className = 'face-status success';
            captureBtn.innerHTML = '✅ Succès !';

            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }

            setTimeout(() => {
                window.location.href = '{{ path('app_login') }}';
            }, 2000);
        } else {
            throw new Error(result.message || 'Erreur lors de l\'enregistrement');
        }

    } catch (error) {
        console.error('Erreur capture:', error);
        faceStatus.innerHTML = '❌ ' + error.message;
        faceStatus.className = 'face-status error';
        captureBtn.disabled = false;
        captureBtn.innerHTML = '📸 Réessayer';
        isCapturing = false;
    }
}

        captureBtn.onclick = () => {
            if (!captureBtn.disabled && !isCapturing) {
                captureFaceSimple();
            }
        };

    } catch (error) {
        console.error('Erreur caméra:', error);

        let errorMessage = ' Impossible d\'accéder à la caméra. ';
        if (error.name === 'NotAllowedError') {
            errorMessage += 'Veuillez autoriser l\'accès à la caméra.';
        } else if (error.name === 'NotFoundError') {
            errorMessage += 'Aucune caméra trouvée.';
        } else {
            errorMessage += error.message;
        }

        faceStatus.innerHTML = errorMessage;
        faceStatus.className = 'face-status error';
        captureBtn.disabled = true;
    }

    const skipBtn = document.getElementById('skipFaceBtn');
    if (skipBtn) {
        skipBtn.onclick = () => {
            console.log('Face ID ignoré');
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }
            window.location.href = '{{ path('app_login') }}';
        };
    }
}
</script>
{% endif %}

<!-- Scripts de validation du formulaire -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const emailField = document.querySelector('[data-email-field]');
    const passwordField = document.querySelector('[data-password-field]');
    const confirmField = document.querySelector('[data-confirm-field]');
    
    if (emailField) {
        emailField.addEventListener('input', function() {
            validateEmail(this.value);
        });
    }
    
    if (passwordField) {
        passwordField.addEventListener('input', function() {
            validatePassword(this.value);
            if (confirmField && confirmField.value) {
                validatePasswordMatch(this.value, confirmField.value);
            }
        });
    }
    
    if (confirmField) {
        confirmField.addEventListener('input', function() {
            if (passwordField) {
                validatePasswordMatch(passwordField.value, this.value);
            }
        });
    }
});

function validateEmail(email) {
    const validationDiv = document.getElementById('emailValidation');
    const emailField = document.querySelector('[data-email-field]');
    
    if (!email || email.trim() === '') {
        validationDiv.textContent = '';
        emailField.classList.remove('error', 'success');
        return false;
    }
    
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        validationDiv.textContent = 'Format d\'email invalide';
        validationDiv.className = 'validation-message error';
        emailField.classList.add('error');
        emailField.classList.remove('success');
        return false;
    }
    
    fetch('{{ path('app_check_email') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'email=' + encodeURIComponent(email)
    })
    .then(response => response.json())
    .then(data => {
        if (data.exists) {
            validationDiv.textContent = 'Cet email est déjà utilisé';
            validationDiv.className = 'validation-message error';
            emailField.classList.add('error');
            emailField.classList.remove('success');
        } else {
            validationDiv.textContent = '✓ Email disponible';
            validationDiv.className = 'validation-message success';
            emailField.classList.add('success');
            emailField.classList.remove('error');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
    });
    
    return true;
}

function validatePassword(password) {
    const validationDiv = document.getElementById('passwordValidation');
    const passwordField = document.querySelector('[data-password-field]');
    
    if (!password || password.trim() === '') {
        validationDiv.textContent = '';
        passwordField.classList.remove('error', 'success');
        return false;
    }
    
    const regex = /^(?=.*[A-Za-z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?])[A-Za-z\d!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]{6,}$/;
    
    if (!regex.test(password)) {
        validationDiv.textContent = '6+ caractères avec lettre, chiffre ET symbole';
        validationDiv.className = 'validation-message error';
        passwordField.classList.add('error');
        passwordField.classList.remove('success');
        return false;
    }
    
    validationDiv.textContent = '✓ Mot de passe valide';
    validationDiv.className = 'validation-message success';
    passwordField.classList.add('success');
    passwordField.classList.remove('error');
    return true;
}

function validatePasswordMatch(password, confirm) {
    const validationDiv = document.getElementById('confirmValidation');
    const confirmField = document.querySelector('[data-confirm-field]');
    
    if (!confirm || confirm.trim() === '') {
        validationDiv.textContent = '';
        confirmField.classList.remove('error', 'success');
        return false;
    }
    
    if (password !== confirm) {
        validationDiv.textContent = 'Les mots de passe ne correspondent pas';
        validationDiv.className = 'validation-message error';
        confirmField.classList.add('error');
        confirmField.classList.remove('success');
        return false;
    }
    
    validationDiv.textContent = '✓ Les mots de passe correspondent';
    validationDiv.className = 'validation-message success';
    confirmField.classList.add('success');
    confirmField.classList.remove('error');
    return true;
}
</script>
{% endblock %}