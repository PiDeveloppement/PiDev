{% extends 'base.html.twig' %}

{% block title %}Inscription - EventFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            overflow-x: hidden;
        }
        
        .signup-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #f0f8ff, #e6f2ff);
            display: flex;
            flex-direction: column;
        }
        
        .back-button {
            padding: 20px 0 0 40px;
        }
        
        .back-button a {
            display: inline-block;
            background: transparent;
            color: #2196F3;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            border: 1px solid #2196F3;
            border-radius: 20px;
            padding: 8px 20px;
            transition: all 0.2s ease;
        }
        
        .back-button a:hover {
            background: #2196F3;
            color: white;
        }
        
        .main-grid {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }
        
        .grid-container {
            display: grid;
            grid-template-columns: 45% 55%;
            gap: 60px;
            max-width: 1200px;
            width: 100%;
            align-items: center;
        }
        
        .left-panel {
            padding: 40px 60px 40px 40px;
        }
        
        .logo-container {
            margin-bottom: 40px;
        }
        
        .logo-container img {
            width: 222px;
            height: auto;
        }
        
        .features {
            display: flex;
            flex-direction: column;
            gap: 25px;
            max-width: 380px;
        }
        
        .feature-item {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(33, 150, 243, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #2196F3;
        }
        
        .feature-text h3 {
            color: #333333;
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 3px;
        }
        
        .feature-text p {
            color: #666666;
            font-size: 13px;
            margin: 0;
        }
        
        .right-panel {
            padding: 60px;
            display: flex;
            justify-content: center;
        }
        
        .signup-card {
            background: white;
            border-radius: 20px;
            padding: 40px 45px;
            max-width: 480px;
            width: 100%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
        }
        
        .card-header {
            text-align: center;
        }
        
        .card-header h2 {
            font-size: 28px;
            font-weight: bold;
            color: #2d3748;
            margin: 0 0 8px 0;
        }
        
        .card-header p {
            color: #718096;
            font-size: 14px;
            margin: 0;
        }
        
        .form-container {
            width: 100%;
            max-width: 380px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        
        .form-group {
            width: 100%;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            font-size: 14px;
            transition: border-color 0.2s ease;
            background: white;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #2196F3;
            box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.1);
        }
        
        .validation-message {
            font-size: 12px;
            margin-top: 4px;
            min-height: 18px;
        }
        
        .validation-message.error {
            color: #ef4444;
        }
        
        .validation-message.success {
            color: #10b981;
        }
        
        .checkbox-container {
            display: flex;
            justify-content: center;
            margin: 10px 0;
        }
        
        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #4a5568;
            font-size: 13px;
            cursor: pointer;
        }
        
        .checkbox-label input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1px solid #cbd5e0;
            cursor: pointer;
        }
        
        .btn-submit {
            background: #2196F3;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 10px;
            padding: 12px 40px;
            font-size: 14px;
            cursor: pointer;
            width: 100%;
            max-width: 300px;
            margin: 0 auto;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(33, 150, 243, 0.2);
        }
        
        .btn-submit:hover {
            background: #1976D2;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(33, 150, 243, 0.3);
        }
        
        .login-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }
        
        .login-link span {
            color: #718096;
            font-size: 13px;
        }
        
        .login-link a {
            color: #2196F3;
            font-weight: bold;
            font-size: 13px;
            text-decoration: none;
        }
        
        .login-link a:hover {
            text-decoration: underline;
        }
        
        .footer {
            background: rgba(33, 150, 243, 0.05);
            padding: 20px;
            text-align: center;
        }
        
        .footer p {
            color: #666666;
            font-size: 12px;
            margin: 0 0 10px 0;
        }
        
        .footer-links {
            display: flex;
            gap: 20px;
            justify-content: center;
        }
        
        .footer-links a {
            color: #2196F3;
            font-size: 12px;
            text-decoration: none;
        }
        
        .footer-links a:hover {
            text-decoration: underline;
        }
        
        .flash-message {
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 13px;
            text-align: center;
            width: 100%;
        }
        
        .flash-message.error {
            background: #fee2e2;
            border: 1px solid #ef4444;
            color: #dc2626;
        }
        
        .flash-message.success {
            background: #dcfce7;
            border: 1px solid #10b981;
            color: #059669;
        }

        /* Styles Face ID Modal */
        .face-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .face-modal-content {
            background: white;
            border-radius: 20px;
            max-width: 650px;
            width: 90%;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .face-modal-header {
            padding: 25px 30px;
            background: linear-gradient(135deg, #2196F3, #1976D2);
            color: white;
            text-align: center;
        }

        .face-modal-header h3 {
            margin: 0 0 8px 0;
            font-size: 26px;
            font-weight: bold;
        }

        .face-modal-header p {
            margin: 0;
            opacity: 0.95;
            font-size: 14px;
        }

        .face-modal-body {
            padding: 30px;
            background: #f8f9fa;
            position: relative;
        }

        .video-container {
            position: relative;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            border-radius: 15px;
            overflow: hidden;
            background: #000;
            min-height: 360px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .face-video {
            width: 100%;
            height: auto;
            display: block;
            transform: scaleX(-1);
        }

        .video-placeholder {
            position: absolute;
            color: white;
            text-align: center;
            z-index: 1;
        }

        .face-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .face-frame {
            width: 200px;
            height: 200px;
            border: 3px solid #4CAF50;
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); border-color: #4CAF50; }
            50% { transform: scale(1.05); border-color: #2196F3; }
            100% { transform: scale(1); border-color: #4CAF50; }
        }

        .face-status {
            text-align: center;
            margin-top: 20px;
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
        }

        .face-status.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .face-status.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .face-status.info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }

        .face-status.warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .face-modal-footer {
            padding: 20px 30px;
            display: flex;
            gap: 15px;
            justify-content: center;
            background: white;
            border-top: 1px solid #e0e0e0;
        }

        .btn-capture, .btn-skip {
            padding: 12px 30px;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            flex: 1;
        }

        .btn-capture {
            background: linear-gradient(135deg, #4CAF50, #45a049);
            color: white;
        }

        .btn-capture:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);
        }

        .btn-capture:disabled {
            background: #cccccc;
            cursor: not-allowed;
        }

        .btn-skip {
            background: #f44336;
            color: white;
        }

        .btn-skip:hover {
            background: #da190b;
            transform: translateY(-2px);
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
            vertical-align: middle;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
{% endblock %}

{% block public_content %}
