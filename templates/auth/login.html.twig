{% extends 'base.html.twig' %}

{% block title %}Connexion - EventFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/design-system.css') }}">
    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .login-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #f0f8ff, #e6f2ff);
            display: flex;
            flex-direction: column;
        }
        
        .back-button {
            padding: 20px 0 0 40px;
        }
        
        .back-button a {
            display: inline-block;
            background: transparent;
            color: #2196F3;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            border: 1px solid #2196F3;
            border-radius: 20px;
            padding: 8px 20px;
            transition: all 0.2s ease;
        }
        
        .back-button a:hover {
            background: #2196F3;
            color: white;
        }
        
        .main-grid {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }
        
        .grid-container {
            display: grid;
            grid-template-columns: 45% 55%;
            gap: 60px;
            max-width: 1200px;
            width: 100%;
            align-items: center;
        }
        
        .left-panel {
            padding: 40px 60px 40px 40px;
        }
        
        .logo-container {
            margin-bottom: 40px;
        }
        
        .logo-container img {
            width: 222px;
            height: auto;
        }
        
        .features {
            display: flex;
            flex-direction: column;
            gap: 25px;
            max-width: 380px;
        }
        
        .feature-item {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(33, 150, 243, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #2196F3;
        }
        
        .feature-text h3 {
            color: #333333;
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 3px;
        }
        
        .feature-text p {
            color: #666666;
            font-size: 13px;
            margin: 0;
        }
        
        .right-panel {
            padding: 60px;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .login-card {
            background: white;
            border-radius: 15px;
            padding: 35px 40px;
            max-width: 420px;
            width: 100%;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
        }
        
        .card-header {
            text-align: center;
        }
        
        .card-header h2 {
            font-size: 26px;
            font-weight: bold;
            color: #2196F3;
            margin: 0 0 6px 0;
        }
        
        .card-header p {
            color: #666666;
            font-size: 13px;
            margin: 0;
        }
        
        .form-container {
            width: 100%;
            max-width: 350px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        
        .form-group {
            width: 100%;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 13px;
            background: white;
            transition: border-color 0.2s ease;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #2196F3;
            box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.15);
        }
        
        .password-container {
            position: relative;
            width: 100%;
        }
        
        .password-field {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 13px;
            background: white;
            transition: border-color 0.2s ease;
            padding-right: 40px;
        }
        
        .password-field:focus {
            outline: none;
            border-color: #2196F3;
            box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.15);
        }
        
        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 20px;
            color: #666;
            cursor: pointer;
            background: transparent;
            z-index: 10;
            padding: 0 10px;
        }
        
        .options-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            width: 100%;
            max-width: 350px;
        }
        
        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #555555;
            font-size: 13px;
            cursor: pointer;
        }
        
        .checkbox-label input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1px solid #cbd5e0;
            cursor: pointer;
        }
        
        .forgot-link {
            color: #2196F3;
            font-size: 12px;
            font-weight: bold;
            text-decoration: none;
        }
        
        .forgot-link:hover {
            text-decoration: underline;
        }
        
        .btn-primary {
            background: #2196F3;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 8px;
            padding: 12px 35px;
            font-size: 14px;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            box-shadow: 0 4px 10px rgba(33, 150, 243, 0.3);
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            background: #1976D2;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(33, 150, 243, 0.4);
        }
        
        .facial-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }
        
        .facial-btn {
            background: linear-gradient(to bottom, #6c5ce7, #a463f5);
            border: none;
            border-radius: 40px;
            width: 80px;
            height: 80px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.6);
            transform: translateY(-30px);
            transition: transform 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .facial-btn:hover {
            transform: translateY(-35px) scale(1.05);
        }
        
        .facial-icon {
            font-size: 38px;
            color: white;
        }
        
        .facial-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 28px;
            height: 28px;
            background: #4CAF50;
            border-radius: 50%;
            border: 2px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: white;
        }
        
        .facial-ring {
            position: absolute;
            width: 76px;
            height: 76px;
            border: 2px dashed white;
            border-radius: 50%;
            opacity: 0.3;
            pointer-events: none;
        }
        
        .facial-label {
            background: white;
            border-radius: 10px;
            padding: 3px 8px;
            font-weight: bold;
            font-size: 11px;
            color: #6c5ce7;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
        }
        
        .flash-message {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 12px;
            text-align: center;
            width: 100%;
        }
        
        .flash-message.error {
            background: #fee2e2;
            border: 1px solid #ef4444;
            color: #dc2626;
        }
        
        .flash-message.success {
            background: #dcfce7;
            border: 1px solid #10b981;
            color: #059669;
        }
        
        .login-message {
            color: #dc2626;
            font-size: 12px;
            text-align: center;
            margin-bottom: 15px;
            background: #fee2e2;
            border: 1px solid #ef4444;
            border-radius: 8px;
            padding: 10px 14px;
            font-weight: 500;
        }
        
        .nav-links {
            margin-top: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        
        .signup-link {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        
        .signup-link span {
            color: #666666;
            font-size: 12px;
        }
        
        .signup-link a {
            color: #2196F3;
            font-weight: bold;
            font-size: 12px;
            text-decoration: none;
        }
        
        .signup-link a:hover {
            text-decoration: underline;
        }
        
        .footer {
            background: rgba(33, 150, 243, 0.05);
            padding: 20px;
            text-align: center;
        }
        
        .footer p {
            color: #666666;
            font-size: 12px;
            margin: 0 0 10px 0;
        }
        
        .footer-links {
            display: flex;
            gap: 20px;
            justify-content: center;
        }
        
        .footer-links a {
            color: #2196F3;
            font-size: 12px;
            text-decoration: none;
        }
        
        .footer-links a:hover {
            text-decoration: underline;
        }

        /* Modal Face ID Styles */
        .face-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .face-modal-content {
            background: white;
            border-radius: 20px;
            max-width: 650px;
            width: 90%;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .face-modal-header {
            padding: 25px 30px;
            background: linear-gradient(135deg, #6c5ce7, #a463f5);
            color: white;
            text-align: center;
        }

        .face-modal-header h3 {
            margin: 0 0 8px 0;
            font-size: 26px;
            font-weight: bold;
        }

        .face-modal-header p {
            margin: 0;
            opacity: 0.95;
            font-size: 14px;
        }

        .face-modal-body {
            padding: 30px;
            background: #f8f9fa;
            position: relative;
        }

        .video-container {
            position: relative;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            border-radius: 15px;
            overflow: hidden;
            background: #000;
            min-height: 360px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .face-video {
            width: 100%;
            height: auto;
            display: block;
            transform: scaleX(-1);
        }

        .video-placeholder {
            position: absolute;
            color: white;
            text-align: center;
            z-index: 1;
        }

        .face-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .face-frame {
            width: 200px;
            height: 200px;
            border: 3px solid #6c5ce7;
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); border-color: #6c5ce7; }
            50% { transform: scale(1.05); border-color: #a463f5; }
            100% { transform: scale(1); border-color: #6c5ce7; }
        }

        .face-status {
            text-align: center;
            margin-top: 20px;
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
        }

        .face-status.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .face-status.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .face-status.info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }

        .face-status.warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .face-modal-footer {
            padding: 20px 30px;
            display: flex;
            gap: 15px;
            justify-content: center;
            background: white;
            border-top: 1px solid #e0e0e0;
        }

        .btn-capture, .btn-cancel {
            padding: 12px 30px;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            flex: 1;
        }

        .btn-capture {
            background: linear-gradient(135deg, #6c5ce7, #a463f5);
            color: white;
        }

        .btn-capture:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);
        }

        .btn-capture:disabled {
            background: #cccccc;
            cursor: not-allowed;
        }

        .btn-cancel {
            background: #f44336;
            color: white;
        }

        .btn-cancel:hover {
            background: #da190b;
            transform: translateY(-2px);
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
            vertical-align: middle;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
{% endblock %}

{% block public_content %}
<div class="login-page">
    <div class="back-button" style="display: flex; justify-content: space-between; align-items: center;">
        <a href="{{ path('app_landing') }}">← Retour à l'accueil</a>
        <button onclick="toggleTheme()" style="background: rgba(33, 150, 243, 0.1); color: #2196F3; border: 1px solid #2196F3; border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold;">
            <i class="fas fa-moon" id="themeIconLogin"></i>
            <span id="themeTextLogin">Mode Sombre</span>
        </button>
    </div>

    <div class="main-grid">
        <div class="grid-container">
            <div class="left-panel">
                <div class="logo-container">
                    <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
                </div>

                <div class="features">
                    <div class="feature-item">
                        <div class="feature-icon">📅</div>
                        <div class="feature-text">
                            <h3>Créez des événements</h3>
                            <p>Organisez et planifiez facilement</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">👥</div>
                        <div class="feature-text">
                            <h3>Gérez les participants</h3>
                            <p>Suivi en temps réel des inscriptions</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">💰</div>
                        <div class="feature-text">
                            <h3>Suivez votre budget</h3>
                            <p>Contrôlez les dépenses et recettes</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="right-panel">
                <div class="login-card">
                    <div class="card-header">
                        <h2>Connexion</h2>
                        <p>Accédez à votre espace de gestion</p>
                    </div>

                    {% if error %}
                        <div class="login-message">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% for message in app.flashes('error') %}
                        <div class="flash-message error">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="flash-message success">{{ message }}</div>
                    {% endfor %}

                    <form method="post" action="{{ path('app_login_check') }}" style="width: 100%;" id="loginForm" onsubmit="return validateLoginForm()">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="form-container">
                            <div class="form-group">
                                <input type="email" 
                                       id="emailField"
                                       name="email" 
                                       value="{{ last_username }}" 
                                       placeholder="Email universitaire"
                                       class="form-control"
                                       required>
                            </div>

                            <div class="password-container">
                                <input type="password" 
                                       id="passwordField" 
                                       name="password" 
                                       placeholder="Mot de passe"
                                       class="password-field"
                                       required>
                                <input type="text" 
                                       id="visiblePasswordField" 
                                       placeholder="Mot de passe"
                                       class="password-field"
                                       style="display: none;">
                                <span id="eyeIcon" class="password-toggle" onclick="togglePassword()">👁️</span>
                            </div>
                        </div>

                        <div class="options-container">
                            <label class="checkbox-label">
                                <input type="checkbox" name="_remember_me">
                                <span>Se souvenir de moi</span>
                            </label>

                            <a href="{{ path('app_forgot_password') }}" class="forgot-link">
                                Mot de passe oublié ?
                            </a>

                            <button type="submit" class="btn-primary">
                                Se connecter
                            </button>

                            <button type="reset" class="btn-primary" onclick="resetForm()">
                                Annuler
                            </button>

                            <div class="nav-links">
                                <div class="signup-link">
                                    <span>Nouveau sur EventFlow?</span>
                                    <a href="{{ path('app_register') }}">Créer un compte</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="facial-container">
                    <button class="facial-btn" onclick="openFacialLogin()">
                        <span class="facial-icon">👤</span>
                        <div class="facial-badge">🔓</div>
                        <div class="facial-ring"></div>
                    </button>
                    <div class="facial-label">Face ID</div>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <p>© 2026 EventFlow - Tous droits réservés</p>
        <div class="footer-links">
            <a href="#">Conditions d'utilisation</a>
            <a href="#">Politique de confidentialité</a>
            <a href="#">Support</a>
        </div>
    </footer>
</div>

<!-- Modal Face ID -->
<div id="faceModal" class="face-modal">
    <div class="face-modal-content">
        <div class="face-modal-header" style="display: flex; justify-content: space-between; align-items: center;">
            <div style="text-align: center; flex: 1;">
                <h3> Connexion Face ID</h3>
                <p>Regardez la caméra pour vous connecter</p>
            </div>
            <button onclick="toggleTheme()" style="background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold;">
                <i class="fas fa-moon" id="themeIconFaceLogin"></i>
                <span id="themeTextFaceLogin">Mode Sombre</span>
            </button>
        </div>
        <div class="face-modal-body">
            <div class="video-container">
                <video id="video" autoplay playsinline class="face-video" style="display: none;"></video>
                <div id="videoPlaceholder" class="video-placeholder">
                    <div style="font-size: 48px;">📷</div>
                    <p>Demande d'accès à la caméra...</p>
                </div>
                <div class="face-overlay" style="display: none;" id="faceOverlay">
                    <div class="face-frame"></div>
                </div>
            </div>
            <canvas id="canvas" style="display: none;"></canvas>
            <div id="faceStatus" class="face-status warning">
                ⚠️ Initialisation de la caméra...
            </div>
        </div>
        <div class="face-modal-footer">
            <button id="captureBtn" class="btn-capture" disabled>
                🔍 Scanner mon visage
            </button>
            <button id="cancelFaceBtn" class="btn-cancel">
                ❌ Annuler
            </button>
        </div>
    </div>
</div>

<script>
let mediaStream = null;
let isScanning = false;

function openFacialLogin() {
    const modal = document.getElementById('faceModal');
    modal.style.display = 'flex';
    initializeFaceRecognition();
}

function closeFacialLogin() {
    const modal = document.getElementById('faceModal');
    if (mediaStream) {
        mediaStream.getTracks().forEach(track => track.stop());
        mediaStream = null;
    }
    modal.style.display = 'none';
}

async function initializeFaceRecognition() {
    const video = document.getElementById('video');
    const videoPlaceholder = document.getElementById('videoPlaceholder');
    const faceOverlay = document.getElementById('faceOverlay');
    const canvas = document.getElementById('canvas');
    const captureBtn = document.getElementById('captureBtn');
    const faceStatus = document.getElementById('faceStatus');

    try {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            throw new Error('Votre navigateur ne supporte pas l\'accès à la caméra');
        }

        if (typeof faceapi === 'undefined') {
            throw new Error('La bibliothèque face-api.js n\'est pas chargée. Veuillez actualiser la page.');
        }

        faceStatus.innerHTML = '📷 Chargement des modèles de reconnaissance faciale...';
        faceStatus.className = 'face-status info';

        const MODEL_URL = '/models';
        await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
        await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
        await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);

        faceStatus.innerHTML = '📷 Demande d\'accès à la caméra...';

        const stream = await navigator.mediaDevices.getUserMedia({
            video: {
                width: { ideal: 640 },
                height: { ideal: 480 },
                facingMode: 'user'
            }
        });

        mediaStream = stream;

        videoPlaceholder.style.display = 'none';
        video.style.display = 'block';
        faceOverlay.style.display = 'flex';

        video.srcObject = stream;

        await new Promise((resolve) => {
            video.onloadedmetadata = () => {
                video.play();
                resolve();
            };
        });

        faceStatus.innerHTML = '✅ Caméra prête ! Regardez la caméra';
        faceStatus.className = 'face-status success';
        captureBtn.disabled = false;

        captureBtn.onclick = () => {
            if (!captureBtn.disabled && !isScanning) {
                scanFace();
            }
        };

        document.getElementById('cancelFaceBtn').onclick = closeFacialLogin;

        async function scanFace() {
            if (isScanning) return;
            isScanning = true;

            try {
                captureBtn.disabled = true;
                captureBtn.innerHTML = '<span class="loading-spinner"></span> Vérification...';

                faceStatus.innerHTML = '🔍 Détection du visage en cours...';
                faceStatus.className = 'face-status info';

                console.log('Début détection visage...');

                const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions())
                    .withFaceLandmarks()
                    .withFaceDescriptors();

                console.log('Visages détectés:', detections.length);

                if (detections.length === 0) {
                    faceStatus.innerHTML = '❌ Aucun visage détecté. Veuillez réessayer.';
                    faceStatus.className = 'face-status error';
                    captureBtn.disabled = false;
                    captureBtn.innerHTML = '🔍 Réessayer';
                    isScanning = false;
                    return;
                }

                // Prendre le premier visage détecté
                const descriptor = Array.from(detections[0].descriptor);
                console.log('Descripteur généré, taille:', descriptor.length);

                faceStatus.innerHTML = '📡 Vérification auprès du serveur...';

                const response = await fetch('{{ path('app_verify_face') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        descriptor: descriptor
                    })
                });

                console.log('Réponse serveur reçue, status:', response.status);

                // Vérifier d'abord le code HTTP avant de traiter le JSON
                if (response.status !== 200) {
                    const result = await response.json();
                    console.error('Erreur HTTP:', response.status, result);
                    faceStatus.innerHTML = '❌ ' + (result.message || 'Visage non reconnu. Veuillez réessayer.');
                    faceStatus.className = 'face-status error';
                    captureBtn.disabled = false;
                    captureBtn.innerHTML = '🔍 Réessayer';
                    isScanning = false;
                    return;
                }

                const result = await response.json();

                console.log('Résultat serveur:', result);

                if (result.success === true) {
    faceStatus.innerHTML = '✅ Connexion réussie ! Redirection...';
    faceStatus.className = 'face-status success';
    captureBtn.innerHTML = '✅ Succès !';

    if (mediaStream) {
        mediaStream.getTracks().forEach(track => track.stop());
    }

    setTimeout(() => {
        // ✅ result.redirect est maintenant une URL directe (ex: /dashboard)
        window.location.href = result.redirect;
    }, 1500);
} else {
                    // Afficher le message d'erreur détaillé
                    let errorMessage = result.message || 'Visage non reconnu. Veuillez réessayer.';
                    if (result.similarity && result.threshold) {
                        errorMessage += ` (Similarité: ${result.similarity}, Seuil: ${result.threshold})`;
                    }
                    faceStatus.innerHTML = '❌ ' + errorMessage;
                    faceStatus.className = 'face-status error';
                    captureBtn.disabled = false;
                    captureBtn.innerHTML = '🔍 Réessayer';
                    isScanning = false;
                    console.error('Face recognition failed:', result);
                }

            } catch (error) {
                console.error('Erreur scan:', error);
                faceStatus.innerHTML = '❌ Erreur lors de la vérification. Veuillez réessayer.';
                faceStatus.className = 'face-status error';
                captureBtn.disabled = false;
                captureBtn.innerHTML = '🔍 Réessayer';
                isScanning = false;
            }
        }

    } catch (error) {
        console.error('Erreur caméra:', error);

        let errorMessage = '❌ Impossible d\'accéder à la caméra. ';
        if (error.name === 'NotAllowedError') {
            errorMessage += 'Veuillez autoriser l\'accès à la caméra.';
        } else if (error.name === 'NotFoundError') {
            errorMessage += 'Aucune caméra trouvée sur votre appareil.';
        } else if (error.name === 'NotReadableError') {
            errorMessage += 'La caméra est déjà utilisée par une autre application.';
        } else {
            errorMessage += error.message || 'Vérifiez vos permissions et réessayez.';
        }

        faceStatus.innerHTML = errorMessage;
        faceStatus.className = 'face-status error';
        captureBtn.disabled = true;

        const videoPlaceholder = document.getElementById('videoPlaceholder');
        videoPlaceholder.innerHTML = `
            <div style="font-size: 48px;">📷</div>
            <p>${errorMessage}</p>
            <button onclick="location.reload()" style="margin-top: 10px; padding: 8px 16px; background: #6c5ce7; color: white; border: none; border-radius: 5px; cursor: pointer;">Réessayer</button>
        `;
    }
}

function togglePassword() {
    const passwordField = document.getElementById('passwordField');
    const visiblePasswordField = document.getElementById('visiblePasswordField');
    const eyeIcon = document.getElementById('eyeIcon');

    if (passwordField.style.display !== 'none') {
        passwordField.style.display = 'none';
        visiblePasswordField.style.display = 'block';
        visiblePasswordField.value = passwordField.value;
        eyeIcon.textContent = '👁️‍🗨️';
    } else {
        passwordField.style.display = 'block';
        visiblePasswordField.style.display = 'none';
        passwordField.value = visiblePasswordField.value;
        eyeIcon.textContent = '👁️';
    }
}

document.getElementById('visiblePasswordField').addEventListener('input', function(e) {
    document.getElementById('passwordField').value = e.target.value;
});

document.getElementById('passwordField').addEventListener('input', function(e) {
    if (document.getElementById('passwordField').style.display === 'none') {
        document.getElementById('visiblePasswordField').value = e.target.value;
    }
});

function validateLoginForm() {
    const emailField = document.getElementById('emailField');
    const passwordField = document.getElementById('passwordField');
    const visiblePasswordField = document.getElementById('visiblePasswordField');

    const passwordValue = passwordField.style.display !== 'none' ? passwordField.value : visiblePasswordField.value;

    if (!emailField.value || emailField.value.trim() === '') {
        showInlineError('Veuillez saisir votre email');
        emailField.focus();
        return false;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailField.value)) {
        showInlineError('Veuillez saisir un email valide');
        emailField.focus();
        return false;
    }

    if (!passwordValue || passwordValue.trim() === '') {
        showInlineError('Veuillez saisir votre mot de passe');
        if (passwordField.style.display !== 'none') {
            passwordField.focus();
        } else {
            visiblePasswordField.focus();
        }
        return false;
    }

    return true;
}

function resetForm() {
    document.getElementById('emailField').value = '';
    document.getElementById('passwordField').value = '';
    document.getElementById('visiblePasswordField').value = '';
}

function showInlineError(message) {
    const existingAlert = document.getElementById('inlineErrorAlert');
    if (existingAlert) {
        existingAlert.remove();
    }

    const formContainer = document.querySelector('.form-container');
    const alertDiv = document.createElement('div');
    alertDiv.id = 'inlineErrorAlert';
    alertDiv.className = 'login-message';
    alertDiv.textContent = message;

    formContainer.parentNode.insertBefore(alertDiv, formContainer);

    setTimeout(() => {
        const alert = document.getElementById('inlineErrorAlert');
        if (alert) {
            alert.remove();
        }
    }, 5000);
}

// Theme toggle for login page
function toggleTheme() {
    const body = document.body;
    const themeIconLogin = document.getElementById('themeIconLogin');
    const themeTextLogin = document.getElementById('themeTextLogin');
    
    if (body.classList.contains('dark-mode')) {
        body.classList.remove('dark-mode');
        localStorage.setItem('theme', 'light');
        if (themeIconLogin) {
            themeIconLogin.classList.remove('fa-sun');
            themeIconLogin.classList.add('fa-moon');
        }
        if (themeTextLogin) {
            themeTextLogin.textContent = 'Mode Sombre';
        }
    } else {
        body.classList.add('dark-mode');
        localStorage.setItem('theme', 'dark');
        if (themeIconLogin) {
            themeIconLogin.classList.remove('fa-moon');
            themeIconLogin.classList.add('fa-sun');
        }
        if (themeTextLogin) {
            themeTextLogin.textContent = 'Mode Clair';
        }
    }
}

// Load saved theme on page load for login page
document.addEventListener('DOMContentLoaded', function() {
    const savedTheme = localStorage.getItem('theme');
    const themeIconLogin = document.getElementById('themeIconLogin');
    const themeTextLogin = document.getElementById('themeTextLogin');
    const themeIconFaceLogin = document.getElementById('themeIconFaceLogin');
    const themeTextFaceLogin = document.getElementById('themeTextFaceLogin');
    
    if (savedTheme === 'dark') {
        document.body.classList.add('dark-mode');
        if (themeIconLogin) {
            themeIconLogin.classList.remove('fa-moon');
            themeIconLogin.classList.add('fa-sun');
        }
        if (themeTextLogin) {
            themeTextLogin.textContent = 'Mode Clair';
        }
        if (themeIconFaceLogin) {
            themeIconFaceLogin.classList.remove('fa-moon');
            themeIconFaceLogin.classList.add('fa-sun');
        }
        if (themeTextFaceLogin) {
            themeTextFaceLogin.textContent = 'Mode Clair';
        }
    }
});
</script>
{% endblock %}