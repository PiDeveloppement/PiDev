{% extends 'base.html.twig' %}

{% block title %}Connexion - EventFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            overflow-x: hidden;
        }
        
        .login-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #f0f8ff, #e6f2ff);
            display: flex;
            flex-direction: column;
        }
        
        /* Bouton retour */
        .back-button {
            padding: 20px 0 0 40px;
        }
        
        .back-button a {
            display: inline-block;
            background: transparent;
            color: #2196F3;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            border: 1px solid #2196F3;
            border-radius: 20px;
            padding: 8px 20px;
            transition: all 0.2s ease;
        }
        
        .back-button a:hover {
            background: #2196F3;
            color: white;
        }
        
        /* Grille principale */
        .main-grid {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }
        
        .grid-container {
            display: grid;
            grid-template-columns: 45% 55%;
            gap: 60px;
            max-width: 1200px;
            width: 100%;
            align-items: center;
        }
        
        /* Partie gauche */
        .left-panel {
            padding: 40px 60px 40px 40px;
        }
        
        .logo-container {
            margin-bottom: 40px;
        }
        
        .logo-container img {
            width: 222px;
            height: auto;
        }
        
        .features {
            display: flex;
            flex-direction: column;
            gap: 25px;
            max-width: 380px;
        }
        
        .feature-item {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(33, 150, 243, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #2196F3;
        }
        
        .feature-text h3 {
            color: #333333;
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 3px;
        }
        
        .feature-text p {
            color: #666666;
            font-size: 13px;
            margin: 0;
        }
        
        /* Partie droite */
        .right-panel {
            padding: 60px;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .login-card {
            background: white;
            border-radius: 15px;
            padding: 35px 40px;
            max-width: 420px;
            width: 100%;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
        }
        
        .card-header {
            text-align: center;
        }
        
        .card-header h2 {
            font-size: 26px;
            font-weight: bold;
            color: #2196F3;
            margin: 0 0 6px 0;
        }
        
        .card-header p {
            color: #666666;
            font-size: 13px;
            margin: 0;
        }
        
        .form-container {
            width: 100%;
            max-width: 350px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        
        .form-group {
            width: 100%;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 13px;
            background: white;
            transition: border-color 0.2s ease;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #2196F3;
            box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.15);
        }
        
        /* Container pour le mot de passe avec œil */
        .password-container {
            position: relative;
            width: 100%;
        }
        
        .password-field {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 13px;
            background: white;
            transition: border-color 0.2s ease;
            padding-right: 40px;
        }
        
        .password-field:focus {
            outline: none;
            border-color: #2196F3;
            box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.15);
        }
        
        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 20px;
            color: #666;
            cursor: pointer;
            background: transparent;
            z-index: 10;
            padding: 0 10px;
        }
        
        /* Options */
        .options-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            width: 100%;
            max-width: 350px;
        }
        
        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #555555;
            font-size: 13px;
            cursor: pointer;
        }
        
        .checkbox-label input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1px solid #cbd5e0;
            cursor: pointer;
        }
        
        .forgot-link {
            color: #2196F3;
            font-size: 12px;
            font-weight: bold;
            text-decoration: none;
        }
        
        .forgot-link:hover {
            text-decoration: underline;
        }
        
        .btn-primary {
            background: #2196F3;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 8px;
            padding: 12px 35px;
            font-size: 14px;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            box-shadow: 0 4px 10px rgba(33, 150, 243, 0.3);
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            background: #1976D2;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(33, 150, 243, 0.4);
        }
        
        /* Bouton de connexion faciale */
        .facial-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }
        
        .facial-btn {
            background: linear-gradient(to bottom, #6c5ce7, #a463f5);
            border: none;
            border-radius: 40px;
            width: 80px;
            height: 80px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.6);
            transform: translateY(-30px);
            transition: transform 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .facial-btn:hover {
            transform: translateY(-35px) scale(1.05);
        }
        
        .facial-icon {
            font-size: 38px;
            color: white;
        }
        
        .facial-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 28px;
            height: 28px;
            background: #4CAF50;
            border-radius: 50%;
            border: 2px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: white;
        }
        
        .facial-ring {
            position: absolute;
            width: 76px;
            height: 76px;
            border: 2px dashed white;
            border-radius: 50%;
            opacity: 0.3;
            pointer-events: none;
        }
        
        .facial-label {
            background: white;
            border-radius: 10px;
            padding: 3px 8px;
            font-weight: bold;
            font-size: 11px;
            color: #6c5ce7;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
        }
        
        /* Messages flash */
        .flash-message {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 12px;
            text-align: center;
            width: 100%;
        }
        
        .flash-message.error {
            background: #fee2e2;
            border: 1px solid #ef4444;
            color: #dc2626;
        }
        
        .flash-message.success {
            background: #dcfce7;
            border: 1px solid #10b981;
            color: #059669;
        }
        
        .login-message {
            color: #ef4444;
            font-size: 12px;
            text-align: center;
            margin-bottom: 5px;
        }
        
        /* Liens de navigation */
        .nav-links {
            margin-top: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        
        .signup-link {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        
        .signup-link span {
            color: #666666;
            font-size: 12px;
        }
        
        .signup-link a {
            color: #2196F3;
            font-weight: bold;
            font-size: 12px;
            text-decoration: none;
        }
        
        .signup-link a:hover {
            text-decoration: underline;
        }
        
        /* Footer */
        .footer {
            background: rgba(33, 150, 243, 0.05);
            padding: 20px;
            text-align: center;
        }
        
        .footer p {
            color: #666666;
            font-size: 12px;
            margin: 0 0 10px 0;
        }
        
        .footer-links {
            display: flex;
            gap: 20px;
            justify-content: center;
        }
        
        .footer-links a {
            color: #2196F3;
            font-size: 12px;
            text-decoration: none;
        }
        
        .footer-links a:hover {
            text-decoration: underline;
        }
    </style>
{% endblock %}

{% block public_content %}
<div class="login-page">
    <!-- BOUTON RETOUR -->
    <div class="back-button">
        <a href="{{ path('app_landing') }}">← Retour à l'accueil</a>
    </div>

    <!-- CONTENU PRINCIPAL -->
    <div class="main-grid">
        <div class="grid-container">
            <!-- Partie gauche : Présentation avec logo -->
            <div class="left-panel">
                <div class="logo-container">
                    <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
                </div>

                <div class="features">
                    <!-- Point 1 -->
                    <div class="feature-item">
                        <div class="feature-icon">📅</div>
                        <div class="feature-text">
                            <h3>Créez des événements</h3>
                            <p>Organisez et planifiez facilement</p>
                        </div>
                    </div>

                    <!-- Point 2 -->
                    <div class="feature-item">
                        <div class="feature-icon">👥</div>
                        <div class="feature-text">
                            <h3>Gérez les participants</h3>
                            <p>Suivi en temps réel des inscriptions</p>
                        </div>
                    </div>

                    <!-- Point 3 -->
                    <div class="feature-item">
                        <div class="feature-icon">💰</div>
                        <div class="feature-text">
                            <h3>Suivez votre budget</h3>
                            <p>Contrôlez les dépenses et recettes</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Partie droite : Carte de connexion -->
            <div class="right-panel">
                <!-- Carte de connexion -->
                <div class="login-card">
                    <!-- En-tête -->
                    <div class="card-header">
                        <h2>Connexion</h2>
                        <p>Accédez à votre espace de gestion</p>
                    </div>

                    <!-- Message d'erreur (équivalent à loginMessageLabel) -->
                    {% if error %}
                        <div class="login-message">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    <!-- Messages flash -->
                    {% for message in app.flashes('error') %}
                        <div class="flash-message error">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="flash-message success">{{ message }}</div>
                    {% endfor %}

                    <!-- Formulaire de connexion -->
                    <form method="post" action="{{ path('app_login_check') }}" style="width: 100%;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="form-container">
                            <!-- Email -->
                            <div class="form-group">
                                <input type="email" 
                                       name="email" 
                                       value="{{ last_username }}" 
                                       placeholder="Email universitaire"
                                       class="form-control"
                                       required>
                            </div>

                            <!-- Mot de passe avec toggle (comme dans JavaFX) -->
                            <div class="password-container">
                                <input type="password" 
                                       id="passwordField" 
                                       name="password" 
                                       placeholder="Mot de passe"
                                       class="password-field"
                                       required>
                                <input type="text" 
                                       id="visiblePasswordField" 
                                       placeholder="Mot de passe"
                                       class="password-field"
                                       style="display: none;">
                                <span id="eyeIcon" class="password-toggle" onclick="togglePassword()">👁️</span>
                            </div>
                        </div>

                        <!-- Options et boutons -->
                        <div class="options-container">
                            <!-- Se souvenir de moi -->
                            <label class="checkbox-label">
                                <input type="checkbox" name="_remember_me">
                                <span>Se souvenir de moi</span>
                            </label>

                            <!-- Mot de passe oublié -->
                            <a href="{{ path('app_forgot_password') }}" class="forgot-link">
                                Mot de passe oublié ?
                            </a>

                            <!-- Bouton Se connecter -->
                            <button type="submit" class="btn-primary">
                                Se connecter
                            </button>

                            <!-- Bouton Annuler -->
                            <button type="reset" class="btn-primary">
                                Annuler
                            </button>

                            <!-- Lien d'inscription -->
                            <div class="nav-links">
                                <div class="signup-link">
                                    <span>Nouveau sur EventFlow?</span>
                                    <a href="{{ path('app_register') }}">Créer un compte</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- BOUTON DE CONNEXION FACIALE -->
                <div class="facial-container">
                    <button class="facial-btn" onclick="window.location.href='{{ path('app_facial_login') }}'">
                        <span class="facial-icon">👤</span>
                        <div class="facial-badge">🔓</div>
                        <div class="facial-ring"></div>
                    </button>
                    <div class="facial-label">Face ID</div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <p>© 2026 EventFlow - Tous droits réservés</p>
        <div class="footer-links">
            <a href="#">Conditions d'utilisation</a>
            <a href="#">Politique de confidentialité</a>
            <a href="#">Support</a>
        </div>
    </footer>
</div>

<script>
function togglePassword() {
    const passwordField = document.getElementById('passwordField');
    const visiblePasswordField = document.getElementById('visiblePasswordField');
    const eyeIcon = document.getElementById('eyeIcon');
    
    if (passwordField.style.display !== 'none') {
        // Cacher le champ password, montrer le champ text
        passwordField.style.display = 'none';
        visiblePasswordField.style.display = 'block';
        visiblePasswordField.value = passwordField.value;
        eyeIcon.textContent = '👁️‍🗨️';
    } else {
        // Montrer le champ password, cacher le champ text
        passwordField.style.display = 'block';
        visiblePasswordField.style.display = 'none';
        passwordField.value = visiblePasswordField.value;
        eyeIcon.textContent = '👁️';
    }
}

// Synchroniser les champs
document.getElementById('visiblePasswordField').addEventListener('input', function(e) {
    document.getElementById('passwordField').value = e.target.value;
});

document.getElementById('passwordField').addEventListener('input', function(e) {
    if (document.getElementById('passwordField').style.display === 'none') {
        document.getElementById('visiblePasswordField').value = e.target.value;
    }
});
</script>
{% endblock %}