<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    {# FIX TURBO: force full reload sur cette page #}
    <meta name="turbo-visit-control" content="reload">
    <title>Rapport Dashboard - EventFlow</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            padding: 40px;
            background: white;
            color: #1e293b;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 3px solid #3b82f6;
            padding-bottom: 20px;
        }
        
        .header h1 {
            color: #0f172a;
            font-size: 28px;
            margin-bottom: 10px;
        }
        
        .header p {
            color: #64748b;
            font-size: 14px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-box {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            background: #f8fafc;
        }
        
        .stat-box h3 {
            color: #475569;
            font-size: 14px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        
        .stat-box .value {
            font-size: 36px;
            font-weight: bold;
            color: #0f172a;
        }
        
        .stat-box .label {
            color: #64748b;
            font-size: 12px;
            margin-top: 5px;
        }
        
        .section {
            margin-bottom: 30px;
        }
        
        .section h2 {
            color: #0f172a;
            font-size: 20px;
            margin-bottom: 15px;
            border-left: 4px solid #3b82f6;
            padding-left: 15px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }
        
        th {
            background: #f1f5f9;
            font-weight: bold;
            color: #0f172a;
        }
        
        .progress-bar {
            height: 20px;
            background: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin: 10px 0;
        }
        
        .progress-fill {
            height: 100%;
            background: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 10px;
            color: white;
            font-size: 12px;
            font-weight: bold;
        }
        
        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 2px solid #e2e8f0;
            text-align: center;
            color: #64748b;
            font-size: 12px;
        }
        
        @media print {
            body {
                padding: 20px;
            }
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📊 Rapport Dashboard - EventFlow</h1>
        <p>Généré le: {{ generated_at|date('d/m/Y H:i:s') }} | Rôle: {{ user_role|capitalize }}</p>
    </div>

    <div class="stats-grid">
        <div class="stat-box">
            <h3>📅 Événements</h3>
            <div class="value">{{ stats.total_events|default(0) }}</div>
            <div class="label">Total événements</div>
        </div>
        
        <div class="stat-box">
            <h3>👥 Utilisateurs</h3>
            <div class="value">{{ stats.total_users_stats|default(0) }}</div>
            <div class="label">Total utilisateurs</div>
        </div>
        
        <div class="stat-box">
            <h3>📈 Taux Participation</h3>
            <div class="value">{{ stats.participation_rate|default(0) }}%</div>
            <div class="label">Moyenne participation</div>
        </div>
        
        <div class="stat-box">
            <h3>🆕 Nouveaux</h3>
            <div class="value">{{ stats.new_users_this_month|default(0) }}</div>
            <div class="label">Utilisateurs ce mois</div>
        </div>
    </div>

    <div class="section">
        <h2>📊 Événements par Statut</h2>
        <table>
            <thead>
                <tr>
                    <th>Statut</th>
                    <th>Nombre</th>
                    <th>Pourcentage</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>🟢 À venir</td>
                    <td>{{ stats.planned|default(0) }}</td>
                    <td>{{ stats.planned_percent|default(0) }}%</td>
                </tr>
                <tr>
                    <td>🔵 En cours</td>
                    <td>{{ stats.ongoing|default(0) }}</td>
                    <td>{{ stats.ongoing_percent|default(0) }}%</td>
                </tr>
                <tr>
                    <td>⚪ Terminé</td>
                    <td>{{ stats.completed|default(0) }}</td>
                    <td>{{ stats.completed_percent|default(0) }}%</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>👥 Utilisateurs par Rôle</h2>
        <table>
            <thead>
                <tr>
                    <th>Rôle</th>
                    <th>Nombre</th>
                    <th>Pourcentage</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>👑 Administrateurs</td>
                    <td>{{ stats.admins_count|default(0) }}</td>
                    <td>{{ stats.admins_percent|default(0) }}%</td>
                </tr>
                <tr>
                    <td>🎯 Organisateurs</td>
                    <td>{{ stats.organizers_count|default(0) }}</td>
                    <td>{{ stats.organizers_percent|default(0) }}%</td>
                </tr>
                <tr>
                    <td>👤 Utilisateurs</td>
                    <td>{{ stats.default_count|default(0) }}</td>
                    <td>{{ stats.default_percent|default(0) }}%</td>
                </tr>
                <tr>
                    <td>💼 Sponsors</td>
                    <td>{{ stats.sponsors_count|default(0) }}</td>
                    <td>{{ stats.sponsors_percent|default(0) }}%</td>
                </tr>
            </tbody>
        </table>
    </div>

    {% if upcoming_events|length > 0 %}
    <div class="section">
        <h2>📅 Événements à Venir</h2>
        <table>
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Lieu</th>
                    <th>Prix</th>
                </tr>
            </thead>
            <tbody>
                {% for event in upcoming_events %}
                <tr>
                    <td>{{ event.title }}</td>
                    <td>{{ event.startDate ? event.startDate|date('d/m/Y H:i') : '-' }}</td>
                    <td>{{ event.location ?: 'Non défini' }}</td>
                    <td>{% if event.isFree %}Gratuit{% else %}{{ event.ticketPrice }} DT{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    <div class="footer">
        <p>© 2026 EventFlow - Système de Gestion Événementielle</p>
        <p>Département Informatique</p>
    </div>

    <div class="no-print" style="margin-top: 20px; text-align: center;">
        <button onclick="window.print()" style="padding: 10px 20px; background: #3b82f6; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 14px;">
            🖨️ Imprimer / Sauvegarder en PDF
        </button>
        <button onclick="window.close()" style="padding: 10px 20px; background: #64748b; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; margin-left: 10px;">
            ❌ Fermer
        </button>
    </div>
</body>
</html>
