{# templates/resource/salle/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Ajouter une Salle - EventFlow{% endblock %}

{% block admin_content %}
<!-- Alert Container -->
<div id="alertContainer" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; max-width: 600px; width: 90%;"></div>
<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 2px; margin-bottom: 20px;">
    <div style="background: white; border-radius: 14px; padding: 30px;">
        
        {# --- HEADER --- #}
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 22px;">
                    <i class="fas fa-door-open"></i>
                </div>
                <div>
                    <h3 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 5px;">
                        {{ salle.id ? 'Modifier la Salle' : 'Ajouter une Salle' }}
                    </h3>
                    <p style="color: #64748b; font-size: 14px;">Gestion des espaces de l'établissement</p>
                </div>
            </div>
            
            {# --- BOUTON VOCAL --- #}
            <div style="text-align: center;">
                <button id="voiceBtn" type="button" style="width: 45px; height: 45px; border-radius: 50%; border: none; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; cursor: pointer; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3); transition: transform 0.2s;">
                    <i class="fas fa-microphone"></i>
                </button>
                <div id="voiceStatus" style="font-size: 9px; color: #94a3b8; font-weight: bold; margin-top: 5px;">Micro Off</div>
            </div>
        </div>

        <hr style="border: 0; border-top: 1px solid #e5e7eb; margin-bottom: 30px;">

        {# --- FORMULAIRE SYMFONY --- #}
        {{ form_start(form, {'attr': {'id': 'salleForm', 'novalidate': 'novalidate'}}) }}
            
            <div style="display: flex; flex-direction: column; gap: 20px;">
                
                {# Nom de la salle + Auto recherche #}
                <div style="background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0;">
                    <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 8px;">
                        <i class="fas fa-door-open" style="color: #667eea; margin-right: 8px;"></i>Nom de la salle
                    </label>
                    <div style="display: flex; gap: 10px;">
                        {{ form_widget(form.name, {'attr': {'style': 'flex-grow: 1; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;', 'placeholder': 'Ex: Salle de conférence'}}) }}
                        <button type="button" id="autoImageBtn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; padding: 0 15px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3); transition: transform 0.2s;">
                            <i class="fas fa-search"></i> Auto
                        </button>
                    </div>
                    <div style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ form_errors(form.name) }}</div>
                </div>

                {# Capacité et Étage sur la même ligne #}
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div style="background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0;">
                        <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 8px;">
                            <i class="fas fa-users" style="color: #3b82f6; margin-right: 8px;"></i>Capacité
                        </label>
                        {{ form_widget(form.capacity, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;', 'placeholder': 'Ex: 30'}}) }}
                        <div style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ form_errors(form.capacity) }}</div>
                    </div>
                    <div style="background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0;">
                        <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 8px;">
                            <i class="fas fa-layer-group" style="color: #10b981; margin-right: 8px;"></i>Étage
                        </label>
                        {{ form_widget(form.floor, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;', 'placeholder': 'Ex: 1'}}) }}
                        <div style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ form_errors(form.floor) }}</div>
                    </div>
                </div>

                {# Bâtiment #}
                <div style="background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0;">
                    <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 8px;">
                        <i class="fas fa-building" style="color: #f59e0b; margin-right: 8px;"></i>Bâtiment / Bloc
                    </label>
                    {{ form_widget(form.building, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;', 'placeholder': 'Ex: Bloc G'}}) }}
                    <div style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ form_errors(form.building) }}</div>
                </div>

                {# Statut #}
                <div style="background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0;">
                    <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 8px;">
                        <i class="fas fa-info-circle" style="color: #6b7280; margin-right: 8px;"></i>Statut actuel
                    </label>
                    {{ form_widget(form.status, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;'}}) }}
                    <div style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ form_errors(form.status) }}</div>
                </div>

                {# Section Image avec onglets Unsplash/Upload #}
                <div style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0;">
                    <label style="display: block; color: #374151; font-weight: 600; font-size: 14px; margin-bottom: 10px;">
                        <i class="fas fa-camera" style="color: #667eea; margin-right: 8px;"></i>Photo de la salle
                    </label>
                    
                    {# Info: Génération automatique #}
                    <div style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); padding: 12px 15px; border-radius: 8px; margin-bottom: 20px; font-size: 13px; color: #1e40af; border-left: 4px solid #3b82f6;">
                        <i class="fas fa-magic"></i> <strong>Auto-génération :</strong> Si vous ne choisissez pas d'image, une photo sera automatiquement générée depuis Unsplash !
                    </div>
                    
                    {# Onglets #}
                    <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                        <button type="button" onclick="setMode('unsplash')" id="tabU" style="flex: 1; padding: 10px; border-radius: 8px; border: none; cursor: pointer; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3); transition: transform 0.2s;">
                            <i class="fas fa-search"></i> Unsplash Auto
                        </button>
                        <button type="button" onclick="setMode('upload')" id="tabL" style="flex: 1; padding: 10px; border-radius: 8px; border: none; cursor: pointer; background: #e2e8f0; color: #475569; font-weight: 600; transition: background 0.2s;">
                            <i class="fas fa-upload"></i> Importer fichier
                        </button>
                    </div>

                    <div style="display: flex; align-items: center; gap: 20px;">
                        <div style="flex-grow: 1;">
                            {# Mode Unsplash #}
                            <div id="modeUnsplash">
                                <input type="text" id="imagePathInput" name="image_url" placeholder="URL Unsplash ou image externe (optionnel)..." 
                                       style="width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;">
                            </div>
                            
                            {# Mode Upload #}
                            <div id="modeUpload" style="display: none;">
                                {{ form_widget(form.imageFile, {'attr': {
                                    'id': 'imageFileInput',
                                    'style': 'width: 100%; padding: 10px; border: 2px solid #e5e7eb; border-radius: 8px; transition: border-color 0.2s;'
                                }}) }}
                            </div>
                        </div>
                        <div style="background: white; padding: 8px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border: 1px solid #e5e7eb;">
                            <img id="imagePreview" src="{{ salle.imagePath|default('https://via.placeholder.com/80?text=Auto') }}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                        </div>
                    </div>
                </div>
            </div>

            {# --- BOUTONS D'ACTION --- #}
            <div style="display: flex; justify-content: space-between; gap: 15px; margin-top: 35px; padding-top: 25px; border-top: 1px solid #e5e7eb;">
                <a href="{{ path('app_resource_salle_index') }}" 
                   style="flex: 1; text-align: center; background: #f8fafc; color: #64748b; padding: 14px; border-radius: 10px; text-decoration: none; font-weight: 600; border: 2px solid #e2e8f0; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;"
                   onmouseover="this.style.background='#e2e8f0'; this.style.transform='translateY(-2px)'" 
                   onmouseout="this.style.background='#f8fafc'; this.style.transform='translateY(0)'">
                    <i class="fas fa-times"></i> Annuler
                </a>
                <button type="submit" 
                        style="flex: 1; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); color: white; border: none; padding: 14px; border-radius: 10px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 15px rgba(34,197,94,0.3); transition: transform 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;"
                        onmouseover="this.style.transform='translateY(-2px)'" 
                        onmouseout="this.style.transform='translateY(0)'">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>

<script>
    // 1. Logique des onglets Unsplash / Upload
    function setMode(mode) {
        const unsplashDiv = document.getElementById('modeUnsplash');
        const uploadDiv = document.getElementById('modeUpload');
        const tabUnsplash = document.getElementById('tabU');
        const tabUpload = document.getElementById('tabL');
        
        if(mode === 'unsplash') {
            unsplashDiv.style.display = 'block';
            uploadDiv.style.display = 'none';
            tabUnsplash.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
            tabUnsplash.style.color = 'white';
            tabUnsplash.style.boxShadow = '0 4px 15px rgba(102, 126, 234, 0.3)';
            tabUpload.style.background = '#e2e8f0';
            tabUpload.style.color = '#475569';
            tabUpload.style.boxShadow = 'none';
        } else {
            unsplashDiv.style.display = 'none';
            uploadDiv.style.display = 'block';
            tabUpload.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
            tabUpload.style.color = 'white';
            tabUpload.style.boxShadow = '0 4px 15px rgba(102, 126, 234, 0.3)';
            tabUnsplash.style.background = '#e2e8f0';
            tabUnsplash.style.color = '#475569';
            tabUnsplash.style.boxShadow = 'none';
        }
    }

    // 2. Preview Image Dynamique (URL)
    const imageInput = document.getElementById('imagePathInput');
    const imagePreview = document.getElementById('imagePreview');

    if(imageInput) {
        imageInput.addEventListener('input', () => {
            if(imageInput.value) imagePreview.src = imageInput.value;
        });
    }

    // 3. Preview Upload Fichier
    const fileInput = document.getElementById('imageFileInput');
    if(fileInput) {
        fileInput.addEventListener('change', (e) => {
            const [file] = e.target.files;
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                // Vider le champ URL si un fichier est uploadé
                if(imageInput) imageInput.value = '';
            }
        });
    }

    // 4. Recherche Auto Unsplash (bouton Auto)
    document.getElementById('autoImageBtn').addEventListener('click', async () => {
        const query = document.querySelector('[name*="[name]"]').value;
        if (!query) {
            alert("Veuillez entrer un nom de salle.");
            return;
        }
        
        document.getElementById('autoImageBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Auto';
        const url = `https://source.unsplash.com/featured/200x200/?room,${encodeURIComponent(query)},conference`;
        
        if(imageInput) {
            imageInput.value = url;
            imagePreview.src = url;
        }
        document.getElementById('autoImageBtn').innerHTML = '<i class="fas fa-search"></i> Auto';
    });

    // 5. Commande Vocale
    const voiceBtn = document.getElementById('voiceBtn');
    const voiceStatus = document.getElementById('voiceStatus');
    
    if ('webkitSpeechRecognition' in window) {
        const recognition = new webkitSpeechRecognition();
        recognition.lang = 'fr-FR';
        
        voiceBtn.onclick = () => {
            recognition.start();
            voiceBtn.style.background = "linear-gradient(135deg, #22c55e 0%, #16a34a 100%)";
            voiceStatus.innerText = "🎙️ Écoute...";
        };

        recognition.onresult = (event) => {
            const cmd = event.results[0][0].transcript.toLowerCase();
            voiceStatus.innerText = "🎙️: " + cmd;
            
            // Commandes vocales
            if (cmd.includes("nom")) {
                document.querySelector('[name*="[name]"]').value = cmd.replace("nom", "").trim();
            }
            if (cmd.includes("bâtiment") || cmd.includes("batiment")) {
                document.querySelector('[name*="[building]"]').value = cmd.replace("bâtiment", "").replace("batiment", "").trim();
            }
            if (cmd.includes("capacité") || cmd.includes("capacite")) {
                const capa = cmd.replace(/[^0-9]/g, "");
                if(capa) document.querySelector('[name*="[capacity]"]').value = capa;
            }
            if (cmd.includes("étage") || cmd.includes("etage")) {
                const floor = cmd.replace(/[^0-9]/g, "");
                if(floor) document.querySelector('[name*="[floor]"]').value = floor;
            }
            
            voiceBtn.style.background = "linear-gradient(135deg, #ef4444 0%, #dc2626 100%)";
            setTimeout(() => { voiceStatus.innerText = "Micro Off"; }, 2000);
        };
        
        recognition.onerror = () => {
            voiceBtn.style.background = "linear-gradient(135deg, #ef4444 0%, #dc2626 100%)";
            voiceStatus.innerText = "Erreur";
        };
    } else {
        voiceStatus.innerText = "Non supporté";
        voiceBtn.style.opacity = "0.5";
        voiceBtn.disabled = true;
    }
</script>

<script>
// Validation du formulaire salle
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('salleForm');
    form.addEventListener('submit', function(event) {
        const errors = validateSalleForm();
        if (errors.length > 0) {
            event.preventDefault();
            showSalleErrors(errors);
        }
    });
});

function validateSalleForm() {
    const errors = [];
    
    const name = document.querySelector('[name*="[name]"]').value;
    const capacity = document.querySelector('[name*="[capacity]"]').value;
    const building = document.querySelector('[name*="[building]"]').value;
    const floor = document.querySelector('[name*="[floor]"]').value;
    const status = document.querySelector('[name*="[status]"]').value;
    
    if (!name || name.trim() === '') {
        errors.push('Le nom de la salle ne peut pas être vide');
    }
    
    if (!capacity || capacity < 1 || capacity > 1000) {
        errors.push('La capacité doit être entre 1 et 1000 places');
    }
    
    if (!building || building.trim() === '') {
        errors.push('Le nom du bâtiment ne peut pas être vide');
    }
    
    if (!floor || floor < 0 || floor > 50) {
        errors.push('L\'étage doit être entre 0 et 50');
    }
    
    if (!status) {
        errors.push('Veuillez sélectionner un statut');
    }
    
    return errors;
}

function showSalleErrors(errors) {
    const alertContainer = document.getElementById('alertContainer');
    
    const alert = document.createElement('div');
    alert.style.cssText = `
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3);
        margin-bottom: 10px;
        transform: translateY(-100px);
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid rgba(255, 255, 255, 0.2);
    `;
    
    const icon = document.createElement('i');
    icon.className = 'fas fa-exclamation-triangle';
    icon.style.marginRight = '10px';
    
    const title = document.createElement('strong');
    title.textContent = 'Erreurs de validation : ';
    
    const message = document.createElement('div');
    message.style.marginTop = '8px';
    message.innerHTML = errors.map(error => `• ${error}`).join('<br>');
    
    alert.appendChild(icon);
    alert.appendChild(title);
    alert.appendChild(message);
    
    alertContainer.appendChild(alert);
    
    setTimeout(() => {
        alert.style.transform = 'translateY(0)';
    }, 100);
    
    setTimeout(() => {
        alert.style.transform = 'translateY(-100px)';
        alert.style.opacity = '0';
        setTimeout(() => {
            if (alert.parentNode) {
                alert.parentNode.removeChild(alert);
            }
        }, 400);
    }, 5000);
    
    alert.addEventListener('click', () => {
        alert.style.transform = 'translateY(-100px)';
        alert.style.opacity = '0';
        setTimeout(() => {
            if (alert.parentNode) {
                alert.parentNode.removeChild(alert);
            }
        }, 400);
    });
}
</script>

<style>
    button[type="submit"]:hover {
        background: linear-gradient(135deg, #16a34a 0%, #15803d 100%) !important;
        transform: translateY(-2px);
    }
    
    a:hover {
        background: #e2e8f0 !important;
        transition: all 0.2s;
    }
    
    input:focus, select:focus {
        outline: none;
        border-color: #667eea !important;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    #autoImageBtn:hover {
        background: linear-gradient(135deg, #5a67d8 0%, #553c9a 100%) !important;
        transform: scale(1.02);
    }
    
    #voiceBtn:hover {
        transform: scale(1.05);
    }
    
    #imagePreview {
        transition: all 0.3s ease;
    }
    
    #imagePreview:hover {
        transform: scale(1.05);
    }
    
    .tab-button:hover {
        transform: translateY(-1px);
    }
</style>
{% endblock %} 