<script>

// Fonction pour afficher des alertes personnalisées
function showAlert(message) {
    // Créer l'élément d'alerte
    const alertDiv = document.createElement('div');
    alertDiv.style.cssText = `
        position: fixed;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
        z-index: 10000;
        font-size: 14px;
        font-weight: 500;
        max-width: 400px;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid rgba(255, 255, 255, 0.2);
    `;
    
    // Ajouter l'icône
    alertDiv.innerHTML = `
        <div style="display: flex; align-items: center;">
            <i class="fas fa-exclamation-circle" style="margin-right: 10px; font-size: 16px;"></i>
            <span>${message}</span>
        </div>
    `;
    
    // Ajouter l'alerte à la page
    document.body.appendChild(alertDiv);
    
    // Animation d'entrée depuis le haut
    setTimeout(() => {
        alertDiv.style.top = '20px';
    }, 100);
    
    // Animation de sortie et suppression après 3 secondes
    setTimeout(() => {
        alertDiv.style.top = '-100px';
        alertDiv.style.opacity = '0';
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 400);
    }, 3000);
    
    // Fermeture au clic avec animation
    alertDiv.addEventListener('click', () => {
        alertDiv.style.top = '-100px';
        alertDiv.style.opacity = '0';
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 400);
    });
}



async function loadResources() {
    const resourceTypeField = document.getElementById('{{ form.resourceType.vars.id }}');
    const startTimeField = document.getElementById('{{ form.startTime.vars.id }}');
    const endTimeField = document.getElementById('{{ form.endTime.vars.id }}');
    const resourceSelect = document.getElementById('resourceSelect');

    const resourceType = resourceTypeField.value;
    const startTime = startTimeField.value;
    const endTime = endTimeField.value;

    // Gérer la quantité en fonction du type de ressource
    handleQuantityField(resourceType);

    // 1. Si aucun type n'est sélectionné, on vide et on arrête
    if (!resourceType) {
        resourceSelect.innerHTML = '<option value="">Sélectionnez d\'abord un type</option>';
        return;
    }

    // 2. Affichage du status de chargement
    resourceSelect.innerHTML = '<option value="">Chargement des disponibilités...</option>';

    try {
        // 3. Construction de l'URL avec les paramètres de date
        const url = new URL('{{ url('app_ajax_resources') }}', window.location.origin);
        url.searchParams.append('type', resourceType);
        if (startTime) url.searchParams.append('start', startTime);
        if (endTime) url.searchParams.append('end', endTime);

        // 4. Appel AJAX vers le contrôleur
        const response = await fetch(url);
        if (!response.ok) throw new Error('Erreur réseau');
        
        const resources = await response.json();
        
        // 5. Reconstruction du menu déroulant
        resourceSelect.innerHTML = '<option value="">Sélectionnez une ressource</option>';
        
        resources.forEach(resource => {
            const option = document.createElement('option');
            option.value = resource.id;
            
            // Formatage du texte : Nom + Info (Stock ou Capacité)
            let statusText = resource.available ? '' : ' - INDISPONIBLE';
            option.textContent = `${resource.name} (${resource.info})${statusText}`;
            
            // Gestion de l'état "Disabled"
            option.disabled = !resource.available;
            
            // Style CSS pour le feedback visuel (Rouge/Vert)
            if (resource.available) {
                option.style.color = '#059669'; // Vert
                option.style.fontWeight = '600';
            } else {
                option.style.color = '#dc2626'; // Rouge
            }
            
            resourceSelect.appendChild(option);
        });

        // 6. Sécurité : Si l'utilisateur avait déjà choisi une ressource qui est devenue 
        // indisponible après le changement de date, on réinitialise la sélection.
        const stillAvailable = Array.from(resourceSelect.options).some(opt => opt.value === resourceSelect.value && !opt.disabled);
        if (!stillAvailable) {
            resourceSelect.value = "";
            // Vider aussi les champs cachés du formulaire Symfony
            document.getElementById('{{ form.salle.vars.id }}').value = '';
            document.getElementById('{{ form.equipement.vars.id }}').value = '';
        }

    } catch (error) {
        console.error('Erreur lors du chargement des ressources:', error);
        resourceSelect.innerHTML = '<option value="">Erreur de connexion</option>';
    }
}

// Fonction pour gérer la visibilité et l'état du champ quantité
function handleQuantityField(resourceType) {
    const quantityField = document.getElementById('{{ form.quantity.vars.id }}');
    const quantityLabel = document.querySelector('label[for="{{ form.quantity.vars.id }}"]');
    
    if (resourceType === 'SALLE') {
        // Les salles se réservent à 1 uniquement
        quantityField.value = 1;
        quantityField.disabled = true;
        if (quantityLabel) {
            quantityLabel.style.opacity = '0.5';
        }
        quantityField.style.opacity = '0.5';
        quantityField.style.backgroundColor = '#f0f0f0';
    } else if (resourceType === 'EQUIPEMENT') {
        // Les équipements peuvent être réservés en quantité
        quantityField.disabled = false;
        if (quantityLabel) {
            quantityLabel.style.opacity = '1';
        }
        quantityField.style.opacity = '1';
        quantityField.style.backgroundColor = 'white';
    } else {
        // Pas de type sélectionné
        quantityField.value = 1;
        quantityField.disabled = false;
    }
}

