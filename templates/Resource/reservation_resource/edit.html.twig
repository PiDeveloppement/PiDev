{% extends 'base.html.twig' %}

{# Infos pour la TopBar #}
{% set pageInfo = {
    'title': 'Gestion des réservations',
    'subtitle': 'Modifiez votre réservation de salle ou d\'équipement'
} %}

{% block admin_content %}
<!-- Alert Container -->
<div id="alertContainer" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; max-width: 600px; width: 90%;"></div>

<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 2px; margin-bottom: 20px;">
    <div style="background: white; border-radius: 14px; padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h3 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 5px;">
                    <i class="fas fa-edit" style="color: #667eea; margin-right: 10px;"></i>
                    Modifier la Réservation
                </h3>
                <p style="color: #64748b; font-size: 14px;">Modifiez les détails de votre réservation</p>
            </div>
            
            <a href="{{ path('app_reservation_resource_index') }}" 
               style="background: #64748b; color: white; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-size: 14px; font-weight: 600; transition: transform 0.2s;">
                <i class="fas fa-arrow-left" style="margin-right: 8px;"></i>
                Retour à la liste
            </a>
        </div>
        
        {{ form_start(form, {'attr': {'id': 'reservationForm', 'novalidate': 'novalidate'}}) }}
        
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px;">
            <!-- Formulaire principal -->
            <div>
                <div style="background: #f8fafc; border-radius: 12px; padding: 25px; border: 1px solid #e2e8f0;">
                    <h4 style="font-size: 18px; font-weight: 600; color: #1e293b; margin-bottom: 20px;">
                        <i class="fas fa-info-circle" style="color: #667eea; margin-right: 8px;"></i>
                        Informations de réservation
                    </h4>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div>
                            {{ form_label(form.resourceType, "Type", {
                                'label_attr': {
                                    'style': 'display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;'
                                }
                            }) }}
                            {{ form_errors(form.resourceType) }}
                            {{ form_widget(form.resourceType, {
                                'attr': {
                                    'id': form.resourceType.vars.id,
                                    'onchange': 'loadResources()',
                                    'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;'
                                }
                            }) }}
                        </div>
                        
                        <div>
                            {{ form_label(form.quantity, "Quantité", {
                                'label_attr': {
                                    'style': 'display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;'
                                }
                            }) }}
                            {{ form_errors(form.quantity) }}
                            {{ form_widget(form.quantity, {
                                'attr': {
                                    'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;',
                                    'min': '1'
                                }
                            }) }}
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div>
                            {{ form_label(form.startTime, "Date de début", {
                                'label_attr': {
                                    'style': 'display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;'
                                }
                            }) }}
                            {{ form_errors(form.startTime) }}
                            {{ form_widget(form.startTime, {
                                'attr': {
                                    'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;'
                                }
                            }) }}
                        </div>
                        
                        <div>
                            {{ form_label(form.endTime, "Date de fin", {
                                'label_attr': {
                                    'style': 'display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;'
                                }
                            }) }}
                            {{ form_errors(form.endTime) }}
                            {{ form_widget(form.endTime, {
                                'attr': {
                                    'style': 'width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: border-color 0.2s;'
                                }
                            }) }}
                        </div>
                    </div>

                    <div style="margin-bottom: 20px;">
                        {{ form_label(form.salle, "Salle", {
                            'label_attr': {
                                'style': 'display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;'
                            }
                        }) }}
                        {{ form_errors(form.salle) }}
                        {{ form_errors(form.equipement) }}
                        
                        <label for="resourceSelect" style="display: block; margin-bottom: 8px; font-weight: 500; color: #374151; font-size: 14px;">
                            <i class="fas fa-boxes" style="margin-right: 5px;"></i>Ressource
                        </label>
                        <select id="resourceSelect" name="resourceSelect" 
                                style="width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; background: white; transition: border-color 0.2s;">
                            <option value="">Sélectionnez d'abord un type</option>
                        </select>
                        {{ form_widget(form.salle, {'attr': {'style': 'display: none;'}}) }}
                        {{ form_widget(form.equipement, {'attr': {'style': 'display: none;'}}) }}
                    </div>

                    <div style="display: flex; gap: 15px; justify-content: flex-end;">
                        <a href="{{ path('app_reservation_resource_index') }}" 
                           style="background: #ef4444; color: white; padding: 12px 30px; border-radius: 10px; text-decoration: none; font-size: 14px; font-weight: 600; transition: transform 0.2s;">
                            <i class="fas fa-times" style="margin-right: 8px;"></i>Annuler
                        </a>
                        <button type="submit" 
                                style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 12px 30px; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: transform 0.2s; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);">
                            <i class="fas fa-save" style="margin-right: 8px;"></i>Enregistrer
                        </button>
                    </div>
                </div>
            </div>

            <!-- Aperçu -->
            <div>
                <div style="background: #f8fafc; border-radius: 12px; padding: 25px; border: 1px solid #e2e8f0; position: sticky; top: 20px;">
                    <h4 style="font-size: 18px; font-weight: 600; color: #1e293b; margin-bottom: 20px;">
                        <i class="fas fa-eye" style="color: #667eea; margin-right: 8px;"></i>
                        Aperçu
                    </h4>
                    
                    <div id="previewContent" style="color: #64748b; font-size: 14px; line-height: 1.6;">
                        <div style="margin-bottom: 15px;">
                            <strong>Type:</strong> 
                            <span id="previewType" style="color: #374151;">{{ form.resourceType.vars.value }}</span>
                        </div>
                        <div style="margin-bottom: 15px;">
                            <strong>Ressource:</strong> 
                            <span id="previewResource" style="color: #374151;">{{ form.salle.vars.data.name ?? form.equipement.vars.data.name ?? 'Non sélectionnée' }}</span>
                        </div>
                        <div style="margin-bottom: 15px;">
                            <strong>Quantité:</strong> 
                            <span id="previewQuantity" style="color: #374151;">{{ form.quantity.vars.value }}</span>
                        </div>
                        <div style="margin-bottom: 15px;">
                            <strong>Début:</strong> 
                            <span id="previewStart" style="color: #374151;">{{ form.startTime.vars.value|date('d/m/Y') }}</span>
                        </div>
                        <div style="margin-bottom: 15px;">
                            <strong>Fin:</strong> 
                            <span id="previewEnd" style="color: #374151;">{{ form.endTime.vars.value|date('d/m/Y') }}</span>
                        </div>
                    </div>

                    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #e2e8f0;">
                        <div style="background: #fef3c7; border: 1px solid #fbbf24; border-radius: 8px; padding: 12px;">
                            <p style="margin: 0; color: #92400e; font-size: 12px;">
                                <i class="fas fa-info-circle" style="margin-right: 5px;"></i>
                                Les modifications seront soumises à validation.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        {{ form_end(form) }}
    </div>
</div>

<script>
// Fonction pour afficher des alertes personnalisées
function showAlert(message) {
    const alertDiv = document.createElement('div');
    alertDiv.style.cssText = `
        position: fixed;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
        z-index: 10000;
        font-size: 14px;
        font-weight: 500;
        max-width: 400px;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid rgba(255, 255, 255, 0.2);
    `;
    
    alertDiv.innerHTML = `
        <div style="display: flex; align-items: center;">
            <i class="fas fa-exclamation-circle" style="margin-right: 10px; font-size: 16px;"></i>
            <span>${message}</span>
        </div>
    `;
    
    document.body.appendChild(alertDiv);
    
    setTimeout(() => {
        alertDiv.style.top = '20px';
    }, 100);
    
    setTimeout(() => {
        alertDiv.style.top = '-100px';
        alertDiv.style.opacity = '0';
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 400);
    }, 3000);
    
    alertDiv.addEventListener('click', () => {
        alertDiv.style.top = '-100px';
        alertDiv.style.opacity = '0';
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 400);
    });
}

async function loadResources() {
    const resourceTypeField = document.getElementById('{{ form.resourceType.vars.id }}');
    const startTimeField = document.getElementById('{{ form.startTime.vars.id }}');
    const endTimeField = document.getElementById('{{ form.endTime.vars.id }}');
    const resourceSelect = document.getElementById('resourceSelect');

    const resourceType = resourceTypeField.value;
    const startTime = startTimeField.value;
    const endTime = endTimeField.value;

    handleQuantityField(resourceType);

    if (!resourceType) {
        resourceSelect.innerHTML = '<option value="">Sélectionnez d\'abord un type</option>';
        return Promise.resolve();
    }

    resourceSelect.innerHTML = '<option value="">Chargement des disponibilités...</option>';

    try {
        const url = new URL('{{ url('app_ajax_resources') }}', window.location.origin);
        url.searchParams.append('type', resourceType);
        if (startTime) url.searchParams.append('start', startTime);
        if (endTime) url.searchParams.append('end', endTime);

        const response = await fetch(url);
        if (!response.ok) throw new Error('Erreur réseau');
        
        const resources = await response.json();
        
        resourceSelect.innerHTML = '<option value="">Sélectionnez une ressource</option>';
        
        resources.forEach(resource => {
            const option = document.createElement('option');
            option.value = resource.id;
            
            let statusText = resource.available ? '' : ' - INDISPONIBLE';
            option.textContent = `${resource.name} (${resource.info})${statusText}`;
            
            option.disabled = !resource.available;
            
            if (resource.available) {
                option.style.color = '#059669';
                option.style.fontWeight = '600';
            } else {
                option.style.color = '#dc2626';
            }
            
            resourceSelect.appendChild(option);
        });

        return Promise.resolve();

    } catch (error) {
        console.error('Erreur lors du chargement des ressources:', error);
        resourceSelect.innerHTML = '<option value="">Erreur de connexion</option>';
        return Promise.reject(error);
    }
}

function handleQuantityField(resourceType) {
    const quantityField = document.getElementById('{{ form.quantity.vars.id }}');
    const quantityLabel = document.querySelector('label[for="{{ form.quantity.vars.id }}"]');
    
    if (resourceType === 'SALLE') {
        quantityField.value = 1;
        quantityField.disabled = true;
        if (quantityLabel) {
            quantityLabel.style.opacity = '0.5';
        }
        quantityField.style.opacity = '0.5';
        quantityField.style.backgroundColor = '#f0f0f0';
    } else if (resourceType === 'EQUIPEMENT') {
        quantityField.disabled = false;
        if (quantityLabel) {
            quantityLabel.style.opacity = '1';
        }
        quantityField.style.opacity = '1';
        quantityField.style.backgroundColor = 'white';
    } else {
        quantityField.value = 1;
        quantityField.disabled = false;
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const typeField = document.getElementById('{{ form.resourceType.vars.id }}');
    const startField = document.getElementById('{{ form.startTime.vars.id }}');
    const endField = document.getElementById('{{ form.endTime.vars.id }}');

    [typeField, startField, endField].forEach(field => {
        field.addEventListener('change', loadResources);
    });

    const form = document.getElementById('reservationForm');
    form.addEventListener('submit', function(event) {
        const quantityField = document.getElementById('{{ form.quantity.vars.id }}');
        
        if (quantityField.disabled) {
            quantityField.disabled = false;
        }
        if (!quantityField.value || quantityField.value < 1) {
            quantityField.value = 1;
        }
        
        // Validation et affichage des erreurs
        const errors = validateForm();
        if (errors.length > 0) {
            event.preventDefault();
            showErrors(errors);
        }
    });

    document.getElementById('resourceSelect').addEventListener('change', function() {
        const resourceType = document.getElementById('{{ form.resourceType.vars.id }}').value;
        const resourceId = this.value;
        const salleField = document.getElementById('{{ form.salle.vars.id }}');
        const equipementField = document.getElementById('{{ form.equipement.vars.id }}');
        
        if (salleField) salleField.value = '';
        if (equipementField) equipementField.value = '';
        
        if (resourceType === 'SALLE' && resourceId && salleField) {
            salleField.value = resourceId;
        } else if (resourceType === 'EQUIPEMENT' && resourceId && equipementField) {
            equipementField.value = resourceId;
        }
    });

    // Initialiser le sélecteur de ressources avec la valeur actuelle
    function initializeResourceSelect() {
        const resourceType = document.getElementById('{{ form.resourceType.vars.id }}').value;
        const salleField = document.getElementById('{{ form.salle.vars.id }}');
        const equipementField = document.getElementById('{{ form.equipement.vars.id }}');
        
        loadResources().then(() => {
            // Sélectionner la ressource actuelle après chargement
            if (resourceType === 'SALLE' && salleField && salleField.value) {
                document.getElementById('resourceSelect').value = salleField.value;
            } else if (resourceType === 'EQUIPEMENT' && equipementField && equipementField.value) {
                document.getElementById('resourceSelect').value = equipementField.value;
            }
        });
    }

    initializeResourceSelect();
});

// Fonction de validation du formulaire
function validateForm() {
    const errors = [];
    
    const resourceType = document.getElementById('{{ form.resourceType.vars.id }}').value;
    const startTime = document.getElementById('{{ form.startTime.vars.id }}').value;
    const endTime = document.getElementById('{{ form.endTime.vars.id }}').value;
    const quantity = document.getElementById('{{ form.quantity.vars.id }}').value;
    const resourceSelect = document.getElementById('resourceSelect').value;
    
    // Validation plus stricte pour le mode édition
    if (!resourceType || resourceType.trim() === '') {
        errors.push('Veuillez sélectionner un type de ressource');
    }
    
    if (!startTime || startTime.trim() === '') {
        errors.push('Veuillez sélectionner une date de début');
    }
    
    if (!endTime || endTime.trim() === '') {
        errors.push('Veuillez sélectionner une date de fin');
    }
    
    if (startTime && endTime && new Date(startTime) >= new Date(endTime)) {
        errors.push('La date de fin doit être postérieure à la date de début');
    }
    
    if (!quantity || quantity < 1 || quantity.trim() === '') {
        errors.push('La quantité doit être supérieure à 0');
    }
    
    // Pour la ressource, vérifier si une ressource est sélectionnée OU si les champs cachés ont des valeurs
    const salleField = document.getElementById('{{ form.salle.vars.id }}');
    const equipementField = document.getElementById('{{ form.equipement.vars.id }}');
    const hasSalle = salleField && salleField.value && salleField.value !== '';
    const hasEquipement = equipementField && equipementField.value && equipementField.value !== '';
    
    if (!resourceSelect && !hasSalle && !hasEquipement) {
        errors.push('Veuillez sélectionner une ressource');
    }
    
    return errors;
}

// Fonction pour afficher les erreurs avec animation
function showErrors(errors) {
    const alertContainer = document.getElementById('alertContainer');
    
    // Créer l'alerte
    const alert = document.createElement('div');
    alert.style.cssText = `
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3);
        margin-bottom: 10px;
        transform: translateY(-100px);
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid rgba(255, 255, 255, 0.2);
    `;
    
    const icon = document.createElement('i');
    icon.className = 'fas fa-exclamation-triangle';
    icon.style.marginRight = '10px';
    
    const title = document.createElement('strong');
    title.textContent = 'Erreurs de validation : ';
    
    const message = document.createElement('div');
    message.style.marginTop = '8px';
    message.innerHTML = errors.map(error => `• ${error}`).join('<br>');
    
    alert.appendChild(icon);
    alert.appendChild(title);
    alert.appendChild(message);
    
    // Ajouter au conteneur
    alertContainer.appendChild(alert);
    
    // Animation d'entrée
    setTimeout(() => {
        alert.style.transform = 'translateY(0)';
    }, 100);
    
    // Animation de sortie après 5 secondes
    setTimeout(() => {
        alert.style.transform = 'translateY(-100px)';
        alert.style.opacity = '0';
        setTimeout(() => {
            if (alert.parentNode) {
                alert.parentNode.removeChild(alert);
            }
        }, 400);
    }, 5000);
    
    // Cliquer pour fermer
    alert.addEventListener('click', () => {
        alert.style.transform = 'translateY(-100px)';
        alert.style.opacity = '0';
        setTimeout(() => {
            if (alert.parentNode) {
                alert.parentNode.removeChild(alert);
            }
        }, 400);
    });
}

</script>

{% endblock %}
