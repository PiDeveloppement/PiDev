{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Modifier budget' : 'Nouveau budget' }} - EventFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# FIX TURBO: force full reload sur cette page #}
    <meta name="turbo-visit-control" content="reload">
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}">
{% endblock %}

{% block admin_content %}
<div class="sponsor-page budget-page">
    <section class="budget-form-shell">
        <div class="budget-form-side">
            <span class="budget-kicker">{{ isEdit ? 'Mise a jour' : 'Creation' }}</span>
            <h2>{{ isEdit ? 'Modifier un budget' : 'Creer un nouveau budget' }}</h2>
            <p>Renseignez les montants de base, associez le budget a un evenement et gardez une structure propre pour le suivi.</p>

            <div class="budget-form-note">
                <strong>Conseil</strong>
                <span>Le budget initial sert de reference visuelle sur toute la gestion budget et depense.</span>
            </div>
        </div>

        <div class="budget-form-card-modern">
            <div class="budget-section-head compact">
                <div>
                    <h3>{{ isEdit ? 'Edition du budget' : 'Formulaire budget' }}</h3>
                    <p>{{ isEdit ? 'Mettez a jour les informations du budget existant.' : 'Ajoutez un budget clair et bien structure.' }}</p>
                </div>
            </div>

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
            <div class="budget-form-grid">
                <div class="budget-field full">
                    {{ form_label(form.eventId) }}
                    {{ form_widget(form.eventId) }}
                    {{ form_errors(form.eventId) }}
                </div>

                <div class="budget-field">
                    {{ form_label(form.initialBudget) }}
                    {{ form_widget(form.initialBudget) }}
                    {{ form_errors(form.initialBudget) }}
                    {{ form_label(form.initialBudgetCurrency) }}
                    {{ form_widget(form.initialBudgetCurrency) }}
                    {{ form_errors(form.initialBudgetCurrency) }}
                    <small class="field-help">Equivalent TND: <span id="initial-budget-tnd">-</span></small>
                </div>

                <div class="budget-field">
                    {{ form_label(form.totalRevenue) }}
                    {{ form_widget(form.totalRevenue) }}
                    {{ form_errors(form.totalRevenue) }}
                    {{ form_label(form.totalRevenueCurrency) }}
                    {{ form_widget(form.totalRevenueCurrency) }}
                    {{ form_errors(form.totalRevenueCurrency) }}
                    <small class="field-help">Equivalent TND: <span id="total-revenue-tnd">-</span></small>
                </div>
            </div>

            <div class="sponsor-form-footer budget-form-footer">
                <a class="btn-sponsor outline" href="{{ path('app_budget_index') }}">Annuler</a>
                <button class="btn-sponsor success" type="submit">{{ isEdit ? 'Enregistrer les modifications' : 'Creer le budget' }}</button>
            </div>
            {{ form_end(form) }}
        </div>
    </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const initialAmount = document.getElementById('{{ form.initialBudget.vars.id }}');
    const initialCurrency = document.getElementById('{{ form.initialBudgetCurrency.vars.id }}');
    const initialOut = document.getElementById('initial-budget-tnd');

    const revenueAmount = document.getElementById('{{ form.totalRevenue.vars.id }}');
    const revenueCurrency = document.getElementById('{{ form.totalRevenueCurrency.vars.id }}');
    const revenueOut = document.getElementById('total-revenue-tnd');

    const renderAmount = function (target, value) {
        if (!target) {
            return;
        }

        if (value === null) {
            target.textContent = '-';
            return;
        }

        target.textContent = Number(value).toLocaleString('fr-FR', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }) + ' DT';
    };

    const updatePreview = async function (amountInput, currencyInput, outputTarget) {
        if (!amountInput || !currencyInput || !outputTarget) {
            return;
        }

        const amount = parseFloat(String(amountInput.value || '').replace(',', '.'));
        const from = currencyInput.value || 'TND';

        if (!Number.isFinite(amount) || amount <= 0) {
            renderAmount(outputTarget, null);
            return;
        }

        if (from === 'TND') {
            renderAmount(outputTarget, amount);
            return;
        }

        try {
            const url = `{{ path('app_currency_convert') }}?amount=${encodeURIComponent(String(amount))}&from=${encodeURIComponent(from)}&to=TND`;
            const response = await fetch(url);
            const payload = await response.json();

            if (!response.ok || !payload.ok) {
                renderAmount(outputTarget, null);
                return;
            }

            renderAmount(outputTarget, payload.converted);
        } catch (error) {
            renderAmount(outputTarget, null);
        }
    };

    const bind = function (amountInput, currencyInput, outputTarget) {
        if (!amountInput || !currencyInput) {
            return;
        }

        const handler = function () {
            updatePreview(amountInput, currencyInput, outputTarget);
        };

        amountInput.addEventListener('input', handler);
        currencyInput.addEventListener('change', handler);
        handler();
    };

    bind(initialAmount, initialCurrency, initialOut);
    bind(revenueAmount, revenueCurrency, revenueOut);
});
</script>
{% endblock %}