<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    (function () {
        const chartCanvas = document.getElementById('portalFxChart');
        const currencySelect = document.getElementById('portalFxCurrency');
        const refreshButton = document.getElementById('portalFxRefresh');
        const pairLabel = document.getElementById('portalFxPairLabel');
        const emptyState = document.getElementById('portalFxEmpty');
        const updatedAt = document.getElementById('portalFxUpdatedAt');
        const rateCards = Array.from(document.querySelectorAll('.portal-fx-rate-item[data-fx-currency]'));

        if (!currencySelect || !updatedAt) {
            return;
        }

        let fxChart = null;

        const formatRate = function (value, precision) {
            return Number(value).toLocaleString('fr-FR', {
                minimumFractionDigits: precision,
                maximumFractionDigits: precision
            });
        };

        const formatDateTime = function (value) {
            if (!value) {
                return '-';
            }

            const dt = new Date(value);
            if (Number.isNaN(dt.getTime())) {
                return '-';
            }

            return dt.toLocaleString('fr-FR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
            });
        };

        const setActiveCard = function () {
            const selected = currencySelect.value || 'EUR';
            rateCards.forEach(function (card) {
                card.classList.toggle('active', card.dataset.fxCurrency === selected);
            });
        };

        const renderFxHistoryChart = function (labels, rates, currency) {
            if (!chartCanvas || typeof Chart === 'undefined') {
                return;
            }

            if (fxChart) {
                fxChart.destroy();
            }

            const ctx = chartCanvas.getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 230);
            gradient.addColorStop(0, 'rgba(37, 99, 235, 0.28)');
            gradient.addColorStop(1, 'rgba(37, 99, 235, 0.04)');

            fxChart = new Chart(chartCanvas, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        data: rates,
                        borderColor: '#2563eb',
                        backgroundColor: gradient,
                        fill: true,
                        borderWidth: 2.4,
                        tension: 0.32,
                        pointRadius: 2.4,
                        pointHoverRadius: 5,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#2563eb',
                        pointBorderWidth: 1.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    return ` 1 ${currency} = ${Number(ctx.raw).toFixed(4)} TND`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        },
                        y: {
                            grid: { color: '#e2e8f0' },
                            ticks: {
                                color: '#64748b',
                                callback: function (value) {
                                    return Number(value).toFixed(3);
                                }
                            }
                        }
                    }
                }
            });
        };

        const loadHistoryForSelected = async function () {
            const currency = currencySelect.value || 'EUR';

            if (pairLabel) {
                pairLabel.textContent = `1 ${currency} = ? TND`;
            }

            if (emptyState) {
                emptyState.style.display = 'none';
            }

            if (typeof Chart === 'undefined') {
                if (emptyState) {
                    emptyState.textContent = 'Bibliotheque graphique indisponible.';
                    emptyState.style.display = 'block';
                }
                return;
            }

            try {
                const url = `{{ path('app_currency_history') }}?from=${encodeURIComponent(currency)}&to=TND&days=7`;
                const response = await fetch(url);
                const payload = await response.json();

                if (!response.ok || !payload.ok || !Array.isArray(payload.labels) || !Array.isArray(payload.rates)) {
                    throw new Error('Invalid history payload');
                }

                renderFxHistoryChart(payload.labels, payload.rates, currency);

                if (pairLabel && payload.rates.length > 0) {
                    const latestRate = Number(payload.rates[payload.rates.length - 1]);
                    pairLabel.textContent = `1 ${currency} = ${formatRate(latestRate, 4)} TND`;
                }
            } catch (error) {
                if (fxChart) {
                    fxChart.destroy();
                    fxChart = null;
                }
                if (emptyState) {
                    emptyState.textContent = 'Impossible de charger l historique pour la devise selectionnee.';
                    emptyState.style.display = 'block';
                }
            }
        };

        const loadRateForCard = async function (card) {
            const code = card.dataset.fxCurrency || 'EUR';
            const valueNode = card.querySelector('[data-fx-value]');
            if (!valueNode) {
                return null;
            }

            card.classList.remove('error');
            valueNode.classList.add('loading');
            valueNode.textContent = 'Chargement...';

            try {
                const url = `{{ path('app_currency_rate') }}?from=${encodeURIComponent(code)}&to=TND`;
                const response = await fetch(url);
                const payload = await response.json();

                if (!response.ok || !payload.ok || !Number.isFinite(Number(payload.rate))) {
                    throw new Error('Invalid rate payload');
                }

                valueNode.classList.remove('loading');
                valueNode.textContent = `${formatRate(payload.rate, 4)} TND`;
                return payload.fetchedAt || null;
            } catch (error) {
                card.classList.add('error');
                valueNode.classList.remove('loading');
                valueNode.textContent = '--';
                return null;
            }
        };

        const refreshRateCards = async function () {
            const timestamps = await Promise.all(rateCards.map(loadRateForCard));
            setActiveCard();

            const parsedTimes = timestamps
                .map(function (value) { return value ? Date.parse(value) : NaN; })
                .filter(function (value) { return !Number.isNaN(value); });

            if (parsedTimes.length > 0) {
                const maxTs = Math.max.apply(null, parsedTimes);
                updatedAt.textContent = `Derniere mise a jour: ${formatDateTime(new Date(maxTs).toISOString())}`;
            } else {
                updatedAt.textContent = 'Derniere mise a jour: indisponible';
            }
        };

        const refreshFxPanel = async function () {
            if (refreshButton) {
                refreshButton.disabled = true;
                refreshButton.textContent = '? Chargement...';
            }

            await Promise.all([
                loadHistoryForSelected(),
                refreshRateCards()
            ]);

            if (refreshButton) {
                refreshButton.disabled = false;
                refreshButton.textContent = '?? Actualiser';
            }
        };

        if (currencySelect) {
            currencySelect.addEventListener('change', refreshFxPanel);
        }

        if (refreshButton) {
            refreshButton.addEventListener('click', refreshFxPanel);
        }

        rateCards.forEach(function (card) {
            card.addEventListener('click', function () {
                const code = card.dataset.fxCurrency || 'EUR';
                currencySelect.value = code;
                refreshFxPanel();
            });
        });

        refreshFxPanel();
    })();
</script>
<div id="google_translate_element" style="display:none;"></div>
<script>
    (function () {
        const toggle = document.getElementById('portalTranslateToggle');
        const menu = document.getElementById('portalTranslateMenu');
        const widget = document.getElementById('portalTranslateWidget');

        const setTranslateCookie = function (value) {
            const host = window.location.hostname;
            document.cookie = 'googtrans=' + value + ';path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=' + value + ';path=/;domain=.' + host;
            }
        };

        const clearTranslateCookie = function () {
            const host = window.location.hostname;
            document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + host;
            }
        };

        if (toggle && menu) {
            toggle.addEventListener('click', function () {
                menu.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!widget || widget.contains(event.target)) {
                    return;
                }
                menu.classList.remove('open');
            });

            menu.querySelectorAll('[data-lang]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const lang = button.getAttribute('data-lang') || 'en';
                    if (lang === 'original') {
                        clearTranslateCookie();
                    } else {
                        setTranslateCookie(lang === 'fr' ? '/fr/fr' : '/fr/' + lang);
                    }
                    window.location.reload();
                });
            });
        }
    })();

    function googleTranslateElementInit() {
        if (!window.google || !window.google.translate || !window.google.translate.TranslateElement) {
            return;
        }

        new window.google.translate.TranslateElement({
            pageLanguage: 'fr',
            includedLanguages: 'fr,en,ar,es,de,it',
            autoDisplay: false,
            multilanguagePage: true
        }, 'google_translate_element');
    }
</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
