<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recommandations sponsor - EventFlow</title>
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}?v=20260416-ia-focus">
    <style>
        /* Navbar aligned with landing dimensions */
        .portal-navbar {
            height: 80px;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .portal-logo-wrap img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }

        .portal-nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }

        .portal-nav-link {
            font-size: 16px;
            font-weight: 500;
        }

        .portal-account-menu {
            position: relative;
            top: -4px;
            display: inline-flex;
            align-items: center;
        }

        .portal-account-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .portal-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .portal-account-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
        }

        .portal-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255, 255, 255, 0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .portal-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .portal-account-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .portal-account-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.84);
        }

        .portal-account-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 180px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .portal-account-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
            border: none;
            background: transparent;
            text-align: left;
            cursor: pointer;
        }

        .portal-account-action:hover {
            background: #f3f7fd;
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            position: relative;
            top: -4px;
        }

        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: 700;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }

        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }

        .portal-translate {
            position: relative;
            top: -4px;
            margin-right: 12px;
        }

        .portal-translate-btn {
            border: none;
            border-radius: 999px;
            padding: 8px 14px;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 18px rgba(22, 163, 74, 0.3);
        }

        .portal-translate-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 180px;
            background: #fff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            display: none;
            z-index: 1400;
        }

        .portal-translate-menu.open {
            display: block;
        }

        .portal-translate-opt {
            width: 100%;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            border-radius: 8px;
            padding: 8px 10px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 6px;
        }

        .portal-translate-opt:last-child {
            margin-bottom: 0;
        }

        .portal-page {
            margin-top: 80px;
        }
    </style>
</head>
