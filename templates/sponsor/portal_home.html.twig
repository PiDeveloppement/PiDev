        <form class="portal-search" method="get" action="{{ path('app_sponsor_portal') }}">
            <div class="portal-search-main">
                <input type="text" name="q" value="{{ search|default('') }}" placeholder="Rechercher un evenement..." autocomplete="off" list="events-list" data-sponsor-suggest>
                <datalist id="events-list"></datalist>
            <select name="sort" onchange="this.form.requestSubmit()">
            <option value="date_asc" {{ sort == 'date_asc' ? 'selected' : '' }}>Tri: Date proche</option>
            <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Tri: Date lointaine</option>
            <option value="title_asc" {{ sort == 'title_asc' ? 'selected' : '' }}>Tri: Titre A-Z</option>
            <option value="title_desc" {{ sort == 'title_desc' ? 'selected' : '' }}>Tri: Titre Z-A</option>
            <option value="location_asc" {{ sort == 'location_asc' ? 'selected' : '' }}>Tri: Lieu</option>
            </select>
        </div>
        {% if isSponsorSession %}
            <select name="my_sort" onchange="this.form.requestSubmit()">
                <option value="recent" {{ mySort == 'recent' ? 'selected' : '' }}>Mes partenariats: recents</option>
                <option value="amount_desc" {{ mySort == 'amount_desc' ? 'selected' : '' }}>Montant decroissant</option>
                <option value="amount_asc" {{ mySort == 'amount_asc' ? 'selected' : '' }}>Montant croissant</option>
                <option value="company_asc" {{ mySort == 'company_asc' ? 'selected' : '' }}>Entreprise A-Z</option>
            </select>
        {% endif %}
        <button type="submit">Rechercher</button>
        {% if search is defined and search is not empty %}
            <a href="{{ path('app_sponsor_portal') }}">Reinitialiser</a>
        {% endif %}
    </form>

    <script>
        (function () {
            const input = document.querySelector('[data-sponsor-suggest]');
            const list = document.getElementById('events-list');
            if (!input || !list) return;

            let controller = null;
            const minChars = 1;

            const clearList = () => {
                list.innerHTML = '';
            };

            const fetchSuggestions = async (value) => {
                if (controller) {
                    controller.abort();
                }
                controller = new AbortController();

                const url = `{{ path('app_sponsor_portal_suggestions') }}?q=${encodeURIComponent(value)}`;
                const response = await fetch(url, { signal: controller.signal });
                if (!response.ok) return [];
                return response.json();
            };

            input.addEventListener('input', async (event) => {
                const value = event.target.value.trim();
                if (value.length < minChars) {
                    clearList();
                    return;
                }

                try {
                    const items = await fetchSuggestions(value);
                    clearList();
                    items.forEach((item) => {
                        const option = document.createElement('option');
                        option.value = item.title || '';
                        option.textContent = item.location ? `${item.title} - ${item.location}` : item.title;
                        list.appendChild(option);
                    });
                } catch (error) {
                    clearList();
                }
            });
        })();
    </script>

    {# Section Événements recommandés - version moderne et prioritaire #}
    <section class="portal-box portal-box-recommendations ai-reco-spotlight">
        <div class="reco-header">
            <div class="reco-header-text">
                <span class="reco-header-icon">✨</span>
                <div>
                    <h2 class="reco-header-title">Événements recommandés</h2>
                    <p class="reco-header-subtitle">Priorité IA basée sur votre secteur et vos habitudes de sponsoring</p>
                </div>
            </div>
            <div class="reco-priority-badge">Section prioritaire</div>
        </div>

        <div class="reco-focus-bar">
            <span class="reco-focus-chip">Moteur IA actif</span>
            <span class="reco-focus-chip light">{{ recommendedEvents|length }} recommandations triees</span>
        </div>

        {% if recommendedEvents is empty %}
            <div class="portal-box-empty">Aucune recommandation disponible pour le moment.</div>
        {% else %}
            <div class="reco-grid">
                {% for event in recommendedEvents %}
                    {# Détermination du type et de l'image par défaut (inchangé) #}
                    {% set t = event.title|lower %}
                    {% set contextText = (event.title ~ ' ' ~ (event.description ?: ''))|lower %}
                    {% set type = 'Conference' %}
                    {% set cls = 'conference' %}
                    {% set mood = event.title|split(' ')|slice(0, 4)|join(' ') %}
                    {% set defaultImage = 'conference.jfif' %}
                    {% if 'atelier' in t %}
                        {% set type = 'Atelier' %}
                        {% set cls = 'atelier' %}
                        {% set mood = 'Atelier pratique' %}
                        {% set defaultImage = 'atelier.jfif' %}
                    {% elseif 'seminaire' in t or 'séminaire' in t %}
                        {% set type = 'Seminaire' %}
                        {% set cls = 'seminaire' %}
                        {% set mood = 'Prise de parole' %}
                        {% set defaultImage = 'formation.jfif' %}
                    {% elseif 'formation' in t %}
                        {% set type = 'Formation' %}
                        {% set cls = 'formation' %}
                        {% set mood = 'Montee en competences' %}
                        {% set defaultImage = 'formation.jfif' %}
                    {% elseif 'workshop' in t %}
                        {% set type = 'Workshop' %}
                        {% set cls = 'workshop' %}
                        {% set mood = 'Session workshop' %}
                        {% set defaultImage = 'atelier.jfif' %}
                    {% elseif 'carriere' in t or 'career' in t or 'emploi' in t %}
                        {% set type = 'Carriere' %}
                        {% set cls = 'carriere' %}
                        {% set mood = 'Projection professionnelle' %}
                        {% set defaultImage = 'conference.jfif' %}
                    {% endif %}

                    {% if 'ia' in contextText or 'ai' in contextText %}
                        {% set mood = 'Contexte IA' %}
                    {% elseif 'cyber' in contextText or 'securite' in contextText %}
                        {% set mood = 'Contexte cybersecurite' %}
                    {% elseif 'data' in contextText %}
                        {% set mood = 'Contexte data science' %}
                    {% elseif 'fintech' in contextText or 'finance' in contextText %}
                        {% set mood = 'Contexte fintech' %}
                    {% elseif 'java' in contextText %}
                        {% set mood = 'Contexte developpement Java' %}
                    {% elseif 'robot' in contextText %}
                        {% set mood = 'Contexte robotique' %}
                    {% elseif 'hackathon' in contextText %}
                        {% set mood = 'Contexte innovation terrain' %}
                    {% endif %}

                    <article class="reco-card {{ cls }}">
                        <div class="reco-rank-badge">Top {{ loop.index }}</div>
                        <img class="reco-card-image" src="{{ asset('images/' ~ event.title ~ '.jpg') }}" alt="{{ event.title }}" onerror="this.src=&quot;{{ asset('images/sponsor-cards/' ~ defaultImage) }}&quot;">
                        <div class="reco-card-content">
                            <div class="reco-card-top">
                                <span class="reco-type-badge {{ cls }}">{{ type }}</span>
                                <span class="reco-mood">{{ mood }}</span>
                            </div>
                            <h3 class="reco-card-title">{{ event.title }}</h3>
                            <p class="reco-card-description">{{ event.description ?: "Cet événement fait partie des rendez-vous les plus suivis et attractifs du moment."|slice(0, 100) ~ '…' }}</p>
                            <div class="reco-card-meta">
                                <div class="reco-meta-item">
                                    <span class="reco-meta-icon">📅</span>
                                    <span>{{ event.startDate ? event.startDate|date("d-m-Y") : "-" }}</span>
                                </div>
                                <div class="reco-meta-item">
                                    <span class="reco-meta-icon">📍</span>
                                    <span>{{ event.location ?: "-" }}</span>
                                </div>
                            </div>
                            <div class="reco-card-actions">
                                <a class="reco-btn-outline" href="{{ path('app_sponsor_portal_event', {id: event.id}) }}">Voir détails</a>
                                <a class="reco-btn-primary" href="{{ path('app_sponsor_portal_sponsorize', {id: event.id}) }}">Sponsoriser</a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <section class="portal-box">
        <div class="portal-box-head portal-box-head-catalog">🎯 Catalogue des evenements a soutenir</div>
        {% if sponsorableEvents is empty %}
            <div class="portal-box-empty">Aucun evenement disponible pour le moment.</div>
        {% else %}
            <div class="portal-catalog-grid">
                {% for event in sponsorableEvents %}
                    {% set t = event.title|lower %}
                    {% set contextText = (event.title ~ ' ' ~ (event.description ?: ''))|lower %}
                    {% set type = 'Conference' %}
                    {% set cls = 'conference' %}
                    {% set mood = event.title|split(' ')|slice(0, 4)|join(' ') %}
                    {% set defaultImage = 'conference.jfif' %}
                    {% if 'atelier' in t %}
                        {% set type = 'Atelier' %}
                        {% set cls = 'atelier' %}
                        {% set mood = 'Atelier pratique' %}
                        {% set defaultImage = 'atelier.jfif' %}
                    {% elseif 'seminaire' in t or 'séminaire' in t %}
                        {% set type = 'Seminaire' %}
                        {% set cls = 'seminaire' %}
                        {% set mood = 'Prise de parole' %}
                        {% set defaultImage = 'formation.jfif' %}
                    {% elseif 'formation' in t %}
                        {% set type = 'Formation' %}
                        {% set cls = 'formation' %}
                        {% set mood = 'Montee en competences' %}
                        {% set defaultImage = 'formation.jfif' %}
                    {% elseif 'workshop' in t %}
                        {% set type = 'Workshop' %}
                        {% set cls = 'workshop' %}
                        {% set mood = 'Session workshop' %}
                        {% set defaultImage = 'atelier.jfif' %}
                    {% elseif 'carriere' in t or 'career' in t or 'emploi' in t %}
                        {% set type = 'Carriere' %}
                        {% set cls = 'carriere' %}
                        {% set mood = 'Orientation et avenir' %}
                        {% set defaultImage = 'conference.jfif' %}
                    {% endif %}

                    {% if 'ia' in contextText or 'ai' in contextText %}
                        {% set mood = 'Contexte IA' %}
                    {% elseif 'cyber' in contextText or 'securite' in contextText %}
                        {% set mood = 'Contexte cybersecurite' %}
                    {% elseif 'data' in contextText %}
                        {% set mood = 'Contexte data science' %}
                    {% elseif 'fintech' in contextText or 'finance' in contextText %}
                        {% set mood = 'Contexte fintech' %}
                    {% elseif 'java' in contextText %}
                        {% set mood = 'Contexte developpement Java' %}
                    {% elseif 'robot' in contextText %}
                        {% set mood = 'Contexte robotique' %}
                    {% elseif 'hackathon' in contextText %}
                        {% set mood = 'Contexte innovation terrain' %}
                    {% endif %}

                    <article class="portal-event-card {{ cls }} {{ loop.index == 3 ? 'highlight' : '' }}" data-live-search-item data-search="{{ event.title }}" data-live-suggest="{{ event.title }}">
                        <img class="portal-event-visual" src="{{ asset('images/' ~ event.title ~ '.jpg') }}" alt="{{ event.title }}" onerror="this.src=&quot;{{ asset('images/sponsor-cards/' ~ defaultImage) }}&quot;">
                        <div class="portal-event-content">
                            <div class="portal-event-topline">
                                <span class="portal-badge {{ cls }}">{{ type }}</span>
                                <span class="portal-event-mood">{{ mood }}</span>
                            </div>
                            <h3 class="portal-event-title">{{ event.title }}</h3>
                            <p class="portal-event-description">{{ event.description ?: "Une occasion pour soutenir la vie universitaire, valoriser les talents et renforcer votre presence." }}</p>

                            <div class="portal-event-meta-row">
                                <div class="portal-event-meta"><span class="portal-event-label">📅 Date:</span> {{ event.startDate ? event.startDate|date("d-m-Y") : "-" }}</div>
                                <div class="portal-event-meta"><span class="portal-event-label">📍 Lieu:</span> {{ event.location ?: "-" }}</div>
                            </div>
                            <div class="portal-card-actions">
                                <a class="portal-btn-secondary" href="{{ path('app_sponsor_portal_event', {id: event.id}) }}">Voir details</a>
                                <a class="portal-btn-sponso" href="{{ path('app_sponsor_portal_sponsorize', {id: event.id}) }}">💼 Sponsoriser cet événement</a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <!-- Section Statistiques Visuelles -->
    <section class="portal-stats-showcase">
        <h2 class="portal-section-title">Pourquoi EventFlow?</h2>
        <div class="stats-showcase-grid">
            <div class="stat-showcase-card">
                <div class="stat-showcase-icon">🌍</div>
                <h3>Portée nationale</h3>
                <p>Acces a plus de 100+ evenements dans toute la Tunisie</p>
                <div class="stat-showcase-number">{{ eventCounts.total }}+</div>
            </div>
            <div class="stat-showcase-card">
                <div class="stat-showcase-icon">🤝</div>
                <h3>Partenariats solides</h3>
                <p>Connectez-vous avec des organisateurs fiables et verifies</p>
                <div class="stat-showcase-number">500+</div>
            </div>
            <div class="stat-showcase-card">
                <div class="stat-showcase-icon">💼</div>
                <h3>Opportunites B2B</h3>
                <p>Construisez votre reseau professionnel et commercial</p>
                <div class="stat-showcase-number">1000+</div>
            </div>
            <div class="stat-showcase-card">
                <div class="stat-showcase-icon">📊</div>
                <h3>Suivi en temps reel</h3>
                <p>Tableau de bord complet pour gerer vos partenariats</p>
                <div class="stat-showcase-number">100%</div>
            </div>
        </div>
    </section>

</main>
<div id="google_translate_element" style="display:none;"></div>
<script>
    (function () {
        const toggle = document.getElementById('portalTranslateToggle');
        const menu = document.getElementById('portalTranslateMenu');
        const widget = document.getElementById('portalTranslateWidget');

        const setTranslateCookie = function (value) {
            const host = window.location.hostname;
            document.cookie = 'googtrans=' + value + ';path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=' + value + ';path=/;domain=.' + host;
            }
        };

        if (toggle && menu) {
            toggle.addEventListener('click', function () {
                menu.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!widget || widget.contains(event.target)) {
                    return;
                }
                menu.classList.remove('open');
            });

            menu.querySelectorAll('[data-lang]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const lang = button.getAttribute('data-lang') || 'en';
                    setTranslateCookie(lang === 'fr' ? '/fr/fr' : '/fr/' + lang);
                    window.location.reload();
                });
            });
        }
    })();

    function googleTranslateElementInit() {
        if (!window.google || !window.google.translate || !window.google.translate.TranslateElement) {
            return;
        }

        new window.google.translate.TranslateElement({
            pageLanguage: 'fr',
            includedLanguages: 'fr,en,ar,es,de,it',
            autoDisplay: false,
            multilanguagePage: true
        }, 'google_translate_element');
    }
</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
