<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recommandations sponsor - EventFlow</title>
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}?v=20260416-ia-focus">
    <style>
        /* Navbar aligned with landing dimensions */
        .portal-navbar {
            height: 80px;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .portal-logo-wrap img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }

        .portal-nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }

        .portal-nav-link {
            font-size: 16px;
            font-weight: 500;
        }

        .portal-account-menu {
            position: relative;
            top: -4px;
            display: inline-flex;
            align-items: center;
        }

        .portal-account-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .portal-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .portal-account-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
        }

        .portal-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255, 255, 255, 0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .portal-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .portal-account-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .portal-account-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.84);
        }

        .portal-account-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 180px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .portal-account-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
            border: none;
            background: transparent;
            text-align: left;
            cursor: pointer;
        }

        .portal-account-action:hover {
            background: #f3f7fd;
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            position: relative;
            top: -4px;
        }

        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: 700;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }

        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }

        .portal-translate {
            position: relative;
            top: -4px;
            margin-right: 12px;
        }

        .portal-translate-btn {
            border: none;
            border-radius: 999px;
            padding: 8px 14px;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 18px rgba(22, 163, 74, 0.3);
        }

        .portal-translate-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 180px;
            background: #fff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            display: none;
            z-index: 1400;
        }

        .portal-translate-menu.open {
            display: block;
        }

        .portal-translate-opt {
            width: 100%;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            border-radius: 8px;
            padding: 8px 10px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 6px;
        }

        .portal-translate-opt:last-child {
            margin-bottom: 0;
        }

        .portal-page {
            margin-top: 80px;
        }

        .portal-fx-premium {
            margin: 16px 0 18px;
            border: 1px solid #d4e4fb;
            border-radius: 20px;
            padding: 14px;
            background:
                radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.14), transparent 34%),
                radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.12), transparent 32%),
                linear-gradient(145deg, #f9fcff 0%, #f7fbff 55%, #f4fff8 100%);
            box-shadow: 0 16px 30px rgba(15, 23, 42, 0.09);
        }

        .portal-fx-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .portal-fx-head h2 {
            margin: 0;
            color: #0f172a;
            font-size: 20px;
            letter-spacing: -0.3px;
        }

        .portal-fx-head p {
            margin: 4px 0 0;
            color: #475569;
            font-size: 13px;
        }

        .portal-fx-controls {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .portal-fx-controls label {
            color: #1e3a8a;
            font-weight: 700;
            font-size: 12px;
        }

        .portal-fx-controls select {
            border: 1px solid #b8cef1;
            border-radius: 9px;
            min-height: 36px;
            padding: 0 9px;
            color: #0f172a;
            font-weight: 700;
            background: #ffffff;
            outline: none;
            font-size: 13px;
        }

        .portal-fx-controls button {
            border: none;
            border-radius: 9px;
            min-height: 36px;
            padding: 0 11px;
            color: #ffffff;
            font-weight: 700;
            font-size: 13px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            cursor: pointer;
            box-shadow: 0 8px 14px rgba(37, 99, 235, 0.23);
        }

        .portal-fx-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.38fr) minmax(260px, 0.9fr);
            gap: 10px;
        }

        .portal-fx-chart-card,
        .portal-fx-rates-card {
            border: 1px solid #d7e5f8;
            border-radius: 14px;
            background: #ffffff;
            box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
            padding: 10px;
        }

        .portal-fx-pair {
            color: #1d4ed8;
            font-weight: 800;
            font-size: 14px;
            margin-bottom: 6px;
        }

        .portal-fx-chart-wrap {
            position: relative;
            height: 180px;
        }

        .portal-fx-empty {
            display: none;
            margin-top: 10px;
            border-radius: 10px;
            border: 1px dashed #f59e0b;
            background: #fff7ed;
            color: #9a3412;
            padding: 9px 10px;
            font-size: 12px;
            font-weight: 700;
        }

        .portal-fx-rates-card h3 {
            margin: 0;
            color: #0f172a;
            font-size: 15px;
        }

        .portal-fx-rates-grid {
            margin-top: 8px;
            display: grid;
            gap: 7px;
        }

        .portal-fx-rate-item {
            border: 1px solid #d9e5f8;
            border-radius: 10px;
            padding: 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            background: linear-gradient(180deg, #ffffff, #f8fbff);
            transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
            cursor: pointer;
        }

        .portal-fx-rate-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(15, 23, 42, 0.10);
        }

        .portal-fx-rate-item.active {
            border-color: #3b82f6;
            background: linear-gradient(180deg, #eff6ff, #ffffff);
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.20);
        }

        .portal-fx-rate-item.error {
            border-color: #fca5a5;
            background: linear-gradient(180deg, #fff1f2, #ffffff);
        }

        .portal-fx-rate-left {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .portal-fx-code {
            color: #0f172a;
            font-size: 12px;
            font-weight: 800;
        }

        .portal-fx-caption {
            color: #64748b;
            font-size: 10px;
            font-weight: 600;
        }

        .portal-fx-value {
            color: #0f172a;
            font-size: 13px;
            font-weight: 800;
            text-align: right;
            white-space: nowrap;
        }

        .portal-fx-value.loading {
            color: #64748b;
        }

        .portal-fx-updated {
            margin: 8px 0 0;
            color: #64748b;
            font-size: 11px;
            font-weight: 600;
        }

        @media (max-width: 1024px) {
            .portal-fx-grid {
                grid-template-columns: 1fr;
            }

            .portal-fx-chart-wrap {
                height: 170px;
            }
        }

        /* Force compact mode when catalog has only one card */
        .portal-catalog-grid.single-card-force {
            display: flex !important;
            justify-content: flex-start !important;
            align-items: stretch !important;
            gap: 12px !important;
            width: 100%;
        }

        .portal-catalog-grid.single-card-force .portal-event-card {
            flex: 0 0 320px !important;
            width: 320px !important;
            max-width: 320px !important;
            min-height: 0 !important;
        }

        .portal-catalog-grid.single-card-force .portal-event-visual {
            height: 160px !important;
        }

        .portal-catalog-grid.single-card-force .portal-card-actions {
            justify-content: flex-start !important;
            gap: 8px !important;
        }

        @media (max-width: 768px) {
            .portal-catalog-grid.single-card-force {
                display: grid !important;
                grid-template-columns: 1fr !important;
            }

            .portal-catalog-grid.single-card-force .portal-event-card {
                width: 100% !important;
                max-width: none !important;
                flex: 1 1 auto !important;
            }
        }
    </style>
</head>
<body class="portal-body">
<nav class="portal-navbar">
    <div class="portal-logo-wrap">
        <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
    </div>

    <div class="portal-nav-links">
        <a class="portal-nav-link" href="{{ path('app_landing') }}">Accueil</a>
        <a class="portal-nav-link" href="{{ path('app_public_events') }}">Evenements</a>
        <a class="portal-nav-link active" href="{{ path('app_sponsor_portal') }}">Recommandations sponsor</a>
        <a class="portal-nav-link" href="{{ path('app_landing') }}#features">Fonctionnalites</a>
        <a class="portal-nav-link" href="{{ path('app_feedback_view') }}">Feedback</a>
        <a class="portal-nav-link" href="{{ path('app_landing') }}#contact">Contact</a>
    </div>

    <div style="display:flex; align-items:center;">
        <div class="portal-translate" id="portalTranslateWidget">
            <button type="button" class="portal-translate-btn" id="portalTranslateToggle"><i class="fas fa-language"></i> Traduire</button>
            <div class="portal-translate-menu" id="portalTranslateMenu">
                <button type="button" class="portal-translate-opt" data-lang="original">Originale (sans traduction)</button>
                <button type="button" class="portal-translate-opt" data-lang="fr">Francais</button>
                <button type="button" class="portal-translate-opt" data-lang="en">English</button>
                <button type="button" class="portal-translate-opt" data-lang="ar">Arabic</button>
                <button type="button" class="portal-translate-opt" data-lang="es">Espanol</button>
                <button type="button" class="portal-translate-opt" data-lang="de">Deutsch</button>
                <button type="button" class="portal-translate-opt" data-lang="it">Italiano</button>
            </div>
        </div>
        {% if app.user %}
            <details class="portal-account-menu">
                <summary class="portal-account-chip">
                    <span class="portal-account-avatar">{{ app.user.initials ?: (app.user.fullName ? app.user.fullName|slice(0, 1)|upper : 'C') }}</span>
                    <span class="portal-account-meta">
                        <span class="portal-account-name">{{ app.user.fullName ?: 'Compte' }}</span>
                        <span class="portal-account-role">Sponsor</span>
                    </span>
                </summary>
                <div class="portal-account-dropdown">
                    <button type="button" class="portal-account-action">Profile</button>
                    <a class="portal-account-action" href="{{ path('app_logout') }}">Deconnexion</a>
                </div>
            </details>
        {% else %}
            <div class="nav-buttons">
                <a class="btn-login" href="{{ path('app_login') }}">Connexion</a>
                <a class="btn-signup" href="{{ path('app_register') }}">Inscription</a>
            </div>
        {% endif %}
    </div>
</nav>

<main class="portal-page">
    <div class="flash-wrap" style="margin-bottom: 10px;">
        {% for message in app.flashes('success') %}<div class="flash-success">{{ message }}</div>{% endfor %}
        {% for message in app.flashes('error') %}<div class="flash-error">{{ message }}</div>{% endfor %}
    </div>

    {% if isSponsorSession and upcomingActionAlerts is not empty %}
        <section class="portal-alert-strip" aria-label="Alertes opportunites 72h">
            <div class="portal-alert-strip-head">?? Alertes opportunite (72h)</div>
            <div class="portal-alert-strip-grid">
                {% for alert in upcomingActionAlerts %}
                    <article class="portal-alert-card">
                        <div class="portal-alert-top">
                            <span class="portal-alert-level">Urgent</span>
                            <span class="portal-alert-time">{{ alert.hoursLeft }}h restantes</span>
                        </div>
                        <h3>{{ alert.title }}</h3>
                        <p>{{ alert.message }}</p>
                        <a href="{{ path('app_sponsor_portal_sponsorize', {id: alert.eventId}) }}">Sponsoriser maintenant</a>
                    </article>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    <section class="portal-hero">
        <div class="portal-hero-top">
            <div>
                <h1>Portail Partenariat EventFlow</h1>
                <p>Decouvrez les evenements recommandes, trouvez de nouvelles opportunites de partenariat et suivez vos collaborations en un seul endroit.</p>
            </div>
            <div class="portal-hero-actions">
                <a class="portal-hero-btn" href="{{ path('app_sponsor_portal_history') }}">?? Historique contributions</a>
                {% if isSponsorSession %}
                    <a class="portal-hero-btn soft" href="{{ path('app_sponsor_portal_export_csv') }}">Exporter CSV</a>
                {% endif %}
            </div>
        </div>

        <div class="portal-hero-stats">
            <div class="portal-stat-card">
                <div class="portal-stat-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">??</div>
                <div class="portal-stat-info">
                    <div class="portal-stat-label">TOTAL …V…NEMENTS</div>
                    <div class="portal-stat-value">{{ eventCounts.total }}</div>
                    <div class="portal-stat-note">Catalogue visible pour votre prospection</div>
                    <div class="portal-stat-meter"><span style="width: 88%;"></span></div>
                </div>
            </div>
            <div class="portal-stat-card">
                <div class="portal-stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);">??</div>
                <div class="portal-stat-info">
                    <div class="portal-stat-label">ņ SPONSORISER</div>
                    <div class="portal-stat-value">{{ eventCounts.sponsorable }}</div>
                    <div class="portal-stat-note">Opportunites actuellement ouvertes</div>
                    <div class="portal-stat-meter"><span style="width: 72%;"></span></div>
                </div>
            </div>
            <div class="portal-stat-card">
                <div class="portal-stat-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">?</div>
                <div class="portal-stat-info">
                    <div class="portal-stat-label">MES CONTRIBUTIONS</div>
                    <div class="portal-stat-value">{{ isSponsorSession ? mySponsors|length : 0 }}</div>
                    <div class="portal-stat-note">Vos collaborations deja enregistrees</div>
                    <div class="portal-stat-meter"><span style="width: {{ isSponsorSession and mySponsors|length > 0 ? 62 : 18 }}%;"></span></div>
                </div>
            </div>
        </div>

    </section>

    <section class="portal-fx-premium" aria-label="Suivi dynamique des devises">
        <div class="portal-fx-head">
            <div>
                <h2>?? Taux de change en direct</h2>
                <p>Historique sur 7 jours et mise a jour multi-devises pour mieux planifier vos budgets sponsor.</p>
            </div>
            <div class="portal-fx-controls">
                <label for="portalFxCurrency">Devise:</label>
                <select id="portalFxCurrency" aria-label="Selection de devise">
                    <option value="EUR">Euro (EUR)</option>
                    <option value="USD">Dollar americain (USD)</option>
                    <option value="GBP">Livre sterling (GBP)</option>
                    <option value="CHF">Franc suisse (CHF)</option>
                    <option value="CAD">Dollar canadien (CAD)</option>
                </select>
                <button type="button" id="portalFxRefresh">?? Actualiser</button>
            </div>
        </div>

        <div class="portal-fx-grid">
            <article class="portal-fx-chart-card">
                <div class="portal-fx-pair" id="portalFxPairLabel">1 EUR = ? TND</div>
                <div class="portal-fx-chart-wrap">
                    <canvas id="portalFxChart" role="img" aria-label="Historique du taux de change contre le TND"></canvas>
                </div>
                <div class="portal-fx-empty" id="portalFxEmpty">Impossible de charger l historique pour la devise selectionnee.</div>
            </article>

            <article class="portal-fx-rates-card">
                <h3>?? Panorama devises</h3>
                <div class="portal-fx-rates-grid" id="portalFxRates">
                    <div class="portal-fx-rate-item active" data-fx-currency="EUR">
                        <div class="portal-fx-rate-left">
                            <span class="portal-fx-code">EUR ? TND</span>
                            <span class="portal-fx-caption">Euro</span>
                        </div>
                        <span class="portal-fx-value loading" data-fx-value>Chargement...</span>
                    </div>
                    <div class="portal-fx-rate-item" data-fx-currency="USD">
                        <div class="portal-fx-rate-left">
                            <span class="portal-fx-code">USD ? TND</span>
                            <span class="portal-fx-caption">Dollar</span>
                        </div>
                        <span class="portal-fx-value loading" data-fx-value>Chargement...</span>
                    </div>
                    <div class="portal-fx-rate-item" data-fx-currency="GBP">
                        <div class="portal-fx-rate-left">
                            <span class="portal-fx-code">GBP ? TND</span>
                            <span class="portal-fx-caption">Livre sterling</span>
                        </div>
                        <span class="portal-fx-value loading" data-fx-value>Chargement...</span>
                    </div>
                    <div class="portal-fx-rate-item" data-fx-currency="CHF">
                        <div class="portal-fx-rate-left">
                            <span class="portal-fx-code">CHF ? TND</span>
                            <span class="portal-fx-caption">Franc suisse</span>
                        </div>
                        <span class="portal-fx-value loading" data-fx-value>Chargement...</span>
                    </div>
                    <div class="portal-fx-rate-item" data-fx-currency="CAD">
                        <div class="portal-fx-rate-left">
                            <span class="portal-fx-code">CAD ? TND</span>
                            <span class="portal-fx-caption">Dollar canadien</span>
                        </div>
                        <span class="portal-fx-value loading" data-fx-value>Chargement...</span>
                    </div>
                </div>
                <p class="portal-fx-updated" id="portalFxUpdatedAt">Derniere mise a jour: -</p>
            </article>
        </div>
    </section>


    <!-- Section Graphiques de Distribution -->
    <section class="portal-distribution-showcase">
        <h2 class="portal-section-title">Distribution des evenements</h2>
        <div class="distribution-grid">
            <div class="distribution-card">
                <div class="distribution-accent atelier"></div>
                <div class="distribution-chart">
                    <svg viewBox="0 0 120 120" class="pie-chart modern">
                        <defs>
                            <linearGradient id="distAtelier" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#4f8cff"/>
                                <stop offset="100%" stop-color="#38bdf8"/>
                            </linearGradient>
                        </defs>
                        <circle cx="60" cy="60" r="44" class="pie-bg"></circle>
                        <circle cx="60" cy="60" r="44" class="pie-segment pie-segment-modern" style="--percentage: 35; --circumference: 276.46; stroke: url(#distAtelier);"></circle>
                        <circle cx="60" cy="60" r="31" class="pie-inner-ring"></circle>
                        <text x="60" y="57" class="pie-label modern">35%</text>
                        <text x="60" y="72" class="pie-caption">part</text>
                    </svg>
                </div>
                <div class="distribution-info">
                    <div class="distribution-chip atelier">Tendance dominante</div>
                    <h3>Ateliers</h3>
                    <p>Les ateliers representent la majorite des evenements a soutenir</p>
                    <div class="distribution-bar"><span class="atelier" style="width: 35%;"></span></div>
                    <div class="distribution-value">{{ eventCounts.sponsorable }} evenements</div>
                </div>
            </div>
            <div class="distribution-card">
                <div class="distribution-accent conference"></div>
