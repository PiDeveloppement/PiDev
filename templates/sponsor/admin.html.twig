{% extends 'base.html.twig' %}

{% block title %}Sponsors - EventFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
    <script src="{{ asset('js/admin-live-search.js') }}" defer></script>
    <script defer>
        document.addEventListener('DOMContentLoaded', function() {
            // Chart: Repartition par evenement
            const eventCtx = document.getElementById('chartsEventDistribution');
            if (eventCtx) {
                const eventData = {{ stats.byEvent|json_encode|raw }};
                new Chart(eventCtx, {
                    type: 'doughnut',
                    data: {
                        labels: Object.keys(eventData),
                        datasets: [{
                            data: Object.values(eventData),
                            backgroundColor: [
                                '#3b82f6', '#06b6d4', '#10b981', '#f59e0b', 
                                '#ef4444', '#8b5cf6', '#ec4899', '#6366f1'
                            ],
                            borderColor: '#fff',
                            borderWidth: 3,
                            borderSkipped: false,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    font: { size: 13, weight: '600' },
                                    padding: 20,
                                    usePointStyle: true,
                                    pointStyle: 'circle'
                                }
                            }
                        }
                    }
                });
            }

            // Chart: Top entreprises
            const topCtx = document.getElementById('chartsTopCompanies');
            if (topCtx) {
                const topCompanies = {{ stats.topCompanies|default({})|json_encode|raw }};
                const labels = Object.keys(topCompanies);
                const values = Object.values(topCompanies);
                if (labels.length > 0) {
                    new Chart(topCtx, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Contribution (DT)',
                                data: values,
                                backgroundColor: ['#1d4ed8', '#2563eb', '#3b82f6', '#60a5fa', '#93c5fd'],
                                borderColor: '#1d4ed8',
                                borderWidth: 1,
                                borderRadius: 8,
                                borderSkipped: false,
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: { font: { size: 12 } }
                                },
                                y: {
                                    ticks: { font: { size: 12 } }
                                }
                            }
                        }
                    });
                }
            }
        });
    </script>
{% endblock %}

{% block admin_content %}
<div class="sponsor-page" data-live-search-root>
    <div class="flash-wrap">
        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}
    </div>

    <!-- Toolbar -->
    <div class="sponsor-toolbar">
        <form method="get" action="{{ path('app_sponsors_index') }}" class="sponsor-toolbar-form">
            <div class="sponsor-search-group">
                <input type="hidden" name="q" value="{{ search }}" data-live-search-hidden>
                <input type="text" id="sponsor-search" value="{{ search }}" placeholder="Rechercher une entreprise..." autocomplete="new-password" autocorrect="off" autocapitalize="off" spellcheck="false" data-live-search-input>
            </div>
            <select name="company" class="sponsor-toolbar-select">
                <option value="">Toutes les entreprises</option>
                {% for item in companies %}
                    <option value="{{ item }}" {{ selectedCompany == item ? 'selected' : '' }}>{{ item }}</option>
                {% endfor %}
            </select>
            <select name="event_id" class="sponsor-toolbar-select">
                <option value="">Tous les evenements</option>
                {% for event in events %}
                    <option value="{{ event.id }}" {{ selectedEventId == event.id ? 'selected' : '' }}>{{ event.title }}</option>
                {% endfor %}
            </select>
            <button class="btn-sponsor outline" type="submit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M11 19a8 8 0 1 0-7-7m7 7l5 5"/></svg>
                Filtrer
            </button>
        </form>

        <div class="sponsor-toolbar-actions">
            <a class="btn-sponsor secondary" href="{{ path('app_sponsors_export_csv', {q: search, company: selectedCompany, event_id: selectedEventId}) }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Exporter CSV
            </a>
            <a class="btn-sponsor success" href="{{ path('app_sponsors_new') }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 5v14M5 12h14"/></svg>
                Nouvelle entreprise
            </a>
        </div>
    </div>

    <!-- KPI Stats -->
    <div class="sponsor-kpi-grid">
        <div class="sponsor-kpi-card tone-blue">
            <div class="sponsor-kpi-icon" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
            </div>
            <div class="sponsor-kpi-content">
                <h4>Total entreprises</h4>
                <p class="sponsor-kpi-value">{{ stats.total }}</p>
                <span class="sponsor-kpi-label">Entreprises enregistrees</span>
            </div>
        </div>

        <div class="sponsor-kpi-card tone-green">
            <div class="sponsor-kpi-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div class="sponsor-kpi-content">
                <h4>Contribution Totale</h4>
                <p class="sponsor-kpi-value">{{ stats.totalContribution|number_format(0, ',', ' ') }}</p>
                <span class="sponsor-kpi-label">DT</span>
            </div>
        </div>

        <div class="sponsor-kpi-card tone-amber">
            <div class="sponsor-kpi-icon" style="background: linear-gradient(135deg, #f59e0b, #f97316);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
                </svg>
            </div>
            <div class="sponsor-kpi-content">
                <h4>Moyenne par entreprise</h4>
                <p class="sponsor-kpi-value">{{ stats.averageContribution|number_format(0, ',', ' ')|default('0') }}</p>
                <span class="sponsor-kpi-label">DT</span>
            </div>
        </div>

        <div class="sponsor-kpi-card tone-violet">
            <div class="sponsor-kpi-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </div>
            <div class="sponsor-kpi-content">
                <h4>Evenements</h4>
                <p class="sponsor-kpi-value">{{ events|length }}</p>
                <span class="sponsor-kpi-label">Evenements actifs</span>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    {% if stats.byEvent is not empty %}
    <div class="sponsor-charts-grid">
        <div class="sponsor-chart-card">
            <h3>Repartition par Evenement</h3>
            <div class="sponsor-chart-container">
                <canvas id="chartsEventDistribution"></canvas>
            </div>
        </div>

        {% if sponsors|length > 0 %}
        <div class="sponsor-chart-card">
            <h3>Top 5 Contributeurs</h3>
            <div class="sponsor-chart-container sponsor-chart-horizontal">
                <canvas id="chartsTopCompanies"></canvas>
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    <div class="sponsor-grid-card">
        <h3>Liste des entreprises ({{ sponsors|length }})</h3>

        {% if sponsors is empty %}
            <p class="sponsor-muted">Aucune entreprise trouvee.</p>
        {% else %}
            <div class="sponsor-cards">
                {% for sponsor in sponsors %}
                    <article class="sponsor-card" data-live-search-item data-search="{{ sponsor.companyName }}" data-live-suggest="{{ sponsor.companyName }}">
                        <div class="top">
                            <div class="sponsor-card-brand">
                                <div class="sponsor-card-logo">
                                    {% if sponsor.logoUrl %}
                                        <img src="{{ sponsor.logoUrl }}" alt="{{ sponsor.companyName }}">
                                    {% else %}
                                        <span>{{ sponsor.companyName|slice(0, 2)|upper }}</span>
                                    {% endif %}
                                </div>
                                <div>
                                <h4>{{ sponsor.companyName }}</h4>
                                <div class="sponsor-muted">{{ sponsor.contactEmail }}</div>
                                <div class="sponsor-muted">Evenement: {{ eventTitleMap[sponsor.eventId]|default('-') }}</div>
                                </div>
                            </div>
                            <span class="sponsor-badge">{{ sponsor.contributionAmount|number_format(2, ',', ' ') }} DT</span>
                        </div>

                        <div class="sponsor-actions">
                            <a class="btn-sponsor light" href="{{ path('app_sponsors_details', {id: sponsor.id}) }}">Details</a>
                            <a class="btn-sponsor primary" href="{{ path('app_sponsors_contract', {id: sponsor.id}) }}">Contrat</a>
                            <a class="btn-sponsor warning" href="{{ path('app_sponsors_edit', {id: sponsor.id}) }}">Modifier</a>
                            <form method="post" action="{{ path('app_sponsors_delete', {id: sponsor.id}) }}" onsubmit="return confirm('Supprimer ce sponsor ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_sponsor_' ~ sponsor.id) }}">
                                <button class="btn-sponsor danger" type="submit">Supprimer</button>
                            </form>
                        </div>
                    </article>
                {% endfor %}
            </div>
            <p class="sponsor-muted" data-live-search-empty hidden>Aucune entreprise ne correspond a votre recherche.</p>
        {% endif %}
    </div>
</div>
{% endblock %}




