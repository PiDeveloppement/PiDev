                    <table class="sp-notif-table">
                        <thead>
                            <tr>
                                <th>Entreprise</th>
                                <th>Contact</th>
                                <th>Inactivite</th>
                                <th>Risque</th>
                                <th>Niveau</th>
                                <th>Cumul</th>
                                <th>Derniere contribution</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in inactiveSponsorAlerts %}
                                <tr>
                                    <td>{{ item.companyName }}</td>
                                    <td>{{ item.contactEmail }}</td>
                                    <td>{{ item.contributionsSinceLast }} contribution(s)</td>
                                    <td><span class="sp-notif-score">{{ item.riskScore }}/100</span></td>
                                    <td><span class="sp-notif-sev {{ item.severity }}">{{ item.severityLabel }}</span></td>
                                    <td>{{ item.contributionTotal|number_format(0, ',', ' ') }} DT</td>
                                    <td>{{ item.lastContributionAmount|number_format(2, ',', ' ') }} DT</td>
                                    <td>
                                        {% if item.representativeSponsorId > 0 %}
                                            <div class="sp-notif-actions">
                                                <a class="sp-notif-btn-mini sp-notif-btn-detail" href="{{ path('app_sponsors_details', {id: item.representativeSponsorId}) }}">
                                                    <i class="fa-regular fa-eye"></i> Détails
                                                </a>
                                                <form method="post" action="{{ path('app_sponsors_send_recommendation_email', {id: item.representativeSponsorId}) }}" onsubmit="return confirm('Envoyer une relance pour ce sponsor inactif ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('send_reco_mail_' ~ item.representativeSponsorId) }}">
                                                    <button class="sp-notif-btn-mini sp-notif-btn-mail" type="submit"><i class="fa-regular fa-paper-plane"></i> Relancer</button>
                                                </form>
                                            </div>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    {% endif %}

    {# topbar #}
    <div class="sp-topbar">
        <div class="sp-topbar-right" style="margin-left: auto;">
            <a class="sp-btn sp-btn-ghost" href="{{ path('app_sponsors_export_csv', {mode: 'all'}) }}">
                <i class="fa-solid fa-arrow-up-from-bracket"></i> Exporter CSV
            </a>
            <a class="sp-btn sp-btn-primary" href="{{ path('app_sponsors_new') }}">
                <i class="fa-solid fa-plus"></i> Nouvelle entreprise
            </a>
        </div>
    </div>

    {# Bloc KPI: resume rapide des chiffres cles sponsors. #}
    <div class="sp-kpi">
        <div class="sp-kpi-card">
            <div class="sp-kpi-top"><div class="sp-kpi-label">Entreprises</div><div class="sp-kpi-dot dot-v"><i class="fa-solid fa-building"></i></div></div>
            <div class="sp-kpi-value">{{ stats.total }}</div>
            <div class="sp-kpi-sub">sponsors enregistrés</div>
        </div>
        <div class="sp-kpi-card">
            <div class="sp-kpi-top"><div class="sp-kpi-label">Contribution totale</div><div class="sp-kpi-dot dot-e"><i class="fa-solid fa-coins"></i></div></div>
            <div class="sp-kpi-value">{{ stats.totalContribution|number_format(0, ',', ' ') }}</div>
            <div class="sp-kpi-sub">dinars tunisiens</div>
        </div>
        <div class="sp-kpi-card">
            <div class="sp-kpi-top"><div class="sp-kpi-label">Moyenne / sponsor</div><div class="sp-kpi-dot dot-a"><i class="fa-solid fa-chart-simple"></i></div></div>
            <div class="sp-kpi-value">{{ stats.averageContribution|number_format(0, ',', ' ')|default('0') }}</div>
            <div class="sp-kpi-sub">DT par entreprise</div>
        </div>
        <div class="sp-kpi-card">
            <div class="sp-kpi-top"><div class="sp-kpi-label">Événements</div><div class="sp-kpi-dot dot-b"><i class="fa-solid fa-calendar-check"></i></div></div>
            <div class="sp-kpi-value">{{ events|length }}</div>
            <div class="sp-kpi-sub">événements associés</div>
        </div>
    </div>

    {# Bloc analytics modernise: graphiques Symfony UX Chartjs avec choix de vue. #}
    {% if stats.byEvent is not empty %}
    <section class="sp-dashboard" aria-label="Dashboard graphique sponsors">
        <div class="sp-dashboard-head">
            <div>
                <h3 class="sp-dashboard-title">Dashboard Sponsors Moderne</h3>
                <p class="sp-dashboard-sub">Choisis une vue pour lire les stats rapidement et comparer les tendances.</p>
            </div>
            <div class="sp-dashboard-choice">
                <label for="chartViewSelect">Vue graphique</label>
                <select id="chartViewSelect" aria-label="Choisir un type de graphique sponsor">
                    <option value="events">Événements les plus sponsorisés</option>
                    <option value="top">Meilleurs sponsors</option>
                    <option value="overview">Vue globale dashboard</option>
                </select>
            </div>
        </div>

        <div class="sp-chart-panels">
            <div class="sp-chart-panel is-active" data-chart-panel="events">
                <div class="sp-chart-grid">
                    <article class="sp-chart-card">
                        <h4>Top 5 événements (montant)</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(eventsByContributionChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Top 5 des événements qui attirent le plus de budget sponsor.</strong></p>
                    </article>
                    <article class="sp-chart-card">
                        <h4>Top 5 volume sponsors</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(eventsShareChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Top 5 des événements avec le plus grand nombre de sponsors engagés.</strong></p>
                    </article>
                </div>
            </div>

            <div class="sp-chart-panel" data-chart-panel="top">
                <div class="sp-chart-grid">
                    <article class="sp-chart-card">
                        <h4>Top sponsors</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(topSponsorsChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Répartition des contributions sur les entreprises les plus engagées.</strong></p>
                    </article>
                    <article class="sp-chart-card">
                        <h4>Frequence partenariats</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(topSponsorsComparisonChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Lecture horizontale pour comparer le nombre de partenariats par sponsor.</strong></p>
                    </article>
                </div>
            </div>

            <div class="sp-chart-panel" data-chart-panel="overview">
                <div class="sp-chart-grid">
                    <article class="sp-chart-card">
                        <h4>Vue globale</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(overviewChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Vision synthétique pour lire l'état global du portefeuille sponsor.</strong></p>
                    </article>
                    <article class="sp-chart-card">
                        <h4>Distribution alertes risque</h4>
                        <div class="sp-chart-canvas">
                            {{ render_chart(overviewKpiChart) }}
                        </div>
                        <p class="sp-chart-note"><strong>Repartition des alertes inactivite par niveau de criticite.</strong></p>
                    </article>
                </div>
            </div>
        </div>
    </section>
    {% else %}
    <section class="sp-dashboard" aria-label="Dashboard graphique sponsors">
        <div class="sp-empty" style="margin:0;">
            <div class="sp-empty-icon"><i class="fa-solid fa-chart-column"></i></div>
            <div class="sp-empty-title">Données insuffisantes pour les graphiques</div>
            <div class="sp-empty-sub">Ajoute des contributions sponsors pour activer le dashboard visuel.</div>
        </div>
    </section>
    {% endif %}

    {# Bloc filtres: recherche et filtrage multi-criteres. #}
    <form method="get" action="{{ path('app_sponsors_index') }}" style="display: flex; gap: 12px; margin-bottom: 0; flex-wrap: wrap; align-items: center;">
        <div class="sp-search-wrap" style="position: relative; flex: 1; min-width: 200px;">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="sponsorSearchInput" name="q" value="{{ search }}" placeholder="Rechercher une entreprise…" autocomplete="off" oninput="showSponsorSuggestions()" onfocus="showSponsorSuggestions()" onblur="setTimeout(hideSponsorSuggestions, 150)">
            <div id="sponsorSuggestionsList" style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1.5px solid var(--border-2); border-top: none; border-radius: 0 0 var(--r-sm) var(--r-sm); max-height: 200px; overflow-y: auto; z-index: 10; display: none; box-shadow: 0 2px 8px rgba(0,0,0,.07);"></div>
        </div>
        <select name="company" class="sp-filter-sel">
            <option value="">Toutes les entreprises</option>
            {% for item in companies %}
                <option value="{{ item }}" {{ selectedCompany == item ? 'selected' : '' }}>{{ item }}</option>
            {% endfor %}
        </select>
        <select name="event_id" class="sp-filter-sel">
            <option value="">Tous les événements</option>
            {% for event in events %}
                <option value="{{ event.id }}" {{ selectedEventId == event.id ? 'selected' : '' }}>{{ event.title }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="sp-btn sp-btn-ghost" style="padding: 10px 20px; border-radius: 40px; font-size: 13px; font-weight: 700;">
            <i class="fa-solid fa-magnifying-glass"></i> Rechercher
        </button>
