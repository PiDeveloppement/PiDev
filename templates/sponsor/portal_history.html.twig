<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historique des partenariats - EventFlow</title>
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}">
    <style>
        {{ include('partials/public_header_styles.html.twig') }}
        .portal-navbar {
            height: 80px;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .portal-logo-wrap img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }

        .portal-nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }

        .portal-nav-link {
            font-size: 16px;
            font-weight: 500;
        }

        .portal-account-menu {
            position: relative;
            top: -4px;
            display: inline-flex;
            align-items: center;
        }

        .portal-account-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .portal-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .portal-account-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
        }

        .portal-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255, 255, 255, 0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .portal-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .portal-account-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .portal-account-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.84);
        }

        .portal-account-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 180px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .portal-account-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
            border: none;
            background: transparent;
            text-align: left;
            cursor: pointer;
        }

        .portal-account-action:hover {
            background: #f3f7fd;
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            position: relative;
            top: -4px;
        }

        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: 700;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }

        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }

        .portal-translate {
            position: relative;
            top: -4px;
            margin-right: 12px;
        }

        .portal-translate-btn {
            border: none;
            border-radius: 999px;
            padding: 8px 14px;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 18px rgba(22, 163, 74, 0.3);
        }

        .portal-translate-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 180px;
            background: #fff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            display: none;
            z-index: 1400;
        }

        .portal-translate-menu.open {
            display: block;
        }

        .portal-translate-opt {
            width: 100%;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            border-radius: 8px;
            padding: 8px 10px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 6px;
        }

        .portal-translate-opt:last-child {
            margin-bottom: 0;
        }

        .portal-page {
            margin-top: 80px;
        }
    </style>
</head>
<body class="portal-body">
{{ include('partials/public_header.html.twig', { active_page: 'sponsor' }) }}

<main class="portal-page">
    {% if not isSponsorSession %}
        <section class="portal-box" style="text-align: center; padding: 60px 20px;">
            <h2 style="color: #0f172a; font-size: 24px; margin-bottom: 10px;">Connectez-vous pour voir vos partenariats</h2>
            <p style="color: #64748b; margin-bottom: 20px;">Accedez a votre historique de partenariats en vous connectant a votre compte.</p>
            <a class="portal-btn-sponso" href="{{ path('app_login') }}" style="display: inline-block;">Se connecter</a>
        </section>
    {% else %}
    <section class="portal-history-page-head">
        <a class="btn-sponsor outline" href="{{ path('app_sponsor_portal') }}">&lt; Retour</a>
        <div>
            <h1>Mes evenements sponsorises</h1>
            <p>Retrouvez ici tous les evenements deja sponsorises, a venir ou termines, avec acces rapide aux details.</p>
        </div>
    </section>

    <section class="portal-history-stats">
        <div class="portal-history-stat-card">
            <span>Total partenariats</span>
            <strong>{{ stats.count }}</strong>
        </div>
        <div class="portal-history-stat-card">
            <span>Contribution totale</span>
            <strong>{{ stats.total|number_format(2, ',', ' ') }} DT</strong>
        </div>
        <div class="portal-history-stat-card">
            <span>Evenements a venir</span>
            <strong>{{ stats.ongoing }}</strong>
        </div>
        <div class="portal-history-stat-card">
            <span>Evenements passes</span>
            <strong>{{ stats.ended }}</strong>
        </div>
    </section>

    <section class="portal-history-filters">
        <form method="get" action="{{ path('app_sponsor_portal_history') }}">
            <input type="text" name="q" value="{{ search }}" placeholder="Recherche par evenement">
            <select name="sort">
                <option value="recent" {{ sort == 'recent' ? 'selected' : '' }}>Plus recents</option>
                <option value="oldest" {{ sort == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                <option value="amount_desc" {{ sort == 'amount_desc' ? 'selected' : '' }}>Montant decroissant</option>
                <option value="amount_asc" {{ sort == 'amount_asc' ? 'selected' : '' }}>Montant croissant</option>
            </select>
            <button type="submit" class="btn-sponsor primary">Rechercher</button>
        </form>
    </section>

    {% set nowTs = "now"|date('U') %}
    {% set hasUpcoming = false %}
    {% set hasPast = false %}
    {% for item in historyItems %}
        {% set itemTs = (item.endDate ?: item.startDate)|date('U') %}
        {% if itemTs >= nowTs %}
            {% set hasUpcoming = true %}
        {% else %}
            {% set hasPast = true %}
        {% endif %}
    {% endfor %}

    <section class="portal-history-list">
        <h2 class="portal-section-title">Evenements a venir</h2>
        {% if historyItems is empty or not hasUpcoming %}
            <div class="portal-box-empty">Aucun evenement a venir.</div>
        {% else %}
            <div class="history-grid">
                {% for item in historyItems %}
                    {% set itemTs = (item.endDate ?: item.startDate)|date('U') %}
                    {% if itemTs >= nowTs %}
                        <article class="history-card wide">
                            <div class="history-top">
                                <div class="history-card-brand">
                                    <div class="history-card-logo">
                                        {% if item.logoUrl %}
                                            <img src="{{ item.logoUrl }}" alt="{{ item.company }}">
                                        {% else %}
                                            <span>{{ item.company|slice(0, 2)|upper }}</span>
                                        {% endif %}
                                    </div>
                                    <span class="history-status {{ item.statusClass }}">{{ item.statusLabel }}</span>
                                </div>
                                <strong>{{ item.contribution|number_format(2, ',', ' ') }} DT</strong>
                            </div>

                            <h3>{{ item.eventTitle }}</h3>
                            <p>{{ item.company }}</p>
                            <div class="history-meta">Lieu: {{ item.location }}</div>
                            <div class="history-meta">
                                {{ item.startDate ? item.startDate|date('d/m/Y H:i') : '-' }}
                                {% if item.endDate %} -> {{ item.endDate|date('d/m/Y H:i') }}{% endif %}
                            </div>

                            <div class="history-actions">
                                <a class="btn-sponsor light" href="{{ path('app_sponsor_portal_event', {id: item.eventId}) }}">Voir evenement</a>
                                <a class="btn-sponsor primary" href="{{ path('app_sponsor_portal_contract', {id: item.id}) }}">Contrat</a>
                                <a class="btn-sponsor primary" href="{{ path('app_sponsor_portal_details', {id: item.id}) }}">Details du partenariat</a>
                                <a class="btn-sponsor warning" href="{{ path('app_sponsor_portal_edit', {id: item.id}) }}">Modifier</a>
                            </div>
                        </article>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <section class="portal-history-list">
        <h2 class="portal-section-title">Evenements passes</h2>
        {% if historyItems is empty or not hasPast %}
            <div class="portal-box-empty">Aucun evenement passe.</div>
        {% else %}
            <div class="history-grid">
                {% for item in historyItems %}
                    {% set itemTs = (item.endDate ?: item.startDate)|date('U') %}
                    {% if itemTs < nowTs %}
                        <article class="history-card wide">
                            <div class="history-top">
                                <div class="history-card-brand">
                                    <div class="history-card-logo">
                                        {% if item.logoUrl %}
                                            <img src="{{ item.logoUrl }}" alt="{{ item.company }}">
                                        {% else %}
                                            <span>{{ item.company|slice(0, 2)|upper }}</span>
                                        {% endif %}
                                    </div>
                                    <span class="history-status {{ item.statusClass }}">{{ item.statusLabel }}</span>
                                </div>
                                <strong>{{ item.contribution|number_format(2, ',', ' ') }} DT</strong>
                            </div>

                            <h3>{{ item.eventTitle }}</h3>
                            <p>{{ item.company }}</p>
                            <div class="history-meta">Lieu: {{ item.location }}</div>
                            <div class="history-meta">
                                {{ item.startDate ? item.startDate|date('d/m/Y H:i') : '-' }}
                                {% if item.endDate %} -> {{ item.endDate|date('d/m/Y H:i') }}{% endif %}
                            </div>

                            <div class="history-actions">
                                <a class="btn-sponsor light" href="{{ path('app_sponsor_portal_event', {id: item.eventId}) }}">Voir evenement</a>
                                <a class="btn-sponsor primary" href="{{ path('app_sponsor_portal_contract', {id: item.id}) }}">Contrat</a>
                                <a class="btn-sponsor primary" href="{{ path('app_sponsor_portal_details', {id: item.id}) }}">Details du partenariat</a>
                            </div>
                        </article>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </section>
    {% endif %}
</main>
<div id="google_translate_element" style="display:none;"></div>
<script>
    (function () {
        const toggle = document.getElementById('portalTranslateToggle');
        const menu = document.getElementById('portalTranslateMenu');
        const widget = document.getElementById('portalTranslateWidget');

        const setTranslateCookie = function (value) {
            const host = window.location.hostname;
            document.cookie = 'googtrans=' + value + ';path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=' + value + ';path=/;domain=.' + host;
            }
        };

        const clearTranslateCookie = function () {
            const host = window.location.hostname;
            document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + host;
            }
        };

        if (toggle && menu) {
            toggle.addEventListener('click', function () {
                menu.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!widget || widget.contains(event.target)) {
                    return;
                }
                menu.classList.remove('open');
            });

            menu.querySelectorAll('[data-lang]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const lang = button.getAttribute('data-lang') || 'en';
                    if (lang === 'original') {
                        clearTranslateCookie();
                    } else {
                        setTranslateCookie(lang === 'fr' ? '/fr/fr' : '/fr/' + lang);
                    }
                    window.location.reload();
                });
            });
        }
    })();

    function googleTranslateElementInit() {
        if (!window.google || !window.google.translate || !window.google.translate.TranslateElement) {
            return;
        }

        new window.google.translate.TranslateElement({
            pageLanguage: 'fr',
            includedLanguages: 'fr,en,ar,es,de,it',
            autoDisplay: false,
            multilanguagePage: true
        }, 'google_translate_element');
    }
</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
