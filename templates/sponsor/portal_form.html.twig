<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ isEdit ? 'Modifier le partenariat' : 'Sponsoriser un evenement' }} - EventFlow</title>
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}">
    <style>
        {{ include('partials/public_header_styles.html.twig') }}
        .portal-navbar {
            height: 80px;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .portal-logo-wrap img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }

        .portal-nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }

        .portal-nav-link {
            font-size: 16px;
            font-weight: 500;
        }

        .portal-account-menu {
            position: relative;
            top: -4px;
            display: inline-flex;
            align-items: center;
        }

        .portal-account-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .portal-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .portal-account-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
        }

        .portal-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255, 255, 255, 0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .portal-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .portal-account-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .portal-account-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.84);
        }

        .portal-account-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 180px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .portal-account-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
            border: none;
            background: transparent;
            text-align: left;
            cursor: pointer;
        }

        .portal-account-action:hover {
            background: #f3f7fd;
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            position: relative;
            top: -4px;
        }

        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: 700;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }

        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }

        .portal-translate {
            position: relative;
            top: -4px;
            margin-right: 12px;
        }

        .portal-translate-btn {
            border: none;
            border-radius: 999px;
            padding: 8px 14px;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 18px rgba(22, 163, 74, 0.3);
        }

        .portal-translate-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 180px;
            background: #fff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            display: none;
            z-index: 1400;
        }

        .portal-translate-menu.open {
            display: block;
        }

        .portal-translate-opt {
            width: 100%;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            border-radius: 8px;
            padding: 8px 10px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 6px;
        }

        .portal-translate-opt:last-child {
            margin-bottom: 0;
        }

        .portal-form-body {
            margin: 0;
            background:
                radial-gradient(circle at 8% 12%, rgba(37, 99, 235, 0.18), transparent 34%),
                radial-gradient(circle at 92% 88%, rgba(34, 197, 94, 0.16), transparent 30%),
                linear-gradient(145deg, #eff5ff 0%, #f4fbf7 45%, #f7fbff 100%);
            color: #0f172a;
        }

        .portal-form-wrap {
            margin-top: 96px;
            max-width: 1180px;
            margin-left: auto;
            margin-right: auto;
            padding: 34px 18px 50px;
            position: relative;
        }

        .portal-form-wrap::before {
            content: "";
            position: absolute;
            right: -40px;
            top: 120px;
            width: 180px;
            height: 180px;
            border-radius: 36px;
            background: linear-gradient(145deg, rgba(59, 130, 246, 0.18), rgba(14, 165, 233, 0.05));
            transform: rotate(22deg);
            pointer-events: none;
            z-index: 0;
        }

        .portal-form-hero {
            position: relative;
            z-index: 1;
            border: 1px solid #cde2ff;
            border-radius: 24px;
            padding: 20px 22px;
            margin-bottom: 16px;
            background:
                radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.16), transparent 42%),
                radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.12), transparent 36%),
                #ffffff;
            box-shadow: 0 22px 38px rgba(15, 23, 42, 0.10);
            display: flex;
            flex-wrap: wrap;
            gap: 14px 22px;
            align-items: center;
            justify-content: space-between;
        }

        .portal-form-hero h2 {
            margin: 0;
            font-size: clamp(24px, 3vw, 32px);
            line-height: 1.2;
            letter-spacing: -0.5px;
            color: #0f172a;
        }

        .portal-form-hero p {
            margin: 8px 0 0;
            color: #4a5d78;
            font-size: 14px;
        }

        .hero-pill-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .hero-pill {
            border: 1px solid #c9d9f6;
            border-radius: 999px;
            padding: 7px 11px;
            background: rgba(255, 255, 255, 0.84);
            color: #1e3a8a;
            font-weight: 700;
            font-size: 12px;
            white-space: nowrap;
        }

        .portal-form-card {
            position: relative;
            z-index: 1;
            border: 1px solid #d7e6fb;
            border-radius: 24px;
            box-shadow: 0 28px 56px rgba(15, 23, 42, 0.14);
            overflow: hidden;
            background: #ffffff;
        }

        .portal-form-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 20px 24px;
            border-bottom: 1px solid #e3edf9;
            background:
                linear-gradient(120deg, rgba(37, 99, 235, 0.09), rgba(37, 99, 235, 0) 36%),
                linear-gradient(120deg, rgba(16, 185, 129, 0.09), rgba(16, 185, 129, 0) 30%),
                #fbfdff;
        }

        .title-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .portal-form-badge {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #fff;
            font-size: 20px;
            box-shadow: 0 14px 24px rgba(37, 99, 235, 0.28);
        }

        .portal-form-header h3 {
            margin: 0;
            font-size: 21px;
            color: #0f172a;
        }

        .portal-form-header p {
            margin: 4px 0 0;
            color: #52627a;
            font-size: 13px;
        }

        .portal-form-watermark {
            border: 1px solid #c7d8f6;
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 12px;
            font-weight: 700;
            color: #1d4ed8;
            background: rgba(255, 255, 255, 0.86);
        }

        .portal-form-content {
            padding: 22px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        }

        .portal-form-section {
            border: 1px solid #dce8f8;
            border-radius: 18px;
            padding: 16px;
            background: #ffffff;
            box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
        }

        .portal-form-section.blue {
            background: linear-gradient(145deg, rgba(219, 234, 254, 0.45), rgba(255, 255, 255, 0.95));
        }

        .portal-form-section.purple {
            background: linear-gradient(145deg, rgba(233, 213, 255, 0.28), rgba(255, 255, 255, 0.95));
        }

        .portal-form-section.green {
            background: linear-gradient(145deg, rgba(187, 247, 208, 0.36), rgba(255, 255, 255, 0.96));
        }

        .portal-form-section-title {
            margin: 0 0 12px 0;
            font-size: 17px;
            font-weight: 800;
            color: #0f172a;
        }

        .section-intro {
            margin: -4px 0 12px 0;
            font-size: 13px;
            color: #475569;
        }

        .event-fixed-pill {
            border: 1px dashed #89a9dd;
            background: #f3f8ff;
            padding: 10px 12px;
            border-radius: 10px;
            color: #1e3a8a;
            font-weight: 700;
            font-size: 14px;
        }

        .portal-form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .portal-form-grid > div {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .portal-form-grid label,
        .finance-row label,
        .logo-layout label {
            font-weight: 700;
            color: #1e293b;
            font-size: 13px;
        }

        .portal-form-grid .form-control,
        .finance-row .form-control,
        .logo-layout .form-control {
            height: 44px;
            border-radius: 12px;
            border: 1px solid #cbd9ed;
            background: #ffffff;
            color: #0f172a;
            font-size: 14px;
            box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.65);
        }

        .portal-form-grid textarea.form-control,
        .finance-row textarea.form-control,
        .logo-layout textarea.form-control {
            min-height: 90px;
            height: auto;
        }

        .portal-form-grid .form-control:focus,
        .finance-row .form-control:focus,
        .logo-layout .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.16);
            outline: none;
        }

        .form-errors {
            color: #b91c1c;
            font-size: 12px;
            font-weight: 600;
            margin-top: 2px;
        }

        .logo-toolbar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .logo-file-name {
            border: 1px solid #d5e3f8;
            border-radius: 999px;
            padding: 8px 10px;
            font-size: 12px;
            font-weight: 600;
            color: #334155;
            background: #f8fbff;
        }

        .logo-layout {
            display: grid;
            grid-template-columns: 170px minmax(0, 1fr);
            gap: 14px;
            align-items: center;
        }

        .logo-preview {
            border: 1px dashed #9db8df;
            background: #f6faff;
            border-radius: 14px;
            min-height: 132px;
        }

        .field-help {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
        }

        .finance-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 12px;
        }

        .fx-summary {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-top: 12px;
        }

        .fx-card {
            border: 1px solid #d4e3f8;
            border-radius: 14px;
            background: #ffffff;
            padding: 12px;
            min-height: 96px;
            box-shadow: 0 10px 18px rgba(15, 23, 42, 0.06);
        }

        .fx-card h5 {
            margin: 0;
            font-size: 13px;
            color: #1d4ed8;
        }

        .fx-card-value {
            margin: 8px 0 0 0;
            font-size: 19px;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.25;
        }

        .fx-card-muted {
            margin: 4px 0 0 0;
            font-size: 12px;
            color: #64748b;
        }

        .portal-form-footer {
            border-top: 1px solid #e1eaf7;
            padding-top: 14px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        @media (max-width: 1024px) {
            .portal-nav-links {
                gap: 16px;
                font-size: 13px;
            }

            .portal-form-wrap {
                padding-left: 14px;
                padding-right: 14px;
            }

            .fx-summary {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 860px) {
            .portal-navbar {
                padding: 0 12px;
            }

            .portal-logo-wrap img {
                height: 48px;
            }

            .portal-nav-links {
                display: none;
            }

            .portal-form-wrap {
                margin-top: 88px;
            }

            .portal-form-grid,
            .finance-row,
            .logo-layout,
            .fx-summary {
                grid-template-columns: 1fr;
            }

            .portal-form-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .portal-form-watermark {
                align-self: flex-start;
            }
        }
    </style>
</head>
<body class="portal-form-body">
{{ include('partials/public_header.html.twig', { active_page: 'sponsor' }) }}

<div class="portal-form-wrap sponsor-page">
    <div class="flash-wrap">
        {% for message in app.flashes('success') %}<div class="flash-success">{{ message }}</div>{% endfor %}
        {% for message in app.flashes('error') %}<div class="flash-error">{{ message }}</div>{% endfor %}
    </div>

    <section class="portal-form-hero">
        <div>
            <h2>{{ isEdit ? 'Mettre a jour votre partenariat' : 'Sponsoriser cet evenement' }}</h2>
            <p>Formulaire optimisé avec conversion dynamique des devises via <strong>FlorianvSwapBundle</strong>.</p>
        </div>
        <div class="hero-pill-list">
            <span class="hero-pill">Sponsoring intelligent</span>
            <span class="hero-pill">Taux en direct</span>
            <span class="hero-pill">Contrat auto</span>
        </div>
    </section>

    <div class="portal-form-card">
        <div class="portal-form-header">
            <div class="title-wrap">
                <span class="portal-form-badge">{{ isEdit ? '✎' : '🤝' }}</span>
                <div>
                    <h3>{{ isEdit ? 'Modifier le partenariat' : 'Nouveau partenariat' }}</h3>
                    <p>{{ isEdit ? 'Mettez a jour les informations de votre sponsoring' : 'Remplissez les informations de l entreprise partenaire' }}</p>
                </div>
            </div>
            <strong class="portal-form-watermark">◆ EventFlow Sponsor</strong>
        </div>

        <div class="portal-form-content">
            {{ form_start(form) }}

            <section class="portal-form-section blue">
                <h4 class="portal-form-section-title">Informations generales</h4>
                <p class="section-intro">Renseignez les informations de base de l entreprise et du contact principal.</p>
                <div class="portal-form-grid">
                    {% if event %}
                    <div>
                        <label>Evenement</label>
                        <div class="event-fixed-pill">Evenement: {{ event.title }}</div>
                        <div style="display:none;">
                            {{ form_widget(form.eventId) }}
                        </div>
                    </div>
                    {% else %}
                    <div>
                        {{ form_label(form.eventId) }}
                        {{ form_widget(form.eventId) }}
                        <div class="form-errors">{{ form_errors(form.eventId) }}</div>
                    </div>
                    {% endif %}
                    <div>
                        {{ form_label(form.companyName) }}
                        {{ form_widget(form.companyName, {'attr': {'placeholder': 'Nom entreprise'}}) }}
                        <div class="form-errors">{{ form_errors(form.companyName) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.contactEmail) }}
                        {{ form_widget(form.contactEmail, {'attr': {'placeholder': 'contact@entreprise.com'}}) }}
                        <div class="form-errors">{{ form_errors(form.contactEmail) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.phone) }}
                        {{ form_widget(form.phone, {'attr': {'placeholder': '216XXXXXXXX'}}) }}
                        <div class="form-errors">{{ form_errors(form.phone) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.industry) }}
                        {{ form_widget(form.industry, {'attr': {'placeholder': 'ex: Technologie, Marketing'}}) }}
                        <div class="form-errors">{{ form_errors(form.industry) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.taxId) }}
                        {{ form_widget(form.taxId, {'attr': {'placeholder': 'ex: 1234567A'}}) }}
                        <div class="form-errors">{{ form_errors(form.taxId) }}</div>
                    </div>
                </div>
            </section>

            <section class="portal-form-section purple">
                <h4 class="portal-form-section-title">Logo de l entreprise</h4>
                <p class="section-intro">Ajoutez un logo pour personnaliser vos documents et contrats de sponsoring.</p>
                <div class="logo-toolbar">
                    <button type="button" class="btn-sponsor light" id="pick-logo-btn">Choisir logo</button>
                    <button type="button" class="btn-sponsor danger" id="clear-logo-btn">Supprimer logo</button>
                    <div style="display:none;">
                        {{ form_widget(form.logoFile) }}
                    </div>
                    <span class="logo-file-name" id="logo-file-name">Aucun fichier</span>
                </div>
                <div class="form-errors">{{ form_errors(form.logoFile) }}</div>

                <div class="logo-layout">
                    <div class="logo-preview" id="logo-preview-box">
                        {% if form.logoUrl.vars.value %}
                            <img id="logo-preview-img" src="{{ form.logoUrl.vars.value }}" alt="Logo preview">
                        {% else %}
                            <img id="logo-preview-img" alt="Logo preview">
                        {% endif %}
                        <span class="placeholder" id="logo-preview-placeholder">Aperçu logo</span>
                    </div>

                    <div>
                        {{ form_label(form.logoUrl) }}
                        {{ form_widget(form.logoUrl, {'attr': {'placeholder': 'URL logo (auto)'}}) }}
                        <div class="form-errors">{{ form_errors(form.logoUrl) }}</div>
                        <div class="field-help">Vous pouvez coller une URL du logo ou choisir un fichier pour l apercu visuel.</div>
                    </div>
                </div>
            </section>

            <section class="portal-form-section green">
                <h4 class="portal-form-section-title">Contribution financiere</h4>
                <p class="section-intro">Le montant final est converti automatiquement en TND selon le taux actuel.</p>
                <div class="finance-row">
                    <div>
                        {{ form_label(form.contributionName) }}
                        {{ form_widget(form.contributionName, {'attr': {'placeholder': 'ex: 3500'}}) }}
                        <div class="form-errors">{{ form_errors(form.contributionName) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.contributionCurrency) }}
                        {{ form_widget(form.contributionCurrency) }}
                        <div class="form-errors">{{ form_errors(form.contributionCurrency) }}</div>
                    </div>
                </div>

                <div class="fx-summary">
                    <article class="fx-card">
                        <h5>Taux live</h5>
                        <p class="fx-card-value" id="fx-rate-value">1 TND = 1.0000 TND</p>
                        <p class="fx-card-muted">Source: FlorianvSwapBundle</p>
                    </article>
                    <article class="fx-card">
                        <h5>Estimation convertie</h5>
                        <p class="fx-card-value" id="contribution-tnd">-</p>
                        <p class="fx-card-muted" id="fx-preview-line">Saisissez un montant pour voir l estimation.</p>
                    </article>
                    <article class="fx-card">
                        <h5>Derniere mise a jour</h5>
                        <p class="fx-card-value" id="fx-updated-at">-</p>
                        <p class="fx-card-muted">Taux recalcule en direct selon la devise choisie.</p>
                    </article>
                </div>
            </section>

            <div class="portal-form-footer">
                <a class="btn-sponsor outline" href="{{ path(backRoute) }}">Annuler</a>
                <button class="btn-sponsor success" type="submit">{{ isEdit ? 'Enregistrer les modifications' : 'Enregistrer le partenariat' }}</button>
            </div>

            {{ form_end(form, {'render_rest': true}) }}
        </div>
    </div>
</div>

<script>
(function () {
    const logoUrlInput = document.getElementById('{{ form.logoUrl.vars.id }}');
    const contributionInput = document.getElementById('{{ form.contributionName.vars.id }}');
    const currencyView = document.getElementById('{{ form.contributionCurrency.vars.id }}');
    const contributionOut = document.getElementById('contribution-tnd');
    const fxRateValue = document.getElementById('fx-rate-value');
    const fxUpdatedAt = document.getElementById('fx-updated-at');
    const fxPreviewLine = document.getElementById('fx-preview-line');

    const pickLogoBtn = document.getElementById('pick-logo-btn');
    const clearLogoBtn = document.getElementById('clear-logo-btn');
    const logoFileInput = document.getElementById('{{ form.logoFile.vars.id }}');
    const logoFileName = document.getElementById('logo-file-name');
    const logoPreviewImg = document.getElementById('logo-preview-img');
    const logoPreviewPlaceholder = document.getElementById('logo-preview-placeholder');

    function parseAmount(value) {
        if (!value) return null;
        const normalized = String(value).replace(',', '.').trim();
        const n = parseFloat(normalized);
        return Number.isFinite(n) ? n : null;
    }

    function formatMoney(value) {
        return Number(value).toLocaleString('fr-FR', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }) + ' DT';
    }

    function formatRate(value) {
        return Number(value).toLocaleString('fr-FR', {
            minimumFractionDigits: 4,
            maximumFractionDigits: 4
        });
    }

    function formatDateTime(value) {
        if (!value) {
            return '-';
        }

        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
            return '-';
        }

        return date.toLocaleString('fr-FR', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
        });
    }

    async function updateRateCard() {
        if (!currencyView || !fxRateValue || !fxUpdatedAt) return;

        const currency = currencyView.value || 'TND';
        if (currency === 'TND') {
            fxRateValue.textContent = '1 TND = 1.0000 TND';
            fxUpdatedAt.textContent = 'Maintenant';
            return;
        }

        try {
            const url = `{{ path('app_currency_rate') }}?from=${encodeURIComponent(currency)}&to=TND`;
            const response = await fetch(url);
            const payload = await response.json();

            if (!response.ok || !payload.ok || !Number.isFinite(Number(payload.rate))) {
                fxRateValue.textContent = 'Taux indisponible';
                fxUpdatedAt.textContent = '-';
                return;
            }

            fxRateValue.textContent = `1 ${currency} = ${formatRate(payload.rate)} TND`;
            fxUpdatedAt.textContent = formatDateTime(payload.fetchedAt);
        } catch (error) {
            fxRateValue.textContent = 'Taux indisponible';
            fxUpdatedAt.textContent = '-';
        }
    }

    async function updateContribution() {
        if (!contributionInput || !currencyView || !contributionOut) return;
        const amount = parseAmount(contributionInput.value);
        if (amount === null) {
            contributionOut.textContent = '-';
            if (fxPreviewLine) {
                fxPreviewLine.textContent = 'Saisissez un montant pour voir l estimation.';
            }
            return;
        }

        const currency = currencyView.value || 'TND';
        if (currency === 'TND') {
            contributionOut.textContent = formatMoney(amount);
            if (fxPreviewLine) {
                fxPreviewLine.textContent = `Montant saisi: ${amount.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`;
            }
            return;
        }

        try {
            const url = `{{ path('app_currency_convert') }}?amount=${encodeURIComponent(String(amount))}&from=${encodeURIComponent(currency)}&to=TND`;
            const response = await fetch(url);
            const payload = await response.json();

            if (!response.ok || !payload.ok) {
                contributionOut.textContent = '-';
                if (fxPreviewLine) {
                    fxPreviewLine.textContent = 'Conversion indisponible pour le moment.';
                }
                return;
            }

            contributionOut.textContent = formatMoney(payload.converted);
            if (fxPreviewLine) {
                fxPreviewLine.textContent = `${amount.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency} ˜ ${formatMoney(payload.converted)}`;
            }
        } catch (error) {
            contributionOut.textContent = '-';
            if (fxPreviewLine) {
                fxPreviewLine.textContent = 'Conversion indisponible pour le moment.';
            }
        }
    }

    function setLogoPreview(src) {
        if (!logoPreviewImg || !logoPreviewPlaceholder) return;
        if (src && src.trim() !== '') {
            logoPreviewImg.src = src;
            logoPreviewImg.style.display = 'block';
            logoPreviewPlaceholder.style.display = 'none';
        } else {
            logoPreviewImg.removeAttribute('src');
            logoPreviewImg.style.display = 'none';
            logoPreviewPlaceholder.style.display = 'block';
        }
    }

    if (logoUrlInput) {
        logoUrlInput.addEventListener('input', function () {
            setLogoPreview(logoUrlInput.value);
        });
        setLogoPreview(logoUrlInput.value);
    }

    if (pickLogoBtn && logoFileInput) {
        pickLogoBtn.addEventListener('click', function () {
            logoFileInput.click();
        });

        logoFileInput.addEventListener('change', function () {
            const file = logoFileInput.files && logoFileInput.files[0] ? logoFileInput.files[0] : null;
            logoFileName.textContent = file ? file.name : 'Aucun fichier';

            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                setLogoPreview(String(e.target && e.target.result ? e.target.result : ''));
            };
            reader.readAsDataURL(file);
        });
    }

    if (clearLogoBtn) {
        clearLogoBtn.addEventListener('click', function () {
            if (logoFileInput) logoFileInput.value = '';
            if (logoUrlInput) logoUrlInput.value = '';
            if (logoFileName) logoFileName.textContent = 'Aucun fichier';
            setLogoPreview('');
        });
    }

    if (contributionInput) {
        contributionInput.addEventListener('input', updateContribution);
        contributionInput.addEventListener('change', updateContribution);
    }
    if (currencyView) {
        currencyView.addEventListener('change', function () {
            updateRateCard();
            updateContribution();
        });
    }

    updateRateCard();
    updateContribution();
})();
</script>
<div id="google_translate_element" style="display:none;"></div>
<script>
    (function () {
        const toggle = document.getElementById('portalTranslateToggle');
        const menu = document.getElementById('portalTranslateMenu');
        const widget = document.getElementById('portalTranslateWidget');

        const setTranslateCookie = function (value) {
            const host = window.location.hostname;
            document.cookie = 'googtrans=' + value + ';path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=' + value + ';path=/;domain=.' + host;
            }
        };

        const clearTranslateCookie = function () {
            const host = window.location.hostname;
            document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
            if (host && host !== 'localhost' && host.indexOf('.') !== -1) {
                document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + host;
            }
        };

        if (toggle && menu) {
            toggle.addEventListener('click', function () {
                menu.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!widget || widget.contains(event.target)) {
                    return;
                }
                menu.classList.remove('open');
            });

            menu.querySelectorAll('[data-lang]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const lang = button.getAttribute('data-lang') || 'en';
                    if (lang === 'original') {
                        clearTranslateCookie();
                    } else {
                        setTranslateCookie(lang === 'fr' ? '/fr/fr' : '/fr/' + lang);
                    }
                    window.location.reload();
                });
            });
    }

    new window.google.translate.TranslateElement({
        pageLanguage: 'fr',
        includedLanguages: 'fr,en,ar,es,de,it',
        autoDisplay: false,
        multilanguagePage: true
    }, 'google_translate_element');
}

// Theme toggle for sponsor portal
function toggleTheme() {
    const body = document.body;
    const themeIconSponsor = document.getElementById('themeIconSponsor');
    const themeTextSponsor = document.getElementById('themeTextSponsor');
    
    if (body.classList.contains('dark-mode')) {
        body.classList.remove('dark-mode');
        localStorage.setItem('theme', 'light');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-sun');
            themeIconSponsor.classList.add('fa-moon');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Sombre';
        }
    } else {
        body.classList.add('dark-mode');
        localStorage.setItem('theme', 'dark');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-moon');
            themeIconSponsor.classList.add('fa-sun');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Clair';
        }
    }
}

// Load saved theme on page load for sponsor portal
document.addEventListener('DOMContentLoaded', function() {
    const savedTheme = localStorage.getItem('theme');
    const themeIconSponsor = document.getElementById('themeIconSponsor');
    const themeTextSponsor = document.getElementById('themeTextSponsor');
    
    if (savedTheme === 'dark') {
        document.body.classList.add('dark-mode');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-moon');
            themeIconSponsor.classList.add('fa-sun');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Clair';
        }
    }
});

</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
