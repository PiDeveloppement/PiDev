<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Details de l entreprise - EventFlow</title>
    <link rel="stylesheet" href="{{ asset('css/sponsor.css') }}?v=20260416-ia-focus">
    <link rel="stylesheet" href="{{ asset('css/dark-mode.css') }}">
    <style>
        {{ include('partials/public_header_styles.html.twig') }}
        body { margin: 0; font-family: Inter, Arial, sans-serif; background: #eef3f9; color: #0f172a; }
        .portal-navbar {
            height: 80px;
            padding: 0 60px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .portal-logo-wrap img {
            width: auto;
            height: 56px;
            max-width: 180px;
            object-fit: contain;
            display: block;
        }

        .portal-nav-links {
            display: flex;
            gap: 40px;
            position: relative;
            top: -4px;
        }

        .portal-nav-link {
            font-size: 16px;
            font-weight: 500;
        }

        .portal-account-menu {
            position: relative;
            top: -4px;
            display: inline-flex;
            align-items: center;
        }

        .portal-account-menu summary {
            list-style: none;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .portal-account-menu summary::-webkit-details-marker {
            display: none;
        }

        .portal-account-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #7fb2ea;
            background: linear-gradient(180deg, #3f8fe2 0%, #2d79ca 100%);
            border-radius: 20px;
            padding: 4px 10px 4px 6px;
            color: #ffffff;
            min-height: 42px;
        }

        .portal-account-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #0f4d90;
            border: 2px solid rgba(255, 255, 255, 0.75);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
            color: #ffffff;
        }

        .portal-account-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .portal-account-name {
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
        }

        .portal-account-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.84);
        }

        .portal-account-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 180px;
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 12px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.16);
            padding: 8px;
            z-index: 1200;
        }

        .portal-account-action {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
            border: none;
            background: transparent;
            text-align: left;
            cursor: pointer;
        }

        .portal-account-action:hover {
            background: #f3f7fd;
        }

        .nav-buttons {
            display: flex;
            gap: 15px;
            position: relative;
            top: -4px;
        }

        .btn-login {
            background: transparent;
            color: #0D47A1;
            font-weight: 700;
            border: 1.5px solid #0D47A1;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login:hover {
            background: rgba(13, 71, 161, 0.05);
        }

        .btn-signup {
            background: #0D47A1;
            color: white;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            padding: 8px 24px;
            cursor: pointer;
            font-size: 14px;
            box-shadow: 0 4px 8px rgba(13, 71, 161, 0.3);
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-signup:hover {
            background: #0A3A80;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 71, 161, 0.4);
        }

        .wrap { max-width: 1180px; margin: 100px auto 20px; padding: 0 14px 24px; }
    </style>
</head>
<body>
{{ include('partials/public_header.html.twig', { active_page: 'sponsor' }) }}

<div class="wrap sponsor-page">
    <div class="sponsor-detail-card sponsor-detail-card-rich">
        <div class="sponsor-detail-head">
            <div class="sponsor-detail-brand">
                <img class="sponsor-detail-eventflow" src="{{ asset('images/logo.png') }}" alt="EventFlow">
                <div>
                    <h3>Details de l entreprise</h3>
                    <p>Votre espace detaille de partenariat avec resume utile et contrat PDF visible directement.</p>
                </div>
            </div>
            <div class="sponsor-detail-logo-box">
                {% if sponsor.logoUrl %}
                    <img src="{{ sponsor.logoUrl }}" alt="{{ sponsor.companyName }}">
                {% else %}
                    <span>{{ sponsor.companyName|slice(0, 2)|upper }}</span>
                {% endif %}
            </div>
        </div>

        <div class="sponsor-overview-grid">
            <article class="sponsor-overview-card accent-blue">
                <span>Entreprise</span>
                <strong>{{ sponsor.companyName ?: '-' }}</strong>
                <small>{{ sponsor.contactEmail ?: '-' }}</small>
            </article>
            <article class="sponsor-overview-card accent-green">
                <span>Contribution</span>
                <strong>{{ sponsor.contributionAmount|number_format(2, ',', ' ') }} DT</strong>
                <small>Votre contribution enregistree</small>
            </article>
            <article class="sponsor-overview-card accent-amber">
                <span>Evenement</span>
                <strong>{{ eventTitle|default('-') }}</strong>
                <small>{{ event and event.startDate ? event.startDate|date('d/m/Y H:i') : 'Date non precisee' }}</small>
            </article>
        </div>

        <div class="sponsor-detail-panels">
            <section class="sponsor-info-panel">
                <div class="sponsor-panel-title">Informations generales</div>
                <dl class="sponsor-detail-grid compact">
                    <dt>Entreprise</dt><dd>{{ sponsor.companyName ?: '-' }}</dd>
                    <dt>Email</dt><dd>{{ sponsor.contactEmail ?: '-' }}</dd>
                    <dt>Evenement</dt><dd>{{ eventTitle|default('-') }}</dd>
                    <dt>Lieu</dt><dd>{{ event and event.location ? event.location : '-' }}</dd>
                    <dt>Secteur</dt><dd>{{ sponsor.industry ?: '-' }}</dd>
                    <dt>Telephone</dt><dd>{{ sponsor.phone ?: '-' }}</dd>
                    <dt>N Fiscal</dt><dd>{{ sponsor.taxId ?: '-' }}</dd>
                    <dt>Justificatif</dt>
                    <dd>
                        {% if sponsor.documentUrl %}
                            <a href="{{ sponsor.documentUrl }}" target="_blank" rel="noopener noreferrer">Voir le justificatif</a>
                        {% else %}
                            -
                        {% endif %}
                    </dd>
                </dl>
            </section>

            <section class="sponsor-doc-panel">
                <div class="sponsor-panel-title">Logo de l entreprise</div>
                {% if sponsor.logoUrl %}
                    <img class="sponsor-doc-preview large" src="{{ sponsor.logoUrl }}" alt="{{ sponsor.companyName }}">
                    <a class="btn-sponsor light" href="{{ sponsor.logoUrl }}" target="_blank" rel="noopener noreferrer">Ouvrir logo</a>
                {% else %}
                    <div class="sponsor-empty-state">Aucun logo disponible.</div>
                {% endif %}
            </section>
        </div>

        <section class="sponsor-contract-panel">
            <div class="sponsor-contract-head">
                <div>
                    <div class="sponsor-panel-title">Contrat de partenariat</div>
                </div>
                <a class="btn-sponsor primary" href="{{ contractDownloadUrl }}">Contrat</a>
            </div>
        </section>

        <div class="sponsor-form-footer">
            <a class="btn-sponsor outline" href="{{ path(backRoute) }}">Retour</a>
        </div>
    </div>
</div>
<script>
// Theme toggle for sponsor portal
function toggleTheme() {
    const body = document.body;
    const themeIconSponsor = document.getElementById('themeIconSponsor');
    const themeTextSponsor = document.getElementById('themeTextSponsor');
    
    if (body.classList.contains('dark-mode')) {
        body.classList.remove('dark-mode');
        localStorage.setItem('theme', 'light');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-sun');
            themeIconSponsor.classList.add('fa-moon');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Sombre';
        }
    } else {
        body.classList.add('dark-mode');
        localStorage.setItem('theme', 'dark');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-moon');
            themeIconSponsor.classList.add('fa-sun');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Clair';
        }
    }
}

// Load saved theme on page load for sponsor portal
document.addEventListener('DOMContentLoaded', function() {
    const savedTheme = localStorage.getItem('theme');
    const themeIconSponsor = document.getElementById('themeIconSponsor');
    const themeTextSponsor = document.getElementById('themeTextSponsor');
    
    if (savedTheme === 'dark') {
        document.body.classList.add('dark-mode');
        if (themeIconSponsor) {
            themeIconSponsor.classList.remove('fa-moon');
            themeIconSponsor.classList.add('fa-sun');
        }
        if (themeTextSponsor) {
            themeTextSponsor.textContent = 'Mode Clair';
        }
    }
});
</script>
</body>
</html>
