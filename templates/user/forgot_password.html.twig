{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - EventFlow{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
        <!-- En-tête -->
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-blue-500">📱 Mot de passe oublié</h2>
            <p class="text-gray-500 text-sm mt-2">
                Saisissez votre numéro de téléphone pour recevoir un SMS de réinitialisation
            </p>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm text-center">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 text-sm text-center">
                {{ message }}
            </div>
        {% endfor %}

        <!-- Formulaire -->
        <form method="post" action="{{ path('app_forgot_password_send') }}" class="space-y-6">
            <!-- Champ téléphone -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Numéro de téléphone</label>
                <input type="tel" 
                       name="phone" 
                       placeholder="+216XXXXXXXX"
                       pattern="^\+?[0-9]{8,15}$"
                       required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm">
                <p class="text-xs text-gray-400 mt-1">Format: +216XXXXXXXX (indicatif international requis)</p>
            </div>

            <!-- Champ email caché (compatibilité) -->
            <input type="email" name="email" style="display: none;">

            <!-- Status message -->
            <div id="statusMessage" class="text-sm text-center min-h-[20px]"></div>

            <!-- Loading indicator -->
            <div id="loadingIndicator" class="flex justify-center hidden">
                <div class="w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
            </div>

            <!-- Bouton de test (visible seulement en développement) -->
            {% if app.environment == 'dev' %}
                <div class="flex justify-center">
                    <button type="button" 
                            onclick="testLink()"
                            class="bg-orange-500 text-white font-bold px-6 py-2 rounded-lg hover:bg-orange-600 transition shadow-sm w-48">
                        Tester le lien
                    </button>
                </div>
            {% endif %}

            <!-- Boutons d'action -->
            <div class="flex justify-center space-x-4">
                <button type="submit" 
                        class="bg-green-500 text-white font-bold px-8 py-3 rounded-lg hover:bg-green-600 transition shadow-sm w-36">
                    Envoyer
                </button>
                <a href="{{ path('app_login') }}" 
                   class="bg-gray-500 text-white px-8 py-3 rounded-lg hover:bg-gray-600 transition shadow-sm w-36 text-center">
                    Retour
                </a>
            </div>

            <p class="text-xs text-gray-400 text-center mt-4">Le lien de réinitialisation expirera dans 1 heure</p>

            <!-- Indicateurs de format -->
            <div class="flex justify-center space-x-3 pt-2">
                <span class="text-xs text-gray-500 bg-gray-100 px-3 py-1 rounded-full">📱 Tunisie: +216</span>
                <span class="text-xs text-gray-500 bg-gray-100 px-3 py-1 rounded-full">🇫🇷 France: +33</span>
            </div>
        </form>
    </div>
</div>

<script>
function showMessage(message, type) {
    const statusDiv = document.getElementById('statusMessage');
    statusDiv.textContent = message;
    statusDiv.className = type === 'success' ? 'text-sm text-center text-green-600' : 'text-sm text-center text-red-600';
}

function showLoading(show) {
    document.getElementById('loadingIndicator').classList.toggle('hidden', !show);
}

function testLink() {
    fetch('{{ path('app_forgot_password_test') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        }
    })
    .then(response => {
        if (response.redirected) {
            window.location.href = response.url;
        }
    })
    .catch(error => {
        showMessage('❌ Erreur: ' + error.message, 'error');
    });
}

document.querySelector('form').addEventListener('submit', function(e) {
    showLoading(true);
});
</script>
{% endblock %}