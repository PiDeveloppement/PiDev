{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe - EventFlow{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
        <!-- En-tête -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">🔐</span>
            </div>
            <h2 class="text-2xl font-bold text-gray-800">Réinitialisation</h2>
            <p class="text-gray-500 text-sm mt-2">
                {% if step == 'reset' %}
                    Choisissez votre nouveau mot de passe
                {% else %}
                    Entrez le code reçu sur WhatsApp
                {% endif %}
            </p>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm text-center">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 text-sm text-center">
                {{ message }}
            </div>
        {% endfor %}

        <!-- Étape 1: Saisie du token -->
        <div id="tokenBox" {% if step == 'reset' %}style="display: none;"{% endif %}>
            <div class="space-y-4">
                <p class="text-sm font-semibold text-gray-700">Étape 1 : Collez votre code WhatsApp</p>
                <input type="text" 
                       id="tokenField"
                       value="{{ token }}"
                       placeholder="Ex: 30e8435c-688b-4da9-bdca-69be587116d4"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 text-sm font-mono">
                
                <button onclick="validateToken()"
                        class="w-full bg-green-500 text-white font-bold py-3 rounded-lg hover:bg-green-600 transition shadow-sm">
                    ✅ Valider le code
                </button>
            </div>
        </div>

        <!-- Étape 2: Nouveau mot de passe -->
        <div id="passwordFormBox" {% if step != 'reset' %}style="display: none;"{% endif %}>
            <form method="post" action="{{ path('app_reset_password_reset') }}" class="space-y-4">
                <input type="hidden" name="token" value="{{ token }}">
                
                <p class="text-sm font-semibold text-gray-700">Étape 2 : Choisissez votre nouveau mot de passe</p>
                
                <div>
                    <input type="password" 
                           name="new_password"
                           placeholder="Nouveau mot de passe"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 text-sm"
                           required
                           minlength="6">
                </div>
                
                <div>
                    <input type="password" 
                           name="confirm_password"
                           placeholder="Confirmer le mot de passe"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 text-sm"
                           required>
                </div>
                
                <button type="submit"
                        class="w-full bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700 transition shadow-sm">
                    🔄 Réinitialiser mon mot de passe
                </button>
            </form>
        </div>

        <!-- Status message -->
        <div id="statusLabel" class="text-sm text-center mt-4 min-h-[20px]"></div>

        <!-- Lien retour -->
        <div class="text-center mt-6">
            <a href="{{ path('app_login') }}" 
               class="text-sm text-gray-500 underline hover:text-gray-700 transition">
                ← Retour au login
            </a>
        </div>
    </div>
</div>

<script>
function validateToken() {
    const token = document.getElementById('tokenField').value.trim();
    
    if (!token) {
        showStatus('❌ Veuillez saisir le code reçu par WhatsApp', 'red');
        return;
    }

    showStatus('⏳ Vérification en cours...', 'orange');
    
    fetch('{{ path('app_reset_password_validate') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'token=' + encodeURIComponent(token)
    })
    .then(response => {
        if (response.redirected) {
            window.location.href = response.url;
        } else {
            return response.text();
        }
    })
    .then(data => {
        if (data && data.includes('error')) {
            showStatus('❌ Code invalide ou expiré', 'red');
        }
    })
    .catch(error => {
        showStatus('❌ Erreur: ' + error.message, 'red');
    });
}

function showStatus(message, color) {
    const statusDiv = document.getElementById('statusLabel');
    statusDiv.textContent = message;
    statusDiv.style.color = color;
}
</script>
{% endblock %}