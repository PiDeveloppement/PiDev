{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe - EventFlow{% endblock %}

{% block stylesheets %}
<style>
    html, body {
        background: white !important;
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
    }

    body {
        min-height: 100vh;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
    }

    .public-container {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 100%;
        min-height: 100vh;
    }

    .login-container {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
    }

    .login-card {
        background: white;
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        border: 1px solid #e1e5e9;
    }

    .logo {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo h1 {
        color: #25D366;
        font-size: 28px;
        margin: 0 0 10px 0;
        font-weight: 700;
    }

    .logo p {
        color: #666;
        font-size: 14px;
        margin: 0;
    }

    .step-title {
        font-weight: bold;
        font-size: 16px;
        margin-bottom: 15px;
        color: #333;
    }

    .step-box {
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #333;
        font-weight: 500;
        font-size: 14px;
    }

    .form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e1e5e9;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color 0.3s;
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: #25D366;
    }

    .form-group input.error {
        border-color: #ff4444;
    }

    .help-text {
        font-size: 12px;
        color: #888;
        margin-top: 5px;
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        margin-bottom: 15px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3);
    }

    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .btn-back {
        display: block;
        text-align: center;
        padding: 12px;
        background: #f8f9fa;
        color: #666;
        text-decoration: none;
        border-radius: 8px;
        font-size: 14px;
        transition: background 0.3s;
    }

    .btn-back:hover {
        background: #e9ecef;
        text-decoration: underline;
    }

    .status-message {
        font-size: 13px;
        text-align: center;
        margin-top: 12px;
        padding: 10px;
        border-radius: 6px;
    }

    .status-success {
        color: #3c3;
        background-color: #efe;
    }

    .status-error {
        color: #c33;
        background-color: #fee;
    }

    .loading {
        display: inline-block;
        width: 14px;
        height: 14px;
        border: 2px solid #fff;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        margin-right: 6px;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .hidden {
        display: none;
    }
</style>
{% endblock %}

{% block public_content %}
<div class="login-container">
    <div class="login-card">
        <!-- Logo -->
        <div class="logo">
            <h1>📱 Réinitialisation par WhatsApp</h1>
            <p>Suivez les étapes pour réinitialiser votre mot de passe</p>
        </div>

        <!-- Messages flash -->
        {% for message in app.flashes('error') %}
            <div class="status-message status-error">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="status-message status-success">
                {{ message }}
            </div>
        {% endfor %}

        <!-- Étape 1: Saisie du token -->
        <div id="tokenBox" class="step-box">
            <div class="step-title">Étape 1 : Collez votre token WhatsApp</div>
            
            <div class="form-group">
                <input type="text" 
                       id="tokenField"
                       placeholder="Ex: 30e8435c-688b-4da9-bdca-69be587116d4"
                       autocomplete="off">
                <div class="help-text">
                    Le code a été envoyé sur votre WhatsApp
                </div>
            </div>

            <div id="tokenStatus" class="status-message"></div>

            <button id="validateTokenBtn" class="btn-submit">
                ✅ Valider le token
            </button>
        </div>

        <!-- Étape 2: Nouveau mot de passe (caché au début) -->
        <div id="passwordFormBox" class="step-box hidden">
            <div class="step-title">Étape 2 : Choisissez votre nouveau mot de passe</div>
            
            <div class="form-group">
                <label>Nouveau mot de passe</label>
                <input type="password" 
                       id="newPasswordField"
                       placeholder="Nouveau mot de passe"
                       autocomplete="new-password">
                <div class="help-text">
                    Minimum 6 caractères
                </div>
            </div>

            <div class="form-group">
                <label>Confirmer le mot de passe</label>
                <input type="password" 
                       id="confirmPasswordField"
                       placeholder="Confirmer le mot de passe"
                       autocomplete="new-password">
            </div>

            <div id="passwordStatus" class="status-message"></div>

            <button id="resetPasswordBtn" class="btn-submit">
                🔄 Réinitialiser mon mot de passe
            </button>
        </div>

        <a href="{{ path('app_login') }}" class="btn-back">
            ← Retour au login
        </a>
    </div>
</div>

<script>
const tokenBox = document.getElementById('tokenBox');
const passwordFormBox = document.getElementById('passwordFormBox');
const tokenField = document.getElementById('tokenField');
const validateTokenBtn = document.getElementById('validateTokenBtn');
const newPasswordField = document.getElementById('newPasswordField');
const confirmPasswordField = document.getElementById('confirmPasswordField');
const resetPasswordBtn = document.getElementById('resetPasswordBtn');
const tokenStatus = document.getElementById('tokenStatus');
const passwordStatus = document.getElementById('passwordStatus');

let currentToken = '{{ token|default('') }}';

function showStatus(element, message, isError = false) {
    element.innerHTML = message;
    element.className = 'status-message ' + (isError ? 'status-error' : 'status-success');
    
    if (!isError) {
        setTimeout(() => {
            if (element.innerHTML === message) {
                element.innerHTML = '';
            }
        }, 3000);
    }
}

function setButtonLoading(btn, loading, originalText) {
    if (loading) {
        btn.disabled = true;
        btn.innerHTML = '<span class="loading"></span> Chargement...';
    } else {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}

// Valider le token
validateTokenBtn.addEventListener('click', function() {
    const token = tokenField.value.trim();
    
    if (!token) {
        showStatus(tokenStatus, 'Veuillez saisir le token WhatsApp', true);
        tokenField.classList.add('error');
        tokenField.focus();
        return;
    }
    
    if (token.length < 8) {
        showStatus(tokenStatus, 'Le token doit contenir au moins 8 caractères', true);
        tokenField.classList.add('error');
        tokenField.focus();
        return;
    }
    
    setButtonLoading(validateTokenBtn, true, '✅ Valider le token');
    
    // Appeler l'API pour valider le token
    fetch('/reset-password/validate', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'token=' + encodeURIComponent(token)
    })
    .then(response => response.text())
    .then(html => {
        setButtonLoading(validateTokenBtn, false, '✅ Valider le token');
        
        // Vérifier si la réponse contient un message d'erreur
        if (html.includes('Token invalide ou expiré')) {
            showStatus(tokenStatus, '❌ Token invalide ou expiré', true);
            tokenField.classList.add('error');
        } else {
            currentToken = token;
            showStatus(tokenStatus, '✅ Token valide !', false);
            
            // Masquer l'étape 1 et afficher l'étape 2
            tokenBox.classList.add('hidden');
            passwordFormBox.classList.remove('hidden');
            
            // Focus sur le champ de mot de passe
            newPasswordField.focus();
        }
    })
    .catch(error => {
        setButtonLoading(validateTokenBtn, false, '✅ Valider le token');
        showStatus(tokenStatus, '❌ Erreur de connexion', true);
        console.error('Error:', error);
    });
});

// Réinitialiser le mot de passe
resetPasswordBtn.addEventListener('click', function() {
    const newPassword = newPasswordField.value;
    const confirmPassword = confirmPasswordField.value;
    
    if (!newPassword) {
        showStatus(passwordStatus, 'Veuillez saisir votre nouveau mot de passe', true);
        newPasswordField.classList.add('error');
        newPasswordField.focus();
        return;
    }
    
    if (newPassword.length < 6) {
        showStatus(passwordStatus, 'Le mot de passe doit contenir au moins 6 caractères', true);
        newPasswordField.classList.add('error');
        newPasswordField.focus();
        return;
    }
    
    if (!confirmPassword) {
        showStatus(passwordStatus, 'Veuillez confirmer votre mot de passe', true);
        confirmPasswordField.classList.add('error');
        confirmPasswordField.focus();
        return;
    }
    
    if (newPassword !== confirmPassword) {
        showStatus(passwordStatus, 'Les mots de passe ne correspondent pas', true);
        confirmPasswordField.classList.add('error');
        confirmPasswordField.focus();
        return;
    }
    
    setButtonLoading(resetPasswordBtn, true, '🔄 Réinitialiser mon mot de passe');
    
    const formData = new FormData();
    formData.append('token', currentToken);
    formData.append('new_password', newPassword);
    formData.append('confirm_password', confirmPassword);
    
    fetch('/reset-password/reset', {
        method: 'POST',
        body: formData
    })
    .then(response => response.text())
    .then(html => {
        if (html.includes('Mot de passe réinitialisé avec succès')) {
            showStatus(passwordStatus, '✅ Mot de passe réinitialisé avec succès !', false);
            
            // Rediriger vers le login après 2 secondes
            setTimeout(() => {
                window.location.href = '/login';
            }, 2000);
        } else {
            setButtonLoading(resetPasswordBtn, false, '🔄 Réinitialiser mon mot de passe');
            
            // Extraire le message d'erreur de la réponse HTML
            const errorMatch = html.match(/❌ ([^<]+)/);
            if (errorMatch) {
                showStatus(passwordStatus, '❌ ' + errorMatch[1], true);
            } else {
                showStatus(passwordStatus, '❌ Erreur lors de la réinitialisation', true);
            }
        }
    })
    .catch(error => {
        setButtonLoading(resetPasswordBtn, false, '🔄 Réinitialiser mon mot de passe');
        showStatus(passwordStatus, '❌ Erreur de connexion', true);
        console.error('Error:', error);
    });
});

// Focus automatique sur le champ token
tokenField.focus();

// Enlever la classe error quand l'utilisateur tape
tokenField.addEventListener('input', function() {
    this.classList.remove('error');
});

newPasswordField.addEventListener('input', function() {
    this.classList.remove('error');
});

confirmPasswordField.addEventListener('input', function() {
    this.classList.remove('error');
});
</script>
{% endblock %}