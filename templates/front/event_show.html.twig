{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Détail événement{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .event-show-page {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 12% 8%, rgba(13, 71, 161, 0.09), transparent 38%),
                radial-gradient(circle at 88% 2%, rgba(25, 118, 210, 0.14), transparent 42%),
                #eef2f6;
            padding: 34px 16px 48px;
        }

        .event-show-shell {
            max-width: 980px;
            margin: 0 auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #1a4f97;
            border: 1px solid #c7d8ee;
            border-radius: 10px;
            padding: 9px 13px;
            background: #f5f9ff;
            margin-bottom: 18px;
            font-weight: 600;
        }

        .show-card {
            background: #ffffff;
            border: 1px solid #d7e2f0;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
        }

        .show-cover {
            min-height: 220px;
            background: linear-gradient(125deg, #d5e7ff 0%, #b8d4f7 48%, #9fc6ef 100%);
            position: relative;
            padding: 22px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
        }

        .show-badge,
        .show-status {
            border-radius: 999px;
            padding: 7px 14px;
            font-size: 12px;
            font-weight: 700;
        }

        .show-status.live {
            color: #0d8f49;
            background: #e7f8ef;
        }

        .show-status.upcoming {
            color: #1e5da8;
            background: #e9f1ff;
        }

        .show-badge {
            background: #4caf50;
            color: #ffffff;
        }

        .show-body {
            padding: 24px;
        }

        .show-title {
            margin: 0 0 12px;
            font-size: clamp(30px, 4vw, 42px);
            color: #0f2037;
            letter-spacing: -0.4px;
        }

        .show-description {
            color: #4d6078;
            line-height: 1.7;
            font-size: 16px;
            margin-bottom: 20px;
            white-space: pre-line;
        }

        .show-poster-wrap {
            border: 1px solid #dbe5f2;
            border-radius: 14px;
            background: #f8fbff;
            min-height: 260px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .show-poster-wrap img {
            display: block;
            width: 100%;
            max-height: 560px;
            object-fit: contain;
        }

        .show-poster-empty {
            color: #5f738c;
            font-size: 14px;
            text-align: center;
            padding: 16px;
        }

        .show-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        .show-item {
            border: 1px solid #dbe5f2;
            border-radius: 12px;
            background: #f8fbff;
            padding: 12px;
        }

        .show-label {
            display: block;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #61748d;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .show-value {
            color: #1a2d45;
            font-weight: 600;
            font-size: 15px;
        }

        .show-price {
            color: #0e9b60;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 18px;
        }

        .weather-panel {
            border: 1px solid #fbbf24;
            border-radius: 16px;
            background: linear-gradient(135deg, #fff8e1, #fff3c4);
            padding: 18px;
            margin-bottom: 20px;
        }

        .weather-panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
        }

        .weather-panel-title {
            margin: 0;
            color: #92400e;
            font-size: 15px;
            font-weight: 800;
        }

        .weather-panel-icon {
            font-size: 30px;
            line-height: 1;
        }

        .weather-panel-temp {
            color: #0f172a;
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -0.4px;
        }

        .weather-panel-desc {
            margin-top: 4px;
            color: #334155;
            font-size: 14px;
            font-weight: 700;
        }

        .weather-panel-meta {
            margin-top: 10px;
            display: grid;
            gap: 4px;
            color: #475569;
            font-size: 13px;
            font-weight: 600;
        }

        .weather-panel-error {
            color: #b45309;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.5;
        }

        .experience-box {
            border: 1px solid #d1ddef;
            border-radius: 14px;
            background: #f7fafe;
            padding: 18px;
            margin-bottom: 20px;
        }

        .experience-title {
            margin: 0 0 12px;
            color: #132947;
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.3px;
        }

        .experience-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 10px;
        }

        .experience-item {
            color: #415570;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .check {
            color: #0eb36f;
            font-weight: 800;
            font-size: 20px;
        }

        .show-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .show-actions form {
            margin: 0;
        }

        .show-btn {
            border-radius: 10px;
            height: 42px;
            padding: 0 16px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .show-btn.primary {
            background: #155ec0;
            color: #ffffff;
        }

        .show-btn.secondary {
            background: #e7f1ff;
            color: #174a92;
            border: 1px solid #c3d6ee;
        }

        .flash-stack {
            display: grid;
            gap: 10px;
            margin-bottom: 14px;
        }

        .flash-msg {
            border-radius: 10px;
            padding: 11px 14px;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .flash-success {
            background: #e8f8ef;
            color: #0d8f49;
            border-color: #bceacb;
        }

        .flash-error {
            background: #ffefef;
            color: #b3261e;
            border-color: #f7c9c7;
        }

        .flash-info {
            background: #eaf2ff;
            color: #1f4d92;
            border-color: #c7daf8;
        }

        .flash-warning {
            background: #fff6e8;
            color: #9d6408;
            border-color: #f2ddb6;
        }

        @media (max-width: 700px) {
            .show-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set nowTs = 'now'|date('U') %}
    {% set startTs = event.startDate ? event.startDate|date('U') : 0 %}
    {% set statusType = startTs > nowTs ? 'upcoming' : 'live' %}
    {% set pendingEventId = app.session ? app.session.get('pending_event') : null %}
    {% set isPendingParticipationForThisEvent = pendingEventId is not null and pendingEventId == event.id %}
    {% set isParticipantUser = app.user and ('ROLE_ADMIN' not in app.user.roles) and ('ROLE_ORGANISATEUR' not in app.user.roles) and ('ROLE_SPONSOR' not in app.user.roles) %}

    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}'">Accueil</button>
                <button class="nav-link" style="color:#0D47A1; font-weight:700; text-decoration:underline;" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#features'">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#contact'">Contact</button>
            </div>

            <div class="nav-buttons">
                <button onclick="toggleTheme()" style="background: rgba(33, 150, 243, 0.1); color: #2196F3; border: 1px solid #2196F3; border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold; margin-right: 10px;">
                    <i class="fas fa-moon" id="themeIconEventShow"></i>
                    <span id="themeTextEventShow">Mode Sombre</span>
                </button>
                {% if isParticipantUser %}
                    {% set frontUnreadCount = unreadNotificationCount|default(notificationUnreadCount|default(0)) %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <details class="participant-chip-menu">
                        <summary class="participant-chip">
                            <span class="participant-chip-avatar">{{ app.user.initials }}</span>
                            <span class="participant-chip-meta">
                                <span class="participant-chip-name">{{ app.user.fullName }}</span>
                                <span class="participant-chip-role">Participant</span>
                            </span>
                        </summary>
                        <div class="participant-chip-dropdown">
                            <a class="participant-chip-action" href="{{ path('app_logout') }}">Déconnexion</a>
                        </div>
                    </details>
                    <div
                        class="notif-bell-wrap"
                        data-notif-root
                        data-notif-url="{{ path('app_front_notifications_latest') }}"
                        data-notif-mark-read-url="{{ path('app_front_notifications_mark_all_read') }}"
                        data-notif-csrf-token="{{ csrf_token('front_notifications_mark_all') }}"
                        data-notif-delete-url-template="{{ path('app_front_notifications_delete', {'id': '__id__'}) }}"
                        data-notif-delete-csrf-token="{{ csrf_token('front_notifications_delete') }}"
                    >
                        <button type="button" class="notif-bell-btn" aria-label="Notifications" data-notif-toggle>
                            <span aria-hidden="true">🔔</span>
                            {% if frontUnreadCount > 0 %}
                                <span class="notif-badge" data-notif-badge>{{ frontUnreadCount > 99 ? '99+' : frontUnreadCount }}</span>
                            {% else %}
                                <span class="notif-badge" data-notif-badge hidden>0</span>
                            {% endif %}
                        </button>

                        <div class="notif-dropdown" data-notif-dropdown hidden>
                            <div class="notif-dropdown-head">
                                <span class="notif-dropdown-title">Notifications</span>
                                <button type="button" class="notif-mark-read-btn" data-notif-mark-all>Tout marquer comme lu</button>
                            </div>
                            <div class="notif-list" data-notif-list>
                                <div class="notif-empty">Chargement...</div>
                            </div>
                        </div>
                    </div>
                {% elseif app.user %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_dashboard') }}'">Back-office</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_logout') }}'">Déconnexion</button>
                {% else %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_login') }}'">Connexion</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_register') }}'">Inscription</button>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="event-show-page">
        <div class="event-show-shell">
            <a class="back-link" href="{{ path('app_public_events') }}">← Retour à tous les événements</a>

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-msg flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-msg flash-error">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="flash-msg flash-info">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="flash-msg flash-warning">{{ message }}</div>
                {% endfor %}
            </div>

            <article class="show-card">
                <div class="show-cover">
                    <span class="show-status {{ statusType }}">{{ statusType == 'upcoming' ? 'À venir' : 'En cours' }}</span>
                    <span class="show-badge">{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : 'Sans catégorie' }}</span>
                </div>

                <div class="show-body">
                    <h1 class="show-title">{{ event.title }}</h1>

                    <div class="show-poster-wrap">
                        {% if event.imageUrl %}
                            <img src="{{ asset(event.imageUrl) }}" alt="Affiche de {{ event.title }}">
                        {% else %}
                            <div class="show-poster-empty">Aucune affiche disponible pour cet événement.</div>
                        {% endif %}
                    </div>

                    <p class="show-description">{{ event.description ?: 'Description non disponible.' }}</p>

                    <div class="show-grid">
                        <div class="show-item">
                            <span class="show-label">📆 Date de début</span>
                            <div class="show-value">{{ event.startDate ? event.startDate|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">📆 Date de fin</span>
                            <div class="show-value">{{ event.endDate ? event.endDate|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">⏰ Heure de début</span>
                            <div class="show-value">{{ event.startDate ? event.startDate|date('H:i') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">⏰ Heure de fin</span>
                            <div class="show-value">{{ event.endDate ? event.endDate|date('H:i') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">📍 Lieu</span>
                            <div class="show-value">{{ event.location ?: 'Lieu non précisé' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">🏙️ Ville</span>
                            <div class="show-value">{{ event.ville ?: '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">👥 Capacité</span>
                            <div class="show-value">{{ event.capacity ?: 0 }} participants</div>
                        </div>
                    </div>

                    <section class="weather-panel">
                        <div class="weather-panel-head">
                            <h2 class="weather-panel-title">Météo actuelle</h2>
                            <div class="weather-panel-icon">{{ eventWeather ? eventWeather.icon : '🌤️' }}</div>
                        </div>
                        {% if eventWeather %}
                            <div class="weather-panel-temp">{{ eventWeather.temperature|number_format(1, '.', ' ') }}°C</div>
                            <div class="weather-panel-desc">{{ eventWeather.description }}</div>
                            <div class="weather-panel-meta">
                                <div>📍 {{ eventWeather.governorate }}</div>
                                <div>💨 {{ eventWeather.windSpeed }} km/h</div>
                                <div>💧 {{ eventWeather.humidity }} %</div>
                            </div>
                        {% elseif weatherError %}
                            <div class="weather-panel-error">{{ weatherError }}</div>
                        {% else %}
                            <div class="weather-panel-error">Aucune météo disponible pour cet événement.</div>
                        {% endif %}
                    </section>

                    <div class="show-price">{{ event.isFree ? 'Gratuit' : (event.ticketPrice|number_format(2, '.', ' ') ~ ' TND') }}</div>

                    <section class="experience-box">
                        <h2 class="experience-title">✨ Ce qui vous attend</h2>
                        <ul class="experience-list">
                            <li class="experience-item"><span class="check">✓</span> Contenu enrichissant et interactif</li>
                            <li class="experience-item"><span class="check">✓</span> Networking avec des professionnels</li>
                            <li class="experience-item"><span class="check">✓</span> Certificat de participation</li>
                        </ul>
                    </section>

                    <div class="show-actions">
                        <a class="show-btn secondary" href="{{ path('app_public_events') }}">Voir les autres événements</a>
                        {% if hasEventTicket|default(false) %}
                            <a class="show-btn primary" href="{{ path('app_my_tickets') }}">Voir mon billet</a>
                        {% else %}
                            <form method="post" action="{{ path('app_public_event_participate', {'id': event.id}) }}" style="display:inline-flex;">
                                <input type="hidden" name="_token" value="{{ csrf_token('participate_event_' ~ event.id) }}">
                                <button type="submit" class="show-btn primary">{{ isPendingParticipationForThisEvent ? 'Confirmer ma participation' : 'Participer' }}</button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </article>
        </div>
    </main>

    <script>
        // Notification JavaScript
        (function () {
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function renderNotifications(listNode, notifications) {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    listNode.innerHTML = '<div class="notif-empty">Aucune notification.</div>';
                    return;
                }

                listNode.innerHTML = notifications.map(function (item) {
                    var icon = item.icon ? escapeHtml(item.icon) : '🔔';
                    var type = item.type ? escapeHtml(item.type) : 'INFO';
                    var createdAt = item.createdAt ? escapeHtml(item.createdAt) : '-';
                    var title = item.title ? escapeHtml(item.title) : 'Notification';
                    var message = item.message ? escapeHtml(item.message) : '';
                    var readClass = item.isRead ? 'read' : 'unread';
                    var notificationId = Number(item.id || 0);

                    return '' +
                        '<article class="notif-item ' + readClass + '">' +
                            '<div class="notif-item-head">' +
                                '<span class="notif-item-meta">' +
                                    '<span>' + icon + ' ' + type + '</span>' +
                                    '<span>•</span>' +
                                    '<span>' + createdAt + '</span>' +
                                '</span>' +
                                '<button type="button" class="notif-delete-btn" title="Supprimer" aria-label="Supprimer notification" data-notif-delete-id="' + notificationId + '"><i class="fas fa-trash-alt" aria-hidden="true"></i></button>' +
                            '</div>' +
                            '<p class="notif-item-title">' + title + '</p>' +
                            '<p class="notif-item-message">' + message + '</p>' +
                        '</article>';
                }).join('');
            }

            function updateBadge(badgeNode, unreadCount) {
                if (!badgeNode) {
                    return;
                }

                if (unreadCount > 0) {
                    badgeNode.hidden = false;
                    badgeNode.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
                } else {
                    badgeNode.hidden = true;
                    badgeNode.textContent = '0';
                }
            }

            async function fetchLatest(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifUrl, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        const bodyText = await response.text();
                        throw new Error('HTTP ' + response.status + ' ' + bodyText.slice(0, 120));
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    renderNotifications(listNode, payload.notifications || []);
                } catch (error) {
                    const message = error && error.message ? error.message : 'Impossible de charger les notifications.';
                    listNode.innerHTML = '<div class="notif-empty">' + escapeHtml(message) + '</div>';
                }
            }

            async function markAllAsRead(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifMarkReadUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('mark all failed');
                    }

                    updateBadge(badgeNode, 0);
                    await fetchLatest(root, badge, listNode);
                } catch (error) {
                    // Keep silent to avoid intrusive UI in header.
                }
            }

            async function deleteNotification(root, notificationId, badgeNode, listNode) {
                const urlTemplate = root.dataset.notifDeleteUrlTemplate || '';
                if (!urlTemplate || !notificationId) {
                    return;
                }

                const deleteUrl = urlTemplate.replace('__id__', String(notificationId));

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifDeleteCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('delete failed');
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep quiet in header UI.
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                const roots = document.querySelectorAll('[data-notif-root]');

                roots.forEach(function (root) {
                    const toggle = root.querySelector('[data-notif-toggle]');
                    const dropdown = root.querySelector('[data-notif-dropdown]');
                    const badge = root.querySelector('[data-notif-badge]');
                    const list = root.querySelector('[data-notif-list]');
                    const markAll = root.querySelector('[data-notif-mark-all]');

                    if (!toggle || !dropdown || !list) {
                        return;
                    }

                    fetchLatest(root, badge, list);

                    toggle.addEventListener('click', function (event) {
                        event.preventDefault();
                        const isOpen = !dropdown.hidden;

                        document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                            node.hidden = true;
                        });

                        dropdown.hidden = isOpen;
                        if (!isOpen) {
                            fetchLatest(root, badge, list);
                        }
                    });

                    if (markAll) {
                        markAll.addEventListener('click', function (event) {
                            event.preventDefault();
                            markAllAsRead(root, badge, list);
                        });
                    }

                    list.addEventListener('click', function (event) {
                        const deleteBtn = event.target.closest('[data-notif-delete-id]');
                        if (!deleteBtn) {
                            return;
                        }

                        event.preventDefault();
                        const notificationId = Number(deleteBtn.getAttribute('data-notif-delete-id'));
                        if (!notificationId) {
                            return;
                        }

                        deleteNotification(root, notificationId, badge, list);
                    });

                    root.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            dropdown.hidden = true;
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    const inside = event.target.closest('[data-notif-root]');
                    if (inside) {
                        return;
                    }

                    document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                        node.hidden = true;
                    });
                });
            });
        })();
    </script>
{% endblock %}