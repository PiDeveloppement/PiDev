{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Détail événement{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .event-show-page {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 12% 8%, rgba(13, 71, 161, 0.09), transparent 38%),
                radial-gradient(circle at 88% 2%, rgba(25, 118, 210, 0.14), transparent 42%),
                #eef2f6;
            padding: 34px 16px 48px;
        }

        .event-show-shell {
            max-width: 980px;
            margin: 0 auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #1a4f97;
            border: 1px solid #c7d8ee;
            border-radius: 10px;
            padding: 9px 13px;
            background: #f5f9ff;
            margin-bottom: 18px;
            font-weight: 600;
        }

        .show-card {
            background: #ffffff;
            border: 1px solid #d7e2f0;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
        }

        .show-cover {
            min-height: 220px;
            background: linear-gradient(125deg, #d5e7ff 0%, #b8d4f7 48%, #9fc6ef 100%);
            position: relative;
            padding: 22px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
        }

        .show-badge,
        .show-status {
            border-radius: 999px;
            padding: 7px 14px;
            font-size: 12px;
            font-weight: 700;
        }

        .show-status.live {
            color: #0d8f49;
            background: #e7f8ef;
        }

        .show-status.upcoming {
            color: #1e5da8;
            background: #e9f1ff;
        }

        .show-badge {
            background: #4caf50;
            color: #ffffff;
        }

        .show-body {
            padding: 24px;
        }

        .show-title {
            margin: 0 0 12px;
            font-size: clamp(30px, 4vw, 42px);
            color: #0f2037;
            letter-spacing: -0.4px;
        }

        .show-description {
            color: #4d6078;
            line-height: 1.7;
            font-size: 16px;
            margin-bottom: 20px;
            white-space: pre-line;
        }

        .show-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        .show-item {
            border: 1px solid #dbe5f2;
            border-radius: 12px;
            background: #f8fbff;
            padding: 12px;
        }

        .show-label {
            display: block;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #61748d;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .show-value {
            color: #1a2d45;
            font-weight: 600;
            font-size: 15px;
        }

        .show-price {
            color: #0e9b60;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 18px;
        }

        .experience-box {
            border: 1px solid #d1ddef;
            border-radius: 14px;
            background: #f7fafe;
            padding: 18px;
            margin-bottom: 20px;
        }

        .experience-title {
            margin: 0 0 12px;
            color: #132947;
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.3px;
        }

        .experience-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 10px;
        }

        .experience-item {
            color: #415570;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .check {
            color: #0eb36f;
            font-weight: 800;
            font-size: 20px;
        }

        .show-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .show-actions form {
            margin: 0;
        }

        .show-btn {
            border-radius: 10px;
            height: 42px;
            padding: 0 16px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .show-btn.primary {
            background: #155ec0;
            color: #ffffff;
        }

        .show-btn.secondary {
            background: #e7f1ff;
            color: #174a92;
            border: 1px solid #c3d6ee;
        }

        .flash-stack {
            display: grid;
            gap: 10px;
            margin-bottom: 14px;
        }

        .flash-msg {
            border-radius: 10px;
            padding: 11px 14px;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .flash-success {
            background: #e8f8ef;
            color: #0d8f49;
            border-color: #bceacb;
        }

        .flash-error {
            background: #ffefef;
            color: #b3261e;
            border-color: #f7c9c7;
        }

        .flash-info {
            background: #eaf2ff;
            color: #1f4d92;
            border-color: #c7daf8;
        }

        .flash-warning {
            background: #fff6e8;
            color: #9d6408;
            border-color: #f2ddb6;
        }

        @media (max-width: 700px) {
            .show-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set nowTs = 'now'|date('U') %}
    {% set startTs = event.startDate ? event.startDate|date('U') : 0 %}
    {% set statusType = startTs > nowTs ? 'upcoming' : 'live' %}

    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            {% set role_name = app.user and app.user.role ? (app.user.role.roleName|default('')|lower) : '' %}
            {% set is_sponsor_user = app.user and (('ROLE_SPONSOR' in app.user.roles) or role_name == 'sponsor' or app.user.roleId == 3) %}
            <div class="nav-links">
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}'">Accueil</button>
                <button class="nav-link" style="color:#0D47A1; font-weight:700; text-decoration:underline;" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>
                {% if is_sponsor_user %}
                    <button class="nav-link" onclick="window.location.href='{{ path('app_sponsor_portal') }}'">Recommandations sponsor</button>
                {% endif %}
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#features'">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#contact'">Contact</button>
            </div>

            <div class="nav-buttons">
                {% include 'partials/public_auth_buttons.html.twig' %}
            </div>
        </div>
    </nav>

    <main class="event-show-page">
        <div class="event-show-shell">
            <a class="back-link" href="{{ path('app_public_events') }}">← Retour à tous les événements</a>

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-msg flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-msg flash-error">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="flash-msg flash-info">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="flash-msg flash-warning">{{ message }}</div>
                {% endfor %}
            </div>

            <article class="show-card">
                <div class="show-cover">
                    <span class="show-status {{ statusType }}">{{ statusType == 'upcoming' ? 'À venir' : 'En cours' }}</span>
                    <span class="show-badge">{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : 'Sans catégorie' }}</span>
                </div>

                <div class="show-body">
                    <h1 class="show-title">{{ event.title }}</h1>
                    <p class="show-description">{{ event.description ?: 'Description non disponible.' }}</p>

                    <div class="show-grid">
                        <div class="show-item">
                            <span class="show-label">📆 Date de début</span>
                            <div class="show-value">{{ event.startDate ? event.startDate|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">📆 Date de fin</span>
                            <div class="show-value">{{ event.endDate ? event.endDate|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">⏰ Heure de début</span>
                            <div class="show-value">{{ event.startDate ? event.startDate|date('H:i') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">⏰ Heure de fin</span>
                            <div class="show-value">{{ event.endDate ? event.endDate|date('H:i') : '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">📍 Lieu</span>
                            <div class="show-value">{{ event.location ?: 'Lieu non précisé' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">🏙️ Ville</span>
                            <div class="show-value">{{ event.ville ?: '-' }}</div>
                        </div>
                        <div class="show-item">
                            <span class="show-label">👥 Capacité</span>
                            <div class="show-value">{{ event.capacity ?: 0 }} participants</div>
                        </div>
                    </div>

                    <div class="show-price">{{ event.isFree ? 'Gratuit' : (event.ticketPrice|number_format(2, '.', ' ') ~ ' TND') }}</div>

                    <section class="experience-box">
                        <h2 class="experience-title">✨ Ce qui vous attend</h2>
                        <ul class="experience-list">
                            <li class="experience-item"><span class="check">✓</span> Contenu enrichissant et interactif</li>
                            <li class="experience-item"><span class="check">✓</span> Networking avec des professionnels</li>
                            <li class="experience-item"><span class="check">✓</span> Certificat de participation</li>
                        </ul>
                    </section>

                    <div class="show-actions">
                        <a class="show-btn secondary" href="{{ path('app_public_events') }}">Voir les autres événements</a>
                        <a class="show-btn primary" href="{{ path('app_login', {'pending_event': event.id}) }}">Participer</a>
                        <a class="show-btn primary" href="{{ path('app_quiz_start', {'event_id': event.id}) }}" style="background: #9c27b0;">🎯 Quiz</a>
                    </div>
                </div>
            </article>
        </div>
    </main>
{% endblock %}

