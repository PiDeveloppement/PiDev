{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Confirmation participation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# FIX TURBO: force full reload sur cette page #}
    <meta name="turbo-visit-control" content="reload">
    <style>
        .confirm-page {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 12% 8%, rgba(13, 71, 161, 0.09), transparent 38%),
                radial-gradient(circle at 88% 2%, rgba(25, 118, 210, 0.14), transparent 42%),
                #eef2f6;
            padding: 36px 16px 56px;
        }

        .confirm-shell {
            max-width: 940px;
            margin: 0 auto;
        }

        .confirm-card {
            background: #ffffff;
            border: 1px solid #d7e2f0;
            border-radius: 20px;
            box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
            overflow: hidden;
        }

        .confirm-head {
            padding: 26px 28px;
            background: linear-gradient(120deg, #d7e8fb 0%, #c3daf6 100%);
            border-bottom: 1px solid #cfe0f4;
        }

        .confirm-title {
            margin: 0 0 8px;
            font-size: clamp(28px, 3.6vw, 40px);
            color: #0f2037;
        }

        .confirm-subtitle {
            margin: 0;
            color: #4f647b;
            line-height: 1.6;
        }

        .confirm-body {
            padding: 26px 28px 30px;
        }

        .confirm-message {
            background: #f8fbff;
            border: 1px solid #dbe5f2;
            border-radius: 14px;
            padding: 18px;
            color: #31455f;
            line-height: 1.7;
            margin-bottom: 18px;
        }

        .confirm-event-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 22px;
        }

        .confirm-item {
            border: 1px solid #dbe5f2;
            border-radius: 12px;
            background: #f8fbff;
            padding: 12px;
        }

        .confirm-label {
            display: block;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #61748d;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .confirm-value {
            color: #1a2d45;
            font-weight: 600;
            font-size: 15px;
        }

        .confirm-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .confirm-btn {
            border-radius: 10px;
            height: 44px;
            padding: 0 16px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .confirm-btn.primary {
            background: #155ec0;
            color: #ffffff;
        }

        .confirm-btn.secondary {
            background: #e7f1ff;
            color: #174a92;
            border: 1px solid #c3d6ee;
        }

        @media (max-width: 700px) {
            .confirm-event-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block public_content %}
    {{ include('partials/public_header.html.twig', { active_page: 'events' }) }}

    <main class="confirm-page">
        <div class="confirm-shell">
            <div class="confirm-card">
                <div class="confirm-head">
                    <h1 class="confirm-title">Confirmer votre participation</h1>
                    <p class="confirm-subtitle">Le billet ne sera créé qu'après votre validation finale. Vérifiez les détails avant de continuer.</p>
                </div>

                <div class="confirm-body">
                    <div class="flash-stack">
                        {% for message in app.flashes('success') %}
                            <div class="flash-msg flash-success">{{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('error') %}
                            <div class="flash-msg flash-error">{{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('info') %}
                            <div class="flash-msg flash-info">{{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('warning') %}
                            <div class="flash-msg flash-warning">{{ message }}</div>
                        {% endfor %}
                    </div>

                    <div class="confirm-message">
                        Vous êtes sur le point de rejoindre <strong>{{ event.title }}</strong>. Si vous confirmez, votre billet sera créé automatiquement et vous serez dirigé vers vos billets.
                    </div>

                    <div class="confirm-event-grid">
                        <div class="confirm-item">
                            <span class="confirm-label">Date</span>
                            <div class="confirm-value">{{ event.startDate ? event.startDate|date('d/m/Y H:i') : '-' }}</div>
                        </div>
                        <div class="confirm-item">
                            <span class="confirm-label">Lieu</span>
                            <div class="confirm-value">{{ event.location ?: 'Lieu non défini' }}</div>
                        </div>
                        <div class="confirm-item">
                            <span class="confirm-label">Catégorie</span>
                            <div class="confirm-value">{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : 'Sans catégorie' }}</div>
                        </div>
                        <div class="confirm-item">
                            <span class="confirm-label">Tarif</span>
                            <div class="confirm-value">{{ event.isFree ? 'Gratuit' : (event.ticketPrice|number_format(2, '.', ' ') ~ ' TND') }}</div>
                        </div>
                    </div>

                    <div class="confirm-actions">
                        <form method="post" action="{{ path('app_public_event_participation_confirm', {'id': event.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('confirm_participation_event_' ~ event.id) }}">
                            <button type="submit" class="confirm-btn primary">Oui, confirmer ma participation</button>
                        </form>
                        <a class="confirm-btn secondary" href="{{ path('app_public_event_show', {'id': event.id}) }}">Annuler</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Notification JavaScript
        (function () {
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function renderNotifications(listNode, notifications) {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    listNode.innerHTML = '<div class="notif-empty">Aucune notification.</div>';
                    return;
                }

                listNode.innerHTML = notifications.map(function (item) {
                    var icon = item.icon ? escapeHtml(item.icon) : '🔔';
                    var type = item.type ? escapeHtml(item.type) : 'INFO';
                    var createdAt = item.createdAt ? escapeHtml(item.createdAt) : '-';
                    var title = item.title ? escapeHtml(item.title) : 'Notification';
                    var message = item.message ? escapeHtml(item.message) : '';
                    var readClass = item.isRead ? 'read' : 'unread';
                    var notificationId = Number(item.id || 0);

                    return '' +
                        '<article class="notif-item ' + readClass + '">' +
                            '<div class="notif-item-head">' +
                                '<span class="notif-item-meta">' +
                                    '<span>' + icon + ' ' + type + '</span>' +
                                    '<span>•</span>' +
                                    '<span>' + createdAt + '</span>' +
                                '</span>' +
                                '<button type="button" class="notif-delete-btn" title="Supprimer" aria-label="Supprimer notification" data-notif-delete-id="' + notificationId + '"><i class="fas fa-trash-alt" aria-hidden="true"></i></button>' +
                            '</div>' +
                            '<p class="notif-item-title">' + title + '</p>' +
                            '<p class="notif-item-message">' + message + '</p>' +
                        '</article>';
                }).join('');
            }

            function updateBadge(badgeNode, unreadCount) {
                if (!badgeNode) {
                    return;
                }

                if (unreadCount > 0) {
                    badgeNode.hidden = false;
                    badgeNode.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
                } else {
                    badgeNode.hidden = true;
                    badgeNode.textContent = '0';
                }
            }

            async function fetchLatest(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifUrl, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        const bodyText = await response.text();
                        throw new Error('HTTP ' + response.status + ' ' + bodyText.slice(0, 120));
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    renderNotifications(listNode, payload.notifications || []);
                } catch (error) {
                    const message = error && error.message ? error.message : 'Impossible de charger les notifications.';
                    listNode.innerHTML = '<div class="notif-empty">' + escapeHtml(message) + '</div>';
                }
            }

            async function markAllAsRead(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifMarkReadUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('mark all failed');
                    }

                    updateBadge(badgeNode, 0);
                    await fetchLatest(root, badge, listNode);
                } catch (error) {
                    // Keep silent to avoid intrusive UI in header.
                }
            }

            async function deleteNotification(root, notificationId, badgeNode, listNode) {
                const urlTemplate = root.dataset.notifDeleteUrlTemplate || '';
                if (!urlTemplate || !notificationId) {
                    return;
                }

                const deleteUrl = urlTemplate.replace('__id__', String(notificationId));

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifDeleteCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('delete failed');
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep quiet in header UI.
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                const roots = document.querySelectorAll('[data-notif-root]');

                roots.forEach(function (root) {
                    const toggle = root.querySelector('[data-notif-toggle]');
                    const dropdown = root.querySelector('[data-notif-dropdown]');
                    const badge = root.querySelector('[data-notif-badge]');
                    const list = root.querySelector('[data-notif-list]');
                    const markAll = root.querySelector('[data-notif-mark-all]');

                    if (!toggle || !dropdown || !list) {
                        return;
                    }

                    fetchLatest(root, badge, list);

                    toggle.addEventListener('click', function (event) {
                        event.preventDefault();
                        const isOpen = !dropdown.hidden;

                        document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                            node.hidden = true;
                        });

                        dropdown.hidden = isOpen;
                        if (!isOpen) {
                            fetchLatest(root, badge, list);
                        }
                    });

                    if (markAll) {
                        markAll.addEventListener('click', function (event) {
                            event.preventDefault();
                            markAllAsRead(root, badge, list);
                        });
                    }

                    list.addEventListener('click', function (event) {
                        const deleteBtn = event.target.closest('[data-notif-delete-id]');
                        if (!deleteBtn) {
                            return;
                        }

                        event.preventDefault();
                        const notificationId = Number(deleteBtn.getAttribute('data-notif-delete-id'));
                        if (!notificationId) {
                            return;
                        }

                        deleteNotification(root, notificationId, badge, list);
                    });

                    root.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            dropdown.hidden = true;
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    const inside = event.target.closest('[data-notif-root]');
                    if (inside) {
                        return;
                    }

                    document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                        node.hidden = true;
                    });
                });
            });
        })();
    </script>
{% endblock %}