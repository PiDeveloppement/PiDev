{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Tous les evenements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# FIX TURBO: force full reload sur cette page #}
    <meta name="turbo-visit-control" content="reload">
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet">
    <style>
        .events-vitrine {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 0% 0%, rgba(13, 71, 161, 0.08), transparent 40%),
                radial-gradient(circle at 100% 10%, rgba(25, 118, 210, 0.12), transparent 42%),
                #eef2f6;
            padding-bottom: 54px;
        }

        .events-header {
            max-width: 1180px;
            margin: 0 auto;
            padding: 52px 16px 34px;
            text-align: center;
        }

        .events-title {
            color: #0f2037;
            font-size: clamp(34px, 4.8vw, 56px);
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }

        .events-subtitle {
            color: #5b6b7f;
            font-size: 19px;
            line-height: 1.55;
            margin-bottom: 12px;
        }

        .events-kpi {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            padding: 8px 14px;
            color: #0d47a1;
            background: rgba(13, 71, 161, 0.12);
            font-weight: 700;
            font-size: 13px;
        }

        .events-header-actions {
            margin-top: 14px;
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .calendar-open-btn {
            border: 0;
            border-radius: 12px;
            background: linear-gradient(135deg, #0d47a1, #1565c0 55%, #1976d2);
            color: #ffffff;
            font-weight: 800;
            font-size: 14px;
            letter-spacing: 0.2px;
            padding: 11px 18px;
            cursor: pointer;
            box-shadow: 0 12px 24px rgba(21, 101, 192, 0.3);
            transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
        }

        .calendar-open-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(21, 101, 192, 0.36);
            filter: brightness(1.04);
        }

        .calendar-open-btn:focus-visible {
            outline: none;
            box-shadow: 0 0 0 4px rgba(21, 101, 192, 0.24), 0 12px 24px rgba(21, 101, 192, 0.3);
        }

        .calendar-modal {
            position: fixed;
            inset: 0;
            background: rgba(10, 24, 44, 0.42);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1200;
            padding: 18px;
        }

        .calendar-modal.open {
            display: flex;
        }

        .calendar-modal-panel {
            width: min(1100px, 100%);
            max-height: 90vh;
            background: #ffffff;
            border-radius: 16px;
            border: 1px solid #d7e2f0;
            box-shadow: 0 20px 44px rgba(15, 23, 42, 0.26);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .calendar-modal-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-bottom: 1px solid #e2eaf4;
        }

        .calendar-modal-title {
            margin: 0;
            font-size: 20px;
            color: #0f2037;
        }

        .calendar-close-btn {
            border: 1px solid #c7d5e8;
            border-radius: 10px;
            background: #f6f9fd;
            color: #23406f;
            font-weight: 700;
            font-size: 13px;
            padding: 7px 11px;
            cursor: pointer;
        }

        .calendar-modal-body {
            padding: 12px;
            overflow: auto;
        }

        #eventsCalendarInModal {
            min-height: 640px;
        }

        .fc .fc-daygrid-day.category-tinted .fc-daygrid-day-frame {
            background: var(--category-day-bg, transparent);
            transition: background-color 0.2s ease;
        }

        .events-toolbar-wrap {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0 16px;
        }

        .events-toolbar {
            background: #ffffff;
            border: 1px solid #dbe5f0;
            border-radius: 20px;
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            padding: 20px;
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px;
        }

        .toolbar-control {
            height: 46px;
            border: 1px solid #ccd9ea;
            border-radius: 12px;
            background: #f8fbff;
            color: #1f2f45;
            padding: 0 14px;
            font-size: 14px;
            outline: none;
        }

        .toolbar-control:focus {
            border-color: #1565c0;
            box-shadow: 0 0 0 3px rgba(21, 101, 192, 0.15);
        }

        .events-content {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0 16px;
        }

        .results-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            color: #43536a;
            font-size: 16px;
            font-weight: 600;
        }

        .clear-btn {
            border: 1px solid #c7d5e8;
            border-radius: 10px;
            background: #f6f9fd;
            color: #23406f;
            font-weight: 600;
            font-size: 13px;
            padding: 8px 12px;
            cursor: pointer;
        }

        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 18px;
        }

        .event-card {
            background: #ffffff;
            border: 1px solid #d7e2f0;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
            transition: transform 0.22s ease, box-shadow 0.22s ease;
        }

        .event-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 32px rgba(15, 23, 42, 0.1);
        }

        .event-cover {
            background: linear-gradient(120deg, #d7e5f9, #c4daf7 55%, #b6d1f2);
            position: relative;
            overflow: hidden;
        }

        .event-cover.no-image {
            min-height: 188px;
        }

        .event-cover.has-image {
            background: transparent;
        }

        .event-cover::after {
            content: none;
        }

        .event-cover-image {
            position: relative;
            width: 100%;
            height: auto;
            object-fit: contain;
            object-position: center;
            display: block;
        }

        .event-status {
            position: absolute;
            top: 12px;
            left: 12px;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            z-index: 2;
        }

        .event-status.live {
            color: #0f8d49;
            background: #e7f8ef;
        }

        .event-status.upcoming {
            color: #245ea8;
            background: #e9f1ff;
        }

        .event-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            background: #4caf50;
            color: #ffffff;
            max-width: calc(100% - 24px);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            z-index: 2;
        }

        .event-body {
            padding: 16px;
        }

        .event-title {
            margin: 0 0 10px;
            font-size: 27px;
            line-height: 1.25;
            color: #0e1f35;
            min-height: 44px;
        }

        .event-meta {
            display: grid;
            gap: 7px;
            color: #5d6f84;
            font-size: 14px;
            margin-bottom: 14px;
        }

        .event-meta-line {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .event-meta-emoji {
            width: 18px;
            display: inline-flex;
            justify-content: center;
            font-size: 14px;
        }

        .event-price {
            color: #0e9b60;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 14px;
        }

        .event-actions {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .details-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 42px;
            text-decoration: none;
            border-radius: 10px;
            border: 1px solid #c3d6ee;
            background: #e7f1ff;
            color: #174a92;
            font-weight: 700;
        }

        .empty-state {
            text-align: center;
            border: 1px dashed #bfd0e4;
            border-radius: 16px;
            padding: 34px 18px;
            background: #ffffff;
            color: #5f7185;
            font-size: 16px;
        }

        .empty-state strong {
            display: block;
            color: #1f324e;
            margin-bottom: 8px;
            font-size: 20px;
        }

        .pagination-wrap {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 40px;
            height: 38px;
            border-radius: 10px;
            border: 1px solid #c7d5e8;
            background: #ffffff;
            color: #1f3f70;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            padding: 0 12px;
        }

        .page-btn.active {
            background: #155ec0;
            color: #ffffff;
            border-color: #155ec0;
        }

        .page-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
        }

        .footer-lite {
            margin: 34px auto 0;
            max-width: 1180px;
            padding: 22px 16px 10px;
            border-top: 1px solid #dce6f3;
            color: #8fa0b7;
            font-size: 13px;
            text-align: center;
        }

        @media (max-width: 980px) {
            .events-toolbar {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 640px) {
            .events-header {
                padding-top: 34px;
            }

            .events-title {
                font-size: 38px;
            }

            .results-row {
                align-items: stretch;
                flex-direction: column;
            }

            .clear-btn {
                width: 100%;
                height: 40px;
            }

            .events-toolbar {
                grid-template-columns: 1fr;
            }
        }

        /* ==================== DARK MODE ==================== */
        body.dark-mode {
            background-color: #0f172a;
        }

        body.dark-mode .events-page {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }

        body.dark-mode .events-title {
            color: #f1f5f9;
        }

        body.dark-mode .events-subtitle {
            color: #94a3b8;
        }

        body.dark-mode .event-card {
            background: #1e293b;
            border-color: #334155;
        }

        body.dark-mode .event-title {
            color: #f1f5f9;
        }

        body.dark-mode .event-meta {
            color: #94a3b8;
        }

        body.dark-mode .event-desc {
            color: #cbd5e1;
        }

        body.dark-mode .event-btn {
            background: #334155;
            color: #f1f5f9;
            border-color: #475569;
        }

        body.dark-mode .event-btn:hover {
            background: #475569;
        }

        body.dark-mode .search-input {
            background: #1e293b;
            border-color: #334155;
            color: #f1f5f9;
        }

        body.dark-mode .filter-btn {
            background: #334155;
            color: #f1f5f9;
            border-color: #475569;
        }

        body.dark-mode .filter-btn:hover {
            background: #475569;
        }

        body.dark-mode .filter-btn.active {
            background: #3b82f6;
            border-color: #3b82f6;
        }

        body.dark-mode .clear-btn {
            background: #334155;
            color: #f1f5f9;
            border-color: #475569;
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set isParticipantUser = app.user and ('ROLE_ADMIN' not in app.user.roles) and ('ROLE_ORGANISATEUR' not in app.user.roles) and ('ROLE_SPONSOR' not in app.user.roles) %}
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}'">Accueil</button>
                <button class="nav-link" style="color:#0D47A1; font-weight:700; text-decoration:underline;" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#features'">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#contact'">Contact</button>
            </div>

            <div class="nav-buttons">
                <button onclick="toggleTheme()" style="background: rgba(33, 150, 243, 0.1); color: #2196F3; border: 1px solid #2196F3; border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold; margin-right: 10px;">
                    <i class="fas fa-moon" id="themeIconEvents"></i>
                    <span id="themeTextEvents">Mode Sombre</span>
                </button>
                {% if isParticipantUser %}
                    {% set frontUnreadCount = unreadNotificationCount|default(notificationUnreadCount|default(0)) %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <details class="participant-chip-menu">
                        <summary class="participant-chip">
                            <span class="participant-chip-avatar">{{ app.user.initials }}</span>
                            <span class="participant-chip-meta">
                                <span class="participant-chip-name">{{ app.user.fullName }}</span>
                                <span class="participant-chip-role">Participant</span>
                            </span>
                        </summary>
                        <div class="participant-chip-dropdown">
                            <a class="participant-chip-action" href="{{ path('app_logout') }}">Déconnexion</a>
                        </div>
                    </details>
                    <div
                        class="notif-bell-wrap"
                        data-notif-root
                        data-notif-url="{{ path('app_front_notifications_latest') }}"
                        data-notif-mark-read-url="{{ path('app_front_notifications_mark_all_read') }}"
                        data-notif-csrf-token="{{ csrf_token('front_notifications_mark_all') }}"
                        data-notif-delete-url-template="{{ path('app_front_notifications_delete', {'id': '__id__'}) }}"
                        data-notif-delete-csrf-token="{{ csrf_token('front_notifications_delete') }}"
                    >
                        <button type="button" class="notif-bell-btn" aria-label="Notifications" data-notif-toggle>
                            <span aria-hidden="true">🔔</span>
                            {% if frontUnreadCount > 0 %}
                                <span class="notif-badge" data-notif-badge>{{ frontUnreadCount > 99 ? '99+' : frontUnreadCount }}</span>
                            {% else %}
                                <span class="notif-badge" data-notif-badge hidden>0</span>
                            {% endif %}
                        </button>

                        <div class="notif-dropdown" data-notif-dropdown hidden>
                            <div class="notif-dropdown-head">
                                <span class="notif-dropdown-title">Notifications</span>
                                <button type="button" class="notif-mark-read-btn" data-notif-mark-all>Tout marquer comme lu</button>
                            </div>
                            <div class="notif-list" data-notif-list>
                                <div class="notif-empty">Chargement...</div>
                            </div>
                        </div>
                    </div>
                {% elseif app.user %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_dashboard') }}'">Back-office</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_logout') }}'">Déconnexion</button>
                {% else %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_login') }}'">Connexion</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_register') }}'">Inscription</button>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="events-vitrine">
        <header class="events-header">
            <h1 class="events-title">Tous les événements</h1>
            <p class="events-subtitle">Découvrez et participez aux événements qui vous intéressent</p>
            <span class="events-kpi" id="eventsCountPill">{{ events|length }} événement(s)</span>
            <div class="events-header-actions">
                <button type="button" class="calendar-open-btn" id="openCalendarBtn">Voir le calendrier</button>
            </div>
        </header>

        <section class="events-toolbar-wrap">
            <div class="events-toolbar">
                <input id="searchInput" class="toolbar-control" type="text" placeholder="Rechercher un événement par titre ou lieu...">
                <select id="categoryFilter" class="toolbar-control">
                    <option value="">Toutes les catégories</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}">{{ (category.icon ?? '📁') ~ ' ' ~ category.name }}</option>
                    {% endfor %}
                </select>
                <select id="priceFilter" class="toolbar-control">
                    <option value="">Tous les prix</option>
                    <option value="free">Gratuit</option>
                    <option value="paid">Payant</option>
                </select>
                <select id="dateFilter" class="toolbar-control">
                    <option value="">Toutes les dates</option>
                    <option value="today">Aujourd'hui</option>
                    <option value="week">Cette semaine</option>
                    <option value="month">Ce mois</option>
                </select>
            </div>
        </section>

        <section class="events-content">
            <div class="results-row">
                <span id="resultLabel">{{ events|length }} événement(s) trouvé(s)</span>
                <button id="clearFiltersBtn" type="button" class="clear-btn">Réinitialiser les filtres</button>
            </div>

            <div id="eventsGrid" class="events-grid">
                {% set nowTs = 'now'|date('U') %}
                {% for event in events %}
                    {% set startTs = event.startDate ? event.startDate|date('U') : 0 %}
                    {% set statusType = startTs > nowTs ? 'upcoming' : 'live' %}
                    <article class="event-card"
                             data-title="{{ event.title|lower }}"
                             data-location="{{ (event.location ?? '')|lower }}"
                             data-category-name="{{ (event.category ? event.category.name : '')|lower }}"
                             data-category="{{ event.category ? event.category.id : '' }}"
                             data-price="{{ event.isFree ? 'free' : 'paid' }}"
                             data-start="{{ event.startDate ? event.startDate|date('U') : 0 }}">
                        <div class="event-cover {{ event.imageUrl ? 'has-image' : 'no-image' }}">
                            {% if event.imageUrl %}
                                <img class="event-cover-image" src="{{ asset(event.imageUrl) }}" alt="Affiche de {{ event.title }}">
                            {% endif %}
                            <span class="event-status {{ statusType }}">{{ statusType == 'upcoming' ? 'À venir' : 'En cours' }}</span>
                            <span
                                class="event-badge"
                                style="background: {{ event.category and event.category.color ? event.category.color : '#4caf50' }}; color: #ffffff;"
                            >{{ event.category ? ((event.category.icon ?? '📁') ~ ' ' ~ event.category.name) : 'Sans catégorie' }}</span>
                        </div>
                        <div class="event-body">
                            <h2 class="event-title">{{ event.title }}</h2>
                            <div class="event-meta">
                                <span class="event-meta-line"><span class="event-meta-emoji">📆</span> Date: {{ event.startDate ? event.startDate|date('d/m/Y') : '-' }}</span>
                                <span class="event-meta-line"><span class="event-meta-emoji">⏰</span> Heure: {{ event.startDate ? event.startDate|date('H:i') : '-' }}</span>
                                <span class="event-meta-line"><span class="event-meta-emoji">📍</span> Lieu: {{ event.location ?: 'Lieu non précisé' }}</span>
                                <span class="event-meta-line"><span class="event-meta-emoji">👥</span> Capacité: {{ event.capacity ?: 0 }} participants</span>
                            </div>
                            <div class="event-price">{{ event.isFree ? 'Gratuit' : (event.ticketPrice|number_format(2, '.', ' ') ~ ' TND') }}</div>
                            <div class="event-actions">
                                <a class="details-btn" href="{{ path('app_public_event_show', {'id': event.id}) }}">Voir détails</a>
                            </div>
                        </div>
                    </article>
                {% else %}
                    <div class="empty-state" id="emptyStateStatic">
                        <strong>Aucun événement disponible</strong>
                        Revenez bientôt pour découvrir les prochaines inscriptions.
                    </div>
                {% endfor %}
            </div>

            <div class="empty-state" id="emptyStateFiltered" style="display:none; margin-top: 12px;">
                <strong>Aucun résultat avec ces filtres</strong>
                Essaie une autre catégorie, un autre prix, ou une recherche plus large.
            </div>

            <div class="pagination-wrap" id="paginationWrap" style="display:none;"></div>
        </section>

        <div class="footer-lite">© 2026 EventFlow - Tous droits réservés</div>
    </main>

    <div class="calendar-modal" id="calendarModal" aria-hidden="true">
        <div class="calendar-modal-panel" role="dialog" aria-modal="true" aria-label="Calendrier des événements">
            <div class="calendar-modal-head">
                <h2 class="calendar-modal-title">Calendrier des événements</h2>
                <button type="button" class="calendar-close-btn" id="closeCalendarBtn">Fermer</button>
            </div>
            <div class="calendar-modal-body">
                <div id="eventsCalendarInModal"></div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.15/locales/fr.global.js"></script>

    <script>
        (() => {
            const searchInput = document.getElementById('searchInput');
            const categoryFilter = document.getElementById('categoryFilter');
            const priceFilter = document.getElementById('priceFilter');
            const dateFilter = document.getElementById('dateFilter');
            const clearBtn = document.getElementById('clearFiltersBtn');
            const resultLabel = document.getElementById('resultLabel');
            const countPill = document.getElementById('eventsCountPill');
            const emptyFiltered = document.getElementById('emptyStateFiltered');
            const paginationWrap = document.getElementById('paginationWrap');
            const cards = Array.from(document.querySelectorAll('.event-card'));
            const total = cards.length;
            const perPage = 6;
            let currentPage = 1;

            const openCalendarBtn = document.getElementById('openCalendarBtn');
            const calendarModal = document.getElementById('calendarModal');
            const closeCalendarBtn = document.getElementById('closeCalendarBtn');
            const calendarEl = document.getElementById('eventsCalendarInModal');
            let modalCalendar = null;

            const hexToRgba = (color, alpha) => {
                if (!color || typeof color !== 'string') {
                    return `rgba(21, 101, 192, ${alpha})`;
                }

                const value = color.trim();
                if (value.startsWith('#')) {
                    const hex = value.slice(1);
                    if (hex.length === 3) {
                        const r = parseInt(hex[0] + hex[0], 16);
                        const g = parseInt(hex[1] + hex[1], 16);
                        const b = parseInt(hex[2] + hex[2], 16);
                        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                    }
                    if (hex.length === 6) {
                        const r = parseInt(hex.slice(0, 2), 16);
                        const g = parseInt(hex.slice(2, 4), 16);
                        const b = parseInt(hex.slice(4, 6), 16);
                        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                    }
                }

                return value;
            };

            const applyDayCellBackgrounds = (calendar) => {
                if (!calendarEl) {
                    return;
                }

                calendarEl.querySelectorAll('.fc-daygrid-day').forEach((dayCell) => {
                    dayCell.classList.remove('category-tinted');
                    dayCell.style.removeProperty('--category-day-bg');
                });

                const appliedDates = new Set();
                calendar.getEvents().forEach((event) => {
                    if (!event.startStr) {
                        return;
                    }

                    const dateKey = event.startStr.slice(0, 10);
                    if (!dateKey || appliedDates.has(dateKey)) {
                        return;
                    }

                    const dayCell = calendarEl.querySelector(`.fc-daygrid-day[data-date="${dateKey}"]`);
                    if (!dayCell) {
                        return;
                    }

                    const tintedColor = hexToRgba(event.backgroundColor || '#1565c0', 0.16);
                    dayCell.classList.add('category-tinted');
                    dayCell.style.setProperty('--category-day-bg', tintedColor);
                    appliedDates.add(dateKey);
                });
            };

            const ensureCalendar = () => {
                if (modalCalendar || !calendarEl) {
                    return;
                }

                modalCalendar = new FullCalendar.Calendar(calendarEl, {
                    locale: 'fr',
                    initialView: 'dayGridMonth',
                    eventDisplay: 'block',
                    height: 'auto',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,timeGridDay'
                    },
                    events: {
                        url: '{{ path('fc_load_events') }}',
                        method: 'POST',
                        extraParams: {
                            filters: JSON.stringify({ scope: 'participant_upcoming' })
                        }
                    },
                    eventsSet: function () {
                        applyDayCellBackgrounds(modalCalendar);
                    },
                    datesSet: function () {
                        applyDayCellBackgrounds(modalCalendar);
                    },
                    eventClick: function (info) {
                        if (info.event.url) {
                            info.jsEvent.preventDefault();
                            window.location.href = info.event.url;
                        }
                    }
                });

                modalCalendar.render();
            };

            const openCalendarModal = () => {
                ensureCalendar();
                calendarModal.classList.add('open');
                calendarModal.setAttribute('aria-hidden', 'false');
                if (modalCalendar) {
                    modalCalendar.updateSize();
                }
            };

            const closeCalendarModal = () => {
                calendarModal.classList.remove('open');
                calendarModal.setAttribute('aria-hidden', 'true');
            };

            const getDateBucket = (timestamp) => {
                const now = new Date();
                const eventDate = new Date(timestamp * 1000);

                const startToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                const endToday = new Date(startToday);
                endToday.setDate(endToday.getDate() + 1);

                const dayOfWeek = now.getDay() === 0 ? 7 : now.getDay();
                const startWeek = new Date(startToday);
                startWeek.setDate(startWeek.getDate() - (dayOfWeek - 1));
                const endWeek = new Date(startWeek);
                endWeek.setDate(endWeek.getDate() + 7);

                const startMonth = new Date(now.getFullYear(), now.getMonth(), 1);
                const endMonth = new Date(now.getFullYear(), now.getMonth() + 1, 1);

                if (eventDate >= startToday && eventDate < endToday) {
                    return 'today';
                }

                if (eventDate >= startWeek && eventDate < endWeek) {
                    return 'week';
                }

                if (eventDate >= startMonth && eventDate < endMonth) {
                    return 'month';
                }

                return 'other';
            };

            const renderPagination = (pages, activePage) => {
                paginationWrap.innerHTML = '';

                if (pages <= 1) {
                    paginationWrap.style.display = 'none';
                    return;
                }

                paginationWrap.style.display = 'flex';

                const prevBtn = document.createElement('button');
                prevBtn.type = 'button';
                prevBtn.className = 'page-btn';
                prevBtn.textContent = 'Précédent';
                prevBtn.disabled = activePage <= 1;
                prevBtn.addEventListener('click', () => {
                    currentPage = Math.max(1, currentPage - 1);
                    applyFilters();
                });
                paginationWrap.appendChild(prevBtn);

                for (let page = 1; page <= pages; page += 1) {
                    const pageBtn = document.createElement('button');
                    pageBtn.type = 'button';
                    pageBtn.className = `page-btn ${page === activePage ? 'active' : ''}`;
                    pageBtn.textContent = String(page);
                    pageBtn.addEventListener('click', () => {
                        currentPage = page;
                        applyFilters();
                    });
                    paginationWrap.appendChild(pageBtn);
                }

                const nextBtn = document.createElement('button');
                nextBtn.type = 'button';
                nextBtn.className = 'page-btn';
                nextBtn.textContent = 'Suivant';
                nextBtn.disabled = activePage >= pages;
                nextBtn.addEventListener('click', () => {
                    currentPage = Math.min(pages, currentPage + 1);
                    applyFilters();
                });
                paginationWrap.appendChild(nextBtn);
            };

            const normalizeText = (value) => {
                return String(value || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^a-z0-9\s-]/g, ' ')
                    .replace(/\s+/g, ' ')
                    .trim();
            };

            const matchesPrefixSearch = (query, ...fields) => {
                const normalizedQuery = normalizeText(query);
                if (!normalizedQuery) {
                    return true;
                }

                const searchable = normalizeText(fields.join(' '));
                if (!searchable) {
                    return false;
                }

                const queryTokens = normalizedQuery.split(' ').filter(Boolean);
                const words = searchable.split(' ').filter(Boolean);

                // Advanced behavior: each typed token must match the prefix of at least one word.
                return queryTokens.every((token) => words.some((word) => word.startsWith(token)));
            };

            const applyFilters = () => {
                const q = (searchInput.value || '').trim();
                const category = categoryFilter.value;
                const price = priceFilter.value;
                const date = dateFilter.value;

                const filtered = cards.filter((card) => {
                    const title = card.dataset.title || '';
                    const location = card.dataset.location || '';
                    const categoryName = card.dataset.categoryName || '';
                    const cardCategory = card.dataset.category || '';
                    const cardPrice = card.dataset.price || '';
                    const startTimestamp = Number(card.dataset.start || 0);
                    const cardDateBucket = getDateBucket(startTimestamp);

                    const matchSearch = matchesPrefixSearch(q, title, location, categoryName);
                    const matchCategory = !category || category === cardCategory;
                    const matchPrice = !price || price === cardPrice;
                    const matchDate = !date || cardDateBucket === date;

                    return matchSearch && matchCategory && matchPrice && matchDate;
                });

                const totalFiltered = filtered.length;
                const totalPages = Math.max(1, Math.ceil(totalFiltered / perPage));

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }

                const start = (currentPage - 1) * perPage;
                const end = start + perPage;
                const visibleOnPage = filtered.slice(start, end);

                cards.forEach((card) => {
                    card.style.display = 'none';
                });

                visibleOnPage.forEach((card) => {
                    card.style.display = '';
                });

                resultLabel.textContent = `${totalFiltered} événement(s) trouvé(s)`;
                countPill.textContent = `${totalFiltered}/${total} événement(s)`;
                emptyFiltered.style.display = totalFiltered === 0 && total > 0 ? '' : 'none';
                renderPagination(totalPages, currentPage);
            };

            searchInput.addEventListener('input', applyFilters);
            categoryFilter.addEventListener('change', applyFilters);
            priceFilter.addEventListener('change', applyFilters);
            dateFilter.addEventListener('change', applyFilters);

            clearBtn.addEventListener('click', () => {
                searchInput.value = '';
                categoryFilter.value = '';
                priceFilter.value = '';
                dateFilter.value = '';
                currentPage = 1;
                applyFilters();
            });

            openCalendarBtn.addEventListener('click', openCalendarModal);
            closeCalendarBtn.addEventListener('click', closeCalendarModal);

            calendarModal.addEventListener('click', (event) => {
                if (event.target === calendarModal) {
                    closeCalendarModal();
                }
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && calendarModal.classList.contains('open')) {
                    closeCalendarModal();
                }
            });

            applyFilters();
        })();

        // Notification JavaScript
        (function () {
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function renderNotifications(listNode, notifications) {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    listNode.innerHTML = '<div class="notif-empty">Aucune notification.</div>';
                    return;
                }

                listNode.innerHTML = notifications.map(function (item) {
                    var icon = item.icon ? escapeHtml(item.icon) : '🔔';
                    var type = item.type ? escapeHtml(item.type) : 'INFO';
                    var createdAt = item.createdAt ? escapeHtml(item.createdAt) : '-';
                    var title = item.title ? escapeHtml(item.title) : 'Notification';
                    var message = item.message ? escapeHtml(item.message) : '';
                    var readClass = item.isRead ? 'read' : 'unread';
                    var notificationId = Number(item.id || 0);

                    return '' +
                        '<article class="notif-item ' + readClass + '">' +
                            '<div class="notif-item-head">' +
                                '<span class="notif-item-meta">' +
                                    '<span>' + icon + ' ' + type + '</span>' +
                                    '<span>•</span>' +
                                    '<span>' + createdAt + '</span>' +
                                '</span>' +
                                '<button type="button" class="notif-delete-btn" title="Supprimer" aria-label="Supprimer notification" data-notif-delete-id="' + notificationId + '"><i class="fas fa-trash-alt" aria-hidden="true"></i></button>' +
                            '</div>' +
                            '<p class="notif-item-title">' + title + '</p>' +
                            '<p class="notif-item-message">' + message + '</p>' +
                        '</article>';
                }).join('');
            }

            function updateBadge(badgeNode, unreadCount) {
                if (!badgeNode) {
                    return;
                }

                if (unreadCount > 0) {
                    badgeNode.hidden = false;
                    badgeNode.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
                } else {
                    badgeNode.hidden = true;
                    badgeNode.textContent = '0';
                }
            }

            async function fetchLatest(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifUrl, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        const bodyText = await response.text();
                        throw new Error('HTTP ' + response.status + ' ' + bodyText.slice(0, 120));
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    renderNotifications(listNode, payload.notifications || []);
                } catch (error) {
                    const message = error && error.message ? error.message : 'Impossible de charger les notifications.';
                    listNode.innerHTML = '<div class="notif-empty">' + escapeHtml(message) + '</div>';
                }
            }

            async function markAllAsRead(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifMarkReadUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('mark all failed');
                    }

                    updateBadge(badgeNode, 0);
                    await fetchLatest(root, badge, listNode);
                } catch (error) {
                    // Keep silent to avoid intrusive UI in header.
                }
            }

            async function deleteNotification(root, notificationId, badgeNode, listNode) {
                const urlTemplate = root.dataset.notifDeleteUrlTemplate || '';
                if (!urlTemplate || !notificationId) {
                    return;
                }

                const deleteUrl = urlTemplate.replace('__id__', String(notificationId));

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifDeleteCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('delete failed');
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep quiet in header UI.
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                const roots = document.querySelectorAll('[data-notif-root]');

                roots.forEach(function (root) {
                    const toggle = root.querySelector('[data-notif-toggle]');
                    const dropdown = root.querySelector('[data-notif-dropdown]');
                    const badge = root.querySelector('[data-notif-badge]');
                    const list = root.querySelector('[data-notif-list]');
                    const markAll = root.querySelector('[data-notif-mark-all]');

                    if (!toggle || !dropdown || !list) {
                        return;
                    }

                    fetchLatest(root, badge, list);

                    toggle.addEventListener('click', function (event) {
                        event.preventDefault();
                        const isOpen = !dropdown.hidden;

                        document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                            node.hidden = true;
                        });

                        dropdown.hidden = isOpen;
                        if (!isOpen) {
                            fetchLatest(root, badge, list);
                        }
                    });

                    if (markAll) {
                        markAll.addEventListener('click', function (event) {
                            event.preventDefault();
                            markAllAsRead(root, badge, list);
                        });
                    }

                    list.addEventListener('click', function (event) {
                        const deleteBtn = event.target.closest('[data-notif-delete-id]');
                        if (!deleteBtn) {
                            return;
                        }

                        event.preventDefault();
                        const notificationId = Number(deleteBtn.getAttribute('data-notif-delete-id'));
                        if (!notificationId) {
                            return;
                        }

                        deleteNotification(root, notificationId, badge, list);
                    });

                    root.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            dropdown.hidden = true;
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    const inside = event.target.closest('[data-notif-root]');
                    if (inside) {
                        return;
                    }

                    document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                        node.hidden = true;
                    });
                });
            });
        }})();

        // Theme toggle for front office
        function toggleTheme() {
            const body = document.body;
            const themeIconEvents = document.getElementById('themeIconEvents');
            const themeTextEvents = document.getElementById('themeTextEvents');
            
            if (body.classList.contains('dark-mode')) {
                body.classList.remove('dark-mode');
                localStorage.setItem('theme', 'light');
                if (themeIconEvents) {
                    themeIconEvents.classList.remove('fa-sun');
                    themeIconEvents.classList.add('fa-moon');
                }
                if (themeTextEvents) {
                    themeTextEvents.textContent = 'Mode Sombre';
                }
            } else {
                body.classList.add('dark-mode');
                localStorage.setItem('theme', 'dark');
                if (themeIconEvents) {
                    themeIconEvents.classList.remove('fa-moon');
                    themeIconEvents.classList.add('fa-sun');
                }
                if (themeTextEvents) {
                    themeTextEvents.textContent = 'Mode Clair';
                }
            }
        }

        // Load saved theme on page load for front office
        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('theme');
            const themeIconEvents = document.getElementById('themeIconEvents');
            const themeTextEvents = document.getElementById('themeTextEvents');
            
            if (savedTheme === 'dark') {
                document.body.classList.add('dark-mode');
                if (themeIconEvents) {
                    themeIconEvents.classList.remove('fa-moon');
                    themeIconEvents.classList.add('fa-sun');
                }
                if (themeTextEvents) {
                    themeTextEvents.textContent = 'Mode Clair';
                }
            }
        });
    </script>
{% endblock %}