{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Mes billets{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .tickets-page {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 0% 0%, rgba(13, 71, 161, 0.08), transparent 40%),
                radial-gradient(circle at 100% 10%, rgba(25, 118, 210, 0.12), transparent 42%),
                #eef2f6;
            padding: 36px 16px 52px;
        }

        .tickets-shell {
            max-width: 1120px;
            margin: 0 auto;
        }

        .tickets-title {
            color: #0f2037;
            font-size: clamp(34px, 4.8vw, 56px);
            margin: 0 0 10px;
            text-align: center;
        }

        .tickets-subtitle {
            color: #5b6b7f;
            font-size: 18px;
            text-align: center;
            margin-bottom: 24px;
        }

        .flash-stack {
            display: grid;
            gap: 10px;
            margin-bottom: 16px;
        }

        .flash-msg {
            border-radius: 10px;
            padding: 12px 14px;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .flash-success {
            background: #e8f8ef;
            color: #0d8f49;
            border-color: #bceacb;
        }

        .flash-error {
            background: #ffefef;
            color: #b3261e;
            border-color: #f7c9c7;
        }

        .flash-info {
            background: #eaf2ff;
            color: #1f4d92;
            border-color: #c7daf8;
        }

        .flash-warning {
            background: #fff6e8;
            color: #9d6408;
            border-color: #f2ddb6;
        }

        .tickets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 16px;
        }

        .ticket-card {
            background: #ffffff;
            border: 1px solid #d8e4f3;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.07);
        }

        .ticket-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .ticket-code {
            color: #164178;
            font-weight: 800;
            font-size: 14px;
            letter-spacing: 0.2px;
        }

        .ticket-status {
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 12px;
            font-weight: 700;
        }

        .ticket-status.active {
            color: #0d8f49;
            background: #e8f8ef;
        }

        .ticket-status.used {
            color: #7c3f00;
            background: #fff2dc;
        }

        .ticket-event {
            font-size: 20px;
            color: #0e1f35;
            margin: 0 0 12px;
        }

        .ticket-row {
            color: #54667d;
            font-size: 14px;
            margin-bottom: 6px;
        }

        .ticket-actions {
            margin-top: 12px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .ticket-btn {
            border-radius: 10px;
            height: 38px;
            padding: 0 12px;
            text-decoration: none;
            border: 1px solid #c7d7ec;
            background: #e7f1ff;
            color: #174a92;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .empty-tickets {
            text-align: center;
            border: 1px dashed #bfd0e4;
            border-radius: 16px;
            background: #ffffff;
            padding: 28px;
            color: #5f7185;
        }
    </style>
{% endblock %}

{% block public_content %}
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}'">Accueil</button>
                <button class="nav-link" style="color:#0D47A1; font-weight:700; text-decoration:underline;" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#features'">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#contact'">Contact</button>
            </div>

            <div class="nav-buttons">
                {% include 'partials/public_auth_buttons.html.twig' %}
            </div>
        </div>
    </nav>

    <main class="tickets-page">
        <div class="tickets-shell">
            <h1 class="tickets-title">Mes billets</h1>
            <p class="tickets-subtitle">Retrouvez ici tous vos billets créés automatiquement après participation.</p>

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-msg flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-msg flash-error">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="flash-msg flash-info">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="flash-msg flash-warning">{{ message }}</div>
                {% endfor %}
            </div>

            {% if tickets is empty %}
                <div class="empty-tickets">
                    <h3>Aucun billet pour le moment</h3>
                    <p>Participez à un événement pour créer votre premier billet.</p>
                </div>
            {% else %}
                <section class="tickets-grid">
                    {% for ticket in tickets %}
                        {% set eventItem = ticket.event %}
                        <article class="ticket-card">
                            <div class="ticket-top">
                                <span class="ticket-code">🎫 {{ ticket.ticketCode }}</span>
                                <span class="ticket-status {{ ticket.isUsed ? 'used' : 'active' }}">{{ ticket.isUsed ? 'Utilisé' : 'Actif' }}</span>
                            </div>
                            <h2 class="ticket-event">{{ eventItem ? eventItem.title : 'Événement supprimé' }}</h2>
                            <div class="ticket-row">📆 Date: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('d/m/Y') : '-' }}</div>
                            <div class="ticket-row">⏰ Heure: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('H:i') : '-' }}</div>
                            <div class="ticket-row">📍 Lieu: {{ eventItem and eventItem.location ? eventItem.location : '-' }}</div>
                            <div class="ticket-row">🏷️ Catégorie: {{ eventItem and eventItem.category ? ((eventItem.category.icon ?? '📁') ~ ' ' ~ eventItem.category.name) : 'Sans catégorie' }}</div>
                            <div class="ticket-row">🕒 Créé le: {{ ticket.createdAt ? ticket.createdAt|date('d/m/Y H:i') : '-' }}</div>

                            <div class="ticket-actions">
                                {% if eventItem %}
                                    <a class="ticket-btn" href="{{ path('app_public_event_show', {'id': eventItem.id}) }}">Voir événement</a>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </section>
            {% endif %}
        </div>
    </main>
{% endblock %}

