{% extends 'auth/landing.html.twig' %}

{% block title %}EventFlow - Mes billets{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .tickets-page {
            margin-top: 80px;
            min-height: 100vh;
            background:
                radial-gradient(circle at 0% 0%, rgba(13, 71, 161, 0.08), transparent 40%),
                radial-gradient(circle at 100% 10%, rgba(25, 118, 210, 0.12), transparent 42%),
                #eef2f6;
            padding: 36px 16px 52px;
        }

        .tickets-shell {
            max-width: 1120px;
            margin: 0 auto;
        }

        .tickets-title {
            color: #0f2037;
            font-size: clamp(34px, 4.8vw, 56px);
            margin: 0 0 10px;
            text-align: center;
        }

        .tickets-subtitle {
            color: #5b6b7f;
            font-size: 18px;
            text-align: center;
            margin-bottom: 24px;
        }

        .tickets-back-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 18px;
        }

        .tickets-back-btn {
            border-radius: 10px;
            height: 40px;
            padding: 0 14px;
            text-decoration: none;
            border: 1px solid #c7d7ec;
            background: #e7f1ff;
            color: #174a92;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .flash-stack {
            display: grid;
            gap: 10px;
            margin-bottom: 16px;
        }

        .flash-msg {
            border-radius: 10px;
            padding: 12px 14px;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .flash-success {
            background: #e8f8ef;
            color: #0d8f49;
            border-color: #bceacb;
        }

        .flash-error {
            background: #ffefef;
            color: #b3261e;
            border-color: #f7c9c7;
        }

        .flash-info {
            background: #eaf2ff;
            color: #1f4d92;
            border-color: #c7daf8;
        }

        .flash-warning {
            background: #fff6e8;
            color: #9d6408;
            border-color: #f2ddb6;
        }

        .tickets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 16px;
        }

        .tickets-section-title {
            color: #10345f;
            font-size: 22px;
            margin: 8px 0 12px;
        }

        .tickets-section-subtitle {
            color: #5b6b7f;
            font-size: 14px;
            margin: 0 0 14px;
        }

        .ticket-card {
            background: #ffffff;
            border: 1px solid #d8e4f3;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.07);
        }

        .ticket-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .ticket-code {
            color: #164178;
            font-weight: 800;
            font-size: 14px;
            letter-spacing: 0.2px;
        }

        .ticket-status {
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 12px;
            font-weight: 700;
        }

        .ticket-status.active {
            color: #0d8f49;
            background: #e8f8ef;
        }

        .ticket-status.used {
            color: #7c3f00;
            background: #fff2dc;
        }

        .ticket-event {
            font-size: 20px;
            color: #0e1f35;
            margin: 0 0 12px;
        }

        .ticket-row {
            color: #54667d;
            font-size: 14px;
            margin-bottom: 6px;
        }

        .ticket-actions {
            margin-top: 12px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .ticket-btn {
            border-radius: 10px;
            height: 38px;
            padding: 0 12px;
            text-decoration: none;
            border: 1px solid #c7d7ec;
            background: #e7f1ff;
            color: #174a92;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .ticket-btn.danger {
            background: #fff1f1;
            border-color: #f0c4c4;
            color: #b3261e;
            cursor: pointer;
        }

        .empty-tickets {
            text-align: center;
            border: 1px dashed #bfd0e4;
            border-radius: 16px;
            background: #ffffff;
            padding: 28px;
            color: #5f7185;
        }

        .notifications-panel {
            margin-bottom: 24px;
            background: linear-gradient(135deg, #ffffff 0%, #f6f9ff 100%);
            border: 1px solid #d8e4f3;
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        }

        .notifications-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .notifications-title {
            margin: 0;
            color: #10345f;
            font-size: 22px;
        }

        .notifications-badge {
            border-radius: 999px;
            padding: 6px 10px;
            background: #e7f1ff;
            color: #174a92;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .notifications-list {
            display: grid;
            gap: 10px;
        }

        .notification-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 14px;
            background: #ffffff;
            border: 1px solid #dbe7f5;
        }

        .notification-headline {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 8px;
        }

        .notification-delete-form {
            margin: 0;
        }

        .notification-delete-btn {
            border: 1px solid #f0c9c9;
            background: #ffffff;
            color: #c22b23;
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 14px;
            line-height: 1;
            transition: all 0.18s ease;
        }

        .notification-delete-btn:hover {
            background: #fff1f1;
            border-color: #e8aaaa;
            transform: translateY(-1px);
        }

        .notification-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #edf4ff;
            font-size: 18px;
            flex: 0 0 36px;
        }

        .notification-content {
            flex: 1;
        }

        .notification-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 4px;
            color: #5b6b7f;
            font-size: 12px;
        }

        .notification-title-line {
            color: #0e1f35;
            font-weight: 800;
            margin: 0 0 4px;
        }

        .notification-message {
            margin: 0;
            color: #516277;
            font-size: 14px;
            line-height: 1.45;
        }

        .notification-empty {
            text-align: center;
            color: #5f7185;
            padding: 18px 10px 6px;
        }

        /* ==================== DARK MODE ==================== */
        body.dark-mode {
            background-color: #0f172a;
        }

        body.dark-mode .tickets-page {
            background:
                radial-gradient(circle at 0% 0%, rgba(30, 64, 175, 0.15), transparent 40%),
                radial-gradient(circle at 100% 10%, rgba(37, 99, 235, 0.2), transparent 42%),
                #0f172a;
        }

        body.dark-mode .tickets-title {
            color: #f1f5f9;
        }

        body.dark-mode .tickets-subtitle {
            color: #94a3b8;
        }

        body.dark-mode .tickets-section-title {
            color: #f1f5f9;
        }

        body.dark-mode .tickets-section-subtitle {
            color: #94a3b8;
        }

        body.dark-mode .ticket-card {
            background: #1e293b;
            border-color: #334155;
        }

        body.dark-mode .ticket-code {
            background: #334155;
            color: #60a5fa;
        }

        body.dark-mode .ticket-event {
            color: #f1f5f9;
        }

        body.dark-mode .ticket-row {
            color: #cbd5e1;
        }

        body.dark-mode .ticket-btn {
            background: #334155;
            color: #f1f5f9;
            border-color: #475569;
        }

        body.dark-mode .ticket-btn:hover {
            background: #475569;
        }

        body.dark-mode .ticket-btn.danger {
            background: #7f1d1d;
            color: #fecaca;
            border-color: #991b1b;
        }

        body.dark-mode .notification-panel {
            background: #1e293b;
            border-color: #334155;
        }

        body.dark-mode .notification-title {
            color: #f1f5f9;
        }

        body.dark-mode .notification-subtitle {
            color: #94a3b8;
        }

        body.dark-mode .notification-item {
            background: #334155;
            border-color: #475569;
        }

        body.dark-mode .notification-meta {
            color: #94a3b8;
        }

        body.dark-mode .notification-title-line {
            color: #f1f5f9;
        }

        body.dark-mode .notification-message {
            color: #cbd5e1;
        }

        body.dark-mode .notification-empty {
            color: #64748b;
        }
    </style>
{% endblock %}

{% block public_content %}
    {% set isParticipantUser = app.user and ('ROLE_ADMIN' not in app.user.roles) and ('ROLE_ORGANISATEUR' not in app.user.roles) and ('ROLE_SPONSOR' not in app.user.roles) %}
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="EventFlow">
            </div>

            <div class="nav-links">
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}'">Accueil</button>
                <button class="nav-link" style="color:#0D47A1; font-weight:700; text-decoration:underline;" onclick="window.location.href='{{ path('app_public_events') }}'">Événements</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#features'">Fonctionnalités</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_feedback_view') }}'">Feedback</button>
                <button class="nav-link" onclick="window.location.href='{{ path('app_landing') }}#contact'">Contact</button>
            </div>

            <div class="nav-buttons">
                <button onclick="toggleTheme()" style="background: rgba(33, 150, 243, 0.1); color: #2196F3; border: 1px solid #2196F3; border-radius: 20px; padding: 8px 20px; cursor: pointer; font-size: 14px; font-weight: bold; margin-right: 10px;">
                    <i class="fas fa-moon" id="themeIconMyTickets"></i>
                    <span id="themeTextMyTickets">Mode Sombre</span>
                </button>
                {% if isParticipantUser %}
                    {% set frontUnreadCount = unreadNotificationCount|default(notificationUnreadCount|default(0)) %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <details class="participant-chip-menu">
                        <summary class="participant-chip">
                            <span class="participant-chip-avatar">{{ app.user.initials }}</span>
                            <span class="participant-chip-meta">
                                <span class="participant-chip-name">{{ app.user.fullName }}</span>
                                <span class="participant-chip-role">Participant</span>
                            </span>
                        </summary>
                        <div class="participant-chip-dropdown">
                            <a class="participant-chip-action" href="{{ path('app_logout') }}">Déconnexion</a>
                        </div>
                    </details>
                    <div
                        class="notif-bell-wrap"
                        data-notif-root
                        data-notif-url="{{ path('app_front_notifications_latest') }}"
                        data-notif-mark-read-url="{{ path('app_front_notifications_mark_all_read') }}"
                        data-notif-csrf-token="{{ csrf_token('front_notifications_mark_all') }}"
                        data-notif-delete-url-template="{{ path('app_front_notifications_delete', {'id': '__id__'}) }}"
                        data-notif-delete-csrf-token="{{ csrf_token('front_notifications_delete') }}"
                    >
                        <button type="button" class="notif-bell-btn" aria-label="Notifications" data-notif-toggle>
                            <span aria-hidden="true">🔔</span>
                            {% if frontUnreadCount > 0 %}
                                <span class="notif-badge" data-notif-badge>{{ frontUnreadCount > 99 ? '99+' : frontUnreadCount }}</span>
                            {% else %}
                                <span class="notif-badge" data-notif-badge hidden>0</span>
                            {% endif %}
                        </button>

                        <div class="notif-dropdown" data-notif-dropdown hidden>
                            <div class="notif-dropdown-head">
                                <span class="notif-dropdown-title">Notifications</span>
                                <button type="button" class="notif-mark-read-btn" data-notif-mark-all>Tout marquer comme lu</button>
                            </div>
                            <div class="notif-list" data-notif-list>
                                <div class="notif-empty">Chargement...</div>
                            </div>
                        </div>
                    </div>
                {% elseif app.user %}
                    <button class="btn-login" onclick="window.location.href='{{ path('app_dashboard') }}'">Back-office</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_logout') }}'">Déconnexion</button>
                {% else %}
                    <button class="btn-login" style="border-color:#0eb36f; color:#0b8f58;" onclick="window.location.href='{{ path('app_my_tickets') }}'">Mes billets</button>
                    <button class="btn-login" onclick="window.location.href='{{ path('app_login') }}'">Connexion</button>
                    <button class="btn-signup" onclick="window.location.href='{{ path('app_register') }}'">Inscription</button>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="tickets-page">
        <div class="tickets-shell">
            <h1 class="tickets-title">Mes billets</h1>
            <p class="tickets-subtitle">Retrouvez ici tous vos billets créés automatiquement après participation.</p>
            <div class="tickets-back-wrap">
                <a class="tickets-back-btn" href="{{ path('app_public_events') }}">← Retour aux événements</a>
            </div>

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-msg flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-msg flash-error">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="flash-msg flash-info">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="flash-msg flash-warning">{{ message }}</div>
                {% endfor %}
            </div>

            <section class="notifications-panel">
                <div class="notifications-header">
                    <h2 class="notifications-title">Notifications</h2>
                    <span class="notifications-badge">
                        {{ unreadNotificationCount }} non lue{{ unreadNotificationCount > 1 ? 's' : '' }}
                    </span>
                </div>

                {% if latestNotifications is not empty %}
                    <div class="notifications-list">
                        {% for notification in latestNotifications %}
                            <article class="notification-item" style="opacity: {{ notification.isRead ? '0.72' : '1' }};">
                                <div class="notification-icon">{{ notification.icon ?? '🔔' }}</div>
                                <div class="notification-content">
                                    <div class="notification-headline">
                                        <div class="notification-meta">
                                            <span>{{ notification.type }}</span>
                                            <span>•</span>
                                            <span>{{ notification.createdAt ? notification.createdAt|date('d/m/Y H:i') : '-' }}</span>
                                            {% if notification.isRead %}
                                                <span>•</span>
                                                <span>Lue</span>
                                            {% endif %}
                                        </div>
                                        <form
                                            method="post"
                                            action="{{ path('app_front_notifications_delete', {'id': notification.id}) }}"
                                            class="notification-delete-form"
                                            onsubmit="return confirm('Supprimer cette notification ?');"
                                        >
                                            <input type="hidden" name="_token" value="{{ csrf_token('front_notifications_delete') }}">
                                            <button type="submit" class="notification-delete-btn" title="Supprimer" aria-label="Supprimer notification">
                                                <i class="fas fa-trash-alt" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <p class="notification-title-line">{{ notification.title }}</p>
                                    <p class="notification-message">{{ notification.message }}</p>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="notification-empty">Aucune notification pour le moment.</div>
                {% endif %}
            </section>

            {% if tickets is empty %}
                <div class="empty-tickets">
                    <h3>Aucun billet pour le moment</h3>
                    <p>Participez à un événement pour créer votre premier billet.</p>
                </div>
            {% else %}
                {% if upcomingTickets is not empty %}
                <h3 class="tickets-section-title">Billets à venir</h3>
                <p class="tickets-section-subtitle">Événements à venir avec billets actifs.</p>
                <section class="tickets-grid" style="margin-bottom: 20px;">
                    {% for ticket in upcomingTickets %}
                        {% set eventItem = ticket.event %}
                        <article class="ticket-card">
                            <div class="ticket-top">
                                <span class="ticket-code">🎫 {{ ticket.ticketCode }}</span>
                                <span class="ticket-status {{ ticket.isUsed ? 'used' : 'active' }}">{{ ticket.isUsed ? 'Utilisé' : 'Actif' }}</span>
                            </div>
                            <h2 class="ticket-event">{{ eventItem ? eventItem.title : 'Événement supprimé' }}</h2>
                            <div class="ticket-row">📆 Date: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('d/m/Y') : '-' }}</div>
                            <div class="ticket-row">⏰ Heure: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('H:i') : '-' }}</div>
                            <div class="ticket-row">📍 Lieu: {{ eventItem and eventItem.location ? eventItem.location : '-' }}</div>
                            <div class="ticket-row">🏷️ Catégorie: {{ eventItem and eventItem.category ? ((eventItem.category.icon ?? '📁') ~ ' ' ~ eventItem.category.name) : 'Sans catégorie' }}</div>
                            <div class="ticket-row">🕒 Créé le: {{ ticket.createdAt ? ticket.createdAt|date('d/m/Y H:i') : '-' }}</div>

                            <div class="ticket-actions">
                                <a class="ticket-btn" href="{{ path('app_my_ticket_pdf', {'id': ticket.id}) }}">Télécharger PDF</a>
                                {% if eventItem %}
                                    <a class="ticket-btn" href="{{ path('app_public_event_show', {'id': eventItem.id}) }}">Voir événement</a>
                                {% endif %}
                                {% if not ticket.isUsed and eventItem and eventItem.startDate and eventItem.startDate > now %}
                                    <form method="post" action="{{ path('app_my_ticket_cancel', {'id': ticket.id}) }}" onsubmit="return confirm('Voulez-vous vraiment annuler ce billet ?');" style="display:inline-flex;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cancel_ticket_' ~ ticket.id) }}">
                                        <button type="submit" class="ticket-btn danger">Annuler mon billet</button>
                                    </form>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </section>
                {% endif %}

                {% if historyTickets is not empty %}
                <h3 class="tickets-section-title">Historique de participation</h3>
                <p class="tickets-section-subtitle">Événements terminés ou billets déjà utilisés.</p>
                <section class="tickets-grid">
                    {% for ticket in historyTickets %}
                        {% set eventItem = ticket.event %}
                        <article class="ticket-card">
                            <div class="ticket-top">
                                <span class="ticket-code">🎫 {{ ticket.ticketCode }}</span>
                                <span class="ticket-status {{ ticket.isUsed ? 'used' : 'active' }}">{{ ticket.isUsed ? 'Utilisé' : 'Actif' }}</span>
                            </div>
                            <h2 class="ticket-event">{{ eventItem ? eventItem.title : 'Événement supprimé' }}</h2>
                            <div class="ticket-row">📆 Date: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('d/m/Y') : '-' }}</div>
                            <div class="ticket-row">⏰ Heure: {{ eventItem and eventItem.startDate ? eventItem.startDate|date('H:i') : '-' }}</div>
                            <div class="ticket-row">📍 Lieu: {{ eventItem and eventItem.location ? eventItem.location : '-' }}</div>
                            <div class="ticket-row">🏷️ Catégorie: {{ eventItem and eventItem.category ? ((eventItem.category.icon ?? '📁') ~ ' ' ~ eventItem.category.name) : 'Sans catégorie' }}</div>
                            <div class="ticket-row">🕒 Créé le: {{ ticket.createdAt ? ticket.createdAt|date('d/m/Y H:i') : '-' }}</div>

                            <div class="ticket-actions">
                                <a class="ticket-btn" href="{{ path('app_my_ticket_pdf', {'id': ticket.id}) }}">Télécharger PDF</a>
                                {% if eventItem and eventItem.endDate and eventItem.endDate >= now %}
                                    <a class="ticket-btn" href="{{ path('app_public_event_show', {'id': eventItem.id}) }}">Voir événement</a>
                                {% endif %}
                                {% if eventItem and ticket.isUsed %}
                                    <a class="ticket-btn" href="{{ path('app_quiz_start', {'event_id': eventItem.id}) }}" style="background: #f3e9ff; color: #6f2dbd; border-color: #d8b4f8;">🎯 Passer le Quiz</a>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </section>
                {% endif %}
            {% endif %}
        </div>
    </main>

    <script>
        (function () {
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function renderNotifications(listNode, notifications) {
                if (!Array.isArray(notifications) || notifications.length === 0) {
                    listNode.innerHTML = '<div class="notif-empty">Aucune notification.</div>';
                    return;
                }

                listNode.innerHTML = notifications.map(function (item) {
                    var icon = item.icon ? escapeHtml(item.icon) : '🔔';
                    var type = item.type ? escapeHtml(item.type) : 'INFO';
                    var createdAt = item.createdAt ? escapeHtml(item.createdAt) : '-';
                    var title = item.title ? escapeHtml(item.title) : 'Notification';
                    var message = item.message ? escapeHtml(item.message) : '';
                    var readClass = item.isRead ? 'read' : 'unread';
                    var notificationId = Number(item.id || 0);

                    return '' +
                        '<article class="notif-item ' + readClass + '">' +
                            '<div class="notif-item-head">' +
                                '<span class="notif-item-meta">' +
                                    '<span>' + icon + ' ' + type + '</span>' +
                                    '<span>•</span>' +
                                    '<span>' + createdAt + '</span>' +
                                '</span>' +
                                '<button type="button" class="notif-delete-btn" title="Supprimer" aria-label="Supprimer notification" data-notif-delete-id="' + notificationId + '"><i class="fas fa-trash-alt" aria-hidden="true"></i></button>' +
                            '</div>' +
                            '<p class="notif-item-title">' + title + '</p>' +
                            '<p class="notif-item-message">' + message + '</p>' +
                        '</article>';
                }).join('');
            }

            function updateBadge(badgeNode, unreadCount) {
                if (!badgeNode) {
                    return;
                }

                if (unreadCount > 0) {
                    badgeNode.hidden = false;
                    badgeNode.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
                } else {
                    badgeNode.hidden = true;
                    badgeNode.textContent = '0';
                }
            }

            async function fetchLatest(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifUrl, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        const bodyText = await response.text();
                        throw new Error('HTTP ' + response.status + ' ' + bodyText.slice(0, 120));
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    renderNotifications(listNode, payload.notifications || []);
                } catch (error) {
                    const message = error && error.message ? error.message : 'Impossible de charger les notifications.';
                    listNode.innerHTML = '<div class="notif-empty">' + escapeHtml(message) + '</div>';
                }
            }

            async function markAllAsRead(root, badgeNode, listNode) {
                try {
                    const response = await fetch(root.dataset.notifMarkReadUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('mark all failed');
                    }

                    updateBadge(badgeNode, 0);
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep silent to avoid intrusive UI in header.
                }
            }

            async function deleteNotification(root, notificationId, badgeNode, listNode) {
                const urlTemplate = root.dataset.notifDeleteUrlTemplate || '';
                if (!urlTemplate || !notificationId) {
                    return;
                }

                const deleteUrl = urlTemplate.replace('__id__', String(notificationId));

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': root.dataset.notifDeleteCsrfToken || ''
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('delete failed');
                    }

                    const payload = await response.json();
                    updateBadge(badgeNode, Number(payload.unreadCount || 0));
                    await fetchLatest(root, badgeNode, listNode);
                } catch (error) {
                    // Keep quiet in header UI.
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                const roots = document.querySelectorAll('[data-notif-root]');

                roots.forEach(function (root) {
                    const toggle = root.querySelector('[data-notif-toggle]');
                    const dropdown = root.querySelector('[data-notif-dropdown]');
                    const badge = root.querySelector('[data-notif-badge]');
                    const list = root.querySelector('[data-notif-list]');
                    const markAll = root.querySelector('[data-notif-mark-all]');

                    if (!toggle || !dropdown || !list) {
                        return;
                    }

                    fetchLatest(root, badge, list);

                    toggle.addEventListener('click', function (event) {
                        event.preventDefault();
                        const isOpen = !dropdown.hidden;

                        document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                            node.hidden = true;
                        });

                        dropdown.hidden = isOpen;
                        if (!isOpen) {
                            fetchLatest(root, badge, list);
                        }
                    });

                    if (markAll) {
                        markAll.addEventListener('click', function (event) {
                            event.preventDefault();
                            markAllAsRead(root, badge, list);
                        });
                    }

                    list.addEventListener('click', function (event) {
                        const deleteBtn = event.target.closest('[data-notif-delete-id]');
                        if (!deleteBtn) {
                            return;
                        }

                        event.preventDefault();
                        const notificationId = Number(deleteBtn.getAttribute('data-notif-delete-id'));
                        if (!notificationId) {
                            return;
                        }

                        deleteNotification(root, notificationId, badge, list);
                    });

                    root.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            dropdown.hidden = true;
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    const inside = event.target.closest('[data-notif-root]');
                    if (inside) {
                        return;
                    }

                    document.querySelectorAll('[data-notif-dropdown]').forEach(function (node) {
                        node.hidden = true;
                    });
                });
            });
        })();

        // Theme toggle for front office
        function toggleTheme() {
            const body = document.body;
            const themeIconMyTickets = document.getElementById('themeIconMyTickets');
            const themeTextMyTickets = document.getElementById('themeTextMyTickets');
            
            if (body.classList.contains('dark-mode')) {
                body.classList.remove('dark-mode');
                localStorage.setItem('theme', 'light');
                if (themeIconMyTickets) {
                    themeIconMyTickets.classList.remove('fa-sun');
                    themeIconMyTickets.classList.add('fa-moon');
                }
                if (themeTextMyTickets) {
                    themeTextMyTickets.textContent = 'Mode Sombre';
                }
            } else {
                body.classList.add('dark-mode');
                localStorage.setItem('theme', 'dark');
                if (themeIconMyTickets) {
                    themeIconMyTickets.classList.remove('fa-moon');
                    themeIconMyTickets.classList.add('fa-sun');
                }
                if (themeTextMyTickets) {
                    themeTextMyTickets.textContent = 'Mode Clair';
                }
            }
        }

        // Load saved theme on page load for front office
        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('theme');
            const themeIconMyTickets = document.getElementById('themeIconMyTickets');
            const themeTextMyTickets = document.getElementById('themeTextMyTickets');
            
            if (savedTheme === 'dark') {
                document.body.classList.add('dark-mode');
                if (themeIconMyTickets) {
                    themeIconMyTickets.classList.remove('fa-moon');
                    themeIconMyTickets.classList.add('fa-sun');
                }
                if (themeTextMyTickets) {
                    themeTextMyTickets.textContent = 'Mode Clair';
                }
            }
        });
    </script>
{% endblock %}