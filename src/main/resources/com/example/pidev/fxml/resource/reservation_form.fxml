<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-background-color: #f1f5f9; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.resource.ReservationFormController">
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button onAction="#goBack" style="-fx-background-color: #64748b; -fx-text-fill: white;" text="← Retour" />
        <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Formulaire de Réservation" />

        <Region HBox.hgrow="ALWAYS" /> <Button fx:id="voiceBtn" onAction="#toggleVoiceControl" style="-fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand;" text="🎙">
        <tooltip><Tooltip text="Cliquez pour donner un ordre vocal" /></tooltip>
    </Button>
    </HBox>

    <HBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e2e8f0;">
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <GridPane hgap="10" vgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="150" /><ColumnConstraints minWidth="150" /><ColumnConstraints minWidth="80" />
                </columnConstraints>
                <Label style="-fx-font-weight: bold;" text="Début :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <DatePicker fx:id="startDatePicker" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label style="-fx-font-weight: bold;" text="Fin :" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <DatePicker fx:id="endDatePicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label style="-fx-font-weight: bold;" text="Type :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="typeCombo" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label style="-fx-font-weight: bold;" text="Ressource :" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <ComboBox fx:id="itemCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Label style="-fx-font-weight: bold;" text="Qté :" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <TextField fx:id="quantityField" prefWidth="60" text="1" GridPane.columnIndex="2" GridPane.rowIndex="3" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#goBack" prefHeight="25.0" prefWidth="100.0" text="Annuler" />
                <Button fx:id="btnValider" onAction="#validerAction" prefWidth="120" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" text="Réserver" />
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="5" style="-fx-border-color: #cbd5e1; -fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8;">
            <Label style="-fx-font-size: 11; -fx-text-fill: #64748b;" text="Aperçu" />
            <ImageView fx:id="imagePreview" fitHeight="120" fitWidth="120" preserveRatio="true" />
        </VBox>
    </HBox>

    <Label fx:id="voiceStatusLabel" style="-fx-text-fill: #94a3b8; -fx-font-style: italic;" text="Micro désactivé" />
</VBox>
