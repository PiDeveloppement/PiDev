<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.resource.ReservationController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5">
            <Label fx:id="welcomeLabel" text="Bienvenue" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
            <Label fx:id="userInfoLabel" text="Session active" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#goToAdd" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Nouvelle Réservation" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 5);">
        <TextField fx:id="searchField" prefWidth="250" promptText="🔍 Rechercher une ressource..." style="-fx-background-radius: 20; -fx-padding: 8 15;" />

        <Separator orientation="VERTICAL" />

        <Label text="Filtrer :" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" />
        <ComboBox fx:id="filterCombo" prefWidth="150.0" promptText="Toutes" style="-fx-background-radius: 8;" />

        <Label text="Trier :" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" />
        <ComboBox fx:id="sortCombo" prefWidth="130.0" promptText="Date" style="-fx-background-radius: 8;" />

        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="10">
            <Button onAction="#goToStats" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;" text="📊 Statistiques" />
            <Button onAction="#exportToPDF" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;" text="📄 PDF" />
            <Button onAction="#refreshTable" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;" text="🔄" />
        </HBox>
    </HBox>

    <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-overflow-x: hidden;">
        <columns>
            <TableColumn fx:id="imgCol" prefWidth="80" resizable="false" text="Aperçu" />
            <TableColumn fx:id="typeCol" prefWidth="110" text="Type" />
            <TableColumn fx:id="nameCol" prefWidth="180" text="Ressource" />
            <TableColumn fx:id="startCol" prefWidth="160" text="Date Début" />
            <TableColumn fx:id="endCol" prefWidth="160" text="Date Fin" />
            <TableColumn fx:id="qtyCol" prefWidth="70" text="Qté" />
            <TableColumn fx:id="actionCol" prefWidth="140" resizable="false" text="Actions" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>