<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="25" styleClass="form-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.resource.EquipementFormController">
    <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 10; -fx-padding: 10;">
            <Text style="-fx-fill: white; -fx-font-size: 20;" text="🛠️" />
        </StackPane>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" styleClass="form-title" text="Ajouter un Équipement" />
            <Label styleClass="form-subtitle" text="Mise à jour de l'inventaire en temps réel" />
        </VBox>

        <VBox alignment="CENTER_RIGHT" spacing="5">
            <Button fx:id="voiceBtn" onAction="#toggleVoiceControl" prefHeight="45" prefWidth="45" style="-fx-background-color: #ef4444; -fx-background-radius: 50; -fx-cursor: hand;" text="🎙" textFill="WHITE">
                <tooltip><Tooltip text="Activer la commande vocale" /></tooltip>
            </Button>
            <Label fx:id="voiceStatusLabel" style="-fx-font-size: 10; -fx-text-fill: #94a3b8; -fx-font-weight: bold;" text="Micro Off" />
        </VBox>
    </HBox>

    <Separator style="-fx-opacity: 0.3;" />

    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
        </columnConstraints>

        <VBox spacing="8" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="0">
            <Label styleClass="field-label" text="Nom de l'équipement" />
            <HBox spacing="10">
                <TextField fx:id="nameField" promptText="Ex: Vidéoprojecteur Epson" styleClass="modern-text-field" HBox.hgrow="ALWAYS" />
                <Button onAction="#rechercherImageAutomatique" styleClass="btn-secondary" text="🔍 Auto-Image" />
            </HBox>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label styleClass="field-label" text="Catégorie" />
            <TextField fx:id="typeField" promptText="Ex: Multimédia" styleClass="modern-text-field" />
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label styleClass="field-label" text="Quantité" />
            <TextField fx:id="quantityField" promptText="0" styleClass="modern-text-field" />
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2">
            <Label styleClass="field-label" text="Statut de disponibilité" />
            <ComboBox fx:id="statusCombo" maxWidth="Infinity" promptText="Choisir un état..." styleClass="modern-combo-box" />
        </VBox>

        <VBox spacing="10" styleClass="image-upload-card" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3">
            <Label styleClass="field-label" text="Visuel de l'article" />
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-border-style: dashed;">
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Text style="-fx-fill: #94a3b8; -fx-font-size: 11;" text="Format supporté : PNG, JPG, URL" />
                    <Button onAction="#choisirImage" styleClass="btn-secondary" text="🖼️ Sélectionner un fichier" />
                </VBox>
                <StackPane prefHeight="80" prefWidth="80" styleClass="image-preview-wrapper">
                    <ImageView fx:id="previewImage" fitHeight="70" fitWidth="70" preserveRatio="true" />
                </StackPane>
            </HBox>
        </VBox>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#annuler" styleClass="btn-cancel" text="✖ Annuler" />
        <Button fx:id="btnValider" onAction="#enregistrer" styleClass="btn-save" text="💾 Confirmer l'enregistrement" />
    </HBox>
</VBox>