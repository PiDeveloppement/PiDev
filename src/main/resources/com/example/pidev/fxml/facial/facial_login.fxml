<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="600.0" prefWidth="500.0"
      style="-fx-background-color: #f8f9fa; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.facial.FacialLoginController">

    <Text text="Authentification Biométrique" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>

    <StackPane prefHeight="350.0" prefWidth="440.0" style="-fx-background-color: black; -fx-border-color: #3498db; -fx-border-width: 3; -fx-border-radius: 5;">
        <ImageView fx:id="cameraView" fitHeight="340.0" fitWidth="430.0" pickOnBounds="true" preserveRatio="true" />
        <ProgressIndicator fx:id="progressIndicator" visible="false" maxHeight="50" maxWidth="50" />
    </StackPane>

    <Label fx:id="statusLabel" text="Caméra prête" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" />

    <VBox fx:id="resultBox" alignment="CENTER" spacing="5" visible="false" style="-fx-background-color: #e8f5e9; -fx-padding: 10; -fx-background-radius: 5;">
        <Label fx:id="userNameLabel" text="Nom Utilisateur" style="-fx-font-weight: bold; -fx-text-fill: #2e7d32;" />
        <Label fx:id="confidenceLabel" text="Confiance" style="-fx-font-size: 11px;" />
    </VBox>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="startCameraBtn" text="Démarrer Caméra" onAction="#handleStartCamera"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;" />

        <Button fx:id="loginBtn" text="Se Connecter" onAction="#handleLogin" disable="true"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;" />

        <Button fx:id="backToLoginBtn" text="Retour" onAction="#handleBackToLogin"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;" />
    </HBox>

</VBox>