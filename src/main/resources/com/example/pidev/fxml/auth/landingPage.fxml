<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.auth.LandingPageController"
      style="-fx-background-color: #f8fafc;"
      prefWidth="1400">

    <HBox style="-fx-background-color: white; -fx-padding: 15 60; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" prefHeight="80">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ImageView fitHeight="110" fitWidth="110" preserveRatio="true">
                <Image url="@../images/logo.png" />
            </ImageView>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="34" alignment="CENTER">
            <Button text="Accueil" onAction="#scrollToTop"
                    style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            <Button fx:id="eventsBtn" text="Evenements" onAction="#handleGoToEvents"
                    style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            <Button fx:id="sponsorRecoBtn" text="Page sponsor" onAction="#handleSponsorPortal"
                    visible="false" managed="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #0D47A1; -fx-font-size: 16px; -fx-font-weight: 700; -fx-cursor: hand;"/>
            <Button text="Fonctionnalites" onAction="#scrollToFeatures"
                    style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            <Button text="Feedback" onAction="#handleFeedback"
                    style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            <Button text="Contact" onAction="#scrollToContact"
                    style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 600; -fx-cursor: hand;"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox fx:id="authButtonsBox" spacing="15">
            <Button text="Connexion" onAction="#handleLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #0D47A1; -fx-font-weight: 700;
                           -fx-border-color: #0D47A1; -fx-border-width: 1.5; -fx-border-radius: 8;
                           -fx-padding: 8 24; -fx-cursor: hand;"/>
            <Button text="Inscription" onAction="#handleSignup"
                    style="-fx-background-color: #0D47A1; -fx-text-fill: white; -fx-font-weight: 700;
                           -fx-background-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;"/>
        </HBox>

        <MenuButton fx:id="profileMenuButton" text="Profil"
                    visible="false" managed="false"
                    style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-weight: 700;
                           -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-border-radius: 8;
                           -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;">
            <items>
                <MenuItem fx:id="profileMenuItem" text="Mon profil" onAction="#handleProfile"/>
                <MenuItem fx:id="logoutMenuItem" text="Deconnexion" onAction="#handleLogout"/>
            </items>
        </MenuButton>
    </HBox>

    <ScrollPane fx:id="mainScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

        <VBox spacing="0">
            <VBox fx:id="homeSection" spacing="30" style="-fx-padding: 70 100;">
                <HBox spacing="60" alignment="CENTER">
                    <VBox spacing="22" HBox.hgrow="ALWAYS" maxWidth="640">
                        <Label text="Organisez vos evenements avec simplicite"
                               style="-fx-font-size: 46px; -fx-font-weight: 800; -fx-text-fill: #0A1929;"
                               wrapText="true"/>
                        <Label text="EventFlow centralise la gestion des evenements, des participants, des sponsors et des ressources."
                               style="-fx-font-size: 18px; -fx-text-fill: #546e7a;"
                               wrapText="true"/>
                        <HBox spacing="18" style="-fx-padding: 8 0 0 0;">
                            <Button text="Commencer" onAction="#handleSignup"
                                    style="-fx-background-color: #0D47A1; -fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 16px;
                                           -fx-background-radius: 10; -fx-padding: 14 30; -fx-cursor: hand;"/>
                            <Button text="Voir la demo" onAction="#handleDemo"
                                    style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-weight: 600; -fx-font-size: 16px;
                                           -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-border-radius: 10;
                                           -fx-background-radius: 10; -fx-padding: 14 28; -fx-cursor: hand;"/>
                            <Button text="Get Certificate" onAction="#handleGetCertificate"
                                    style="-fx-background-color: #f59e0b; -fx-text-fill: white;
                                           -fx-font-weight: 700; -fx-font-size: 16px; -fx-background-radius: 10;
                                           -fx-padding: 14 24; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                    <StackPane prefWidth="420" prefHeight="360"
                               style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #E3F2FD, #BBDEFB); -fx-background-radius: 28;">
                        <Label text="EF" style="-fx-font-size: 120px; -fx-font-weight: 900; -fx-text-fill: #0D47A1;"/>
                    </StackPane>
                </HBox>
            </VBox>

            <VBox fx:id="featuresSection" spacing="42" style="-fx-padding: 90 100; -fx-background-color: white;">
                <VBox spacing="12" alignment="CENTER">
                    <Label text="FONCTIONNALITES" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #0D47A1; -fx-letter-spacing: 2;"/>
                    <Label text="Tout ce dont vous avez besoin" style="-fx-font-size: 34px; -fx-font-weight: 800; -fx-text-fill: #0A1929;"/>
                    <Label text="Une plateforme claire et rapide pour tous vos evenements" style="-fx-font-size: 18px; -fx-text-fill: #546e7a;"/>
                </VBox>
                <GridPane hgap="26" vgap="26" alignment="CENTER">
                    <StackPane style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 26;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <VBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Gestion des evenements" style="-fx-font-size: 21px; -fx-font-weight: 800; -fx-text-fill: #0A1929;"/>
                            <Label text="Creez, modifiez et suivez vos evenements en temps reel." wrapText="true" style="-fx-text-fill: #546e7a; -fx-font-size: 15px;"/>
                        </VBox>
                    </StackPane>
                    <StackPane style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 26;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <VBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Participants" style="-fx-font-size: 21px; -fx-font-weight: 800; -fx-text-fill: #0A1929;"/>
                            <Label text="Suivez les inscriptions et les presences." wrapText="true" style="-fx-text-fill: #546e7a; -fx-font-size: 15px;"/>
                        </VBox>
                    </StackPane>
                </GridPane>
            </VBox>

            <VBox fx:id="feedbackSection" spacing="30" style="-fx-padding: 70 100; -fx-background-color: #f8fafc;">
                <VBox spacing="10" alignment="CENTER">
                    <Label text="FEEDBACKS" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #0D47A1; -fx-letter-spacing: 2;"/>
                    <Label text="Ce que disent nos utilisateurs" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #0A1929;"/>
                </VBox>
                <VBox fx:id="feedbackListContainer" spacing="15"/>
            </VBox>

            <VBox fx:id="contactSection" spacing="34" style="-fx-padding: 90 100; -fx-background-color: linear-gradient(to right, #0D47A1, #1976D2);">
                <VBox spacing="12" alignment="CENTER">
                    <Label text="CONTACT" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: rgba(255,255,255,0.85); -fx-letter-spacing: 2;"/>
                    <Label text="Restons en contact" style="-fx-font-size: 34px; -fx-font-weight: 800; -fx-text-fill: white;"/>
                    <Label text="Une question ? Notre equipe est la pour vous repondre" style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
