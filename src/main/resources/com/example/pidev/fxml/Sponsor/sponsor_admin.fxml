<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1600" style="-fx-background-color: #f1f5f9;" stylesheets="@../../css/design-system.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.sponsor.SponsorAdminController">

    <center>
        <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
            <VBox spacing="0">

                <!-- STATS (3 cards) -->
                <HBox spacing="14" style="-fx-padding: 24 35; -fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

                    <VBox spacing="10" styleClass="stat-card stat-card-purple" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-size: 32px;" text="💼" />
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="totalSponsorsSectionLabel" styleClass="label-section" text="Sponsors Total" />
                                <Label fx:id="totalSponsorsLabel" style="-fx-text-fill: #7c3aed;" styleClass="label-value" text="0" />
                            </VBox>
                        </HBox>
                        <Label style="-fx-text-fill: #a855f7; -fx-font-size: 12px; -fx-font-weight: bold;" text="✓ Actifs" />
                    </VBox>

                    <VBox spacing="10" styleClass="stat-card stat-card-emerald" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-size: 32px;" text="💎" />
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="totalContributionSectionLabel" styleClass="label-section" text="Contribution Totale" />
                                <Label fx:id="totalContributionLabel" style="-fx-text-fill: #15803d;" styleClass="label-value" text="0,00 DT" />
                            </VBox>
                        </HBox>
                        <Label style="-fx-text-fill: #059669; -fx-font-size: 12px; -fx-font-weight: bold;" text="💰 Engagée" />
                    </VBox>

                    <VBox spacing="10" styleClass="stat-card stat-card-blue" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-size: 32px;" text="📊" />
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="avgContributionSectionLabel" styleClass="label-section" text="Moyenne/Sponsor" />
                                <Label fx:id="avgContributionLabel" style="-fx-text-fill: #1e40af;" styleClass="label-value" text="0,00 DT" />
                            </VBox>
                        </HBox>
                        <Label style="-fx-text-fill: #2563eb; -fx-font-size: 12px; -fx-font-weight: bold;" text="📈 Performance" />
                    </VBox>
                </HBox>

                <!-- Graphique circulaire -->
                <HBox alignment="CENTER" style="-fx-padding: 20 35;">
                    <PieChart fx:id="contributionsChart" labelsVisible="true" legendVisible="true" prefHeight="450" prefWidth="800" style="-fx-font-size: 14px;" title="Répartition des contributions par événement" />
                </HBox>

                <!-- FILTRES -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 20 35; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

                    <TextField fx:id="searchField" prefWidth="250" promptText="🔍 Rechercher sponsor..." styleClass="text-field" />

                    <ComboBox fx:id="companyFilter" prefWidth="220" promptText="🏢 Entreprise" styleClass="text-field" />

                    <ComboBox fx:id="eventFilter" prefWidth="220" promptText="📅 Événement" styleClass="text-field" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="exportExcelBtn" minHeight="40" minWidth="160" styleClass="btn-primary" text="📥 Exporter Excel" />
                    <Button fx:id="addSponsorBtn" minHeight="40" minWidth="180" styleClass="btn-success" text="➕ Nouveau Sponsor" />
                </HBox>

                <!-- LISTE -->
                <VBox spacing="20" style="-fx-padding: 28 35;" VBox.vgrow="ALWAYS">
                    <Label styleClass="label-subtitle" text="📋 Sponsors Enregistrés" />

                    <ScrollPane fx:id="cardsScroll" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <TilePane fx:id="cardsPane" hgap="16" prefColumns="3" style="-fx-padding: 10;" vgap="16" />
                    </ScrollPane>

                    <Label fx:id="statusLabel" styleClass="label-description" text="..." />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
