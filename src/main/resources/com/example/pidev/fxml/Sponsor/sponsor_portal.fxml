<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="900" prefWidth="1600" styleClass="sponsor-portal-root" stylesheets="@../../css/design-system.css,@../../css/sponsor-portal.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.sponsor.SponsorPortalController">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f1f5f9; -fx-background-color: #f1f5f9; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
            <VBox spacing="0" style="-fx-background-color: #f1f5f9;">

                <VBox spacing="14" style="-fx-padding: 22 35;" styleClass="sponsor-header-block">
                     <Button fx:id="homeBtn" managed="false" prefHeight="45.0" prefWidth="112.0" styleClass="sponsor-top-btn" text="Back" visible="false" />
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2">
                            <Label styleClass="sponsor-title" text="Portail Sponsoring" />
                            <Label styleClass="sponsor-subtitle" text="Recommandations IA et opportunites de sponsoring" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="exportCsvBtn" cacheShape="false" centerShape="false" focusTraversable="false" scaleShape="false" styleClass="sponsor-top-btn" visible="false" />
                        <Label fx:id="todayLabel" styleClass="sponsor-date-chip" text="--" />
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button fx:id="exportExcelBtn" styleClass="sponsor-top-btn" text="Exporter Excel" />
                        <Button fx:id="historyBtn" styleClass="sponsor-top-btn" text="Historique" />
                    </HBox>

                    <HBox spacing="16">
                        <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="myContributionSectionLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 700;" text="Ma contribution" />
                                    <Label fx:id="myContributionLabel" style="-fx-text-fill: #15803d; -fx-font-size: 24px; -fx-font-weight: 900;" text="0,00 DT" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 18;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="myEventsSectionLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 700;" text="Mes evenements" />
                                    <Label fx:id="myEventsLabel" style="-fx-text-fill: #1e40af; -fx-font-size: 28px; -fx-font-weight: 900;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox style="-fx-padding: 0 35 28 35; -fx-background-color: #f1f5f9;">
                    <VBox prefHeight="111.0" prefWidth="1520.0" style="-fx-padding: 20;" styleClass="sponsor-section-card">
                        <StackPane mouseTransparent="true" pickOnBounds="false" prefHeight="100.0" prefWidth="1484.0" styleClass="sponsor-badge">
                            <Label cacheShape="false" centerShape="false" focusTraversable="false" scaleShape="false" styleClass="sponsor-badge-text" visible="false" />
                           <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-padding: 0 0 12 0;" text="Evenements recommandes " />
                        </StackPane>
                        <FlowPane fx:id="recommendedEventsGrid" hgap="18" prefWrapLength="1080" styleClass="sponsor-events-grid" vgap="18" />
                        <VBox fx:id="noRecommendedMessage" alignment="CENTER" managed="false" spacing="8" style="-fx-padding: 20 0 6 0;" visible="false">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: 600;" text="Renseignez votre biographie (secteur) dans votre profil pour activer les recommandations." wrapText="true" />
                        </VBox>
                    </VBox>
                </VBox>

                <VBox style="-fx-padding: 0 35 28 35; -fx-background-color: #f1f5f9;">
                    <VBox prefHeight="98.0" prefWidth="1529.0" style="-fx-padding: 20;" styleClass="sponsor-section-card">
                  <StackPane mouseTransparent="true" pickOnBounds="false" prefHeight="116.0" prefWidth="1484.0" styleClass="sponsor-badge">
                     <children>
                        <Label cacheShape="false" centerShape="false" focusTraversable="false" scaleShape="false" styleClass="sponsor-badge-text" visible="false" />
                        <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-padding: 0 0 12 0;" />
                              <Label prefHeight="80.0" prefWidth="305.0" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-padding: 0 0 12 0;" text="Catalogue des evenements a sponsoriser" />
                     </children>
                  </StackPane>
                        <FlowPane fx:id="allEventsGrid" hgap="18" prefWrapLength="1080" styleClass="sponsor-events-grid" vgap="18" />
                        <VBox fx:id="noEventsMessage" alignment="CENTER" managed="false" spacing="10" style="-fx-padding: 25 0 10 0;" visible="false">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #64748b;" text="Aucun evenement trouve" />
                        </VBox>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
