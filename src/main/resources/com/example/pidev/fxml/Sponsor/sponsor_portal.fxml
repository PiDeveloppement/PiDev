<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="900" prefWidth="1600"
            style="-fx-background-color: #f1f5f9;"
            stylesheets="@../../css/design-system.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pidev.controller.sponsor.SponsorPortalController">

    <center>
        <!-- Scroll global UNIQUE de toute la page -->
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    pannable="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

            <!-- IMPORTANT:
                 1) VBox doit être le contenu unique du ScrollPane
                 2) On force la largeur du contenu à suivre la largeur visible du ScrollPane
                 3) On évite fitToHeight=true (ça peut empêcher le scroll global selon le layout) -->
            <content>
                <VBox spacing="0" style="-fx-fill-width: true;">
                    <!-- En-tête -->
                    <VBox spacing="12"
                          style="-fx-padding: 22 35; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"
                                   text="🧾 Sponsor Portal" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="todayLabel"
                                   style="-fx-text-fill: #64748b; -fx-font-weight: 700;"
                                   text="--" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-text-fill:#334155; -fx-font-weight:800;" text="Compte email:" />
                            <ComboBox fx:id="emailAccount" prefWidth="280" promptText="Choisir un email (demo)" />
                        </HBox>

                        <HBox spacing="14">
                            <VBox spacing="8" styleClass="stat-card stat-card-purple" HBox.hgrow="ALWAYS">
                                <Label fx:id="mySponsorsSectionLabel" styleClass="label-section" text="Mes Sponsors" />
                                <Label fx:id="mySponsorsLabel" style="-fx-text-fill:#7c3aed;" styleClass="label-value" text="0" />
                            </VBox>
                            <VBox spacing="8" styleClass="stat-card stat-card-emerald" HBox.hgrow="ALWAYS">
                                <Label fx:id="myContributionSectionLabel" styleClass="label-section" text="Ma Contribution" />
                                <Label fx:id="myContributionLabel" style="-fx-text-fill:#15803d;" styleClass="label-value" text="0,00 DT" />
                            </VBox>
                            <VBox spacing="8" styleClass="stat-card stat-card-blue" HBox.hgrow="ALWAYS">
                                <Label fx:id="myEventsSectionLabel" styleClass="label-section" text="Mes Événements" />
                                <Label fx:id="myEventsLabel" style="-fx-text-fill:#1e40af;" styleClass="label-value" text="0" />
                            </VBox>
                        </HBox>

                        <BarChart fx:id="myContributionsChart" prefHeight="300" prefWidth="800" title="Mes contributions par sponsor">
                            <xAxis>
                                <CategoryAxis label="Entreprise" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Montant (DT)" />
                            </yAxis>
                        </BarChart>

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <TextField fx:id="searchField" prefWidth="260" promptText="🔍 Rechercher..." styleClass="text-field" />
                            <ComboBox fx:id="companyFilter" prefWidth="220" promptText="🏢 Entreprise" styleClass="text-field" />
                            <ComboBox fx:id="eventFilter" prefWidth="220" promptText="📅 Événement" styleClass="text-field" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="addSponsorBtn" minHeight="40" minWidth="180" styleClass="btn-success" text="➕ Nouveau Sponsor" />
                        </HBox>
                    </VBox>

                    <!-- Liste des sponsors -->
                    <VBox spacing="14" style="-fx-padding: 18 35;">
                        <Label styleClass="label-subtitle" text="📋 Mes Sponsors" />
                        <TilePane fx:id="cardsPane" hgap="16" prefColumns="3" style="-fx-padding: 10;" vgap="16" />
                        <Label fx:id="statusLabel" styleClass="label-description" text="..." />
                    </VBox>

                    <!-- Événements recommandés -->
                    <VBox spacing="8" style="-fx-padding: 10 35 20 35;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155;"
                               text="🎯 Événements recommandés pour vous" />

                        <!-- Pour éviter un scroll interne, il ne faut PAS limiter la hauteur.
                             Donc: on supprime prefHeight.
                             La ListView prendra sa taille par défaut (scroll interne possible si beaucoup d'items),
                             mais le scroll GLOBAL sera bien celui du ScrollPane. -->
                        <ListView fx:id="suggestedEventsListView"
                                  style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0;" />

                        <Region prefHeight="10" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>