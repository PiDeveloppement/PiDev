<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="920" prefWidth="1600" styleClass="sponsor-portal-root" stylesheets="@../../css/design-system.css,@../../css/sponsor-portal.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.sponsor.SponsorPortalController">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f1f5f9; -fx-background-color: #f1f5f9; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
            <VBox spacing="0" style="-fx-background-color: #f1f5f9;">

                <VBox spacing="14" style="-fx-padding: 22 35;" styleClass="sponsor-header-block">
                    <Button fx:id="homeBtn" managed="false" styleClass="sponsor-top-btn" text="Back" visible="false" />

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2">
                            <Label styleClass="sponsor-title" text="Portail Sponsoring" />
                            <Label styleClass="sponsor-subtitle" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="todayLabel" styleClass="sponsor-date-chip" text="--" />
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button fx:id="exportExcelBtn" styleClass="sponsor-top-btn" text="Exporter Excel" />
                        <Button fx:id="historyBtn" styleClass="sponsor-top-btn" text="Historique" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sponsor-filter-row">
                        <TextField fx:id="searchField" promptText="Recherche par evenement / entreprise / email" HBox.hgrow="ALWAYS" />
                        <Label fx:id="statusLabel" styleClass="sponsor-status-pill" text="0 sponsor(s)" />
                    </HBox>

                    <HBox spacing="16">
                        <VBox styleClass="sponsor-kpi-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="myContributionSectionLabel" styleClass="sponsor-kpi-title" text="Ma contribution" />
                            <Label fx:id="myContributionLabel" styleClass="sponsor-kpi-value-green" text="0,00 DT" />
                        </VBox>

                        <VBox styleClass="sponsor-kpi-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="myEventsSectionLabel" styleClass="sponsor-kpi-title" text="Mes evenements" />
                            <Label fx:id="myEventsLabel" styleClass="sponsor-kpi-value-blue" text="0" />
                        </VBox>

                        <VBox styleClass="sponsor-kpi-card" HBox.hgrow="ALWAYS">
                            <Label fx:id="mySponsorsSectionLabel" styleClass="sponsor-kpi-title" text="Mes sponsorships" />
                            <Label fx:id="mySponsorsLabel" styleClass="sponsor-kpi-value-violet" text="0" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="16" style="-fx-padding: 0 35 20 35; -fx-background-color: #f1f5f9;">
                    <VBox styleClass="sponsor-section-card">
                        <StackPane styleClass="sponsor-section-banner">
                            <Label styleClass="sponsor-section-banner-text" text="Contributions par evenement" />
                        </StackPane>
                        <Label styleClass="sponsor-info-label" />
                        <Label fx:id="topCompanyLabel" styleClass="sponsor-leader-value" text="--" wrapText="true" />
                        <VBox fx:id="topCompaniesBox" alignment="CENTER_LEFT" spacing="10" styleClass="sponsor-chart-container" />
                    </VBox>
                </VBox>

                <VBox style="-fx-padding: 0 35 24 35; -fx-background-color: #f1f5f9;">
                    <VBox styleClass="sponsor-section-card">
                        <StackPane styleClass="sponsor-section-banner">
                            <Label styleClass="sponsor-section-banner-text" text="Evenements recommandes" />
                        </StackPane>
                        <FlowPane fx:id="recommendedEventsGrid" hgap="18" prefWrapLength="1080" styleClass="sponsor-events-grid" vgap="18" />
                        <VBox fx:id="noRecommendedMessage" alignment="CENTER" managed="false" spacing="8" style="-fx-padding: 20 0 6 0;" visible="false">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: 600;" text="Renseignez votre biographie (secteur) dans votre profil pour activer les recommandations." wrapText="true" />
                        </VBox>
                    </VBox>
                </VBox>

                <VBox style="-fx-padding: 0 35 28 35; -fx-background-color: #f1f5f9;">
                    <VBox styleClass="sponsor-section-card">
                        <StackPane styleClass="sponsor-section-banner">
                            <Label styleClass="sponsor-section-banner-text" text="Catalogue des evenements a sponsoriser" />
                        </StackPane>
                        <FlowPane fx:id="allEventsGrid" hgap="18" prefWrapLength="1080" styleClass="sponsor-events-grid" vgap="18" />
                        <VBox fx:id="noEventsMessage" alignment="CENTER" managed="false" spacing="10" style="-fx-padding: 25 0 10 0;" visible="false">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #64748b;" text="Aucun evenement trouve" />
                        </VBox>
                    </VBox>
                </VBox>

                <ComboBox fx:id="emailAccount" managed="false" visible="false" />

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
