<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.front.EventDetailController">

    <!-- ==================== NAVBAR FIXE ==================== -->
    <HBox alignment="CENTER_LEFT" prefHeight="80" style="-fx-background-color: white; -fx-padding: 15 60; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <!-- Logo -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <ImageView fitHeight="140" fitWidth="140" preserveRatio="true">
                <Image url="@../images/logo.png" />
            </ImageView>
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Liens de navigation -->
        <HBox alignment="CENTER" spacing="40">
            <Button onAction="#handleGoToHome" style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 500; -fx-cursor: hand;" text="Accueil" />
            <Button onAction="#handleGoToEvents" style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 500; -fx-cursor: hand;" text="Événements" />
            <Button onAction="#handleGoToFeatures" style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 500; -fx-cursor: hand;" text="Fonctionnalités" />
            <Button onAction="#handleGoToFeedback" style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 500; -fx-cursor: hand;" text="Feedback" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: 500; -fx-cursor: hand;" text="Contact" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Boutons d'action -->
        <HBox spacing="15">
            <Button onAction="#handleLogin" style="-fx-background-color: transparent; -fx-text-fill: #0D47A1; -fx-font-weight: bold;                            -fx-border-color: #0D47A1; -fx-border-width: 1.5; -fx-border-radius: 8;                            -fx-padding: 8 24; -fx-cursor: hand;" text="Connexion" />
            <Button onAction="#handleSignup" style="-fx-background-color: #0D47A1; -fx-text-fill: white; -fx-font-weight: bold;                            -fx-background-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;                            -fx-effect: dropshadow(gaussian, rgba(13,71,161,0.3), 8, 0, 0, 2);" text="Inscription" />
        </HBox>
    </HBox>

    <!-- ==================== CONTENU PRINCIPAL ==================== -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

        <VBox spacing="0">

            <!-- HERO SECTION COMPACT (150px avec gradient dynamique) -->
            <StackPane fx:id="heroImage" maxHeight="150" prefHeight="150" style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <!-- L'image ou gradient sera défini dynamiquement selon la catégorie -->
            </StackPane>

            <!-- CONTENU PRINCIPAL (Layout moderne asymétrique) -->
            <HBox spacing="0" style="-fx-padding: 0;">

                <!-- COLONNE GAUCHE - Contenu principal (70%) -->
                <VBox spacing="20" style="-fx-padding: 25 30 40 50;" HBox.hgrow="ALWAYS">

                    <!-- BREADCRUMB Compact -->
                    <Button onAction="#handleGoToEvents" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand;                                    -fx-font-weight: 500; -fx-font-size: 13px; -fx-padding: 5 0;" text="← Événements" />

                    <!-- HEADER avec badges -->
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="categoryBadge" style="-fx-background-color: #E3F2FD; -fx-text-fill: #0D47A1; -fx-padding: 6 14;                                           -fx-background-radius: 16; -fx-font-size: 12px; -fx-font-weight: 600;" text="📌 Catégorie" />
                            <Label fx:id="statusBadge" style="-fx-background-color: #d1fae5; -fx-text-fill: #065f46; -fx-padding: 6 14;                                           -fx-background-radius: 16; -fx-font-size: 12px; -fx-font-weight: 600;" text="✓ À venir" />
                        </HBox>

                        <Label fx:id="titleLabel" maxWidth="650" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0A1929;                                       -fx-wrap-text: true; -fx-line-spacing: 2px;" text="Titre de l'événement" wrapText="true" />
                    </VBox>

                    <!-- TIMELINE VISUELLE (Date, Heure, Durée) -->
                    <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;                                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <HBox alignment="CENTER_LEFT" spacing="25">
                            <VBox alignment="CENTER" prefWidth="140" spacing="6">
                                <Label style="-fx-font-size: 24px;" text="📅" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Date" />
                                <Label fx:id="dateLabel" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 700;" text="15 Mars 2026" />
                            </VBox>
                            <Separator orientation="VERTICAL" prefHeight="50" />
                            <VBox alignment="CENTER" prefWidth="140" spacing="6">
                                <Label style="-fx-font-size: 24px;" text="⏰" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Heure" />
                                <Label fx:id="timeLabel" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 700;" text="14:00" />
                            </VBox>
                            <Separator orientation="VERTICAL" prefHeight="50" />
                            <VBox alignment="CENTER" prefWidth="140" spacing="6">
                                <Label style="-fx-font-size: 24px;" text="⏱️" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Durée" />
                                <Label fx:id="durationLabel" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 700;" text="2h00" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- SECTION MÉTÉO (Dynamique) -->
                    <VBox fx:id="weatherContainer" spacing="12" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;                                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A1929;" text="🌤️ Météo prévue" />

                        <!-- Contenu météo (mis à jour dynamiquement) -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox alignment="CENTER" prefWidth="140" spacing="8">
                                <Label fx:id="weatherEmoji" style="-fx-font-size: 48px;" text="☀️" />
                                <Label fx:id="weatherTemp" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0A1929;" text="22°C" />
                            </VBox>

                            <VBox spacing="12" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label style="-fx-font-size: 16px;" text="📍" />
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Description" />
                                        <Label fx:id="weatherDescription" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 600;" text="Ciel dégagé" />
                                    </VBox>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label style="-fx-font-size: 16px;" text="💧" />
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Risque de pluie" />
                                        <Label fx:id="weatherRain" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 600;" text="10%" />
                                    </VBox>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label style="-fx-font-size: 16px;" text="💨" />
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Humidité" />
                                        <Label fx:id="weatherHumidity" style="-fx-text-fill: #0A1929; -fx-font-size: 14px; -fx-font-weight: 600;" text="65%" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- Message d'erreur (si météo indisponible) -->
                        <Label fx:id="weatherErrorLabel" managed="false" style="-fx-text-fill: #ef4444; -fx-font-size: 13px; -fx-padding: 10;                                       -fx-background-color: #fee2e2; -fx-background-radius: 8;" text="" visible="false" />
                    </VBox>

                    <!-- DESCRIPTION -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;                                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A1929;" text="📋 À propos" />
                        <Label fx:id="descriptionLabel" style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-line-spacing: 4px; -fx-wrap-text: true;" text="Description de l'événement..." wrapText="true" />
                    </VBox>

                    <!-- CE QUI VOUS ATTEND -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;                                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A1929;" text="✨ Ce qui vous attend" />
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-text-fill: #10b981; -fx-font-size: 16px; -fx-font-weight: bold;" text="✓" />
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Contenu enrichissant et interactif" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-text-fill: #10b981; -fx-font-size: 16px; -fx-font-weight: bold;" text="✓" />
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Networking avec des professionnels" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-text-fill: #10b981; -fx-font-size: 16px; -fx-font-weight: bold;" text="✓" />
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Certificat de participation" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- INFOS COMPLÉMENTAIRES (AVEC BOUTON CERTIFICAT) -->
                    <HBox spacing="15">
                        <VBox spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 18; -fx-background-radius: 12;                                      -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #64748b;" text="📍 Lieu" />
                            <Label fx:id="locationLabel" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #0A1929; -fx-wrap-text: true;" text="Salle de conférence" wrapText="true" />
                        </VBox>
                        <VBox spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 18; -fx-background-radius: 12;                                      -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #64748b;" text="👤 Organisateur" />
                            <Label fx:id="organizerLabel" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #0A1929;" text="EventFlow" />

                            <!-- ✅ BOUTON CERTIFICAT (placé ici, sous l'organisateur) -->
                            <Button onAction="#handleGetCertificate"
                                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;
                                           -fx-background-radius: 12; -fx-padding: 12 0; -fx-cursor: hand; -fx-pref-width: 100%;
                                           -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.3), 15, 0, 0, 5);"
                                    text="🎓 Obtenir mon certificat">
                                <VBox.margin>
                                    <Insets top="15" />
                                </VBox.margin>
                            </Button>
                        </VBox>
                    </HBox>

                </VBox>

                <!-- COLONNE DROITE - Card sticky (30%) -->
                <VBox maxWidth="380" prefWidth="380" spacing="0" style="-fx-padding: 25 50 40 0;">

                    <!-- CARD D'ACTION STICKY (Glassmorphism) -->
                    <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 16;                                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 8);                                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 16;">

                        <!-- PRIX avec urgence -->
                        <VBox alignment="CENTER" spacing="8">
                            <Label fx:id="priceLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #0D47A1;" text="Gratuit" />
                            <Label fx:id="capacityLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 13px; -fx-font-weight: 700;                                           -fx-background-color: #fee2e2; -fx-padding: 4 10; -fx-background-radius: 8;" text="⚡ Plus que 12 places" />
                        </VBox>

                        <!-- BOUTON CTA Principal -->
                        <Button onAction="#handleParticipate" style="-fx-background-color: #0D47A1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;                                        -fx-background-radius: 12; -fx-padding: 16 0; -fx-cursor: hand; -fx-pref-width: 100%;                                        -fx-effect: dropshadow(gaussian, rgba(13,71,161,0.4), 15, 0, 0, 5);" text="🎫 Réserver ma place" />

                        <Separator style="-fx-padding: 4 0;" />

                        <!-- INFOS CLÉS -->
                        <VBox spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-size: 20px;" text="👥" />
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;" text="Capacité totale" />
                                    <Label fx:id="capacityInfoLabel" style="-fx-text-fill: #0A1929; -fx-font-size: 13px; -fx-font-weight: 600;" text="50 personnes" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- BADGE SÉCURITÉ -->
                        <HBox alignment="CENTER" spacing="8" style="-fx-padding: 12 0 0 0;">
                            <Label style="-fx-font-size: 16px;" text="🔒" />
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: 500;" text="Inscription 100% sécurisée" />
                        </HBox>
                    </VBox>

                </VBox>

            </HBox>

            <!-- FOOTER COMPACT (sans le bouton en double) -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 30 0 25 0; -fx-background-color: white;                                                           -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="© 2026 EventFlow - Tous droits réservés" />
                <HBox alignment="CENTER" spacing="20">
                    <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-size: 12px;" text="Conditions" />
                    <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-size: 12px;" text="Confidentialité" />
                    <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-size: 12px;" text="Contact" />
                </HBox>
                <!-- ❌ Le bouton certificat a été supprimé d'ici -->
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>