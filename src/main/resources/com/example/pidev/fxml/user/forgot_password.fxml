<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 40;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.user.ForgotPasswordController">

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2196F3;" text="📱 Mot de passe oublié" />

    <Label style="-fx-text-fill: #666; -fx-font-size: 14px;" text="Saisissez votre numéro de téléphone pour recevoir un SMS de réinitialisation" wrapText="true" textAlignment="CENTER" />

    <VBox spacing="10" prefWidth="400">
        <Label style="-fx-font-weight: bold; -fx-text-fill: #333;" text="Numéro de téléphone" />
        <TextField fx:id="phoneField" promptText="+216XXXXXXXX" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
        <Label style="-fx-text-fill: #999; -fx-font-size: 11px;" text="Format: +216XXXXXXXX (indicatif international requis)" />
    </VBox>

    <!-- Champ email caché (pour compatibilité) -->
    <TextField fx:id="emailField" visible="false" managed="false" />

    <Label fx:id="statusLabel" style="-fx-font-size: 12px;" />

    <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="30" prefHeight="30" />

    <!-- Bouton de test (visible seulement en développement) -->
    <Button fx:id="testLinkButton"
            onAction="#handleTestLink"
            style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;"
            text="Tester le lien"
            visible="false"
            managed="false"
            prefWidth="200" />

    <HBox alignment="CENTER" spacing="15">
        <Button fx:id="sendResetLinkBtn" onAction="#handleSendResetLink" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 5; -fx-cursor: hand;" text="Envoyer le SMS" prefWidth="150" />
        <Button fx:id="backToLoginBtn" onAction="#handleBackToLogin" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 12 25; -fx-background-radius: 5; -fx-cursor: hand;" text="Retour" prefWidth="150" />
    </HBox>

    <Label style="-fx-text-fill: #999; -fx-font-size: 11px;" text="Le lien de réinitialisation expirera dans 1 heure" />

    <!-- Indicateurs de format -->
    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
        <Label text="📱 Tunisie: +216" style="-fx-text-fill: #666; -fx-font-size: 11px; -fx-background-color: #f0f0f0; -fx-padding: 3 8; -fx-background-radius: 10;"/>
        <Label text="🇫🇷 France: +33" style="-fx-text-fill: #666; -fx-font-size: 11px; -fx-background-color: #f0f0f0; -fx-padding: 3 8; -fx-background-radius: 10;"/>
    </HBox>
</VBox>