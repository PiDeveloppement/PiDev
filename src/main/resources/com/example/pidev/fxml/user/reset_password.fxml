<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 40;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.user.ResetPasswordController">

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #25D366;"
           text="📱 Réinitialisation par WhatsApp" />

    <!-- Étape 1: Saisie du token -->
    <VBox spacing="10" prefWidth="400" fx:id="tokenBox">
        <Label style="-fx-font-weight: bold;" text="Étape 1 : Collez votre token WhatsApp" />
        <TextField fx:id="tokenField" promptText="Ex: 30e8435c-688b-4da9-bdca-69be587116d4"
                   style="-fx-padding: 10; -fx-background-radius: 5;" />
        <Button fx:id="validateTokenBtn" text="✅ Valider le token"
                onAction="#handleValidateToken"
                style="-fx-background-color: #25D366; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-padding: 10; -fx-background-radius: 5;" />
    </VBox>

    <!-- Étape 2: Nouveau mot de passe (caché au début) -->
    <VBox fx:id="passwordFormBox" spacing="15" prefWidth="400" visible="false" managed="false">
        <Label style="-fx-font-weight: bold;" text="Étape 2 : Choisissez votre nouveau mot de passe" />

        <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe"
                       style="-fx-padding: 10; -fx-background-radius: 5;" />

        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                       style="-fx-padding: 10; -fx-background-radius: 5;" />

        <Button fx:id="resetPasswordBtn" text="🔄 Réinitialiser mon mot de passe"
                onAction="#handleResetPassword"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-padding: 10; -fx-background-radius: 5;" />
    </VBox>

    <Label fx:id="statusLabel" style="-fx-font-size: 12px;" />

    <Button fx:id="backToLoginBtn" text="← Retour au login"
            onAction="#handleBackToLogin"
            style="-fx-background-color: transparent; -fx-text-fill: #666;
                   -fx-underline: true; -fx-cursor: hand;" />
</VBox>