<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="1600" style="-fx-background-color: #f1f5f9;" stylesheets="@../../css/design-system.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pidev.controller.budget.BudgetListController">

    <center>
        <ScrollPane fx:id="pageScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="0">

                    <!-- STATS CARDS -->
                    <HBox spacing="14" style="-fx-padding: 24 35; -fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                        <VBox spacing="10" styleClass="stat-card stat-card-emerald" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-size: 32px;" text="💰" />
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-section" text="Total Budgets" />
                                    <Label fx:id="kpiCountLabel" styleClass="label-value" text="0" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox spacing="10" styleClass="stat-card stat-card-blue" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-size: 32px;" text="📥" />
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-section" text="Budget Initial" />
                                    <Label fx:id="kpiInitialLabel" styleClass="label-value" text="0,00 DT" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox spacing="10" styleClass="stat-card stat-card-purple" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-size: 32px;" text="📈" />
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-section" text="Rentabilité" />
                                    <Label fx:id="kpiRentLabel" styleClass="label-value" text="0,00 DT" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox spacing="10" styleClass="stat-card stat-card-rose" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-size: 32px;" text="⚠" />
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-section" text="En Déficit" />
                                    <Label fx:id="kpiDeficitLabel" styleClass="label-value" text="0" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                        </VBox>
                    </HBox>

                    <!-- FILTRES -->
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 20 35; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                        <ComboBox fx:id="healthFilter" prefWidth="200" promptText="🏥 Santé Financière" styleClass="text-field" />
                        <ComboBox fx:id="eventFilter" prefWidth="200" promptText="📅 Événement" styleClass="text-field" />
                        <ComboBox fx:id="statusFilter" prefWidth="180" promptText="📌 État" styleClass="text-field" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="addBtn" minHeight="40" minWidth="160" styleClass="btn-success" text="➕ Nouveau Budget" />
                    </HBox>

                    <!-- Graphiques côte à côte -->
                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 35;">
                        <ImageView fx:id="budgetComparisonImage" fitHeight="400" fitWidth="440" preserveRatio="true" />
                        <ImageView fx:id="roiTrendImage" fitHeight="400" fitWidth="440" preserveRatio="true" />
                    </HBox>

                    <!-- LISTE DES BUDGETS -->
                    <VBox spacing="20" style="-fx-padding: 28 35;" VBox.vgrow="ALWAYS">
                        <Label styleClass="label-subtitle" text="📋 Liste des Budgets" />
                        <TilePane fx:id="cardsPane" hgap="16" prefColumns="3" style="-fx-padding: 10;" vgap="16" />
                        <Label fx:id="statusLabel" styleClass="label-description" text="..." />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
