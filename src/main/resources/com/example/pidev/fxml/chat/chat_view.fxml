<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" style="-fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.controller.chat.ChatController"
      prefWidth="550" prefHeight="600">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: linear-gradient(to right, #2196F3, #1565C0); -fx-background-radius: 10; -fx-padding: 10;">
        <Label style="-fx-font-size: 28px;" text="🤖" />
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="Assistant IA - EventFlow" />
            <Label fx:id="statusIndicator" style="-fx-font-size: 11px; -fx-text-fill: #BBDEFB;" text="● Connecté • Posez vos questions" />
        </VBox>
        <Button fx:id="clearButton" onAction="#handleClearChat" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20; -fx-text-fill: white; -fx-cursor: hand;" text="🗑️ Nouvelle conversation" />
    </HBox>

    <!-- Zone de chat -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: white; -fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 10;">
        <VBox fx:id="chatBox" spacing="10" style="-fx-padding: 15;">
            <!-- Les messages seront ajoutés dynamiquement -->
        </VBox>
    </ScrollPane>

    <!-- Zone de saisie -->
    <HBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 10;">
        <TextField fx:id="inputField" promptText="Posez votre question..." HBox.hgrow="ALWAYS"
                   style="-fx-padding: 12; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ccc;">
            <font>
                <Font size="14" />
            </font>
        </TextField>
        <Button fx:id="sendButton" onAction="#handleSendMessage"
                style="-fx-background-color: #2196F3; -fx-background-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;"
                text="Envoyer" textFill="white">
            <font>
                <Font size="14" />
            </font>
        </Button>
    </HBox>

    <!-- Suggestions rapides -->
    <HBox spacing="8" alignment="CENTER" prefWidth="550">
        <Button onAction="#handleSuggestion"
                style="-fx-background-color: #e3f2fd; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: #90caf9; -fx-border-radius: 20;"
                text="📊 Statistiques"
                userData="statistiques" />
        <Button onAction="#handleSuggestion"
                style="-fx-background-color: #e3f2fd; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: #90caf9; -fx-border-radius: 20;"
                text="👥 Liste admins"
                userData="liste des admins" />
        <Button onAction="#handleSuggestion"
                style="-fx-background-color: #e3f2fd; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: #90caf9; -fx-border-radius: 20;"
                text="📅 Nouveaux ce mois"
                userData="nouveaux utilisateurs ce mois" />
        <Button onAction="#handleSuggestion"
                style="-fx-background-color: #e3f2fd; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: #90caf9; -fx-border-radius: 20;"
                text="❓ Aide"
                userData="aide" />
    </HBox>
</VBox>