<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pidev.MainController"
      prefHeight="900" prefWidth="1400"
      minWidth="960" minHeight="680"
      stylesheets="/com/example/pidev/css/atlantafx-custom.css">

    <!-- ==================== SIDEBAR ==================== -->
    <VBox prefWidth="210" minWidth="210" maxWidth="210"
          styleClass="sidebar-root">

        <!-- Logo TOUJOURS visible en haut -->
        <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="4"
              minHeight="120" maxHeight="120">
            <ImageView fitHeight="70" fitWidth="70" preserveRatio="true">
                <Image url="@images/logo.png"/>
            </ImageView>
            <Label text="EventFlow" styleClass="sidebar-appname"/>
            <Label text="Gestion Événements" styleClass="sidebar-appsubtitle"/>
        </VBox>

        <!-- Menu navigation scrollable -->
        <ScrollPane fitToWidth="true"
                    vbarPolicy="NEVER"
                    hbarPolicy="NEVER"
                    styleClass="sidebar-scroll"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="sidebar-menu" spacing="3">

                    <!-- Dashboard -->
                    <Button fx:id="dashboardBtn"
                            text="Dashboard"
                            styleClass="main-menu-button"
                            maxWidth="1.7976931348623157E308"
                            prefHeight="40">
                        <graphic>
                            <Text text="📊" style="-fx-font-size: 14px;"/>
                        </graphic>
                    </Button>

                    <!-- Événements -->
                    <VBox spacing="2">
                        <Button fx:id="eventsToggleBtn"
                                text="Événements"
                                styleClass="main-menu-button"
                                maxWidth="1.7976931348623157E308"
                                prefHeight="40">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Text text="📅" style="-fx-font-size: 14px;"/>
                                    <Text fx:id="eventsArrow" text="▶"
                                          style="-fx-font-size: 10px; -fx-fill: white;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="eventsSubmenu" visible="false" managed="false" spacing="2">
                            <Button fx:id="eventsListBtn" text="  Liste événements"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📋" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="categoriesBtn" text="  Catégories"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="🏷️" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="ticketsBtn" text="  Billets"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="🎫" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Participants -->
                    <VBox spacing="2">
                        <Button fx:id="usersToggleBtn"
                                text="Participants"
                                styleClass="main-menu-button"
                                maxWidth="1.7976931348623157E308"
                                prefHeight="40">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Text text="👥" style="-fx-font-size: 14px;"/>
                                    <Text fx:id="usersArrow" text="▶"
                                          style="-fx-font-size: 10px; -fx-fill: white;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="usersSubmenu" visible="false" managed="false" spacing="2">
                            <Button fx:id="rolesBtn" text="  Rôles"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="👤" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="inscriptionsBtn" text="  Inscriptions"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📝" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Sponsors -->
                    <VBox spacing="2">
                        <Button fx:id="sponsorsBtn"
                                text="Sponsors"
                                styleClass="main-menu-button"
                                maxWidth="1.7976931348623157E308"
                                prefHeight="40">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Text text="💼" style="-fx-font-size: 14px;"/>
                                    <Text fx:id="sponsorsArrow" text="▶"
                                          style="-fx-font-size: 10px; -fx-fill: white;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="sponsorsSubmenu" visible="false" managed="false" spacing="2">
                            <Button fx:id="sponsorsListBtn" text="  Admin Sponsors"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📋" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="budgetBtn" text="  Budget"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="💰" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="contratsBtn" text="  Dépenses"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📄" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Ressources -->
                    <VBox spacing="2">
                        <Button fx:id="resourcesToggleBtn"
                                text="Ressources"
                                styleClass="main-menu-button"
                                maxWidth="1.7976931348623157E308"
                                prefHeight="40">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Text text="📦" style="-fx-font-size: 14px;"/>
                                    <Text fx:id="resourcesArrow" text="▶"
                                          style="-fx-font-size: 10px; -fx-fill: white;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="resourcesSubmenu" visible="false" managed="false" spacing="2">
                            <Button fx:id="sallesBtn" text="  Salles"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="🏢" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="equipementsBtn" text="  Équipements"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="💻" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="reservationsBtn" text="  Réservations"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📅" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <!-- Questionnaires -->
                    <VBox spacing="2">
                        <Button fx:id="questionnairesToggleBtn"
                                text="Questionnaires"
                                styleClass="main-menu-button"
                                maxWidth="1.7976931348623157E308"
                                prefHeight="40">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Text text="📝" style="-fx-font-size: 14px;"/>
                                    <Text fx:id="questionnairesArrow" text="▶"
                                          style="-fx-font-size: 10px; -fx-fill: white;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <VBox fx:id="questionnairesSubmenu" visible="false" managed="false" spacing="2">
                            <Button fx:id="questionsBtn" text="  Questions"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="❓" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="reponsesBtn" text="  Réponses"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="📊" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                            <Button fx:id="participantQuizBtn" text="  Passer Quiz"
                                    styleClass="submenu-button"
                                    maxWidth="1.7976931348623157E308" prefHeight="34">
                                <graphic><Text text="🎯" style="-fx-font-size: 12px;"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <!-- Bas sidebar : Paramètres + Déconnexion TOUJOURS visibles -->
        <VBox styleClass="sidebar-bottom" spacing="4"
              minHeight="100" maxHeight="100">
            <Button fx:id="settingsBtn"
                    text="Paramètres"
                    styleClass="main-menu-button"
                    maxWidth="1.7976931348623157E308"
                    prefHeight="40">
                <graphic><Text text="⚙️" style="-fx-font-size: 14px;"/></graphic>
            </Button>
            <Button fx:id="logoutBtn"
                    text="Déconnexion"
                    styleClass="logout-button"
                    maxWidth="1.7976931348623157E308"
                    prefHeight="40">
                <graphic><Text text="🚪" style="-fx-font-size: 14px;"/></graphic>
            </Button>
        </VBox>
    </VBox>

    <!-- ==================== CONTENU DROIT ==================== -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- TOP BAR -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="14"
              minHeight="56" maxHeight="56">

            <TextField fx:id="globalSearchField"
                       promptText="Recherche globale..."
                       styleClass="topbar-search"
                       prefWidth="300"/>

            <Button onAction="#onSearchClick"
                    style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 7 14; -fx-cursor: hand;">
                <graphic><Text text="🔍" style="-fx-font-size: 14px;"/></graphic>
            </Button>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Date / heure -->
            <VBox alignment="CENTER_RIGHT" spacing="1">
                <Label fx:id="navDateLabel"
                       text="mercredi 04 mars 2026"
                       styleClass="topbar-date"/>
                <Label fx:id="navTimeLabel"
                       text="00:00:00"
                       styleClass="topbar-time"/>
            </VBox>

            <!-- Profil -->
            <MenuButton fx:id="profileMenu" styleClass="topbar-profile">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <StackPane fx:id="avatarContainer" alignment="CENTER">
                            <Circle radius="16" fill="rgba(255,255,255,0.25)"/>
                            <Circle radius="14" fill="white"/>
                            <ImageView fx:id="profileImageView"
                                       fitHeight="26" fitWidth="26"
                                       preserveRatio="true"
                                       visible="false">
                                <clip>
                                    <Circle centerX="13" centerY="13" radius="13"/>
                                </clip>
                            </ImageView>
                            <StackPane fx:id="initialsContainer" visible="true">
                                <Circle radius="13" fill="#1565C0"/>
                                <Text fx:id="userInitialsText"
                                      text="EF"
                                      style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-fill: white;"/>
                            </StackPane>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="0">
                            <Label fx:id="userNameLabel" text="EventFlow"
                                   styleClass="topbar-username"/>
                            <Label fx:id="userRoleLabel" text="Admin"
                                   styleClass="topbar-role"/>
                        </VBox>
                        <Text text="▼" style="-fx-fill: white; -fx-font-size: 9px;"/>
                    </HBox>
                </graphic>
                <items>
                    <MenuItem text="👤 Mon Profil"    onAction="#showProfile"/>
                    <MenuItem text="⚙️ Paramètres"   onAction="#showSettings"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="🚪 Déconnexion"  onAction="#logout"/>
                </items>
            </MenuButton>
        </HBox>

        <!-- PAGE HEADER -->
        <HBox styleClass="page-header" alignment="CENTER_LEFT"
              minHeight="62" maxHeight="62">
            <VBox spacing="3">
                <Label fx:id="pageTitle"
                       text="Tableau de bord"
                       styleClass="page-title"/>
                <Label fx:id="pageSubtitle"
                       text="Aperçu général de votre activité"
                       styleClass="page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="kpiContainer"
                  spacing="14"
                  alignment="CENTER_RIGHT"
                  visible="false"
                  managed="false"/>
        </HBox>

        <!-- ZONE CONTENU CENTRAL -->
        <VBox fx:id="pageContentContainer"
              styleClass="page-content"
              minHeight="0.0"
              VBox.vgrow="ALWAYS"/>

    </VBox>
</HBox>
