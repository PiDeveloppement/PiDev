###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_to_a_random_secret_value
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/db_name?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> OpenAI API Key ###
OPENAI_API_KEY=your_openai_api_key_here
###< OpenAI API Key ###

###> GCP API Key ###
GCP_API_KEY=your_gcp_api_key_here
###< GCP API Key ###

###> Groq API Key ###
GROQ_API_KEY=your_groq_api_key_here
###< Groq API Key ###

###> SendGrid API Key ###
SENDGRID_API_KEY=your_sendgrid_api_key_here
###< SendGrid API Key ###

###> Additional Environment Variables ###
# Add any other environment variables here with placeholder values

###> Infobip SMS ###
INFOBIP_DSN=infobip://API_KEY@default?from=SENDER_ID
###< Infobip SMS ###

###> Twilio SMS ###
TWILIO_DSN=twilio://SID:TOKEN@default?from=+1234567890
###< Twilio SMS ###
